    <main class="main-panel">
      <div class="page-header-area">
        <h1 class="page-title">OTP Input</h1>
        <p class="page-desc">A one-time password entry field that presents individual digit boxes for verification code input. Supports 4-digit and 6-digit codes, three sizes, five interaction states, and full RTL layout.</p>
        <nav class="content-tabs">
          <button class="tab-item active">Overview</button>
          <button class="tab-item">Style</button>
          <button class="tab-item">Usage</button>
          <button class="tab-item">Code</button>
          <button class="tab-item">Accessibility</button>
        </nav>
      </div>

      <div class="main-content-area">
        <div class="main-content-inner">

        <!-- ========== OVERVIEW ========== -->
        <div class="tab-content" id="tab-overview">
          <h3 id="anatomy" class="doc-h3">Anatomy</h3>
          <div class="anatomy-diagram">
            <div style="display:flex;flex-direction:column;align-items:center;gap:12px;margin:20px 0;">
              <!-- Label row -->
              <div style="position:relative;display:flex;align-items:center;gap:6px;">
                <span class="anat-marker-inline">1</span>
                <div style="width:28px; height:2px; background:#2563eb;"></div>
                <span style="font-size:13px;font-weight:600;color:var(--prism-text);margin-left:2px;">Verification Code</span>
              </div>
              <!-- Digit boxes row -->
              <div style="position:relative;display:flex;align-items:center;gap:10px;">
                <div style="position:absolute;right:calc(100% + 6px);top:50%;transform:translateY(-50%);display:flex;align-items:center;gap:6px;"><span class="anat-marker-inline">2</span><div style="width:28px; height:2px; background:#2563eb;"></div></div>
                <div class="otp-box">0</div>
                <div class="otp-box">0</div>
                <div class="otp-box">0</div>
                <div class="otp-box">0</div>
              </div>
              <!-- Helper row -->
              <div style="position:relative;display:flex;align-items:center;gap:6px;">
                <span class="anat-marker-inline">3</span>
                <div style="width:28px; height:2px; background:#2563eb;"></div>
                <span style="font-size:12px;color:var(--prism-text-muted);display:flex;align-items:center;gap:4px;margin-left:2px;">&#9432; Help text</span>
              </div>
            </div>
          </div>
          <div class="anat-legend" style="grid-template-columns:repeat(3,1fr);">
            <div class="anat-legend-item"><span class="anat-marker-inline">1</span><div><strong>Label</strong><span>Semibold label text above the digit boxes. Toggleable via Show Label property. Uses Text-Primary color.</span></div></div>
            <div class="anat-legend-item"><span class="anat-marker-inline">2</span><div><strong>Digit Boxes</strong><span>Individual square input fields (4 or 6). Each box displays a single digit, centered. Styled by size and state.</span></div></div>
            <div class="anat-legend-item"><span class="anat-marker-inline">3</span><div><strong>Helper Row</strong><span>Contextual help or error message below the boxes. Shared sub-component (Form Field Helper Row). Toggleable via Show Helper Row.</span></div></div>
          </div>

          <hr class="doc-divider"/>

          <div style="margin-bottom:64px;">
            <h2 id="live-demo" class="doc-section-title" style="margin-bottom:8px;">Preview</h2>
            <p class="doc-section-subtitle" style="margin-bottom:28px;">Explore OTP Input across states and lengths.</p>
            <div class="demo-container">
<div class="demo-canvas" style="align-items:flex-start;gap:32px;padding:48px 64px;">
                <!-- Default 4-digit -->
                <div class="otp-demo">
                  <span class="otp-label">Verification Code</span>
                  <div class="otp-boxes">
                    <div class="otp-box">0</div><div class="otp-box">0</div><div class="otp-box">0</div><div class="otp-box">0</div>
                  </div>
                  <span class="otp-helper">&#9432; Enter the code sent to your device</span>
                </div>
                <!-- Focus -->
                <div class="otp-demo">
                  <span class="otp-label">Verification Code <span style="font-size:11px;font-weight:500;color:var(--prism-text-muted);margin-left:4px;">(Focus)</span></span>
                  <div class="otp-boxes">
                    <div class="otp-box focus">|</div><div class="otp-box">0</div><div class="otp-box">0</div><div class="otp-box">0</div>
                  </div>
                  <span class="otp-helper">&#9432; Enter the code sent to your device</span>
                </div>
                <!-- Filled -->
                <div class="otp-demo">
                  <span class="otp-label">Verification Code <span style="font-size:11px;font-weight:500;color:var(--prism-text-muted);margin-left:4px;">(Filled)</span></span>
                  <div class="otp-boxes">
                    <div class="otp-box filled">4</div><div class="otp-box filled">8</div><div class="otp-box filled">2</div><div class="otp-box filled">7</div>
                  </div>
                  <span class="otp-helper">&#9432; Code verified successfully</span>
                </div>
                <!-- Error -->
                <div class="otp-demo">
                  <span class="otp-label">Verification Code <span style="font-size:11px;font-weight:500;color:var(--prism-text-muted);margin-left:4px;">(Error)</span></span>
                  <div class="otp-boxes">
                    <div class="otp-box error">1</div><div class="otp-box error">2</div><div class="otp-box error">3</div><div class="otp-box error">4</div>
                  </div>
                  <span class="otp-helper error">&#10007; Invalid code. Please try again.</span>
                </div>
                <!-- Disabled -->
                <div class="otp-demo">
                  <span class="otp-label" style="opacity:0.5;">Verification Code <span style="font-size:11px;font-weight:500;margin-left:4px;">(Disabled)</span></span>
                  <div class="otp-boxes">
                    <div class="otp-box disabled">0</div><div class="otp-box disabled">0</div><div class="otp-box disabled">0</div><div class="otp-box disabled">0</div>
                  </div>
                  <span class="otp-helper" style="opacity:0.5;">&#9432; Help text</span>
                </div>
                <!-- 6-digit variant -->
                <div class="otp-demo" style="margin-top:8px;">
                  <span class="otp-label">6-Digit Code</span>
                  <div class="otp-boxes">
                    <div class="otp-box filled">7</div><div class="otp-box filled">3</div><div class="otp-box filled">9</div><div class="otp-box filled">2</div><div class="otp-box filled">0</div><div class="otp-box filled">5</div>
                  </div>
                  <span class="otp-helper">&#9432; Code sent to +91 &#8226;&#8226;&#8226;&#8226;&#8226;&#8226;7890</span>
                </div>
              </div>
            </div>
          </div>

          <div class="doc-section">
            <h3 id="content-guidelines" class="doc-h3">Content Guidelines<span class="h3-badge" style="background:rgba(37,99,235,0.1);color:var(--prism-violet);">Recommended</span></h3>
            <div class="do-dont-grid">
              <div class="do-card"><span class="card-label">Do</span><ul>
                <li>Set Length to match the actual code length sent to the user.</li>
                <li>Display the Error state + helper text immediately on incorrect code.</li>
                <li>Use <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">autocomplete="one-time-code"</code> for SMS autofill.</li>
                <li>Show a clear helper text (e.g. "Code sent to +91 &#8226;&#8226;&#8226;&#8226;&#8226;&#8226;7890").</li>
                <li>Clear all boxes and show Error state on wrong code.</li>
              </ul></div>
              <div class="dont-card"><span class="card-label">Don't</span><ul>
                <li>Show a 6-box OTP for a 4-digit code &#8212; mismatched lengths confuse users.</li>
                <li>Only reveal errors after the user submits the full form.</li>
                <li>Disable paste &#8212; it frustrates users switching from SMS.</li>
                <li>Leave the helper row empty &#8212; context reduces re-send rates.</li>
                <li>Keep entered digits in Error state without clearing.</li>
              </ul></div>
            </div>
          </div>
        </div>

        <!-- ========== STYLE ========== -->
        <div class="tab-content" id="tab-style" style="display:none;padding-top:32px;">
          <h2 id="style-overview" class="doc-section-title">Style</h2>
          <p class="doc-section-subtitle">Design tokens, size specifications, and visual states that define the OTP Input's appearance.</p>

          <div class="doc-section">
            <h2 id="variants" class="doc-section-title">Variants</h2>
            <p class="doc-section-subtitle">60 variants across Size (3) &times; State (5) &times; Length (2) &times; RTL (2).</p>
            <table class="size-table">
              <thead><tr><th>Axis</th><th>Values</th><th>Description</th></tr></thead>
              <tbody>
                <tr><td><strong>Size</strong></td><td><code>Small</code>, <code>Medium</code>, <code>Large</code></td><td>Controls box dimensions, font size, gap, and radius.</td></tr>
                <tr><td><strong>State</strong></td><td><code>Default</code>, <code>Focus</code>, <code>Filled</code>, <code>Error</code>, <code>Disabled</code></td><td>Interaction / validation state.</td></tr>
                <tr><td><strong>Length</strong></td><td><code>4</code>, <code>6</code></td><td>Number of digit boxes.</td></tr>
                <tr><td><strong>RTL</strong></td><td><code>False</code>, <code>True</code></td><td>Reverses visual order; Arabic label and helper text.</td></tr>
              </tbody>
            </table>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h2 id="states" class="doc-section-title">States</h2>
            <p class="doc-section-subtitle">OTP Input has five interaction states controlling borders, shadows, and text colors.</p>
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:14px;margin-top:24px;">
              <div style="padding:24px 16px;border-radius:14px;background:var(--prism-surface);border:1px solid var(--prism-border);text-align:center;">
                <div style="display:flex;gap:6px;justify-content:center;margin-bottom:16px;"><div class="otp-box" style="width:32px;height:32px;font-size:14px;">0</div><div class="otp-box" style="width:32px;height:32px;font-size:14px;">0</div></div>
                <div style="font-size:13px;font-weight:600;color:var(--prism-text);">Default</div>
                <div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;">Border-Secondary stroke</div>
              </div>
              <div style="padding:24px 16px;border-radius:14px;background:var(--prism-surface);border:1px solid var(--prism-border);text-align:center;">
                <div style="display:flex;gap:6px;justify-content:center;margin-bottom:16px;"><div class="otp-box focus" style="width:32px;height:32px;font-size:14px;">|</div><div class="otp-box" style="width:32px;height:32px;font-size:14px;">0</div></div>
                <div style="font-size:13px;font-weight:600;color:var(--prism-text);">Focus</div>
                <div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;">2px blue border + shadow</div>
              </div>
              <div style="padding:24px 16px;border-radius:14px;background:var(--prism-surface);border:1px solid var(--prism-border);text-align:center;">
                <div style="display:flex;gap:6px;justify-content:center;margin-bottom:16px;"><div class="otp-box filled" style="width:32px;height:32px;font-size:14px;">4</div><div class="otp-box filled" style="width:32px;height:32px;font-size:14px;">8</div></div>
                <div style="font-size:13px;font-weight:600;color:var(--prism-text);">Filled</div>
                <div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;">Border-Primary, Text-Primary</div>
              </div>
              <div style="padding:24px 16px;border-radius:14px;background:var(--prism-surface);border:1px solid var(--prism-border);text-align:center;">
                <div style="display:flex;gap:6px;justify-content:center;margin-bottom:16px;"><div class="otp-box error" style="width:32px;height:32px;font-size:14px;">1</div><div class="otp-box error" style="width:32px;height:32px;font-size:14px;">2</div></div>
                <div style="font-size:13px;font-weight:600;color:var(--prism-text);">Error</div>
                <div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;">Red border + shadow ring</div>
              </div>
              <div style="padding:24px 16px;border-radius:14px;background:var(--prism-surface);border:1px solid var(--prism-border);text-align:center;">
                <div style="display:flex;gap:6px;justify-content:center;margin-bottom:16px;"><div class="otp-box disabled" style="width:32px;height:32px;font-size:14px;">0</div><div class="otp-box disabled" style="width:32px;height:32px;font-size:14px;">0</div></div>
                <div style="font-size:13px;font-weight:600;color:var(--prism-text);">Disabled</div>
                <div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;">BG-Disabled, 50% opacity</div>
              </div>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h2 id="sizes" class="doc-section-title">Sizes</h2>
            <p class="doc-section-subtitle">Three sizes for different layout contexts.</p>
            <table class="size-table">
              <thead><tr><th>Property</th><th>Small</th><th>Medium</th><th>Large</th></tr></thead>
              <tbody>
                <tr><td><strong>Box size</strong></td><td>36 &times; 36 px</td><td>40 &times; 40 px</td><td>48 &times; 48 px</td></tr>
                <tr><td><strong>Digit font size</strong></td><td>16 px</td><td>18 px</td><td>22 px</td></tr>
                <tr><td><strong>Inter-box gap</strong></td><td>8 px</td><td>10 px</td><td>12 px</td></tr>
                <tr><td><strong>Corner radius</strong></td><td>6 px (<code>radius-6</code>)</td><td>8 px (<code>radius-8</code>)</td><td>8 px (<code>radius-8</code>)</td></tr>
                <tr><td><strong>Label font size</strong></td><td>12 px</td><td>13 px</td><td>14 px</td></tr>
                <tr><td><strong>Root vertical gap</strong></td><td>8 px</td><td>8 px</td><td>8 px</td></tr>
              </tbody>
            </table>
            <!-- Size previews -->
            <div style="display:flex;gap:40px;flex-wrap:wrap;margin-top:32px;align-items:flex-end;">
              <div style="text-align:center;">
                <div style="display:flex;gap:8px;margin-bottom:8px;">
                  <div class="otp-box otp-sm filled">3</div><div class="otp-box otp-sm filled">7</div><div class="otp-box otp-sm filled">1</div><div class="otp-box otp-sm filled">9</div>
                </div>
                <div style="font-size:12px;font-weight:600;color:var(--prism-text-muted);">Small (36px)</div>
              </div>
              <div style="text-align:center;">
                <div style="display:flex;gap:10px;margin-bottom:8px;">
                  <div class="otp-box filled">4</div><div class="otp-box filled">8</div><div class="otp-box filled">2</div><div class="otp-box filled">7</div>
                </div>
                <div style="font-size:12px;font-weight:600;color:var(--prism-text-muted);">Medium (40px)</div>
              </div>
              <div style="text-align:center;">
                <div style="display:flex;gap:12px;margin-bottom:8px;">
                  <div class="otp-box otp-lg filled">5</div><div class="otp-box otp-lg filled">0</div><div class="otp-box otp-lg filled">6</div><div class="otp-box otp-lg filled">2</div>
                </div>
                <div style="font-size:12px;font-weight:600;color:var(--prism-text-muted);">Large (48px)</div>
              </div>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="color-tokens" class="doc-h3">Color Tokens<span class="h3-badge" style="background:rgba(37,99,235,0.1);color:var(--prism-violet);">Tokens</span></h3>

            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Box Fill</h4>
            <table class="size-table" style="margin-bottom:32px;">
              <thead><tr><th>State</th><th>Token</th><th>Resolves (Light)</th></tr></thead>
              <tbody>
                <tr><td>Default, Focus, Filled, Error</td><td><code>Background/BG-Base-White</code></td><td>#FFFFFF</td></tr>
                <tr><td>Disabled</td><td><code>Background/BG-Disabled</code></td><td>#E1E4EB</td></tr>
              </tbody>
            </table>

            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Box Border</h4>
            <table class="size-table" style="margin-bottom:32px;">
              <thead><tr><th>State</th><th>Token</th><th>Resolves (Light)</th></tr></thead>
              <tbody>
                <tr><td>Default</td><td><code>Border/Border-Secondary</code></td><td>#C3C9D6</td></tr>
                <tr><td>Focus (active box)</td><td><code>Border/Border-Accent</code> (2px)</td><td>#006AFF</td></tr>
                <tr><td>Filled</td><td><code>Border/Border-Primary</code></td><td>#B4BBCC</td></tr>
                <tr><td>Error</td><td><code>Border/Border-Error</code></td><td>#E42527</td></tr>
                <tr><td>Disabled</td><td><code>Border/Border-Disabled</code></td><td>#E1E4EB</td></tr>
              </tbody>
            </table>

            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Box Shadow</h4>
            <table class="size-table" style="margin-bottom:32px;">
              <thead><tr><th>State</th><th>Effect</th></tr></thead>
              <tbody>
                <tr><td>Focus</td><td>Blue shadow ring (accent glow)</td></tr>
                <tr><td>Error</td><td>Red shadow ring (error glow)</td></tr>
                <tr><td>Others</td><td>None</td></tr>
              </tbody>
            </table>

            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Digit Text</h4>
            <table class="size-table" style="margin-bottom:32px;">
              <thead><tr><th>State</th><th>Token</th><th>Resolves (Light)</th></tr></thead>
              <tbody>
                <tr><td>Default (placeholder)</td><td><code>Text/Text-Disabled</code></td><td>#8893AD</td></tr>
                <tr><td>Focus</td><td><code>Text/Text-Primary</code></td><td>#15181E</td></tr>
                <tr><td>Filled</td><td><code>Text/Text-Primary</code></td><td>#15181E</td></tr>
                <tr><td>Error</td><td><code>Text/Text-Error</code></td><td>#C1181B</td></tr>
                <tr><td>Disabled</td><td><code>Text/Text-Disabled</code></td><td>#8893AD</td></tr>
              </tbody>
            </table>

            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Label Text</h4>
            <table class="size-table">
              <thead><tr><th>State</th><th>Token</th></tr></thead>
              <tbody>
                <tr><td>All non-disabled</td><td><code>Text/Text-Primary</code></td></tr>
                <tr><td>Disabled</td><td><code>Text/Text-Disabled</code> at 50%</td></tr>
              </tbody>
            </table>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="spacing-tokens" class="doc-h3">Spacing Tokens</h3>
            <table class="size-table">
              <thead><tr><th>Token</th><th>Small</th><th>Medium</th><th>Large</th></tr></thead>
              <tbody>
                <tr><td><strong>Inter-box gap</strong></td><td>8 px</td><td>10 px</td><td>12 px</td></tr>
                <tr><td><strong>Root vertical gap</strong></td><td>8 px</td><td>8 px</td><td>8 px</td></tr>
                <tr><td><strong>Label gap</strong></td><td>4 px</td><td>4 px</td><td>4 px</td></tr>
              </tbody>
            </table>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="corner-radius-border-radius" class="doc-h3">Corner Radius (Border Radius)</h3>
            <p class="doc-section-subtitle">OTP digit boxes use rounded corners that scale with size.</p>
            <div style="display:flex;gap:24px;flex-wrap:wrap;">
              <div style="flex:1;min-width:200px;padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;text-align:center;">
                <div style="width:36px;height:36px;border:2px dashed #006AFF;border-radius:6px;margin:0 auto 16px;display:flex;align-items:center;justify-content:center;background:rgba(0,106,255,0.05);color:#006AFF;font-weight:600;font-size:11px;">6</div>
                <div style="font-size:14px;font-weight:600;color:var(--prism-text);">radius-6</div>
                <div style="font-size:12px;color:var(--prism-text-muted);margin-top:4px;">Small size</div>
              </div>
              <div style="flex:1;min-width:200px;padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;text-align:center;">
                <div style="width:40px;height:40px;border:2px dashed #006AFF;border-radius:8px;margin:0 auto 16px;display:flex;align-items:center;justify-content:center;background:rgba(0,106,255,0.05);color:#006AFF;font-weight:600;font-size:11px;">8</div>
                <div style="font-size:14px;font-weight:600;color:var(--prism-text);">radius-8</div>
                <div style="font-size:12px;color:var(--prism-text-muted);margin-top:4px;">Medium / Large size</div>
              </div>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="typography-family" class="doc-h3">Typography Family</h3>
            <p class="doc-section-subtitle">All OTP Input text uses <strong>Zoho Puvi</strong>. Digits are Bold weight, labels are Semibold.</p>
            <table class="size-table">
              <thead><tr><th>Element</th><th>Weight</th><th>Notes</th></tr></thead>
              <tbody>
                <tr><td>Digit text</td><td><code>700 (Bold)</code></td><td>Centered inside each box, sized per variant</td></tr>
                <tr><td>Label text</td><td><code>600 (Semibold)</code></td><td>12px (S) / 13px (M) / 14px (L)</td></tr>
                <tr><td>Helper text</td><td><code>400 (Regular)</code></td><td>12px, Text-Tertiary or Text-Error</td></tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- ========== USAGE ========== -->
        <div class="tab-content" id="tab-usage" style="display:none;padding-top:32px;">
          <div class="doc-section">
            <h2 id="when-to-use" class="doc-section-title">When and Where to Use</h2>
            <p class="doc-section-subtitle">OTP Input is designed for numeric verification code entry across authentication flows.</p>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:24px;">
              <div style="padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;">
                <h3 style="font-size:15px;font-weight:600;color:var(--prism-text);margin-bottom:16px;display:flex;align-items:center;gap:8px;"><svg width="20" height="20" fill="none" stroke="#2563eb" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>When to use</h3>
                <ul class="doc-list" style="border:none;background:transparent;padding-left:20px;font-size:14.5px;">
                  <li style="border:none;background:transparent;margin-bottom:8px;">Verify identity via a numeric code sent by SMS, email, or authenticator app.</li>
                  <li style="border:none;background:transparent;margin-bottom:8px;">For 2FA (two-factor authentication) flows.</li>
                  <li style="border:none;background:transparent;">For PIN entry where each digit is individually confirmed.</li>
                </ul>
              </div>
              <div style="padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;">
                <h3 style="font-size:15px;font-weight:600;color:var(--prism-text);margin-bottom:16px;display:flex;align-items:center;gap:8px;"><svg width="20" height="20" fill="none" stroke="#e42527" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>When NOT to use</h3>
                <ul class="doc-list" style="border:none;background:transparent;padding-left:20px;font-size:14.5px;">
                  <li style="border:none;background:transparent;margin-bottom:8px;">For passwords &#8212; use a password input field instead.</li>
                  <li style="border:none;background:transparent;margin-bottom:8px;">For codes longer than 6 digits &#8212; use a single text input with <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">inputmode="numeric"</code>.</li>
                  <li style="border:none;background:transparent;">For alphanumeric codes &#8212; extend the component or use a standard text input.</li>
                </ul>
              </div>
            </div>

            <!-- Choosing Length / Size -->
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:32px;">
              <div style="padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;">
                <h4 style="font-size:15px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Choosing Length</h4>
                <table class="size-table" style="font-size:13px;">
                  <thead><tr><th>Scenario</th><th>Length</th></tr></thead>
                  <tbody>
                    <tr><td>Standard SMS OTP, email verification</td><td><code>6</code></td></tr>
                    <tr><td>PIN / short code</td><td><code>4</code></td></tr>
                    <tr><td>Authenticator app TOTP</td><td><code>6</code></td></tr>
                  </tbody>
                </table>
              </div>
              <div style="padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;">
                <h4 style="font-size:15px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Choosing Size</h4>
                <table class="size-table" style="font-size:13px;">
                  <thead><tr><th>Context</th><th>Size</th></tr></thead>
                  <tbody>
                    <tr><td>Dense forms, compact UI</td><td><code>Small</code></td></tr>
                    <tr><td>Default web UI</td><td><code>Medium</code></td></tr>
                    <tr><td>Prominent / hero placement (e.g. login page)</td><td><code>Large</code></td></tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h2 id="alignment-placement" class="doc-section-title">Alignment &amp; Placement</h2>
            <p class="doc-section-subtitle">Consistent placement ensures the OTP Input is predictable and easy to locate.</p>
            <ul class="doc-list">
              <li><strong>Login / verification pages:</strong> Center the OTP Input horizontally on the page for a focused, hero-style placement.</li>
              <li><strong>Inline forms:</strong> Left-align the OTP Input with other form fields for visual consistency.</li>
              <li><strong>Mobile:</strong> Use Large size for comfortable touch targets. Center on screen for single-purpose verification flows.</li>
              <li><strong>RTL layouts:</strong> Set <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">dir="rtl"</code> on the wrapper and let the browser handle visual mirroring. Do not reorder DOM inputs.</li>
            </ul>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h2 id="detailed-guidelines" class="doc-section-title">Complete Do's and Don'ts</h2>
            <p class="doc-section-subtitle">Guidelines for effective OTP Input usage.</p>
            <div class="do-dont-grid">
              <div class="do-card"><span class="card-label">Do</span><ul>
                <li><strong>Match length to code:</strong> Set Length to match the actual code length sent to the user.</li>
                <li><strong>Immediate error feedback:</strong> Display the Error state + helper text immediately on incorrect code.</li>
                <li><strong>Enable SMS autofill:</strong> Use <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">autocomplete="one-time-code"</code> for SMS autofill.</li>
                <li><strong>Show context:</strong> Show a clear helper text (e.g. "Code sent to +91 &#8226;&#8226;&#8226;&#8226;&#8226;&#8226;7890").</li>
                <li><strong>Use Show Label=OFF only</strong> when the label is already provided by surrounding page content.</li>
                <li><strong>Clear on error:</strong> Clear all boxes and show Error state on wrong code &#8212; users should re-enter cleanly.</li>
              </ul></div>
              <div class="dont-card"><span class="card-label">Don't</span><ul>
                <li><strong>Mismatched length:</strong> Show a 6-box OTP for a 4-digit code &#8212; mismatched lengths confuse users.</li>
                <li><strong>Delayed errors:</strong> Only reveal errors after the user submits the full form.</li>
                <li><strong>Block paste:</strong> Disable paste &#8212; it frustrates users switching from SMS.</li>
                <li><strong>Empty helpers:</strong> Leave the helper row empty &#8212; context reduces re-send rates.</li>
                <li><strong>Hidden label without context:</strong> Hide the label without another visible indication of what the field expects.</li>
                <li><strong>Stale error digits:</strong> Keep entered digits in Error state without clearing.</li>
              </ul></div>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h2 id="related" class="doc-section-title">Related</h2>
            <p class="doc-section-subtitle">Components that complement or can be used alongside OTP Input.</p>
            <div class="related-grid">
              <a href="Text-field.html" class="related-chip"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 7V4h16v3M9 20h6M12 4v16"/></svg> Text Input</a>
              <a href="Form.html" class="related-chip"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 3v18M3 9h6"/></svg> Form</a>
              <a href="Help-text.html" class="related-chip"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg> Form Field Helper Row</a>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h2 id="references" class="doc-section-title">References</h2>
            <p class="doc-section-subtitle">Design tokens and resources for implementing the OTP Input component.</p>
            <ul class="doc-list">
              <li><strong>Figma Node:</strong> <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">18019:574607</code> &#8212; Component Set: OTP Input</li>
              <li><strong>Total Variants:</strong> 3 Sizes &times; 5 States &times; 2 Lengths &times; 2 RTL = <strong>60 variants</strong></li>
              <li><strong>Typography:</strong> Zoho Puvi Bold (700) for digits, Semibold (600) for labels</li>
              <li><strong>Sub-component:</strong> Form Field Helper Row (<code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">17905:5403</code>)</li>
            </ul>
          </div>

        </div>

        <!-- ========== CODE ========== -->
        <div class="tab-content" id="tab-code" style="display:none;padding-top:32px;">
          <h2 id="live-demo-code" class="doc-section-title">Live demo (Code)</h2>
          <p class="doc-section-subtitle">Configure the OTP Input component and view generated HTML.</p>
          <div class="code-playground">
            <div class="cp-toolbar">
              <div class="cp-control-group"><label class="cp-label">Length</label><select class="cp-select" id="pg-length"><option value="4" selected>4 digits</option><option value="6">6 digits</option></select></div>
              <div class="cp-control-group"><label class="cp-label">Size</label><select class="cp-select" id="pg-size"><option value="sm">Small</option><option value="md" selected>Medium</option><option value="lg">Large</option></select></div>
              <div class="cp-control-group"><label class="cp-label">State</label><select class="cp-select" id="pg-state"><option value="default" selected>Default</option><option value="focus">Focus</option><option value="filled">Filled</option><option value="error">Error</option><option value="disabled">Disabled</option></select></div>
              <div class="cp-control-group"><label class="cp-label">Direction</label><select class="cp-select" id="pg-dir"><option value="ltr" selected>LTR</option><option value="rtl">RTL</option></select></div>
            </div>
            <div class="cp-preview" id="pg-preview-area"></div>
            <div class="cp-code-header">
              <div style="font-size:13.5px;font-weight:600;color:var(--prism-text);">HTML</div>
              <button class="cp-action-btn" id="pg-copy-btn"><svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2"/></svg> Copy code</button>
            </div>
            <div class="cp-code-area" id="pg-code-output"></div>
          </div>
          <script>
          (function(){
            var els = {length:document.getElementById('pg-length'),size:document.getElementById('pg-size'),state:document.getElementById('pg-state'),dir:document.getElementById('pg-dir')};
            var previewArea = document.getElementById('pg-preview-area');
            var codeOut = document.getElementById('pg-code-output');
            var copyBtn = document.getElementById('pg-copy-btn');
            var sizeMap = {sm:{w:36,h:36,r:6,fs:16,gap:8,lfs:12},md:{w:40,h:40,r:8,fs:18,gap:10,lfs:13},lg:{w:48,h:48,r:8,fs:22,gap:12,lfs:14}};
            var stateDigits = {default:'0',focus:'|',filled:'4',error:'1',disabled:'0'};
            var filledDigits = ['4','8','2','7','5','3'];
            var errorDigits = ['1','2','3','4','5','6'];
            function esc(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
            function update(){
              var len = parseInt(els.length.value);
              var sz = els.size.value;
              var st = els.state.value;
              var dir = els.dir.value;
              var s = sizeMap[sz];
              var isRTL = dir === 'rtl';
              var label = isRTL ? '\u0631\u0645\u0632 \u0627\u0644\u062A\u062D\u0642\u0642' : 'Verification Code';
              var helper = isRTL ? '\u0646\u0635 \u0645\u0633\u0627\u0639\u062F' : 'Enter the code sent to your device';
              if(st==='error') helper = isRTL ? '\u0631\u0645\u0632 \u063A\u064A\u0631 \u0635\u062D\u064A\u062D' : 'Invalid code. Please try again.';

              // Build preview
              var html = '<div class="otp-demo" style="'+(isRTL?'direction:rtl;':'')+'"><span class="otp-label" style="font-size:'+s.lfs+'px;'+(st==='disabled'?'opacity:0.5;':'')+'">'+label+'</span><div class="otp-boxes" style="gap:'+s.gap+'px;">';
              for(var i=0;i<len;i++){
                var cls = 'otp-box';
                var digit = '0';
                var extraStyle = 'width:'+s.w+'px;height:'+s.h+'px;border-radius:'+s.r+'px;font-size:'+s.fs+'px;';
                if(st==='focus' && i===0){ cls+=' focus'; digit='|'; }
                else if(st==='filled'){ cls+=' filled'; digit=filledDigits[i]||'0'; }
                else if(st==='error'){ cls+=' error'; digit=errorDigits[i]||'0'; }
                else if(st==='disabled'){ cls+=' disabled'; }
                html += '<div class="'+cls+'" style="'+extraStyle+'">'+digit+'</div>';
              }
              html += '</div><span class="otp-helper'+(st==='error'?' error':'')+'" style="'+(st==='disabled'?'opacity:0.5;':'')+'">'+(st==='error'?'&#10007; ':'&#9432; ')+helper+'</span></div>';
              previewArea.innerHTML = html;

              // Build code output
              var dirAttr = isRTL ? ' dir="rtl"' : '';
              var ariaLabel = isRTL ? '\u0631\u0642\u0645 N \u0645\u0646 '+len : 'Digit N of '+len;
              var codeStr = '<fieldset'+dirAttr+'>\n  <legend>'+label+'</legend>\n  <div class="otp-fields">\n';
              for(var j=1;j<=len;j++){
                var al = ariaLabel.replace('N', j);
                codeStr += '    <input type="text" inputmode="numeric" pattern="[0-9]*" maxlength="1" autocomplete="one-time-code" aria-label="'+al+'"'+(st==='disabled'?' disabled':'')+' />\n';
              }
              codeStr += '  </div>\n  <div class="helper-row" aria-live="'+(st==='error'?'assertive':'polite')+'">\n    <span>'+helper+'</span>\n  </div>\n</fieldset>';
              codeOut.innerHTML = esc(codeStr)
                .replace(/class=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">class</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/type=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">type</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/inputmode=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">inputmode</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/pattern=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">pattern</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/maxlength=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">maxlength</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/autocomplete=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">autocomplete</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/aria-label=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">aria-label</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/aria-live=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">aria-live</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/dir=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">dir</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/ disabled/g,' <span style="color:#f97316;">disabled</span>')
                .replace(/&lt;(\/?)(fieldset|legend|div|input|span)(.*?)&gt;/g,'&lt;$1<span style="color:#a78bfa;">$2</span>$3&gt;');
            }
            Object.values(els).forEach(function(e){e.addEventListener('change',update);});
            copyBtn.addEventListener('click',function(){
              var r=document.createElement('div');r.innerHTML=codeOut.innerHTML;
              navigator.clipboard.writeText(r.innerText).then(function(){
                var o=copyBtn.innerHTML;copyBtn.innerHTML='<svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Copied!';setTimeout(function(){copyBtn.innerHTML=o;},2000);
              });
            });
            update();
          })();
          </script>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="component-api-properties" class="doc-h3">Component API &amp; Properties</h3>
            <table class="size-table">
              <thead><tr><th>Property</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
              <tbody>
                <tr><td><code>Label</code></td><td>Text</td><td>"Verification Code"</td><td>Label text (LTR). RTL label is always Arabic.</td></tr>
                <tr><td><code>Show Label</code></td><td>Boolean</td><td>ON</td><td>Toggles the label row.</td></tr>
                <tr><td><code>Show Helper Row</code></td><td>Boolean</td><td>ON</td><td>Toggles the helper text row below the boxes.</td></tr>
                <tr><td><code>Digit 1</code></td><td>Text</td><td>"0"</td><td>Individual digit override for box 1 (Figma design-time only).</td></tr>
                <tr><td><code>Digit 2</code></td><td>Text</td><td>"0"</td><td>Individual digit override for box 2.</td></tr>
                <tr><td><code>Digit 3</code></td><td>Text</td><td>"0"</td><td>Individual digit override for box 3.</td></tr>
                <tr><td><code>Digit 4</code></td><td>Text</td><td>"0"</td><td>Individual digit override for box 4.</td></tr>
                <tr><td><code>Digit 5</code></td><td>Text</td><td>"0"</td><td>Individual digit override for box 5 (Length=6 only).</td></tr>
                <tr><td><code>Digit 6</code></td><td>Text</td><td>"0"</td><td>Individual digit override for box 6 (Length=6 only).</td></tr>
              </tbody>
            </table>
            <div style="margin-top:16px;padding:16px 20px;background:rgba(37,99,235,0.05);border:1px solid rgba(37,99,235,0.15);border-radius:12px;">
              <p style="font-size:14px;color:var(--prism-text);line-height:1.6;margin:0;"><strong>Note:</strong> Digit 1&#8211;6 properties are for Figma design-time overrides only. In production, digits are controlled by component state.</p>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="implementation-idea-ember-hook-form" class="doc-h3">Implementation Idea: Ember Hook Form</h3>
            <div class="cp-code-area" style="border-radius:12px;margin-top:16px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;">
                <span style="color:#94a3b8;">&lt;!-- otp-verification.hbs --&gt;</span><br>
                <span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">UemsOtpInput</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">@length</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"6"</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">@size</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"md"</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">@state</span><span style="color:#56B6C2;">=</span><span style="color:#C678DD;">{{</span><span style="color:#E5C07B;">this.otpState</span><span style="color:#C678DD;">}}</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">@label</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"Verification Code"</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">@helperText</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"Code sent to +91 &#8226;&#8226;&#8226;&#8226;&#8226;&#8226;7890"</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">@onComplete</span><span style="color:#56B6C2;">=</span><span style="color:#C678DD;">{{</span><span style="color:#E5C07B;">this.verifyOtp</span><span style="color:#C678DD;">}}</span><br>
                <span style="color:#ABB2BF;">/&gt;</span>
              </div>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="rtl-support" class="doc-h3">RTL Support</h3>
            <ul class="doc-list">
              <li><strong>Wrapper direction:</strong> Set <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">dir="rtl"</code> on the wrapper element. The browser handles visual mirroring of the flex layout.</li>
              <li><strong>Do not reorder DOM:</strong> Inputs remain in DOM order (1&#8594;4 or 1&#8594;6). The <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">dir="rtl"</code> attribute reverses the visual display.</li>
              <li><strong>Arabic labels:</strong> RTL variants use Arabic label text (<code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&#x631;&#x645;&#x632; &#x627;&#x644;&#x62A;&#x62D;&#x642;&#x642;</code>) and right-aligned helper text.</li>
              <li><strong>Keyboard navigation:</strong> Arrow keys follow visual direction &#8212; ArrowRight moves to the visually right box (which is the previous input in DOM order).</li>
            </ul>
            <div class="cp-code-area" style="border-radius:12px;margin-top:16px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;">
                <span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">div</span> <span style="color:#D19A66;">dir</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"rtl"</span><span style="color:#ABB2BF;">&gt;</span><br>
                &nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">label</span><span style="color:#ABB2BF;">&gt;</span><span style="color:#e2e8f0;">&#x631;&#x645;&#x632; &#x627;&#x644;&#x62A;&#x62D;&#x642;&#x642;</span><span style="color:#ABB2BF;">&lt;/</span><span style="color:#E06C75;">label</span><span style="color:#ABB2BF;">&gt;</span><br>
                &nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">div</span> <span style="color:#D19A66;">class</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"otp-fields"</span><span style="color:#ABB2BF;">&gt;</span><br>
                &nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#94a3b8;">&lt;!-- Inputs in DOM order (1&#8594;4), visually reversed by dir="rtl" --&gt;</span><br>
                &nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">input</span> ... <span style="color:#D19A66;">aria-label</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"&#x631;&#x642;&#x645; 1 &#x645;&#x646; 4"</span> <span style="color:#ABB2BF;">/&gt;</span><br>
                &nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#ABB2BF;">...</span><br>
                &nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;/</span><span style="color:#E06C75;">div</span><span style="color:#ABB2BF;">&gt;</span><br>
                <span style="color:#ABB2BF;">&lt;/</span><span style="color:#E06C75;">div</span><span style="color:#ABB2BF;">&gt;</span>
              </div>
            </div>
          </div>
        </div>

        <!-- ========== ACCESSIBILITY ========== -->
        <div class="tab-content" id="tab-accessibility" style="display:none;padding-top:32px;">
          <h2 id="accessibility" class="doc-section-title">Accessibility</h2>
          <p class="doc-section-subtitle">Guidelines for ensuring OTP Input is accessible across assistive technologies and input methods.</p>

          <div class="doc-section">
            <h3 id="keyboard-interaction" class="doc-h3">Keyboard Interaction</h3>
            <table class="size-table">
              <thead><tr><th>Action</th><th>Result</th></tr></thead>
              <tbody>
                <tr><td><code>Numeric key (0&#8211;9)</code></td><td>Enters digit in focused box and auto-advances focus to next box.</td></tr>
                <tr><td><code>Backspace</code> on filled box</td><td>Clears digit, stays on current box.</td></tr>
                <tr><td><code>Backspace</code> on empty box</td><td>Moves focus to previous box.</td></tr>
                <tr><td><code>Tab</code></td><td>Moves focus to next box.</td></tr>
                <tr><td><code>Shift+Tab</code></td><td>Moves focus to previous box.</td></tr>
                <tr><td>Paste (full code)</td><td>Distributes pasted digits across all boxes from the focused position.</td></tr>
                <tr><td><code>ArrowLeft</code> / <code>ArrowRight</code></td><td>Moves focus to adjacent box.</td></tr>
              </tbody>
            </table>
            <div style="margin-top:16px;padding:16px 20px;background:rgba(37,99,235,0.05);border:1px solid rgba(37,99,235,0.15);border-radius:12px;">
              <p style="font-size:14px;color:var(--prism-text);line-height:1.6;margin:0;">Auto-advance on input must not trap keyboard users; <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">Tab</code> must still work as expected to move focus out of the OTP group.</p>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="aria-attributes-screen-reader-guidance" class="doc-h3">ARIA Attributes &amp; Screen Reader Guidance</h3>
            <ul class="doc-list">
              <li><strong>Group label:</strong> Wrap all digit inputs in a <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;fieldset&gt;</code> with a <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;legend&gt;</code> matching the label text.</li>
              <li><strong>Per-input label:</strong> Each <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;input&gt;</code> must have <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-label="Digit N of M"</code> (e.g. "Digit 1 of 4").</li>
              <li><strong>Error announcement:</strong> When Error state activates, update an <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-live="assertive"</code> region with the error message.</li>
              <li><strong>Helper text association:</strong> Associate the helper text with the group using <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-describedby</code> on the <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;fieldset&gt;</code>.</li>
              <li><strong>Disabled:</strong> Disabled inputs must have the <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">disabled</code> attribute, not just visual styling.</li>
              <li><strong>Mobile autofill:</strong> <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">autocomplete="one-time-code"</code> enables OS-level SMS autofill without ARIA intervention.</li>
              <li><strong>Screen reader paste:</strong> Ensure paste events reflect the result back through value changes the screen reader can detect.</li>
              <li><strong>RTL:</strong> Set <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">dir="rtl"</code> on the wrapper; do not reorder DOM inputs.</li>
            </ul>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="focus-state-design" class="doc-h3">Focus State Design</h3>
            <ul class="doc-list">
              <li><strong>Visible focus indicator:</strong> The active box receives a 2px blue border (<code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">#006AFF</code>) plus a blue shadow ring &#8212; this must not be overridden (WCAG 2.4.7).</li>
              <li><strong>Cursor indicator:</strong> A "|" cursor indicator appears inside the focused box to signal text input readiness.</li>
              <li><strong>Single active box:</strong> Only one box is focused at a time. Remaining boxes retain their current state styling.</li>
            </ul>
            <div style="margin-top:24px;display:flex;gap:16px;align-items:center;padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;">
              <div class="otp-box focus" style="width:48px;height:48px;font-size:22px;">|</div>
              <div>
                <div style="font-weight:600;font-size:15px;color:var(--prism-text);">Focus ring: 2px border + 3px shadow</div>
                <div style="font-size:14px;color:var(--prism-text-muted);margin-top:4px;">Border: #006AFF | Shadow: rgba(0,106,255,0.15)</div>
              </div>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="color-contrast-minimums" class="doc-h3">Color Contrast Minimums<span class="h3-badge" style="background:rgba(34,197,94,0.15);color:#16a34a;">WCAG AA Pass</span></h3>
            <p class="doc-section-subtitle">All color combinations meet WCAG 2.1 AA contrast requirements. Disabled state is exempt.</p>
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px;margin-top:24px;">
              <div style="background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;overflow:hidden;">
                <div style="background:#fff;padding:28px 24px;text-align:center;color:#15181E;border:2px solid #B4BBCC;border-radius:12px 12px 0 0;"><div style="font-size:24px;font-weight:700;">4 8 2 7</div></div>
                <div style="padding:16px 24px;display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--prism-border);"><div><div style="font-size:13px;color:var(--prism-text-muted);font-weight:600;">TEXT-PRIMARY ON WHITE</div><div style="font-size:15px;color:var(--prism-text);font-family:monospace;margin-top:4px;">#15181E on #FFFFFF</div></div><div style="text-align:right;"><div style="display:inline-flex;align-items:center;gap:6px;background:rgba(34,197,94,0.1);color:#16a34a;padding:4px 10px;border-radius:100px;font-size:12px;font-weight:700;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><polyline points="20 6 9 17 4 12"></polyline></svg> 17.4:1</div><div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;font-weight:600;">WCAG AAA Pass</div></div></div>
              </div>
              <div style="background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;overflow:hidden;">
                <div style="background:#fff;padding:28px 24px;text-align:center;color:#C1181B;border:2px solid #E42527;border-radius:12px 12px 0 0;"><div style="font-size:24px;font-weight:700;">1 2 3 4</div></div>
                <div style="padding:16px 24px;display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--prism-border);"><div><div style="font-size:13px;color:var(--prism-text-muted);font-weight:600;">ERROR RED ON WHITE</div><div style="font-size:15px;color:var(--prism-text);font-family:monospace;margin-top:4px;">#C1181B on #FFFFFF</div></div><div style="text-align:right;"><div style="display:inline-flex;align-items:center;gap:6px;background:rgba(34,197,94,0.1);color:#16a34a;padding:4px 10px;border-radius:100px;font-size:12px;font-weight:700;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><polyline points="20 6 9 17 4 12"></polyline></svg> 5.9:1</div><div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;font-weight:600;">WCAG AA Pass</div></div></div>
              </div>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="touch-target-size" class="doc-h3">Touch Target Size</h3>
            <p class="doc-section-subtitle">Large size boxes meet the 48px minimum touch target. Smaller sizes should ensure adequate spacing.</p>
            <div style="margin-top:16px;padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;display:flex;align-items:center;gap:24px;">
              <div style="width:48px;height:48px;background:rgba(37,99,235,0.1);border:1px dashed var(--prism-violet);border-radius:8px;display:flex;align-items:center;justify-content:center;color:var(--prism-violet);font-size:13px;font-weight:600;flex-shrink:0;">48px</div>
              <div><div style="font-weight:600;font-size:15px;color:var(--prism-text);">Large box: 48&times;48px &#8212; meets minimum</div><div style="font-size:14px;color:var(--prism-text-muted);margin-top:4px;">The Large size (48px) meets the 48px minimum touch target (WCAG 2.5.5). For Small (36px) and Medium (40px), the inter-box gap provides additional touch area.</div></div>
            </div>
          </div>
        </div>

        </div><!-- main-content-inner -->

        <aside class="toc-sidebar">
