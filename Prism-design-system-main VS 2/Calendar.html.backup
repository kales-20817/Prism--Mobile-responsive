    <main class="main-panel">
      <div class="page-header-area">
        <h1 class="page-title">Calendar</h1>
        <p class="page-desc">A date picker panel component used for selecting a single date or a date range. Composed of a header, weekday row, date grid, and optional footer actions. Renders as an elevated floating panel with a dark background and drop shadow.</p>
        <nav class="content-tabs">
          <button class="tab-item active">Overview</button>
          <button class="tab-item">Style</button>
          <button class="tab-item">Usage</button>
          <button class="tab-item">Code</button>
          <button class="tab-item">Accessibility</button>
        </nav>
      </div>

      <div class="main-content-area">
        <div class="main-content-inner">

        <!-- ========== OVERVIEW ========== -->
        <div class="tab-content" id="tab-overview">
          <h3 id="anatomy" class="doc-h3">Anatomy</h3>
          <div class="anatomy-diagram">
            <div style="display:flex;flex-direction:column;align-items:center;gap:0;margin:20px 0;">
              <!-- Single calendar with anatomy markers -->
              <div class="cal-panel single" style="position:relative;">
                <!-- Marker 1: Calendar Header -->
                <div style="position:relative;">
                  <div style="position:absolute;right:calc(100% + 6px);top:50%;transform:translateY(-50%);display:flex;align-items:center;gap:6px;z-index:5;"><span class="anat-marker-inline">1</span><div style="width:28px;height:2px;background:#2563eb;"></div></div>
                  <div class="cal-header">
                    <button class="cal-header-btn"><svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15 19l-7-7 7-7"/></svg></button>
                    <span class="cal-header-title">March 2026</span>
                    <button class="cal-header-btn"><svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg></button>
                  </div>
                </div>
                <!-- Marker 2: Weekday Row -->
                <div style="position:relative;">
                  <div style="position:absolute;right:calc(100% + 6px);top:50%;transform:translateY(-50%);display:flex;align-items:center;gap:6px;z-index:5;"><span class="anat-marker-inline">2</span><div style="width:28px;height:2px;background:#2563eb;"></div></div>
                  <div class="cal-weekdays">
                    <span>Sun</span><span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span>
                  </div>
                </div>
                <!-- Marker 3: Calendar Grid -->
                <div style="position:relative;">
                  <div style="position:absolute;right:calc(100% + 6px);top:30%;transform:translateY(-50%);display:flex;align-items:center;gap:6px;z-index:5;"><span class="anat-marker-inline">3</span><div style="width:28px;height:2px;background:#2563eb;"></div></div>
                  <div class="cal-grid">
                    <div class="cal-day">1</div><div class="cal-day">2</div><div class="cal-day">3</div><div class="cal-day">4</div><div class="cal-day">5</div><div class="cal-day">6</div><div class="cal-day">7</div>
                    <div class="cal-day">8</div><div class="cal-day">9</div><div class="cal-day">10</div><div class="cal-day">11</div><div class="cal-day">12</div><div class="cal-day">13</div><div class="cal-day">14</div>
                    <div class="cal-day selected">15</div><div class="cal-day">16</div><div class="cal-day">17</div><div class="cal-day">18</div><div class="cal-day">19</div><div class="cal-day">20</div><div class="cal-day">21</div>
                    <div class="cal-day">22</div><div class="cal-day">23</div><div class="cal-day">24</div><div class="cal-day">25</div><div class="cal-day">26</div><div class="cal-day">27</div><div class="cal-day">28</div>
                    <div class="cal-day">29</div><div class="cal-day">30</div><div class="cal-day">31</div><div class="cal-day other-month">1</div><div class="cal-day other-month">2</div><div class="cal-day other-month">3</div><div class="cal-day other-month">4</div>
                  </div>
                </div>
                <!-- Marker 4: Footer Actions -->
                <div style="position:relative;">
                  <div style="position:absolute;right:calc(100% + 6px);top:50%;transform:translateY(-50%);display:flex;align-items:center;gap:6px;z-index:5;"><span class="anat-marker-inline">4</span><div style="width:28px;height:2px;background:#2563eb;"></div></div>
                  <div class="cal-footer">
                    <button class="cal-footer-btn secondary">Cancel</button>
                    <button class="cal-footer-btn primary">Apply</button>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="anat-legend" style="grid-template-columns:repeat(2,1fr);">
            <div class="anat-legend-item"><span class="anat-marker-inline">1</span><div><strong>Calendar Header</strong><span>Navigation chevrons and Month Year label. 252px wide, 28px tall. Bold centered text with left/right arrow buttons.</span></div></div>
            <div class="anat-legend-item"><span class="anat-marker-inline">2</span><div><strong>Weekday Row</strong><span>7-column row of abbreviated weekday labels (Sun&#8211;Sat). 252px wide, 36px tall. Medium weight, muted color.</span></div></div>
            <div class="anat-legend-item"><span class="anat-marker-inline">3</span><div><strong>Calendar Grid</strong><span>6-row by 7-column date grid. 252px wide, 196px tall. Contains individual Day Cell instances with various states.</span></div></div>
            <div class="anat-legend-item"><span class="anat-marker-inline">4</span><div><strong>Footer Actions</strong><span>Optional action row with Cancel and Apply buttons. 276px wide, 52px tall. Hidden by default (Show Footer = OFF).</span></div></div>
          </div>

          <hr class="doc-divider"/>

