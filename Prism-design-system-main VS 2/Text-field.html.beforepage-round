        <script>
        (function(){
          var els={size:document.getElementById('tf-pg-size'),state:document.getElementById('tf-pg-state'),label:document.getElementById('tf-pg-label'),helper:document.getElementById('tf-pg-helper')};
          var previewArea=document.getElementById('tf-pg-preview');
          var codeOut=document.getElementById('tf-pg-code');
          var copyBtn=document.getElementById('tf-pg-copy');
          function esc(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
          function update(){
            var sz=els.size.value,st=els.state.value,lp=els.label.value,showHelper=els.helper.value==='true';
            var sizeClass='text-input-'+sz;
            var isDisabled=st==='disabled';
            var isReadonly=st==='readonly';
            var stateClass=st==='default'?'':' '+st;
            var fieldClass='text-input-field'+(st==='focus'?' focus':'')+(st==='error'?' error':'')+(st==='success'?' success':'')+(isDisabled?' disabled':'')+(isReadonly?' readonly':'');
            var val=st==='filled'||st==='error'||st==='success'?'Entered value':'';
            var placeholder=val?'':'Placeholder';
            var helperText=st==='error'?'This field is required':st==='success'?'Looks good!':'Helper text';
            var helperClass='text-input-helper-text'+(st==='error'?' error':'')+(st==='success'?' success':'');

            // Preview
            var h='<div class="text-input-demo '+sizeClass+'" style="width:100%;max-width:360px;">';
            h+='<div class="text-input-row label-'+lp+'">';
            h+='<span class="text-input-label">Label <span class="required">*</span></span>';
            h+='<div style="flex:1;"><div class="'+fieldClass+'">';
            h+='<input type="text" '+(val?'value="'+val+'"':'placeholder="'+placeholder+'"')+(isDisabled?' disabled':'')+(isReadonly?' readonly':'')+'>';
            h+='</div>';
            if(showHelper){
              h+='<div class="text-input-helper"><span class="'+helperClass+'">'+helperText+'</span><span class="text-input-counter" style="font-size:12px;color:var(--prism-text-muted);">0/100</span></div>';
            }
            h+='</div></div></div>';
            previewArea.innerHTML=h;

            // Code
            var code='<div class="text-input" data-size="'+sz+'">\n';
            code+='  <label class="text-input-label">Label <span class="required">*</span></label>\n';
            code+='  <div class="text-input-field">\n';
            code+='    <input\n      type="text"\n';
            if(val) code+='      value="'+val+'"\n';
            else code+='      placeholder="Placeholder"\n';
            if(isDisabled) code+='      disabled\n';
            if(isReadonly) code+='      readonly\n';
            if(st==='error') code+='      aria-invalid="true"\n      aria-describedby="helper-1"\n';
            code+='    />\n  </div>\n';
            if(showHelper){
              code+='  <div class="text-input-helper"'+(st==='error'?' id="helper-1" role="alert"':'')+'>\n';
              code+='    <span class="text-input-helper-text'+(st==='error'?' error':'')+'">'+helperText+'</span>\n';
              code+='    <span class="text-input-counter">0/100</span>\n';
              code+='  </div>\n';
            }
            code+='</div>';
            codeOut.innerHTML=esc(code)
              .replace(/class=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">class</span>=<span style="color:#34d399;">"$1"</span>')
              .replace(/type=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">type</span>=<span style="color:#34d399;">"$1"</span>')
              .replace(/value=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">value</span>=<span style="color:#34d399;">"$1"</span>')
              .replace(/placeholder=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">placeholder</span>=<span style="color:#34d399;">"$1"</span>')
              .replace(/data-size=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">data-size</span>=<span style="color:#34d399;">"$1"</span>')
              .replace(/aria-invalid=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">aria-invalid</span>=<span style="color:#34d399;">"$1"</span>')
              .replace(/aria-describedby=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">aria-describedby</span>=<span style="color:#34d399;">"$1"</span>')
              .replace(/id=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">id</span>=<span style="color:#34d399;">"$1"</span>')
              .replace(/role=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">role</span>=<span style="color:#34d399;">"$1"</span>')
              .replace(/ disabled/g,' <span style="color:#f97316;">disabled</span>')
              .replace(/ readonly/g,' <span style="color:#f97316;">readonly</span>')
              .replace(/&lt;(\/?)(div|label|input|span)(.*?)&gt;/g,'&lt;$1<span style="color:#a78bfa;">$2</span>$3&gt;');
          }
          Object.values(els).forEach(function(e){e.addEventListener('change',update);});
          copyBtn.addEventListener('click',function(){
            var r=document.createElement('div');r.innerHTML=codeOut.innerHTML;
            navigator.clipboard.writeText(r.innerText).then(function(){
              var o=copyBtn.innerHTML;copyBtn.innerHTML='<svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Copied!';setTimeout(function(){copyBtn.innerHTML=o;},2000);
            });
          });
          update();
        })();
        </script>

