        </div>

        <!-- ========== CODE ========== -->
        <div class="tab-content" id="tab-code" style="display:none;padding-top:32px;">
          <h2 id="live-demo-code" class="doc-section-title">Live demo (Code)</h2>
          <p class="doc-section-subtitle">Configure the Empty State component and view generated HTML.</p>
          <div class="code-playground">
            <div class="cp-toolbar">
              <div class="cp-control-group"><label class="cp-label">Illustration</label><select class="cp-select" id="pg-illus">
                <option value="network-device-group.svg" selected>Network devices</option>
                <option value="access-denied.svg">Access denied</option>
                <option value="schedule-task.svg">Schedule task</option>
                <option value="two-factor-auth.svg">Two-factor auth</option>
                <option value="upload-cloud.svg">Upload cloud</option>
                <option value="common-search.svg">Common search</option>
              </select></div>
              <div class="cp-control-group"><label class="cp-label">Primary button</label><select class="cp-select" id="pg-primary"><option value="yes" selected>Yes</option><option value="no">No</option></select></div>
              <div class="cp-control-group"><label class="cp-label">Secondary button</label><select class="cp-select" id="pg-secondary"><option value="yes" selected>Yes</option><option value="no">No</option></select></div>
              <div class="cp-control-group"><label class="cp-label">Supported row</label><select class="cp-select" id="pg-supported"><option value="no" selected>No</option><option value="yes">Yes</option></select></div>
            </div>
            <div class="cp-preview" id="pg-preview-area"></div>
            <div class="cp-code-header">
              <div style="font-size:13.5px;font-weight:600;color:var(--prism-text);">HTML</div>
              <button class="cp-action-btn" id="pg-copy-btn"><svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2"/></svg> Copy code</button>
            </div>
            <div class="cp-code-area" id="pg-code-output"></div>
          </div>
          <script>
          (function(){
            var els = {illus:document.getElementById('pg-illus'),primary:document.getElementById('pg-primary'),secondary:document.getElementById('pg-secondary'),supported:document.getElementById('pg-supported')};
            var previewArea = document.getElementById('pg-preview-area');
            var codeOut = document.getElementById('pg-code-output');
            var copyBtn = document.getElementById('pg-copy-btn');
            var presets = {
              'network-device-group.svg':{title:'No devices enrolled',desc:'Enrol your first device to start managing configurations, policies, and patches.',primary:'Enrol device',secondary:'View docs'},
              'access-denied.svg':{title:'You don\u2019t have access',desc:'This workspace is restricted. Contact an administrator to request access.',primary:'Request access',secondary:'Contact admin'},
              'schedule-task.svg':{title:'Nothing scheduled',desc:'Create a scheduled task to automate patch jobs, reports, and policy rollouts.',primary:'Schedule a task',secondary:'Browse templates'},
              'two-factor-auth.svg':{title:'Set up two-factor authentication',desc:'Protect your account with a second verification step at sign-in.',primary:'Enable 2FA',secondary:'Learn more'},
              'upload-cloud.svg':{title:'No files uploaded yet',desc:'Drag and drop files here, or click upload to share assets with your team.',primary:'Upload file',secondary:'Browse files'},
              'common-search.svg':{title:'No results found',desc:'Try different keywords or clear active filters to see more.',primary:'Clear filters',secondary:'View all'}
            };
            function esc(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
            function update(){
              var illus = els.illus.value;
              var showP = els.primary.value === 'yes';
              var showS = els.secondary.value === 'yes';
              var showSup = els.supported.value === 'yes';
              var p = presets[illus];

              // Build preview
              var html = '<div class="es-container">';
              html += '<div class="es-illustration"><img src="assets/Illustration/'+illus+'" alt=""></div>';
              html += '<div class="es-title">'+p.title+'</div>';
              html += '<div class="es-description">'+p.desc+' <a href="#">Learn more</a></div>';
              if(showP || showS){
                html += '<div class="es-actions">';
                if(showP) html += '<button class="es-btn primary">'+p.primary+'</button>';
                if(showS) html += '<button class="es-btn secondary">'+p.secondary+'</button>';
                html += '</div>';
              }
              if(showSup){
                html += '<div class="es-supported"><span class="es-supported-label">Supported</span><span style="font-size:12px;color:var(--prism-text-muted);">Windows &#8226; macOS &#8226; Linux</span></div>';
              }
              html += '</div>';
              previewArea.innerHTML = html;

              // Build code output
              var titleId = 'es-title';
              var codeStr = '<section class="es-container" role="region" aria-labelledby="'+titleId+'">\n';
              codeStr += '  <div class="es-illustration" aria-hidden="true">\n';
              codeStr += '    <img src="/illustrations/'+illus+'" alt="" />\n';
              codeStr += '  </div>\n';
              codeStr += '  <h2 id="'+titleId+'" class="es-title">'+p.title+'</h2>\n';
              codeStr += '  <p class="es-description">\n';
              codeStr += '    '+p.desc+' <a href="/docs">Learn more</a>\n';
              codeStr += '  </p>\n';
              if(showP || showS){
                codeStr += '  <div class="es-actions">\n';
                if(showP) codeStr += '    <button type="button" class="es-btn primary">'+p.primary+'</button>\n';
                if(showS) codeStr += '    <button type="button" class="es-btn secondary">'+p.secondary+'</button>\n';
                codeStr += '  </div>\n';
              }
              if(showSup){
                codeStr += '  <div class="es-supported">\n';
                codeStr += '    <span class="es-supported-label">Supported</span>\n';
                codeStr += '    <div class="es-supported-icons" aria-hidden="true">\n';
                codeStr += '      <img src="/icons/windows.svg" alt="Windows" />\n';
                codeStr += '      <img src="/icons/macos.svg" alt="macOS" />\n';
                codeStr += '      <img src="/icons/linux.svg" alt="Linux" />\n';
                codeStr += '    </div>\n';
                codeStr += '  </div>\n';
              }
              codeStr += '</section>';
              codeOut.innerHTML = esc(codeStr)
                .replace(/class=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">class</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/id=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">id</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/role=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">role</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/aria-labelledby=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">aria-labelledby</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/aria-hidden=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">aria-hidden</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/type=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">type</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/src=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">src</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/alt=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">alt</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/href=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">href</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/&lt;(\/?)(section|div|h2|p|a|button|img|span)(.*?)&gt;/g,'&lt;$1<span style="color:#a78bfa;">$2</span>$3&gt;');
            }
            Object.values(els).forEach(function(e){e.addEventListener('change',update);});
            copyBtn.addEventListener('click',function(){
              var r=document.createElement('div');r.innerHTML=codeOut.innerHTML;
              navigator.clipboard.writeText(r.innerText).then(function(){
                var o=copyBtn.innerHTML;copyBtn.innerHTML='<svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Copied!';setTimeout(function(){copyBtn.innerHTML=o;},2000);
              });
            });
            update();
          })();
          </script>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="component-api" class="doc-h3">Component API &amp; Properties</h3>
            <table class="size-table">
              <thead><tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
              <tbody>
                <tr><td><code>title</code></td><td>string</td><td>&#8212;</td><td>Primary headline text.</td></tr>
                <tr><td><code>description</code></td><td>string | ReactNode</td><td>&#8212;</td><td>Supporting text. Pass a React node to embed inline links.</td></tr>
                <tr><td><code>illustration</code></td><td>ReactNode</td><td>Default illustration</td><td>Illustration asset (SVG, image, or custom component).</td></tr>
                <tr><td><code>showIllustration</code></td><td>boolean</td><td><code>true</code></td><td>Show or hide the illustration block.</td></tr>
                <tr><td><code>primaryAction</code></td><td>{ label, onClick, href? }</td><td>&#8212;</td><td>Primary action rendered as a solid Button.</td></tr>
                <tr><td><code>secondaryAction</code></td><td>{ label, onClick, href? }</td><td>&#8212;</td><td>Secondary action rendered as a subtle / ghost Button.</td></tr>
                <tr><td><code>showPrimaryAction</code></td><td>boolean</td><td><code>true</code></td><td>Show the primary button.</td></tr>
                <tr><td><code>showSecondaryAction</code></td><td>boolean</td><td><code>true</code></td><td>Show the secondary button.</td></tr>
                <tr><td><code>supportedPlatforms</code></td><td>Platform[]</td><td><code>[]</code></td><td>Platforms shown in the Supported row.</td></tr>
                <tr><td><code>supportedLabel</code></td><td>string</td><td><code>"Supported"</code></td><td>Label preceding the icon cluster.</td></tr>
                <tr><td><code>showSupported</code></td><td>boolean</td><td><code>true</code></td><td>Show or hide the Supported row.</td></tr>
                <tr><td><code>size</code></td><td>'sm' | 'md' | 'lg'</td><td><code>'md'</code></td><td>Overall scale &#8212; sm (card/drawer), md (panel), lg (full-page).</td></tr>
                <tr><td><code>rtl</code></td><td>boolean</td><td><code>false</code></td><td>Mirrors layout for right-to-left reading order.</td></tr>
                <tr><td><code>className</code></td><td>string</td><td>&#8212;</td><td>Optional class hook for container overrides.</td></tr>
              </tbody>
            </table>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="html-example" class="doc-h3">HTML Example</h3>
            <div class="cp-code-area" style="border-radius:12px;margin-top:16px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;">
                <span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">section</span> <span style="color:#D19A66;">class</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"es-container"</span> <span style="color:#D19A66;">role</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"region"</span> <span style="color:#D19A66;">aria-labelledby</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"es-title"</span><span style="color:#ABB2BF;">&gt;</span><br>
                &nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">div</span> <span style="color:#D19A66;">class</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"es-illustration"</span> <span style="color:#D19A66;">aria-hidden</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"true"</span><span style="color:#ABB2BF;">&gt;</span><br>
                &nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">img</span> <span style="color:#D19A66;">src</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"/illustrations/network-device-group.svg"</span> <span style="color:#D19A66;">alt</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">""</span> <span style="color:#ABB2BF;">/&gt;</span><br>
                &nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;/</span><span style="color:#E06C75;">div</span><span style="color:#ABB2BF;">&gt;</span><br>
                &nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">h2</span> <span style="color:#D19A66;">id</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"es-title"</span> <span style="color:#D19A66;">class</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"es-title"</span><span style="color:#ABB2BF;">&gt;</span>No devices enrolled<span style="color:#ABB2BF;">&lt;/</span><span style="color:#E06C75;">h2</span><span style="color:#ABB2BF;">&gt;</span><br>
                &nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">p</span> <span style="color:#D19A66;">class</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"es-description"</span><span style="color:#ABB2BF;">&gt;</span><br>
                &nbsp;&nbsp;&nbsp;&nbsp;Enrol your first device to start managing configurations.<br>
                &nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">a</span> <span style="color:#D19A66;">href</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"/docs"</span><span style="color:#ABB2BF;">&gt;</span>Learn more<span style="color:#ABB2BF;">&lt;/</span><span style="color:#E06C75;">a</span><span style="color:#ABB2BF;">&gt;</span><br>
                &nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;/</span><span style="color:#E06C75;">p</span><span style="color:#ABB2BF;">&gt;</span><br>
                &nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">div</span> <span style="color:#D19A66;">class</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"es-actions"</span><span style="color:#ABB2BF;">&gt;</span><br>
                &nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">button</span> <span style="color:#D19A66;">type</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"button"</span> <span style="color:#D19A66;">class</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"es-btn primary"</span><span style="color:#ABB2BF;">&gt;</span>Enrol device<span style="color:#ABB2BF;">&lt;/</span><span style="color:#E06C75;">button</span><span style="color:#ABB2BF;">&gt;</span><br>
                &nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">button</span> <span style="color:#D19A66;">type</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"button"</span> <span style="color:#D19A66;">class</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"es-btn secondary"</span><span style="color:#ABB2BF;">&gt;</span>View docs<span style="color:#ABB2BF;">&lt;/</span><span style="color:#E06C75;">button</span><span style="color:#ABB2BF;">&gt;</span><br>
                &nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;/</span><span style="color:#E06C75;">div</span><span style="color:#ABB2BF;">&gt;</span><br>
                <span style="color:#ABB2BF;">&lt;/</span><span style="color:#E06C75;">section</span><span style="color:#ABB2BF;">&gt;</span>
              </div>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="react-example" class="doc-h3">React Example &#8212; Default</h3>
            <div class="cp-code-area" style="border-radius:12px;margin-top:16px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;">
                <span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">EmptyState</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">title</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"Explore a diverse array of configurations"</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">description</span><span style="color:#56B6C2;">=</span><span style="color:#C678DD;">{</span><br>
                &nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;&gt;</span>Configurations helps you manage applications and security policies.<br>
                &nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">a</span> <span style="color:#D19A66;">href</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"/docs/configurations"</span><span style="color:#ABB2BF;">&gt;</span>Learn more<span style="color:#ABB2BF;">&lt;/</span><span style="color:#E06C75;">a</span><span style="color:#ABB2BF;">&gt;&lt;/&gt;</span><br>
                &nbsp;&nbsp;<span style="color:#C678DD;">}</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">primaryAction</span><span style="color:#56B6C2;">=</span><span style="color:#C678DD;">{{</span> <span style="color:#E5C07B;">label</span>: <span style="color:#98C379;">'Create configuration'</span>, <span style="color:#E5C07B;">onClick</span>: <span style="color:#E5C07B;">openCreate</span> <span style="color:#C678DD;">}}</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">secondaryAction</span><span style="color:#56B6C2;">=</span><span style="color:#C678DD;">{{</span> <span style="color:#E5C07B;">label</span>: <span style="color:#98C379;">'Learn more'</span>, <span style="color:#E5C07B;">href</span>: <span style="color:#98C379;">'/docs'</span> <span style="color:#C678DD;">}}</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">supportedPlatforms</span><span style="color:#56B6C2;">=</span><span style="color:#C678DD;">{</span><span style="color:#E5C07B;">supportedOs</span><span style="color:#C678DD;">}</span><br>
                <span style="color:#ABB2BF;">/&gt;</span>
              </div>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="react-example-minimal" class="doc-h3">React Example &#8212; Minimal zero-results</h3>
            <div class="cp-code-area" style="border-radius:12px;margin-top:16px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;">
                <span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">div</span> <span style="color:#D19A66;">role</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"region"</span> <span style="color:#D19A66;">aria-live</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"polite"</span> <span style="color:#D19A66;">aria-label</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"Search results"</span><span style="color:#ABB2BF;">&gt;</span><br>
                &nbsp;&nbsp;<span style="color:#C678DD;">{</span><span style="color:#E5C07B;">results.length</span> === <span style="color:#D19A66;">0</span> <span style="color:#56B6C2;">&amp;&amp;</span> <span style="color:#C678DD;">(</span><br>
                &nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">EmptyState</span><br>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#D19A66;">title</span><span style="color:#56B6C2;">=</span><span style="color:#C678DD;">{</span><span style="color:#98C379;">`No results for "</span><span style="color:#C678DD;">${</span><span style="color:#E5C07B;">query</span><span style="color:#C678DD;">}</span><span style="color:#98C379;">"`</span><span style="color:#C678DD;">}</span><br>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#D19A66;">description</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"Try different keywords or clear active filters."</span><br>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#D19A66;">primaryAction</span><span style="color:#56B6C2;">=</span><span style="color:#C678DD;">{{</span> <span style="color:#E5C07B;">label</span>: <span style="color:#98C379;">'Clear filters'</span>, <span style="color:#E5C07B;">onClick</span>: <span style="color:#E5C07B;">clearFilters</span> <span style="color:#C678DD;">}}</span><br>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#D19A66;">showSecondaryAction</span><span style="color:#56B6C2;">=</span><span style="color:#C678DD;">{</span><span style="color:#D19A66;">false</span><span style="color:#C678DD;">}</span><br>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#D19A66;">showSupported</span><span style="color:#56B6C2;">=</span><span style="color:#C678DD;">{</span><span style="color:#D19A66;">false</span><span style="color:#C678DD;">}</span><br>
                &nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#ABB2BF;">/&gt;</span><br>
                &nbsp;&nbsp;<span style="color:#C678DD;">)}</span><br>
                <span style="color:#ABB2BF;">&lt;/</span><span style="color:#E06C75;">div</span><span style="color:#ABB2BF;">&gt;</span>
              </div>
            </div>
          </div>
        </div>

        <!-- ========== ACCESSIBILITY ========== -->
        <div class="tab-content" id="tab-accessibility" style="display:none;padding-top:32px;">
          <h2 id="accessibility" class="doc-section-title">Accessibility</h2>
          <p class="doc-section-subtitle">Guidelines for ensuring Empty State is accessible across assistive technologies and input methods.</p>

          <div class="doc-section">
            <h3 id="heading-hierarchy" class="doc-h3">Heading Hierarchy</h3>
            <ul class="doc-list">
              <li><strong>Render the title as a real heading:</strong> Use <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;h2&gt;</code> or <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;h3&gt;</code> depending on page hierarchy so screen readers announce the landing.</li>
              <li><strong>Never skip levels:</strong> If the surrounding page uses an <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;h1&gt;</code>, the empty state title should be an <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;h2&gt;</code>.</li>
              <li><strong>Visual weight is not a heading:</strong> Don&rsquo;t use a styled <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;div&gt;</code> &#8212; screen readers won&rsquo;t find it in the outline.</li>
            </ul>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="aria-patterns" class="doc-h3">ARIA Patterns</h3>
            <table class="size-table">
              <thead><tr><th>Concern</th><th>Requirement</th></tr></thead>
              <tbody>
                <tr><td><strong>Landmark</strong></td><td>Wrap the empty state in <code>role="region"</code> with <code>aria-labelledby</code> pointing to the title <code>id</code>. When it replaces the main content of a page, a <code>&lt;section&gt;</code> with <code>aria-labelledby</code> is sufficient.</td></tr>
                <tr><td><strong>Illustration</strong></td><td>Decorative illustrations use <code>aria-hidden="true"</code> and <code>alt=""</code>. Informative illustrations use <code>role="img"</code> with a descriptive <code>aria-label</code>.</td></tr>
                <tr><td><strong>Inline link</strong></td><td>The inline "Learn more" is a real <code>&lt;a&gt;</code> with a visible underline or colour and a non-colour hover affordance.</td></tr>
                <tr><td><strong>Button semantics</strong></td><td>Actions are <code>&lt;button&gt;</code> for in-app commands and <code>&lt;a&gt;</code> for navigation. Primary and secondary must have distinct visible styles &#8212; not rely on position alone.</td></tr>
                <tr><td><strong>Supported icons</strong></td><td>Each OS icon has <code>aria-label</code> ("Windows", "macOS", "Linux"). If the row is purely decorative, set <code>aria-hidden="true"</code> on the icon cluster and keep only the label visible.</td></tr>
                <tr><td><strong>Live announcement</strong></td><td>If the empty state appears dynamically (after a filter yields zero results), announce via an <code>aria-live="polite"</code> region so SR users hear "No matches found".</td></tr>
              </tbody>
            </table>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="focus-management" class="doc-h3">Focus Management</h3>
            <ul class="doc-list">
              <li><strong>Tab order:</strong> title &rarr; inline description links &rarr; primary button &rarr; secondary button &rarr; supported-row icons (if interactive).</li>
              <li><strong>Visible focus ring:</strong> All focusable elements expose a 2 px focus ring that meets WCAG 2.4.7.</li>
              <li><strong>Do not autofocus:</strong> The empty state should not steal focus when it renders. Let the user keyboard-tab into it naturally.</li>
              <li><strong>Dynamic appearance:</strong> When the empty state replaces content after a user action (e.g. applying a filter), keep focus on the triggering control &#8212; don&rsquo;t jump focus to the empty state.</li>
              <li><strong>RTL:</strong> Tab order follows DOM order; visual mirroring is handled by <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">dir="rtl"</code>. The action cluster mirrors (primary visually on the right).</li>
            </ul>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="screen-reader-guidance" class="doc-h3">Screen Reader Guidance</h3>
            <ul class="doc-list">
              <li><strong>Announce the landing:</strong> Because the title is a real heading within a region landmark, screen readers announce "region, [title], heading level 2" &#8212; clearly conveying "the list is empty, here&rsquo;s what to do".</li>
              <li><strong>Describe the illustration only if informative:</strong> Most empty-state illustrations are decorative. Hide them with <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-hidden="true"</code> to avoid redundant narration of "image" before the real content.</li>
              <li><strong>Keep button labels verbs:</strong> "Create configuration", "Invite teammate" &#8212; these are self-describing for SR users who encounter buttons out of visual context.</li>
              <li><strong>Localised Supported row:</strong> Translate OS names in Arabic/Hebrew/CJK layouts; never leave them un-translated.</li>
              <li><strong>Error vs empty distinction:</strong> If the surface is actually an error (network failure), use Inline Alert Message &#8212; not Empty State. SR users rely on the correct landmark/role.</li>
            </ul>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="color-contrast" class="doc-h3">Color Contrast<span class="h3-badge" style="background:rgba(34,197,94,0.15);color:#16a34a;">WCAG AA Pass</span></h3>
            <p class="doc-section-subtitle">Title (Text-Primary) and description (Text-Secondary) both meet WCAG AA 4.5:1. Link colour against background meets 4.5:1 plus a non-colour affordance.</p>
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px;margin-top:24px;">
              <div style="background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;overflow:hidden;">
                <div style="background:#fff;padding:28px 24px;text-align:center;color:#15181E;border-radius:12px 12px 0 0;"><div style="font-size:20px;font-weight:600;">Explore configurations</div></div>
                <div style="padding:16px 24px;display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--prism-border);"><div><div style="font-size:13px;color:var(--prism-text-muted);font-weight:600;">TITLE ON SURFACE</div><div style="font-size:15px;color:var(--prism-text);font-family:monospace;margin-top:4px;">#15181E on #FFFFFF</div></div><div style="text-align:right;"><div style="display:inline-flex;align-items:center;gap:6px;background:rgba(34,197,94,0.1);color:#16a34a;padding:4px 10px;border-radius:100px;font-size:12px;font-weight:700;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><polyline points="20 6 9 17 4 12"></polyline></svg> 17.4:1</div><div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;font-weight:600;">WCAG AAA Pass</div></div></div>
              </div>
              <div style="background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;overflow:hidden;">
                <div style="background:#fff;padding:28px 24px;text-align:center;color:#64748B;border-radius:12px 12px 0 0;"><div style="font-size:14px;font-weight:400;">Supporting description text, typically two lines max</div></div>
                <div style="padding:16px 24px;display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--prism-border);"><div><div style="font-size:13px;color:var(--prism-text-muted);font-weight:600;">DESCRIPTION ON SURFACE</div><div style="font-size:15px;color:var(--prism-text);font-family:monospace;margin-top:4px;">#64748B on #FFFFFF</div></div><div style="text-align:right;"><div style="display:inline-flex;align-items:center;gap:6px;background:rgba(34,197,94,0.1);color:#16a34a;padding:4px 10px;border-radius:100px;font-size:12px;font-weight:700;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><polyline points="20 6 9 17 4 12"></polyline></svg> 4.5:1</div><div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;font-weight:600;">WCAG AA Pass</div></div></div>
              </div>
            </div>
          </div>
        </div>

        </div><!-- main-content-inner -->

