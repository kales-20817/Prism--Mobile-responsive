                <clipPath id="clip0_zia">
                  <rect width="40" height="40" fill="white"/>
                </clipPath>
              </defs>
            </svg>
            <span class="zia-typing-text" id="ziaTypingText"></span>
            <div class="zia-input-wrap">
              <input type="text" class="zia-input" placeholder="Ask Zia anything..." />
              <button class="zia-send-btn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2L11 13"/><path d="M22 2L15 22L11 13L2 9L22 2Z"/></svg>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <section id="resource-section" style="position:relative; z-index:5;">
    <style>
      #resource-section {
        padding: 100px 64px;
        background: #ffffff;
      }
      :root:not([data-theme="light"]) #resource-section {
        background: transparent;
      }
      .rs-wrap {
        max-width: 1280px;
        margin: 0 auto;
      }
      .rs-header {
        text-align: center;
        margin-bottom: 56px;
      }
      .rs-tag {
        display: inline-block;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--prism-violet-light, #8b5cf6);
        background: rgba(124, 58, 237, 0.1);
        border: 1px solid rgba(124, 58, 237, 0.2);
        padding: 6px 16px;
        border-radius: 99px;
        margin-bottom: 20px;
      }
      .rs-title {
        font-size: 42px;
        font-weight: 800;
        color: var(--text);
        letter-spacing: -0.03em;
        line-height: 1.15;
        margin-bottom: 16px;
      }
      .rs-title span {
        background: linear-gradient(135deg, #0058ff 40%, #3c50ff 30%, #0fd095 100%);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
      }
      .rs-subtitle {
        font-size: 16px;
        color: var(--text-muted);
        max-width: 560px;
        margin: 0 auto;
        line-height: 1.7;
      }
      .rs-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
      }
      @media (max-width: 900px) {
        .rs-grid { grid-template-columns: 1fr; }
        #resource-section { padding: 80px 24px; }
        .rs-title { font-size: 32px; }
      }
      .rs-card {
        position: relative;
        display: flex;
        flex-direction: column;
        padding: 36px 32px;
        background: linear-gradient(135deg, rgba(59, 130, 246, 0.08), rgba(99, 102, 241, 0.04));
        border: 1px solid var(--border);
        border-radius: 20px;
        text-decoration: none;
        color: var(--text);
        overflow: hidden;
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                    border-color 0.3s ease,
                    box-shadow 0.3s ease;
      }
      [data-theme="light"] .rs-card { border-color: rgba(0,0,0,0.06); }
      .rs-card:hover {
        transform: translateY(-4px);
        border-color: rgba(124, 58, 237, 0.25);
        /* box-shadow: 0 20px 50px rgba(0, 88, 255, 0.12); */
        background: linear-gradient(135deg, rgba(0, 88, 255, 0.1) 40%, rgba(60, 80, 255, 0.1) 30%, rgba(15, 208, 149, 0.1) 100%);
      }
      .rs-card-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 56px;
        height: 56px;
        border-radius: 16px;
        background: linear-gradient(135deg, #006AFF, #1E52BB);
        color: #fff;
        margin-bottom: 20px;
        /* box-shadow: 0 8px 24px rgba(0, 88, 255, 0.25); */
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .rs-card:hover .rs-card-icon {
        transform: scale(1.08) rotate(-4deg);
      }
      .rs-card-title {
        font-size: 22px;
        font-weight: 700;
        margin-bottom: 10px;
        letter-spacing: -0.01em;
      }
      .rs-card-desc {
        font-size: 14px;
        color: var(--text-muted);
        line-height: 1.6;
        margin-bottom: 24px;
        flex: 1;
      }
      .rs-card-cta {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        font-weight: 600;
        color: #7386f0;
        letter-spacing: 0.01em;
      }
      .rs-card-cta svg {
        transition: transform 0.3s ease;
      }
      .rs-card:hover .rs-card-cta svg {
        transform: translateX(4px);
      }
    </style>

    <div class="rs-wrap">
      <div class="rs-header">
        <h2 class="rs-title">Assets, <span>ready to use</span></h2>
        <p class="rs-subtitle">Icons, logos, and illustrations — all on-brand, production-ready, and built for UEMS.</p>
      </div>

      <div class="rs-grid">
        <a href="Icons.html" class="rs-card">
          <span class="rs-card-icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg>
          </span>
          <h3 class="rs-card-title">Icons</h3>
          <p class="rs-card-desc">A comprehensive set of pixel-perfect icons designed for clarity across every surface and scale.</p>
          <span class="rs-card-cta">Explore icons
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>

        <a href="Logos.html" class="rs-card">
          <span class="rs-card-icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/><path d="M18 5l.5 1.5L20 7l-1.5.5L18 9l-.5-1.5L16 7l1.5-.5z"/></svg>
          </span>
          <h3 class="rs-card-title">Product Logos</h3>
          <p class="rs-card-desc">Official product marks and lockups with clear usage rules, safe-area guidelines, and every supported format.</p>
          <span class="rs-card-cta">Explore logos
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>

        <a href="Illustrations.html" class="rs-card">
          <span class="rs-card-icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
          </span>
          <h3 class="rs-card-title">Illustrations</h3>
          <p class="rs-card-desc">Expressive, on-brand illustrations for empty states, onboarding flows, and storytelling moments.</p>
          <span class="rs-card-cta">Explore illustrations
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>
      </div>
    </div>
  </section>

  <section id="zia-section" style="position:relative; z-index:5; margin-bottom:90px;">
    <div class="zia-container" style="gap: 130px;">
      <div class="zia-right">
        <h2 class="zia-title">LLM-powered <span>intelligence</span></h2>
        <p class="zia-subtitle">Access the model-driven repository that powers with scalable patterns, tokens, and system-aware components.</p>
        <a href="llm-reference.html" class="zia-cta">LLM reference</a>
      </div>
      <div class="zia-left">
        <svg class="llm-diagram" viewBox="120 30 840 320" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Natural Language AI input and output flow" style="width:100%; height:auto; display:block; font-family: Inter, system-ui, sans-serif; transform: scale(1.5); transform-origin: center;">
          <defs>
            <linearGradient id="ziaOrb" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0" stop-color="#60a5fa"></stop>
              <stop offset="1" stop-color="#1e3a8a"></stop>
            </linearGradient>
            <filter id="ziaCardShadow" x="-40%" y="-20%" width="180%" height="140%">
              <feDropShadow dx="0" dy="6" stdDeviation="10" flood-color="#3b0764" flood-opacity="0.12"></feDropShadow>
            </filter>
          </defs>

          <g stroke="#b59fe8" stroke-opacity="0.45" stroke-width="30" fill="none" stroke-linecap="round">
            <path d="M 332,109 C 390,109 420,178 460,178"></path>
            <path d="M 332,184 C 390,184 430,180 460,180"></path>
            <path d="M 332,259 C 390,259 420,182 460,182"></path>
          </g>
          <g stroke="#b59fe8" stroke-opacity="0.45" stroke-width="30" fill="none" stroke-linecap="round">
            <path d="M 570,178 C 620,178 650,89 700,89"></path>
            <path d="M 570,180 C 620,180 650,154 700,154"></path>
            <path d="M 570,182 C 620,182 650,219 700,219"></path>
            <path d="M 570,184 C 620,184 650,289 700,289"></path>
          </g>

          <text x="306" y="50" text-anchor="end" font-size="12" font-weight="700" letter-spacing="2" fill="#a399c2">INPUT</text>
          <g fill="#1e1b4b">
            <rect x="318" y="95" width="4" height="28" fill="#6d28d9" rx="1"></rect>
            <text x="306" y="114" text-anchor="end" font-size="17" font-weight="700">color.md</text>

            <rect x="318" y="170" width="4" height="28" fill="#6d28d9" rx="1"></rect>
            <text x="306" y="189" text-anchor="end" font-size="17" font-weight="700">token.md</text>

            <rect x="318" y="245" width="4" height="28" fill="#6d28d9" rx="1"></rect>
            <text x="306" y="264" text-anchor="end" font-size="17" font-weight="700">grid.md</text>
          </g>

          <g>
            <rect x="460" y="80" width="110" height="200" rx="20" fill="#ffffff" filter="url(#ziaCardShadow)"></rect>
            <circle cx="515" cy="140" r="48" stroke="#60a5fa" stroke-width="1" fill="none" stroke-opacity="0.25"></circle>
            <circle cx="515" cy="140" r="40" stroke="#60a5fa" stroke-width="1" fill="none" stroke-opacity="0.55"></circle>
            <circle cx="515" cy="140" r="32" fill="url(#ziaOrb)"></circle>
            <circle cx="527" cy="127" r="5" fill="#ffffff" fill-opacity="0.85"></circle>
            <text x="515" y="230" text-anchor="middle" font-size="13" font-weight="700" fill="#1e1b4b">Natural</text>
            <text x="515" y="250" text-anchor="middle" font-size="13" font-weight="700" fill="#1e1b4b">Language AI</text>
          </g>

          <text x="724" y="50" text-anchor="start" font-size="12" font-weight="700" letter-spacing="2" fill="#a399c2">OUTPUT</text>
          <g fill="#1e1b4b">
            <rect x="708" y="75" width="4" height="28" fill="#6d28d9" rx="1"></rect>
            <text x="724" y="94" text-anchor="start" font-size="17" font-weight="700">Input field</text>

            <rect x="708" y="140" width="4" height="28" fill="#6d28d9" rx="1"></rect>
            <text x="724" y="159" text-anchor="start" font-size="17" font-weight="700">Button</text>

            <rect x="708" y="205" width="4" height="28" fill="#6d28d9" rx="1"></rect>
            <text x="724" y="224" text-anchor="start" font-size="17" font-weight="700">Dropdown</text>

            <rect x="708" y="275" width="4" height="28" fill="#6d28d9" rx="1"></rect>
            <text x="724" y="294" text-anchor="start" font-size="17" font-weight="700">Checkbox</text>
          </g>
        </svg>
      </div>
    </div>
  </section>

  <footer class="site-footer" style="position:relative;z-index:10;padding:64px 40px 40px;border-top:1px solid var(--border);">
    <div class="site-footer-grid" style="max-width:1200px;margin:0 auto;display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:48px;">
      <div>
        <div style="font-size:24px;font-weight:800;letter-spacing:-0.03em;background:linear-gradient(135deg,#0058ff 40%,#3c50ff 30%,#0fd095 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:12px;">Prism</div>
        <p style="font-size:14px;color:var(--text-muted);line-height:1.7;max-width:320px;">The design language of UEMS — one source of truth for every team, every surface, every product.</p>
