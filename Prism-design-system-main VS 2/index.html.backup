<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Prism Design System</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Playfair+Display:ital,wght@0,700;1,700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.9.0/p5.min.js"></script>
<style>
@font-face { font-family: 'Zoho Puvi'; src: url('https://fonts.zohowebstatic.com/zohopuvi/3.5/zoho_puvi_thin.woff2') format('woff2'); font-weight: 100; font-style: normal; font-display: swap; }
@font-face { font-family: 'Zoho Puvi'; src: url('https://fonts.zohowebstatic.com/zohopuvi/3.5/zoho_puvi_extralight.woff2') format('woff2'); font-weight: 200; font-style: normal; font-display: swap; }
@font-face { font-family: 'Zoho Puvi'; src: url('https://fonts.zohowebstatic.com/zohopuvi/3.5/zoho_puvi_light.woff2') format('woff2'); font-weight: 300; font-style: normal; font-display: swap; }
@font-face { font-family: 'Zoho Puvi'; src: url('https://fonts.zohowebstatic.com/zohopuvi/3.5/zoho_puvi_regular.woff2') format('woff2'); font-weight: 400; font-style: normal; font-display: swap; }
@font-face { font-family: 'Zoho Puvi'; src: url('https://fonts.zohowebstatic.com/zohopuvi/3.5/zoho_puvi_medium.woff2') format('woff2'); font-weight: 500; font-style: normal; font-display: swap; }
@font-face { font-family: 'Zoho Puvi'; src: url('https://fonts.zohowebstatic.com/zohopuvi/3.5/zoho_puvi_semibold.woff2') format('woff2'); font-weight: 600; font-style: normal; font-display: swap; }
@font-face { font-family: 'Zoho Puvi'; src: url('https://fonts.zohowebstatic.com/zohopuvi/3.5/zoho_puvi_bold.woff2') format('woff2'); font-weight: 700; font-style: normal; font-display: swap; }
@font-face { font-family: 'Zoho Puvi'; src: url('https://fonts.zohowebstatic.com/zohopuvi/3.5/zoho_puvi_extrabold.woff2') format('woff2'); font-weight: 800; font-style: normal; font-display: swap; }
@font-face { font-family: 'Zoho Puvi'; src: url('https://fonts.zohowebstatic.com/zohopuvi/3.5/zoho_puvi_black.woff2') format('woff2'); font-weight: 900; font-style: normal; font-display: swap; }
@font-face { font-family: 'Zoho Puvi'; src: url('https://fonts.zohowebstatic.com/zohopuvi/3.5/zoho_puvi_extrablack.woff2') format('woff2'); font-weight: 950; font-style: normal; font-display: swap; }
@font-face { font-family: 'Zoho Puvi'; src: url('https://fonts.zohowebstatic.com/zohopuvi/3.5/zoho_puvi_regular_italic.woff2') format('woff2'); font-weight: 400; font-style: italic; font-display: swap; }
@font-face { font-family: 'Zoho Puvi'; src: url('https://fonts.zohowebstatic.com/zohopuvi/3.5/zoho_puvi_bold_italic.woff2') format('woff2'); font-weight: 700; font-style: italic; font-display: swap; }
@font-face { font-family: 'Zoho Puvi'; src: url('https://fonts.zohowebstatic.com/zohopuvi/3.5/zoho_puvi_semibold_italic.woff2') format('woff2'); font-weight: 600; font-style: italic; font-display: swap; }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    /* ═══ DARK MODE (default) ═══ */
    :root {
        --bg: #0d0d10;
        --text: #f4f4f6;
        --text-soft: #c8c8d0;
        --text-muted: rgba(255, 255, 255, 0.55);
        --surface: rgba(255, 255, 255, 0.08);
        --surface-strong: rgba(255, 255, 255, 0.1);
        --surface-hover: rgba(255, 255, 255, 0.16);
        --border: rgba(255, 255, 255, 0.12);
        --cta-bg: #f4f4f6;
        --cta-text: #0d0d10;
        --cta-bg-hover: #fff;
        --text-glow: rgba(13, 13, 16, 0.6);

        --prism-violet: #2563eb;
        --prism-violet-light: #a78bfa;
        --prism-emerald: #10b981;
        --prism-cyan: #06b6d4;
        --prism-orange: #f59e0b;
        --prism-fuchsia: #d946ef;
        --prism-red: #ef4444;
        --prism-text: #f4f4f6;
        --prism-text-muted: rgba(255, 255, 255, 0.55);
        --prism-surface: rgba(20, 20, 28, 0.85);
        --prism-surface-hover: rgba(30, 30, 40, 0.95);
        --prism-border: rgba(255, 255, 255, 0.08);

        --nav-bg: rgba(10,10,12,0.75);
        --logo-gradient: linear-gradient(135deg, #0058ff 40%, #3c50ff 30%, #0fd095 100%);
        --logo-filter: drop-shadow(0 2px 10px rgba(124, 58, 237, 0.3));
        --nav-link-color: rgba(255, 255, 255, 0.85);
    }

    /* ═══ LIGHT MODE ═══ */
    [data-theme="light"] {
        --bg: #ffffff;
        --text: #111;
        --text-soft: #3a3a3a;
        --text-muted: rgba(0, 0, 0, 0.55);
        --surface: rgba(255, 255, 255, 0.6);
        --surface-strong: rgba(255, 255, 255, 0.7);
        --surface-hover: rgba(255, 255, 255, 0.9);
        --border: rgba(0, 0, 0, 0.08);
        --cta-bg: #111;
        --cta-text: #fff;
        --cta-bg-hover: #000;
        --text-glow: rgba(236, 242, 255, 0.5);

        --prism-text: #1a1a22;
        --prism-text-muted: rgba(0, 0, 0, 0.55);
        --prism-surface: rgba(255, 255, 255, 0.85);
        --prism-surface-hover: rgba(255, 255, 255, 0.95);
        --prism-border: rgba(0, 0, 0, 0.08);

        --nav-bg: transparent;
        --logo-gradient: linear-gradient(135deg, #0058ff 40%, #3c50ff 30%, #0fd095 100%);
        --logo-filter: drop-shadow(0 2px 8px rgba(0,0,0,0.15));
        --nav-link-color: #000000;
    }

    html, body {
        font-family: 'Zoho Puvi', 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        background: var(--bg);
        transition: background 0.5s ease;
    }
    body {
        min-height: 100vh;
        position: relative;
        overflow-x: hidden;
    }

    /* ═══ NAV ═══ */
    .nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      padding: 0 32px; height: 72px;
      display: flex; align-items: center; justify-content: space-between;
      background: transparent;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      border-bottom: 1px solid transparent;
      transition: background 0.3s ease, backdrop-filter 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
    }
    .nav.scrolled {
      background: var(--nav-bg);
      backdrop-filter: blur(24px) saturate(1.4);
      -webkit-backdrop-filter: blur(24px) saturate(1.4);
      border-bottom: 1px solid var(--prism-border);
    }
    [data-theme="light"] .nav { background: transparent; border-bottom: 1px solid transparent; box-shadow: none; }
  [data-theme="light"] .nav.scrolled { background: rgba(255, 255, 255, 0.78); border-bottom: 1px solid rgba(37, 99, 235, 0.06); box-shadow: 0 1px 3px rgba(37, 99, 235, 0.04), 0 4px 24px rgba(37, 99, 235, 0.03); }
    .nav-logo { display: inline-flex; flex-direction: row; align-items: center; gap: 10px; text-decoration: none; line-height: 1; }
  .nav-logo-img { width: 40px; height: 40px; flex-shrink: 0; display: block; }
  .nav-logo-text { display: inline-flex; flex-direction: column; align-items: flex-start; gap: 0; }
    .nav-logo-mark {
        font-size: 26px; font-weight: 900; letter-spacing: 0.02em;
        background: var(--logo-gradient);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
        padding-right: 0.1em;
        padding-bottom: 0.05em;
        line-height: 1;
    }
    :root:not([data-theme="light"]) .nav-logo-mark {
        background: linear-gradient(135deg, #3b97ff 40%, #0fd095 100%);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    .nav-logo-sub {
        font-size: 10px; font-weight: 600; color: var(--prism-text-muted);
        letter-spacing: 0.08em; text-transform: none;
        margin-top: 2px;
    }
    .nav-logo-sub .caps { text-transform: uppercase; }
    .nav-links { display: flex; align-items: center; gap: 6px; }
    .nav-links a {
        color: var(--nav-link-color, var(--prism-text-muted)); text-decoration: none; font-size: 14px; font-weight: 600;
        padding: 8px 16px; border-radius: 999px; transition: all 0.3s ease; border: none;
    }
    .nav-links a:hover { color: var(--prism-text); background: var(--prism-surface-hover); }
    .nav-links a.active { color: var(--prism-violet); background: rgba(124, 58, 237, 0.08); border: none; }

    .icon-btn, .btn-ghost {
        background: var(--surface);
        border: 1px solid var(--border);
        color: var(--text);
        cursor: pointer;
        transition: background 0.3s ease, transform 0.3s ease;
    }
    .icon-btn:hover, .btn-ghost:hover {
        background: var(--surface-hover);
        transform: scale(1.05);
    }

    /* Nav dropdown */
    .nav-dropdown { position: relative; }
    .nav-dropdown > a { display: flex; align-items: center; gap: 4px; }
    .nav-dropdown > a .nav-chevron { width: 12px; height: 12px; transition: transform 0.2s ease; }
    .nav-dropdown:hover > a .nav-chevron { transform: rotate(180deg); }
    .nav-dropdown-menu { position: absolute; top: calc(100% + 8px); right: 0; min-width: 200px; background: var(--bg); border: 1px solid var(--border); border-radius: 12px; padding: 6px; opacity: 0; visibility: hidden; transform: translateY(-8px); transition: all 0.25s cubic-bezier(0.4,0,0.2,1); z-index: 200; backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); box-shadow: 0 8px 32px rgba(0,0,0,0.12); }
    .nav-dropdown:hover .nav-dropdown-menu { opacity: 1; visibility: visible; transform: translateY(0); }
    .nav-dropdown-menu a { display: flex !important; align-items: center; gap: 10px; padding: 10px 14px !important; border-radius: 8px !important; font-size: 13.5px !important; font-weight: 500; color: var(--text-soft); text-decoration: none; transition: all 0.2s ease; background: transparent !important; width: 100%; }
    .nav-dropdown-menu a:hover { color: var(--text); background: var(--surface-hover) !important; }
    .nav-dropdown-menu a svg { width: 18px; height: 18px; flex-shrink: 0; opacity: 0.7; }
    .nav-dropdown-menu a:hover svg { color: var(--primary); opacity: 1; }

    .page {
        position: relative;
        z-index: 10;
    }
    .hero-section {
        position: relative;
        min-height: 50vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 80px 20px 18px;
        gap: 20px;
    }
    .showcase-section {
        padding: 0px 0 0px;
    }
    [data-theme="light"] .showcase-section {
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.00) 0%, #FFF 100%);
    }
    #container {
        position: absolute !important;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        z-index: 1;
        pointer-events: none;
        overflow: hidden;
    }
    /* Light mode: fixed so the canvas ribbon scrolls with the page */
    [data-theme="light"] #container {
        position: fixed;
        inset: 0;
    }
    #bgVideo, #bgVideoLight {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        pointer-events: none;
        opacity: 0.9;
        transition: opacity 1s ease;
    }
    /* Hide canvas in both themes */
    #container canvas { display: none !important; }
    /* Dark mode: show dark video, hide light video */
    :root:not([data-theme="light"]) #bgVideo { display: block; }
    :root:not([data-theme="light"]) #bgVideoLight { display: none; }
    /* Light mode: show light video, hide dark video */
    [data-theme="light"] #bgVideo { display: none; }
    [data-theme="light"] #bgVideoLight { display: block; }
    #container::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, rgba(0, 0, 0, 0.00) 0%, #000 100%);
        z-index: 2;
        pointer-events: none;
    }
    [data-theme="light"] #container::after {
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.00) 0%, #FFF 100%);
    }
    /* Dark mode: global dark veil over the video */
    #container::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(0deg, rgb(0 0 0 / 70%) 0%, rgb(0 0 0 / 16%) 100%);
        z-index: 2;
        pointer-events: none;
    }
    [data-theme="light"] #container::before { display: none; }
    .overlay {
        position: relative;
        z-index: 10;
        text-align: center;
        padding: 24px;
        max-width: 1200px;
        pointer-events: none;
    }
    .badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 16px;
        background: var(--surface);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid var(--border);
        border-radius: 100px;
        font-size: 0.8rem;
        font-weight: 500;
        color: var(--text);
        letter-spacing: 0.05em;
        margin-bottom: 28px;
        text-transform: uppercase;
        pointer-events: auto;
    }
    .badge .dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: linear-gradient(135deg, #ff3c0a, #b4ff00);
        box-shadow: 0 0 8px rgba(255, 60, 10, 0.6);
    }
    h1 {
        font-size: clamp(1.5rem, 4.2vw, 4rem);
        font-weight: 800;
        letter-spacing: -0.04em;
        line-height: 1.1;
        color: var(--text);
        margin-bottom: 24px;
        white-space: nowrap;
    }
    h1 .accent {
        background: linear-gradient(135deg, #3b97ff 40%, #0fd095 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }
    [data-theme="light"] h1 .accent {
        background: linear-gradient(135deg, #0058ff 40%, #3c50ff 30%, #0fd095 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }
    .subtext {
        font-size: clamp(1rem, 1.6vw, 1.25rem);
        font-weight: 400;
        color: var(--text-soft);
        line-height: 1.6;
        max-width: 620px;
        /* margin: 0 auto 40px; */
        text-shadow: 0 1px 20px var(--text-glow);
    }
    .hero-cta {
        position: relative;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 16px 70px;
        background: linear-gradient(135deg, #006AFF, #1ebb99);
        color: #ffffff;
        font-size: 20px;
        font-weight: 600;
        letter-spacing: 0.02em;
        text-decoration: none;
        border-radius: 999px;
        /* box-shadow: 0 10px 28px rgba(0, 106, 255, 0.35); */
        pointer-events: auto;
        transition: transform 0.25s ease, box-shadow 0.25s ease, filter 0.25s ease;
        z-index: 10;
    }
    .hero-cta:hover {
        transform: translateY(-3px);
        box-shadow: 0 14px 36px rgba(0, 106, 255, 0.45);
        filter: brightness(1.05);
    }

    .hero-showcase {
        position: relative;
        z-index: 5;
        width: 100%;
        margin-top: 56px;
        padding: 16px 0;
        -webkit-mask-image: linear-gradient(90deg, transparent 0, #000 8%, #000 92%, transparent 100%);
                mask-image: linear-gradient(90deg, transparent 0, #000 8%, #000 92%, transparent 100%);
    }
    .marquee-wrapper {
        display: flex;
        flex-direction: column;
        gap: 18px;
        overflow: hidden;
    }
    .marquee-row {
        display: flex;
        gap: 18px;
        width: max-content;
        opacity: 0;
        animation: rowEnter 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0s both, marquee-left 60s linear 0.9s infinite;
        padding-top: 10px;
    }
    .marquee-row.right {
        animation: rowEnter 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.7s both,
                   marquee-right 75s linear 1.6s infinite;
    }
    .marquee-row.left-fast {
        animation: rowEnter 0.9s cubic-bezier(0.22, 1, 0.36, 1) 1.4s both,
                   marquee-left 45s linear 2.3s infinite;
    }
    @keyframes marquee-left {
        from { transform: translateX(0); }
        to { transform: translateX(-50%); }
    }
    @keyframes marquee-right {
        from { transform: translateX(-50%); }
        to { transform: translateX(0); }
    }
    @keyframes rowEnter {
        from { opacity: 0; filter: blur(6px); }
        to   { opacity: 1; filter: blur(0); }
    }
    @media (prefers-reduced-motion: reduce) {
        .marquee-row { opacity: 1; animation: none; }
    }
    .sc-card {
        background: var(--prism-surface);
        border: 1px solid var(--prism-border);
        border-radius: 16px;
        padding: 18px;
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        display: flex;
        flex-direction: column;
        flex-shrink: 0;
        font-size: 13px;
        color: var(--prism-text);
        box-shadow: none;
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.3s ease;
        cursor: pointer;
    }
    .sc-cal-day:not(.empty):not(.active) {
        cursor: pointer;
        transition: background 0.2s, color 0.2s;
    }
    .sc-cal-day:not(.empty):not(.active):hover {
        background: rgba(124, 58, 237, 0.12);
        color: var(--prism-violet);
    }
    .sc-toggle {
        cursor: pointer;
    }
    .sc-radio-label {
        cursor: pointer;
    }
    .sc-radio-label:hover .sc-radio-custom:not(.active) {
        border-color: var(--prism-violet-light);
    }
    .sc-progress-title {
        font-size: 12px;
        font-weight: 700;
        margin-bottom: 4px;
        padding-bottom: 2px;
        color: var(--prism-text);
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }
    .sc-progress-bar {
        height: 6px;
        background: rgba(124, 58, 237, 0.12);
        border-radius: 99px;
        overflow: hidden;
    }
    .sc-progress-fill {
        height: 100%;
        background: linear-gradient(90deg, var(--prism-violet), var(--prism-violet-light));
        border-radius: 99px;
        transition: width 1.2s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .sc-progress-label {
        display: flex;
        justify-content: space-between;
        font-size: 11px;
        font-weight: 600;
        color: var(--prism-text-muted);
        margin-top: 6px;
    }
    .sc-card-title {
        font-size: 14px;
        font-weight: 700;
        color: var(--prism-text);
        margin-bottom: 4px;
    }
    .sc-card-subtitle {
        font-size: 12px;
        color: var(--prism-text-muted);
        margin-top: 4px;
        margin-bottom: 12px;
    }
    /* Calendar */
    .sc-cal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 8px;
    }
    .sc-cal-month {
        font-size: 12px;
        font-weight: 700;
        color: var(--prism-text);
    }
    .sc-cal-nav {
        background: transparent;
        border: none;
        color: var(--prism-text-muted);
        cursor: pointer;
        font-size: 14px;
    }
    .sc-cal-days {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 4px;
        font-size: 11px;
        text-align: center;
    }
    .sc-cal-weekday {
        color: var(--prism-text-muted);
        font-weight: 700;
        padding: 2px 0;
    }
    .sc-cal-day {
        padding: 4px 0;
        border-radius: 6px;
        color: var(--prism-text);
    }
    .sc-cal-day.active {
        background: var(--prism-violet);
        color: #fff;
        font-weight: 700;
    }
    .sc-cal-day.empty { color: transparent; }
    /* Notifications */
    .sc-notif-item {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 6px 0;
        font-size: 12px;
        color: var(--prism-text);
    }
    .sc-notif-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
    }
    /* Radio */
    .sc-radio-label {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 6px 0;
        font-size: 12px;
        color: var(--prism-text);
        cursor: pointer;
    }
    .sc-radio-custom {
        width: 16px;
        height: 16px;
        border-radius: 50%;
        border: 2px solid var(--prism-border);
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .sc-radio-custom.active {
        border-color: var(--prism-violet);
    }
    .sc-radio-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--prism-violet);
    }
    /* Toggle */
    .sc-toggle-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 8px 0;
        font-size: 12px;
        color: var(--prism-text);
    }
    .sc-toggle {
        width: 32px;
        height: 18px;
        border-radius: 99px;
        background: rgba(239, 68, 68, 0.4);
        position: relative;
        cursor: pointer;
        transition: background 0.3s;
    }
    .sc-toggle.active {
        background: linear-gradient(135deg, #0058ff 40%, #3c50ff 30%, #0fd095 100%);
    }
    [data-theme="light"] .sc-toggle:not(.active) { background: rgba(239, 68, 68, 0.3); }
    .sc-toggle-knob {
        position: absolute;
        top: 2px;
        left: 2px;
        width: 14px;
        height: 14px;
        border-radius: 50%;
        background: #fff;
        transition: transform 0.3s;
    }
    .sc-toggle.active .sc-toggle-knob { transform: translateX(14px); }
    @keyframes spin {
        to { transform: rotate(360deg); }
    }
    @keyframes pulse-dot {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.4; transform: scale(0.8); }
    }
    [data-theme="light"] .sc-toggle:not(.active) { background: rgba(0, 0, 0, 0.15); }

    /* Hamburger + mobile drawer (mobile-only — visible by default, hidden on desktop) */
    .nav .nav-hamburger { display: inline-flex; align-items: center; justify-content: center; background: transparent; border: none; color: var(--prism-text); padding: 8px; margin-right: 8px; cursor: pointer; border-radius: 8px; width: 40px; height: 40px; order: -1; }
    .nav .nav-hamburger:hover { background: var(--prism-surface-hover); }
    @media (min-width: 769px) { .nav .nav-hamburger { display: none; } }
    .sidebar-backdrop { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 95; opacity: 0; transition: opacity 0.25s ease; }
    .sidebar-backdrop.open { display: block; opacity: 1; }
    .mobile-drawer { display: none; position: fixed; top: 0; left: 0; width: 300px; max-width: 86vw; height: 100vh; padding: 24px 18px 32px; border-right: 1px solid var(--prism-border); overflow-y: auto; transform: translateX(-100%); transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1); z-index: 96; background: var(--prism-black); }
    [data-theme="light"] .mobile-drawer { background: #ffffff; }
    .mobile-drawer.open { transform: translateX(0); box-shadow: 12px 0 40px rgba(0,0,0,0.25); }
    body.sidebar-locked { overflow: hidden; }
    .mobile-drawer h4 { font-size: 11px; font-weight: 700; color: var(--prism-text-muted); text-transform: uppercase; letter-spacing: 0.1em; margin: 20px 0 10px; padding-left: 4px; }
    .mobile-drawer ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 4px; }
    .mobile-drawer a { display: block; padding: 10px 12px; font-size: 14px; font-weight: 600; color: var(--prism-text); text-decoration: none; border-radius: 8px; transition: all 0.2s ease; }
    .mobile-drawer a:hover { background: var(--prism-surface-hover); color: var(--prism-violet); }

    @media (max-width: 900px) {
        .nav { padding: 0 24px; }
    }

    /* ═══ Component Functional Hovers ═══ */
    .sc-card svg { transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
    .sc-card:hover svg { transform: scale(1.2); }
    .sc-card { cursor: pointer; }
    .sc-hover-anim {
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.6s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.4s ease, background 0.4s ease;
    }
    .sc-hover-anim:hover {
        border-color: rgba(255,255,255,0.25);
        background: var(--prism-surface-hover);
        transform: translateY(-8px) !important;
        box-shadow: 0 24px 48px rgba(0,0,0,0.25);
    }
    [data-theme="light"] .sc-hover-anim:hover {
        box-shadow: 0 12px 30px rgba(37,99,235,0.08);
    }
    .sc-progress-fill, .file-fill {
        transition: width 1.2s cubic-bezier(0.16, 1, 0.3, 1), background 0.6s ease;
    }
    .sc-hover-anim:hover .sc-progress-fill { width: 100% !important; background: var(--prism-violet-light) !important; }
    .sc-hover-anim:hover .file-fill { width: 100% !important; background: var(--prism-emerald) !important; }
    .sc-hover-anim.sc-calendar:hover .sc-cal-days { transform: scale(1.02); transition: transform 0.3s ease; }
    .sc-cal-day:not(.empty):hover { background: var(--prism-violet); color: #fff; box-shadow: 0 4px 12px rgba(37,99,235,0.4); font-weight: 700; border-radius: 8px; }
    .sc-radio-label { transition: background 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease; }
    .sc-radio-label:hover { background: rgba(124, 58, 237, 0.06); border-color: rgba(124, 58, 237, 0.2); box-shadow: 0 0 0 1px rgba(124, 58, 237, 0.1); }
    .sc-radio-label:hover .sc-radio-custom:not(.active) { border-color: var(--prism-violet); }
    .sc-radio-label:hover .sc-radio-custom:not(.active)::after { transform: translate(-50%, -50%) scale(1); opacity: 0.5; background: var(--prism-violet); }
    .sc-toggle-row:hover .sc-toggle:not(.active) { background: rgba(124, 58, 237, 0.3); }
    .sc-toggle-row { transition: background 0.3s ease, transform 0.3s ease; }
    .sc-toggle-row:hover { transform: translateX(4px); }
    .sc-hover-anim:hover .sc-profile-badge { background: var(--prism-violet) !important; color: #fff !important; }
    .sc-hover-anim:hover .icon-pulse { transform: scale(1.1) rotate(5deg); background: rgba(16,185,129,0.3) !important; }
    .sc-notif-item:hover .sc-notif-dot { transform: scale(1.5); box-shadow: 0 0 12px var(--prism-violet); }
    .storage-chart {
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.6s ease;
    }
    .sc-hover-anim:hover .storage-chart {
        transform: scale(1.12) rotate(8deg);
        box-shadow: 0 0 24px rgba(217, 70, 239, 0.35);
    }
    .sc-hover-anim:hover .num-bump { transform: scale(1.05) translateY(-4px); }
    .sc-hover-anim:hover .upgrade-btn { background: linear-gradient(135deg, #0058ff 40%, #3c50ff 30%, #0fd095 100%) !important; color:#fff !important; border-color:transparent !important; transform: scale(1.05); }
    .sc-hover-anim:not(#sc-card-component-31):not(#sc-network-latency-card):hover .bar-anim { height: 90% !important; border-color: var(--prism-violet-light) !important; box-shadow: 0 0 8px rgba(124,58,237,0.3); }
    #sc-network-latency-card:hover .bar-anim:nth-child(1) { height: 45% !important; }
    #sc-network-latency-card:hover .bar-anim:nth-child(2) { height: 65% !important; }
    #sc-network-latency-card:hover .bar-anim:nth-child(3) { height: 95% !important; }
    #sc-network-latency-card:hover .bar-anim:nth-child(4) { height: 55% !important; }
    #sc-network-latency-card:hover .bar-anim:nth-child(5) { height: 75% !important; }
    #sc-network-latency-card:hover .bar-anim:nth-child(6) { height: 40% !important; }
    #sc-network-latency-card:hover .bar-anim:nth-child(7) { height: 85% !important; }
    #sc-card-component-31 .bar-anim {
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        cursor: pointer;
    }
    #sc-card-component-31 .bar-anim:hover {
        height: 95% !important;
        background: var(--prism-violet-light) !important;
        box-shadow: 0 0 14px rgba(124,58,237,0.45);
        transform: scaleX(1.15);
    }
    .sc-hover-anim:hover .shield-icon { background: var(--prism-red) !important; color: #fff !important; transform: scale(1.1); }
    .sc-hover-anim:hover .badge-anim { background: var(--prism-violet) !important; color: #fff !important; border-color:var(--prism-violet) !important; }
    .sc-hover-anim:hover .ring-anim { border-top-color: var(--prism-cyan) !important; animation-duration: 1s !important; }
    .sc-card:hover .gauge-fill { stroke-dashoffset: 44 !important; }
    .sc-vuln-gauge-card .gauge-val-hover { display: none; }
    .sc-vuln-gauge-card:hover .gauge-val-default { display: none; }
    .sc-vuln-gauge-card:hover .gauge-val-hover { display: inline; }
    .sc-vuln-stat { transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), background 0.3s ease; }
    .sc-vuln-card:hover .sc-vuln-stat { transform: translateY(-4px) scale(1.05); }
    .sc-vuln-card:hover .sc-vuln-bar { width: 82% !important; background: linear-gradient(90deg, var(--prism-emerald), #34d399) !important; transition: width 0.8s cubic-bezier(0.16, 1, 0.3, 1), background 0.5s ease; }
    .sc-vuln-search { transition: border-color 0.2s ease, background 0.2s ease; }
    .sc-vuln-search:focus-within { border-color: rgba(239,68,68,0.4) !important; background: rgba(239,68,68,0.04) !important; }
    .sc-vuln-search input::placeholder { color: var(--prism-text-muted); }
    [data-theme="light"] .sc-vuln-search { border-color: rgba(15,23,42,0.08) !important; background: rgba(15,23,42,0.02) !important; }
    [data-theme="light"] .sc-vuln-search:focus-within { border-color: rgba(239,68,68,0.35) !important; background: rgba(239,68,68,0.05) !important; }
    [data-theme="light"] .sc-vuln-search span { background: rgba(15,23,42,0.05) !important; border-color: rgba(15,23,42,0.08) !important; color: var(--prism-text-muted); }

    @media (max-width: 640px) {
        .meta { font-size: 0.7rem; gap: 16px; }
        .meta span::before { margin-right: 16px; }
    }

    /* ═══ Mobile Responsive Overrides ═══ */
    @media (max-width: 1024px) {
        .nav { padding: 0 20px !important; height: 64px !important; }
        .nav-logo-mark { font-size: 22px !important; }
        .nav-logo-sub { font-size: 11px !important; }
        #features-section { padding: 80px 32px !important; }
        #resource-section { padding: 80px 32px !important; }
        .wn-section { padding: 24px 32px !important; }
        .wn-bento { grid-template-columns: 1fr 1fr !important; }
    }

    @media (max-width: 768px) {
        .nav { padding: 0 16px !important; height: 60px !important; }
        .nav-links { gap: 0 !important; }
        .nav-links a:not(.nav-dropdown-menu a) { font-size: 13px !important; padding: 6px 10px !important; }
        .nav-links > a:nth-child(-n+3),
        .nav-links .nav-dropdown > a { display: none !important; }
        .nav-dropdown { display: none !important; }
        #themeToggle { width: 36px !important; height: 36px !important; padding: 6px !important; margin-left: 4px !important; }

        .hero-section { min-height: auto !important; padding: 72px 16px 24px !important; flex-direction: column !important; justify-content: center !important; gap: 8px !important; }
        h1 { white-space: normal !important; font-size: clamp(1.75rem, 8vw, 2.5rem) !important; }
        .subtext { font-size: 0.95rem !important; margin-bottom: 16px !important; padding: 0 8px; }
        .badge { font-size: 0.7rem !important; padding: 6px 12px !important; margin-bottom: 20px !important; }
        .hero-cta { padding: 12px 32px !important; font-size: 14px !important; }

        #features-section { padding: 64px 20px !important; }
        .features-title, #features-section h2 { font-size: 30px !important; line-height: 1.15 !important; }
        .features-subtitle, #features-section p { font-size: 14.5px !important; }

        #whats-next-section, .wn-root { padding: 0 !important; }
        .wn-section { padding: 16px 20px 48px !important; }
        .wn-title { font-size: 26px !important; line-height: 1.2 !important; }
        .wn-subtitle { font-size: 14px !important; padding: 0 8px; }
        .wn-bento { grid-template-columns: 1fr !important; gap: 16px !important; }
        .wn-card-img { height: 180px !important; min-height: unset !important; }
        .wn-card--theme .wn-card-img { height: 160px !important; }
        .wn-card-body { padding: 20px 22px !important; }
        .wn-card-title { font-size: 17px !important; }
        .wn-card-desc { font-size: 13.5px !important; }

        #resource-section { padding: 64px 20px !important; }
        #resource-section h2, .rs-title { font-size: 28px !important; line-height: 1.2 !important; }
        .rs-subtitle { font-size: 14px !important; }
        .rs-grid { grid-template-columns: 1fr !important; gap: 16px !important; }

        /* Footer */
        .site-footer { padding: 56px 24px 32px !important; }
        .site-footer-grid {
            grid-template-columns: 1fr 1fr !important;
            gap: 32px !important;
        }
        .site-footer-bottom {
            flex-direction: column !important;
            align-items: flex-start !important;
            gap: 8px !important;
            text-align: left !important;
        }

        /* Showcase marquee sizing */
        .showcase-section { padding: 0 !important; }
        .hero-showcase { margin-top: 16px !important; padding: 8px 0 !important; }
    }

    @media (max-width: 480px) {
        .nav-logo-sub { display: none !important; }
        .nav-links a:not(.nav-dropdown-menu a) { font-size: 12px !important; padding: 6px 8px !important; }

        .hero-section { min-height: auto !important; padding: 64px 14px 20px !important; }
        h1 { font-size: clamp(1.6rem, 9vw, 2.25rem) !important; }

        #features-section { padding: 48px 16px !important; }
        .features-title, #features-section h2 { font-size: 26px !important; }

        .wn-section { padding: 12px 16px 40px !important; }
        .wn-title { font-size: 22px !important; }

        #resource-section { padding: 48px 16px !important; }
        #resource-section h2, .rs-title { font-size: 24px !important; }

        .site-footer { padding: 40px 16px 24px !important; }
        .site-footer-grid {
            grid-template-columns: 1fr !important;
            gap: 28px !important;
        }
        .site-footer-grid h4 { font-size: 11.5px !important; margin-bottom: 12px !important; }
        .site-footer-grid ul { gap: 8px !important; }
        .site-footer-grid a { font-size: 13.5px !important; }
        .site-footer-bottom { margin-top: 28px !important; padding-top: 20px !important; }
        .site-footer-bottom span { font-size: 12px !important; }
    }

    /* Hamburger drawer — placed LAST so it wins the cascade at ≤ 768 px */
    @media (max-width: 768px) {
        .nav { padding: 0 16px !important; justify-content: flex-start !important; gap: 4px !important; }
        .nav-links { display: flex !important; margin-left: auto !important; gap: 0 !important; }
        .nav-links > a,
        .nav-links > .nav-dropdown { display: none !important; }
        .mobile-drawer { display: block; }
    }

    /* Ensure no horizontal overflow anywhere */
    html, body { overflow-x: hidden; }
    img, svg, video { max-width: 100%; height: auto; }
</style>
</head>
