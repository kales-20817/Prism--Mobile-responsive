<div class="page">
<section class="hero-section">
<main class="overlay">
    <h1><span class="accent">One system.</span><br>Every surface.</h1>
    <p class="subtext">
        Prism is the single source of truth for UEMS — tokens, foundations, and production-ready components that keep every team building consistently.
    </p>
</main>
<a href="#features-section" class="hero-cta" aria-label="Explore Prism" onclick="event.preventDefault(); document.getElementById('features-section').scrollIntoView({behavior:'smooth', block:'start'});">
    Explore Prism
</a>
</section>
<section id="showcase" class="showcase-section">
<div class="hero-showcase">
  <div class="marquee-wrapper">
    <div class="marquee-row left">
      <!-- Patch Compliance -->
      <div id="sc-patch-compliance" class="sc-card sc-hover-anim" style="min-width: 270px;">
        <div style="display:flex; align-items:center; gap:10px; margin-bottom:12px;">
          <div style="width:36px; height:36px; border-radius:10px; background:rgba(124,58,237,0.15); display:flex; align-items:center; justify-content:center; color:var(--prism-violet-light);">
            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          </div>
          <div>
            <div id="spt-patch-compliance-1" class="sc-progress-title" style="margin:0;">Patch Compliance</div>
            <div style="font-size:10px; color:var(--prism-text-muted);">1,240 devices managed</div>
          </div>
        </div>
        <div style="display:flex; gap:8px; margin-bottom:12px;">
          <div style="flex:1; text-align:center; padding:8px 6px; background:rgba(124,58,237,0.06); border:1px solid rgba(124,58,237,0.12); border-radius:10px;">
            <div style="font-size:20px; font-weight:800; color:var(--prism-violet-light);">78%</div>
            <div style="font-size:9px; color:var(--prism-text-muted); font-weight:600;">Overall</div>
          </div>
          <div style="flex:1; text-align:center; padding:8px 6px; background:rgba(16,185,129,0.06); border:1px solid rgba(16,185,129,0.12); border-radius:10px;">
            <div style="font-size:20px; font-weight:800; color:var(--prism-emerald);">92%</div>
            <div style="font-size:9px; color:var(--prism-text-muted); font-weight:600;">Critical</div>
          </div>
        </div>
        <div class="sc-progress-bar"><div class="sc-progress-fill" style="width: 78%;"></div></div>
        <div class="sc-progress-label"><span>78%</span><span>All Patches</span></div>
        <div style="margin-top:8px">
          <div class="sc-progress-bar"><div class="sc-progress-fill" style="width: 92%; background:linear-gradient(90deg,var(--prism-emerald),#34d399);"></div></div>
          <div class="sc-progress-label"><span style="color:var(--prism-emerald)">92%</span><span>Critical Server Patches</span></div>
        </div>
      </div>
      <!-- Calendar -->
      <div id="sc-calendar" class="sc-card sc-calendar sc-hover-anim" style="min-width: 280px;">
