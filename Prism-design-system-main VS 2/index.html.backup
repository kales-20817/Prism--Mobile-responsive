  <section id="features-section" style="position:relative; z-index:5;">
    <style>
      #features-section {
        padding: 140px 64px;
        background: #ffffff;
      }
      :root:not([data-theme="light"]) #features-section {
        background: transparent;
      }
      .features-wrap {
        max-width: 1280px;
        margin: 0 auto;
      }
      .features-title {
        font-size: 48px;
        font-weight: 800;
        color: var(--text);
        letter-spacing: -0.03em;
        line-height: 1.1;
        margin-bottom: 16px;
        text-align: center;
      }
      .features-subtitle {
        font-size: 16px;
        color: var(--text-muted);
        line-height: 1.7;
        max-width: 560px;
        margin: 0 auto 64px;
        text-align: center;
      }
      .features-grid {
        display: flex;
        gap: 20px;
      }
      .features-col {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 20px;
      }
      .feat-card {
        background: linear-gradient(135deg, rgba(59, 130, 246, 0.08), rgba(99, 102, 241, 0.04));
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 36px 32px;
        display: flex;
        flex-direction: column;
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.3s;
        overflow: hidden;
      }
      [data-theme="light"] .feat-card {
        background: linear-gradient(135deg, rgba(59, 130, 246, 0.08), rgba(99, 102, 241, 0.04));
        border-color: rgba(0,0,0,0.06);
      }
      .feat-card:hover,
      [data-theme="light"] .feat-card:hover {
        transform: translateY(-3px);
        background: linear-gradient(135deg, rgba(0, 88, 255, 0.1) 40%, rgba(60, 80, 255, 0.1) 30%, rgba(15, 208, 149, 0.1) 100%) !important;
        border-color: rgba(124, 58, 237, 0.15);
      }
      .feat-card-title {
        font-size: 20px;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 12px;
        text-align: center;
      }
      .feat-card-desc {
        font-size: 14px;
        color: var(--text-muted);
        line-height: 1.6;
        text-align: center;
        margin-bottom: 24px;
      }
      .feat-card-visual {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 120px;
      }

      /* Notification mini */
      .feat-notif {
        display: flex;
        align-items: center;
        gap: 12px;
        background: var(--surface-strong);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 12px 20px;
      }
      [data-theme="light"] .feat-notif {
        background: #fff;
        border-color: rgba(0,0,0,0.08);
      }
      .grid-bg {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        backdrop-filter: blur(16px) saturate(1.4);
        -webkit-backdrop-filter: blur(16px) saturate(1.4);
        box-shadow: 0 8px 32px rgba(0,0,0,0.2);
      }
      [data-theme="light"] .grid-bg {
        background: rgba(255,255,255,0.6);
        border-color: rgba(0,0,0,0.06);
        box-shadow: 0 8px 32px rgba(0,0,0,0.06);
      }
      .feat-notif-icon {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        background: #006aff;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }
      .feat-notif-text strong { display: block; font-size: 13px; color: #1a191b; }
      :root:not([data-theme="light"]) .feat-notif-text strong { color: #fff; }
      .feat-notif-text span { font-size: 12px; color: #006aff; }

      /* Update badge */
      .feat-update-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 24px;
        border-radius: 99px;
        background: var(--surface-strong);
        border: 1px solid var(--border);
        font-size: 13px;
        font-weight: 600;
        color: var(--text-soft);
      }
      [data-theme="light"] .feat-update-badge {
        background: #fff;
        border-color: rgba(0,0,0,0.08);
      }
      .feat-update-badge svg { animation: spin 2s linear infinite; }

      /* Plugin cards */
      .feat-plugin-stack {
        display: flex;
        align-items: center;
        gap: -8px;
      }
      .feat-plugin-card {
        width: 56px;
        height: 56px;
        border-radius: 14px;
        background: var(--surface-strong);
        border: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-left: -8px;
        transition: transform 0.3s;
      }
      .feat-plugin-card:first-child { margin-left: 0; }
      .feat-plugin-card:hover { transform: translateY(-4px); }
      .feat-plugin-card.main {
        width: 64px;
        height: 64px;
        z-index: 2;
        background: var(--surface-hover);
      }
      [data-theme="light"] .feat-plugin-card {
        background: #fff;
        border-color: rgba(0,0,0,0.08);
      }
      [data-theme="light"] .feat-plugin-card.main {
        background: #f0f0f2;
      }

      /* API icons */
      .feat-api-row {
        display: flex;
        align-items: center;
        gap: 16px;
      }
      .feat-api-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        background: var(--surface-strong);
        border: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 700;
        color: var(--text-soft);
      }
      [data-theme="light"] .feat-api-icon {
        background: #fff;
        border-color: rgba(0,0,0,0.08);
      }
      .feat-api-icon.brand {
        background: linear-gradient(135deg, rgba(37,99,235,0.15), rgba(37,99,235,0.05));
        color: #2563eb;
      }

      /* Window mini */
      .feat-window-mini {
        width: 200px;
        height: 120px;
        border-radius: 10px;
        background: var(--surface-strong);
        border: 1px solid var(--border);
        overflow: hidden;
      }
      [data-theme="light"] .feat-window-mini {
        background: #fff;
        border-color: rgba(0,0,0,0.08);
      }
      .feat-window-mini-bar {
        display: flex;
        align-items: center;
        gap: 5px;
        padding: 8px 10px;
        border-bottom: 1px solid var(--border);
      }
      .feat-window-mini-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
      }

      /* Installer pills */
      .feat-installer-row {
        display: flex;
        align-items: center;
        gap: 12px;
      }
      .feat-installer-pill {
        padding: 10px 22px;
        border-radius: 12px;
        background: var(--surface-strong);
        border: 1px solid var(--border);
        font-size: 13px;
        font-weight: 700;
        color: var(--text-soft);
        letter-spacing: 0.02em;
        transition: transform 0.3s ease, box-shadow 0.3s ease, background 0.3s ease, border-color 0.3s ease;
        transition: transform 0.3s;
      }
      [data-theme="light"] .feat-installer-pill {
        background: #fff;
        border-color: rgba(0,0,0,0.08);
      }
      .feat-installer-pill:hover { transform: translateY(-2px); box-shadow: 0 6px 20px #072a68c2; background: var(--surface-hover); border-color: rgba(124,58,237,0.2); }
      [data-theme="light"] .feat-installer-pill:hover { box-shadow: 0 6px 20px #b9d1fbc2; }
      .feat-installer-pill.active {
        background: linear-gradient(135deg, #0058ff 40%, #3c50ff 30%, #0fd095 100%);
        border-color: transparent;
        color: #fff;
        box-shadow: 0 4px 16px rgba(0,88,255,0.3);
      }

      @media (max-width: 900px) {
        #features-section { padding: 64px 20px; }
        .features-title { font-size: 32px; }
        .features-grid { flex-direction: column; }
      }
    </style>

    <div class="features-wrap">
      <h2 class="features-title">Foundations, <span style="background:linear-gradient(135deg, #0058ff 40%, #3c50ff 30%, #0fd095 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">codified</span></h2>
      <p class="features-subtitle">The building blocks every team needs — color, spacing, typography, and motion — documented, tokenized, and ready to use.</p>
      <div class="features-grid">

        <!-- Column 1 -->
        <div class="features-col">
          <div class="feat-card" style="height:214px;">
            <div class="feat-card-title">Color with clear intent</div>
            <div class="feat-card-visual">
              <div class="feat-notif">
                <div class="feat-notif-icon">
                </div>
                <div class="feat-notif-text">
                  <strong>BG-Button-Primary</strong>
                  <span>#006aff</span>
                </div>
              </div>
            </div>
          </div>
          <div class="feat-card">
            <div class="feat-card-title">Spacing that creates rhythm</div>
            <div class="feat-card-desc">A disciplined 8px system that improves grouping, readability, and decision speed across dense screens.</div>
            <div class="feat-card-visual">
              <div class="feat-api-row" style="position:relative;">
                <div class="feat-api-icon brand">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 12h8"/><path d="M12 8v8"/></svg>
                </div>
                <!-- 16px spacing indicator -->
                <div style="display:flex; flex-direction:column; align-items:center; gap:2px;">
                  <div style="width:16px; height:2px; background:rgba(239,68,108,0.4);"></div>
                  <span style="font-size:8px; font-weight:700; color:#ef4444; font-family:'JetBrains Mono',monospace;">16</span>
                  <div style="width:16px; height:2px; background:rgba(239,68,108,0.4);"></div>
                </div>
                <div class="feat-api-icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M4 6h16M4 12h16M4 18h8"/></svg>
                </div>
                <!-- 16px spacing indicator -->
                <div style="display:flex; flex-direction:column; align-items:center; gap:2px;">
                  <div style="width:16px; height:2px; background:rgba(239,68,108,0.4);"></div>
                  <span style="font-size:8px; font-weight:700; color:#ef4444; font-family:'JetBrains Mono',monospace;">16</span>
                  <div style="width:16px; height:2px; background:rgba(239,68,108,0.4);"></div>
                </div>
                <div class="feat-api-icon">API</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Column 2 -->
        <div class="features-col">
          <div class="feat-card">
            <div class="feat-card-title">Words that guide action</div>
            <div class="feat-card-desc">Clear, system-first language for alerts, patching, confirmations, and AI-powered decisions.</div>
            <div class="feat-card-visual">
              <div class="feat-update-badge">
                Always in sync
              </div>
            </div>
          </div>
          <div class="feat-card" style="height:214px;">
            <div class="feat-card-title">Grid that structures complexity</div>
            <div class="feat-card-visual">
              <div style="position:relative; padding:12px; border-radius:10px; overflow:hidden;">
                <!-- Grid background -->
                <div class="grid-bg" style="position:absolute; inset:0; border-radius:10px;"></div>
                <!-- Scaling boxes -->
                <div style="position:relative; display:flex; align-items:flex-end; gap:6px; padding:24px 8px 8px; min-height:80px;">
                  <div style="width:6px; height:6px; border-radius:1px; background:#87a6eb;"></div>
                  <div style="width:8px; height:8px; border-radius:1px; background:#87a6eb;"></div>
                  <div style="width:12px; height:12px; border-radius:2px; background:#87a6eb;"></div>
                  <div style="width:18px; height:18px; border-radius:2px; background:#87a6eb;"></div>
                  <div style="width:26px; height:26px; border-radius:3px; background:#87a6eb;"></div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Column 3 -->
        <div class="features-col">
          <div class="feat-card" style="height:214px;">
            <div class="feat-card-title">Tokens as the single source</div>
            <div class="feat-card-visual">
              <div style="display:flex; flex-direction:column; gap:0; align-items:flex-start; position:relative; padding:12px 0;">
                <!-- Component-specific token -->
                <div style="display:flex; align-items:center; gap:10px;">
                  <div style="display:flex; align-items:center; gap:8px; padding:6px 14px; border-radius:8px; background:var(--surface-strong); border:1px solid var(--border);">
                    <div style="width:12px; height:12px; border-radius:3px; background:#0058ff;"></div>
                    <span style="font-size:11px; font-weight:600; font-family:'JetBrains Mono',monospace; color:var(--text);">Background/BG-Button-Primary</span>
                  </div>
                </div>
                <!-- Connector line -->
                <div style="width:1px; height:20px; background:var(--border); margin-left:24px;"></div>
                <!-- Alias token -->
                <div style="display:flex; align-items:center; gap:10px;">
                  <div style="display:flex; align-items:center; gap:8px; padding:6px 14px; border-radius:8px; background:var(--surface-strong); border:1px solid var(--border);">
                    <div style="width:12px; height:12px; border-radius:3px; background:#ebf4ff;"></div>
                    <span style="font-size:11px; font-weight:600; font-family:'JetBrains Mono',monospace; color:var(--text);">Background/Background</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="feat-card">
            <div class="feat-card-title">Layering with purpose</div>
            <div class="feat-card-desc">Elevation tokens create clear layering across surfaces, guiding focus, interaction, and visual priority.</div>
            <div class="feat-card-visual">
              <div class="feat-installer-row">
                <span class="feat-installer-pill">DMG</span>
                <span class="feat-installer-pill active">EXE</span>
                <span class="feat-installer-pill">PKG</span>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section id="whats-next-section" style="background:#ffffff; position:relative; z-index:5;" class="wn-root">
    <style>
      :root:not([data-theme="light"]) #whats-next-section.wn-root { background: transparent !important; }
      .wn-section {
        padding: 30px 64px;
        width: 100%;
        max-width: 1400px;
        margin: 0 auto;
      }
      .wn-header {
        text-align: center;
        margin-bottom: 56px;
      }
      .wn-tag {
        display: inline-block;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--prism-violet-light);
        background: rgba(124, 58, 237, 0.1);
        border: 1px solid rgba(124, 58, 237, 0.2);
        padding: 6px 16px;
        border-radius: 99px;
        margin-bottom: 20px;
      }
      .wn-title {
        font-size: 42px;
        font-weight: 800;
        color: var(--prism-text);
        letter-spacing: -0.03em;
        line-height: 1.15;
        margin-bottom: 16px;
      }
      .wn-title span {
        background: linear-gradient(135deg, #0058ff 40%, #3c50ff 30%, #0fd095 100%);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
      }
      .wn-subtitle {
        font-size: 16px;
        color: var(--prism-text-muted);
        max-width: 520px;
        margin: 0 auto;
        line-height: 1.6;
      }

      .wn-bento {
        display: grid;
        grid-template-columns: 1fr 1.3fr 1fr;
        grid-template-rows: auto auto;
        grid-template-areas:
          "rtl theme wcag"
          "font theme cta";
        gap: 20px;
      }
      .wn-card {
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 20px;
        overflow: hidden;
        transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        position: relative;
        display: flex;
        flex-direction: column;
      }
      .wn-card-img {
        width: 100%;
        height: 160px;
        background: linear-gradient(135deg, rgba(0, 88, 255, 0.1) 40%, rgba(60, 80, 255, 0.1) 30%, rgba(15, 208, 149, 0.1) 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        transition: transform 0.4s cubic-bezier(0.16,1,0.3,1), filter 0.3s ease, background 0.3s ease;
        flex-shrink: 0;
      }
      .wn-card-img svg {
        width: 56px;
        height: 56px;
        opacity: 0.45;
        transition: opacity 0.3s ease, transform 0.3s ease;
        position: relative;
        z-index: 1;
        stroke: var(--prism-text);
      }
      .wn-card-img::before,
      .wn-card-img::after {
        content: '';
        position: absolute;
        border-radius: 999px;
        opacity: 0.16;
        filter: blur(18px);
      }
      .wn-card-img::before {
        width: 100px;
        height: 100px;
        top: 12px;
        right: -20px;
        background: rgba(255, 255, 255, 0.06);
      }
      .wn-card-img::after {
        width: 60px;
        height: 60px;
        bottom: 14px;
        left: 18px;
        background: rgba(255, 255, 255, 0.08);
      }

      .img-rtl {
        background: linear-gradient(135deg, rgba(0, 88, 255, 0.05) 40%, rgba(60, 80, 255, 0.05) 30%, rgba(15, 208, 149, 0.05) 100%);
        padding: 0;
      }
      .img-rtl:hover {
        background: linear-gradient(135deg, rgba(0, 88, 255, 0.1) 40%, rgba(60, 80, 255, 0.1) 30%, rgba(15, 208, 149, 0.1) 100%);
      }

      .rtl-split {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        background: transparent;
        width: 100%;
        height: 100%;
        padding: 16px 12px;
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.3s, background 0.3s;
      }
      [data-theme="light"] .rtl-split {
        background: transparent;
        border-color: rgba(0,0,0,0.06);
      }
      .rtl-split:hover,
      [data-theme="light"] .rtl-split:hover {
        transform: translateY(-3px);
        background: linear-gradient(135deg, rgba(0, 88, 255, 0.1) 40%, rgba(60, 80, 255, 0.1) 30%, rgba(15, 208, 149, 0.1) 100%) !important;
        border-color: rgba(124, 58, 237, 0.15);
      }
      .rtl-card-mini {
        flex: 1;
        background: var(--prism-surface);
        border: 1px solid var(--prism-border);
        border-radius: 10px;
        padding: 10px;
        display: flex;
        flex-direction: column;
        gap: 8px;
        max-width: 120px;
      }
      .rtl-mini-nav { display: flex; align-items: center; gap: 5px; }
      .rtl-dot { width: 8px; height: 8px; border-radius: 50%; background: #3b82f6; flex-shrink: 0; }
      .rtl-nav-bar { height: 4px; border-radius: 2px; flex: 1; background: var(--prism-border); }
      .rtl-nav-bar.short { flex: 0.5; }
      .rtl-mini-body { display: flex; flex-direction: column; gap: 4px; }
      .rtl-line { height: 3px; border-radius: 2px; width: 100%; background: var(--prism-border); }
      .rtl-line.title { height: 5px; width: 55%; border-radius: 3px; background: #3b82f6; opacity: 0.6; }
      .rtl-line.med { width: 80%; }
      .rtl-line.short { width: 60%; }
      .rtl-btn { width: 36px; height: 10px; border-radius: 5px; background: #3b82f6; opacity: 0.5; margin-top: 2px; transition: background 0.3s ease, opacity 0.3s ease; }
      .wn-card-img:hover .rtl-btn { background: linear-gradient(135deg, #0058ff 40%, #3c50ff 30%, #0fd095 100%); opacity: 0.8; }
      .rtl-mini-label { text-align: center; font-size: 9px; font-weight: 700; color: #3b82f6; font-family: 'Zoho Puvi', sans-serif; }
      .rtl-arrow { display: flex; align-items: center; flex-shrink: 0; }
      .img-theme {
        background: linear-gradient(135deg, rgba(0, 88, 255, 0.05) 40%, rgba(60, 80, 255, 0.05) 30%, rgba(15, 208, 149, 0.05) 100%) !important;
        padding: 0;
      }
      .img-theme:hover {
        background: linear-gradient(135deg, rgba(0, 88, 255, 0.1) 40%, rgba(60, 80, 255, 0.1) 30%, rgba(15, 208, 149, 0.1) 100%) !important;
      }

      .theme-minimal {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 14px;
        width: 100%;
        height: 100%;
        transition: background 0.3s ease;
      }
      .theme-minimal:hover {
        background: linear-gradient(135deg, rgba(0, 88, 255, 0.12) 50%, rgba(60, 80, 255, 0.1) 60%, rgba(15, 208, 149, 0.08) 100%);
      }
      .theme-minimal:hover .theme-icon-sun svg,
      .theme-minimal:hover .theme-icon-moon svg {
        transform: scale(1.15);
        transition: transform 0.3s ease;
      }
      .theme-label-light, .theme-label-dark {
        font-size: 11px;
        font-weight: 600;
        font-family: 'Zoho Puvi', sans-serif;
        color: var(--prism-text-muted);
      }
      .theme-toggle-track {
        width: 44px; height: 22px; border-radius: 11px;
        background: var(--prism-surface);
        border: 1px solid var(--prism-border);
        position: relative; cursor: pointer;
        transition: background 0.3s, border-color 0.3s;
      }
      .theme-toggle-track:hover {
        border-color: var(--prism-violet);
        box-shadow: 0 0 12px rgba(37, 99, 235, 0.2);
      }
      .theme-toggle-thumb {
        width: 16px; height: 16px; border-radius: 50%;
        background: var(--prism-violet);
        position: absolute; top: 2px; right: 3px;
        transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
      }
      [data-theme="light"] .theme-toggle-thumb { transform: translateX(-21px); }
      .theme-icon-sun {
        width: 80px; height: 80px;
        transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.4s, filter 0.4s;
        opacity: 0.2; transform: scale(0.7) rotate(-20deg); filter: saturate(0.2);
      }
      .theme-icon-sun svg { width: 100%; height: 100%; }
      .theme-icon-moon {
        width: 72px; height: 72px;
        transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.4s, filter 0.4s;
        opacity: 1; transform: scale(1);
        filter: drop-shadow(0 0 16px rgba(203, 213, 225, 0.5));
      }
      .theme-icon-moon svg { width: 100%; height: 100%; }
      [data-theme="light"] .theme-icon-sun {
        opacity: 1; transform: scale(1) rotate(0deg);
        filter: saturate(1) drop-shadow(0 0 20px rgba(251, 191, 36, 0.55));
      }
      [data-theme="light"] .theme-icon-moon {
        opacity: 0.15; transform: scale(0.65) rotate(15deg);
        filter: saturate(0.2) drop-shadow(0 0 0 transparent);
      }
      .theme-label-light, .theme-label-dark { transition: opacity 0.3s, color 0.3s; }
      .theme-label-light { opacity: 0.4; }
      .theme-label-dark { opacity: 1; color: var(--prism-violet-light); }
      [data-theme="light"] .theme-label-light { opacity: 1; color: var(--prism-violet); }
      [data-theme="light"] .theme-label-dark { opacity: 0.4; color: var(--prism-text-muted); }
      .img-wcag {
        background: linear-gradient(135deg, rgba(37, 99, 235, 0.06), rgba(6, 182, 212, 0.04));
        padding: 0;
      }
      .img-font {
        background: linear-gradient(135deg, rgba(0, 88, 255, 0.05) 40%, rgba(60, 80, 255, 0.05) 30%, rgba(15, 208, 149, 0.05) 100%) !important;
        padding: 0;
      }
      .img-font:hover {
        background: linear-gradient(135deg, rgba(0, 88, 255, 0.1) 40%, rgba(60, 80, 255, 0.1) 30%, rgba(15, 208, 149, 0.1) 100%) !important;
      }

      .wcag-pills {
        display: flex; align-items: center; justify-content: center;
        gap: 12px; width: 100%; height: 100%; transition: background 0.3s ease;
      }
      .wcag-pills:hover {
        background: linear-gradient(135deg, rgba(0, 88, 255, 0.1) 40%, rgba(60, 80, 255, 0.1) 30%, rgba(15, 208, 149, 0.1) 100%);
      }
      .wcag-pill {
        padding: 8px 20px; border-radius: 20px;
        font-size: 15px; font-weight: 700;
        font-family: 'Zoho Puvi', sans-serif;
        background: var(--prism-surface);
        border: 1px solid var(--prism-border);
        color: var(--prism-violet-light);
        transition: transform 0.3s ease, box-shadow 0.3s ease, background 0.3s ease;
        cursor: pointer;
      }
      .wcag-pill:hover {
        transform: translateY(-3px) scale(1.08);
        box-shadow: 0 6px 20px rgba(0,88,255,0.2);
        background: linear-gradient(135deg, #0058ff 40%, #3c50ff 30%, #0fd095 100%);
        color: #fff;
        border-color: transparent;
      }
      .wcag-aa {
        background: rgba(37, 99, 235, 0.15);
        border-color: rgba(37, 99, 235, 0.25);
        color: var(--prism-violet);
      }

      .font-typo {
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        gap: 8px; width: 100%; height: 100%; padding: 16px;
        background: transparent;
        transition: background 0.3s ease;
      }
      .font-typo:hover .font-typo-aa {
        background: linear-gradient(135deg, #0058ff 40%, #3c50ff 30%, #0fd095 100%);
        -webkit-background-clip: text; background-clip: text;
        -webkit-text-fill-color: transparent;
        opacity: 1;
        transform: scale(1.05);
        transition: all 0.3s ease;
      }
      .font-typo-aa {
        font-size: 46px; font-weight: 800;
        font-family: 'Zoho Puvi', sans-serif;
        color: var(--prism-violet); opacity: 0.8; line-height: 1;
      }
      .font-typo-weights {
        display: flex; align-items: center; gap: 6px;
        font-family: 'Zoho Puvi', sans-serif;
        font-size: 11px; color: var(--prism-text-muted);
      }
      .fw-item { transition: color 0.3s; }
      .fw-dot { width: 3px; height: 3px; border-radius: 50%; background: var(--prism-border); }
      .font-typo-label {
        padding: 4px 16px; border-radius: 12px;
        font-size: 10px; font-weight: 600;
        font-family: 'Zoho Puvi', sans-serif;
        background: var(--prism-surface);
        border: 1px solid var(--prism-border);
        color: var(--prism-text-muted);
      }

      .wn-card-body { padding: 28px 32px; transition: background 0.3s ease; }
      .wn-card-title {
        font-size: 20px; font-weight: 700;
        color: var(--prism-text);
        margin-bottom: 8px; letter-spacing: -0.01em;
      }
      .wn-card-desc {
        font-size: 14px; color: var(--prism-text-muted); line-height: 1.6;
      }

      .wn-card--rtl { grid-area: rtl; }
      .wn-card--theme { grid-area: theme; }
      .wn-card--wcag { grid-area: wcag; }
      .wn-card--font { grid-area: font; }
      .wn-card--cta { grid-area: cta; }

      .wn-card--theme .wn-card-img {
        height: 100%; min-height: 200px; flex: 1;
      }

      .wn-card.wn-cta {
        background: linear-gradient(135deg, rgba(59, 130, 246, 0.08), rgba(99, 102, 241, 0.04));
        border: 1px solid rgba(124, 58, 237, 0.2);
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        text-align: center; padding: 48px 32px; min-height: 200px;
        transition: transform 0.4s cubic-bezier(0.16,1,0.3,1), background 0.3s ease, box-shadow 0.3s ease;
      }
      .wn-card.wn-cta:hover {
        transform: translateY(-4px) !important;
        background: linear-gradient(135deg, rgba(0, 88, 255, 0.1) 40%, rgba(60, 80, 255, 0.1) 30%, rgba(15, 208, 149, 0.1) 100%) !important;
        /* box-shadow: 0 8px 32px rgba(0,88,255,0.2) !important; */
        border-color: rgba(0,88,255,0.25) !important;
      }
      .wn-card.wn-cta:hover .wn-cta-btn {
        transform: scale(1.05);
        box-shadow: 0 6px 20px rgba(0,88,255,0.3);
      }
      .wn-card.wn-cta:hover .wn-cta-title {
        background: linear-gradient(135deg, #0058ff 40%, #3c50ff 30%, #0fd095 100%);
        -webkit-background-clip: text; background-clip: text;
        -webkit-text-fill-color: transparent;
      }
      .wn-cta-title {
        font-size: 22px; font-weight: 800;
        color: var(--prism-text); margin-bottom: 8px;
      }
      .wn-cta-desc {
        font-size: 14px; color: var(--prism-text-muted);
        max-width: 280px; line-height: 1.5; margin-bottom: 20px;
      }
      .wn-cta-btn {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 12px 28px; border-radius: 12px;
        font-size: 14px; font-weight: 700;
        background: linear-gradient(135deg, #0058ff 40%, #3c50ff 30%, #0fd095 100%); color: #fff;
        border: none; cursor: pointer;
        transition: all 0.3s ease; text-decoration: none;
      }
      .wn-cta-btn:hover {
        background: linear-gradient(135deg, #0058ff 40%, #3c50ff 30%, #0fd095 100%);
        transform: scale(1.05);
        box-shadow: 0 8px 24px rgba(124, 58, 237, 0.35);
      }

      /* Light theme overrides */
      [data-theme="light"] .wn-card {
        background: #ffffff;
        border-color: rgba(0, 0, 0, 0.07);
        box-shadow: none;
      }
      [data-theme="light"] .wn-card.wn-cta {
        background: linear-gradient(135deg, rgba(37, 99, 235, 0.05), rgba(6, 182, 212, 0.03));
        border-color: rgba(37, 99, 235, 0.1);
      }
      .wn-card-img:hover {
        background: linear-gradient(135deg, rgba(0, 88, 255, 0.2) 40%, rgba(60, 80, 255, 0.2) 30%, rgba(15, 208, 149, 0.2) 100%);
        transform: scale(1.02);
      }
      .wn-card-img:hover svg {
        opacity: 0.8;
        transform: scale(1.1);
      }
      [data-theme="light"] .wn-card-img {
        border-bottom-color: rgba(0, 0, 0, 0.06);
      }
      [data-theme="light"] .img-rtl {
        background: linear-gradient(135deg, rgba(0, 88, 255, 0.05) 40%, rgba(60, 80, 255, 0.05) 30%, rgba(15, 208, 149, 0.05) 100%) !important;
      }
      [data-theme="light"] .img-rtl:hover {
        background: linear-gradient(135deg, rgba(0, 88, 255, 0.1) 40%, rgba(60, 80, 255, 0.1) 30%, rgba(15, 208, 149, 0.1) 100%) !important;
      }
      [data-theme="light"] .img-theme {
        background: linear-gradient(135deg, rgba(0, 88, 255, 0.05) 40%, rgba(60, 80, 255, 0.05) 30%, rgba(15, 208, 149, 0.05) 100%) !important;
      }
      [data-theme="light"] .img-theme:hover {
        background: linear-gradient(135deg, rgba(0, 88, 255, 0.1) 40%, rgba(60, 80, 255, 0.1) 30%, rgba(15, 208, 149, 0.1) 100%) !important;
      }
      [data-theme="light"] .rtl-card-mini {
        background: rgba(255,255,255,0.8);
        border-color: rgba(0,0,0,0.08);
      }
      [data-theme="light"] .img-wcag {
        background: linear-gradient(135deg, rgba(37, 99, 235, 0.08), rgba(6, 182, 212, 0.05));
      }
      [data-theme="light"] .img-font {
        background: linear-gradient(135deg, rgba(0, 88, 255, 0.05) 40%, rgba(60, 80, 255, 0.05) 30%, rgba(15, 208, 149, 0.05) 100%) !important;
      }
      [data-theme="light"] .img-font:hover {
        background: linear-gradient(135deg, rgba(0, 88, 255, 0.1) 40%, rgba(60, 80, 255, 0.1) 30%, rgba(15, 208, 149, 0.1) 100%) !important;
      }

      @media (max-width: 768px) {
        .wn-section { padding: 64px 20px; }
        .wn-title { font-size: 28px; }
        .wn-bento {
          grid-template-columns: 1fr;
          grid-template-areas:
            "rtl"
            "theme"
            "wcag"
            "font"
            "cta";
        }
        .wn-card--theme .wn-card-img {
          height: 160px; min-height: unset; flex: unset;
        }
      }
    </style>

    <div class="wn-section">
      <div class="wn-header reveal">
                <h2 class="wn-title">What's next <span>in Prism</span></h2>
        <p class="wn-subtitle">The next generation of Prism — accessibility-first, multi-language ready, and built for deep theming across every surface.</p>
      </div>

      <div class="wn-bento">
        <div class="wn-card wn-card--rtl reveal" style="transition-delay:0.1s">
          <div class="wn-card-img img-rtl">
            <div class="rtl-split">
              <div class="rtl-card-mini rtl-ltr">
                <div class="rtl-mini-nav">
                  <span class="rtl-dot"></span>
                  <span class="rtl-nav-bar"></span>
                  <span class="rtl-nav-bar short"></span>
                </div>
                <div class="rtl-mini-body">
                  <span class="rtl-line title"></span>
                  <span class="rtl-line"></span>
                  <span class="rtl-line med"></span>
                  <span class="rtl-line short"></span>
                  <span class="rtl-btn"></span>
                </div>
                <div class="rtl-mini-label">LTR</div>
              </div>
              <div class="rtl-arrow">
                <svg viewBox="0 0 20 20" fill="none" style="stroke:none;width:16px;height:16px"><path d="M4 8l-4 4 4 4" stroke="#93c5fd" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><line x1="2" y1="12" x2="18" y2="12" stroke="#93c5fd" stroke-width="1.5" stroke-linecap="round"/><path d="M16 4l4 4-4 4" stroke="#93c5fd" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><line x1="18" y1="8" x2="2" y2="8" stroke="#93c5fd" stroke-width="1.5" stroke-linecap="round"/></svg>
              </div>
              <div class="rtl-card-mini rtl-rtl">
                <div class="rtl-mini-nav" style="flex-direction:row-reverse">
                  <span class="rtl-dot"></span>
                  <span class="rtl-nav-bar"></span>
                  <span class="rtl-nav-bar short"></span>
                </div>
                <div class="rtl-mini-body" style="align-items:flex-end">
                  <span class="rtl-line title"></span>
                  <span class="rtl-line"></span>
                  <span class="rtl-line med"></span>
                  <span class="rtl-line short"></span>
                  <span class="rtl-btn"></span>
                </div>
                <div class="rtl-mini-label">RTL</div>
              </div>
            </div>
          </div>
          <div class="wn-card-body">
            <div class="wn-card-title">RTL Layout</div>
            <div class="wn-card-desc">Full right-to-left layout support for Arabic, Hebrew, and Persian interfaces — every component mirrors seamlessly with zero manual overrides.</div>
          </div>
        </div>

        <div class="wn-card wn-card--theme reveal" style="transition-delay:0.15s">
          <div class="wn-card-img img-theme">
            <div class="theme-minimal">
              <div class="theme-icon-sun" id="themeCardSun">
                <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="20" cy="20" r="8" fill="#fbbf24"/>
                  <line x1="20" y1="4" x2="20" y2="8" stroke="#fbbf24" stroke-width="2.5" stroke-linecap="round"/>
                  <line x1="20" y1="32" x2="20" y2="36" stroke="#fbbf24" stroke-width="2.5" stroke-linecap="round"/>
                  <line x1="4" y1="20" x2="8" y2="20" stroke="#fbbf24" stroke-width="2.5" stroke-linecap="round"/>
                  <line x1="32" y1="20" x2="36" y2="20" stroke="#fbbf24" stroke-width="2.5" stroke-linecap="round"/>
                  <line x1="8.7" y1="8.7" x2="11.5" y2="11.5" stroke="#fbbf24" stroke-width="2.5" stroke-linecap="round"/>
                  <line x1="28.5" y1="28.5" x2="31.3" y2="31.3" stroke="#fbbf24" stroke-width="2.5" stroke-linecap="round"/>
                  <line x1="31.3" y1="8.7" x2="28.5" y2="11.5" stroke="#fbbf24" stroke-width="2.5" stroke-linecap="round"/>
                  <line x1="11.5" y1="28.5" x2="8.7" y2="31.3" stroke="#fbbf24" stroke-width="2.5" stroke-linecap="round"/>
                </svg>
              </div>
              <span class="theme-label-light">Light</span>
              <div class="theme-toggle-track" id="themeCardToggle">
                <div class="theme-toggle-thumb" id="themeCardThumb"></div>
              </div>
              <span class="theme-label-dark">Dark</span>
              <div class="theme-icon-moon" id="themeCardMoon">
                <svg viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M28 18.5a13 13 0 0 1-13-13A12.4 12.4 0 0 1 16.2 1 15 15 0 1 0 35 19.8a12.4 12.4 0 0 1-4.5 1.2 13 13 0 0 1-2.5-2.5z" fill="#cbd5e1"/>
                  <circle cx="22" cy="8" r="1" fill="#cbd5e1" opacity="0.6"/>
                  <circle cx="28" cy="12" r="0.7" fill="#cbd5e1" opacity="0.4"/>
                  <circle cx="25" cy="4" r="0.8" fill="#cbd5e1" opacity="0.5"/>
                </svg>
              </div>
            </div>
          </div>
          <div class="wn-card-body">
            <div class="wn-card-title">Theme Switch</div>
            <div class="wn-card-desc">Instant light-to-dark mode switching with intelligent token mapping — every surface, text, and border adapts automatically to the selected theme.</div>
          </div>
        </div>

        <div class="wn-card wn-card--wcag reveal" style="transition-delay:0.2s">
          <div class="wn-card-img img-wcag">
            <div class="wcag-pills">
              <span class="wcag-pill wcag-a">A</span>
              <span class="wcag-pill wcag-aa">AA</span>
              <span class="wcag-pill wcag-aaa">AAA</span>
            </div>
          </div>
          <div class="wn-card-body">
            <div class="wn-card-title">WCAG Guideline</div>
            <div class="wn-card-desc">Built-in AA/AAA contrast compliance, focus indicators, and screen reader semantics baked into every component from the ground up.</div>
          </div>
        </div>

        <div class="wn-card wn-card--font reveal" style="transition-delay:0.25s">
          <div class="wn-card-img img-font">
            <div class="font-typo">
              <div class="font-typo-aa">Aa</div>
              <div class="font-typo-weights">
                <span class="fw-item" style="font-weight:300">Thin</span>
                <span class="fw-dot"></span>
                <span class="fw-item" style="font-weight:400">Regular</span>
                <span class="fw-dot"></span>
                <span class="fw-item" style="font-weight:600">Semi</span>
                <span class="fw-dot"></span>
                <span class="fw-item" style="font-weight:800">Bold</span>
              </div>
              <span class="font-typo-label">Zoho Puvi</span>
            </div>
          </div>
          <div class="wn-card-body">
            <div class="wn-card-title">Font Switch</div>
            <div class="wn-card-desc">Dynamic typeface switching between system fonts, brand fonts, and accessibility-optimized faces — with live preview across all components.</div>
          </div>
        </div>

        <div class="wn-card wn-card--cta wn-cta reveal" style="transition-delay:0.3s">
          <div class="wn-cta-title">Explore the full component library</div>
          <div class="wn-cta-desc">Every component documented, tokenized, and production-ready — built to scale with your product.</div>
          <a href="Components.html" class="wn-cta-btn">View All <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
        </div>
      </div>
    </div>
  </section>

  <section id="zia-ai-section" class="zia-section reveal visible" style="position:relative; z-index:5; background:#ffffff;">
    <style>
      .zia-section {
        height: 500px;
        background: #ffffff;
        display: flex;
        align-items: center;
        width: 100%;
        overflow: hidden;
        position: relative;
        margin-top: 120px;
      }
      :root:not([data-theme="light"]) .zia-container {
        background: linear-gradient(330deg, rgba(119, -46, 113, 1.2) 0%, rgba(0, -174, 140, 11.04) 120%);
        border-radius: 24px;
      }
      [data-theme="light"] .zia-container {
        background: linear-gradient(180deg, rgba(219, 24, 193, 0.05) 0%, rgba(0, 106, 230, 0.05) 100%);
        border-radius: 24px;
      }
      .zia-container {
        max-width: 1280px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1fr;
        align-items: center;
        gap: 80px;
        padding: 70px 64px;
        width: 100%;
      }
      .zia-left {
        display: flex;
        justify-content: center;
      }
      .zia-window {
        width: 516px;
        height: 358px;
        border-radius: 16px;
        overflow: hidden;
        background: #1a1a2e;
        border: 1px solid rgba(255,255,255,0.08);
        display: flex;
        flex-direction: column;
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
      }
      [data-theme="light"] .zia-window {
        background: #ffffff;
        border-color: rgba(0,0,0,0.1);
      }
      .zia-section:hover .zia-window {
        transform: scale(1.02) translateY(-10px);
      }
      .zia-window-bar {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 12px 16px;
        background: rgba(255,255,255,0.04);
        border-bottom: 1px solid rgba(255,255,255,0.06);
      }
      [data-theme="light"] .zia-window-bar {
        background: #f5f5f7;
        border-bottom-color: rgba(0,0,0,0.06);
      }
      .zia-window-dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
      }
      .zia-window-body {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 20px;
      }
      .zia-typing-text {
        font-size: 20px;
        font-weight: 500;
        font-family: 'Inter', sans-serif;
        background: linear-gradient(270deg, #DB18C1 0%, #006AE6 100%);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        white-space: nowrap;
        min-height: 28px;
      }
      .zia-typing-text + .zia-input-wrap {
        margin-top: 20px;
      }
      .zia-input-wrap {
        width: 90%;
        max-width: 420px;
        position: relative;
        display: flex;
        align-items: center;
        background: #fff;
        border: 1px solid transparent;
        border-radius: 12px;
        padding: 10px 12px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        background-image: linear-gradient(#fff, #fff), linear-gradient(180deg, rgba(219, 24, 193, 0.8) 0%, rgba(0, 106, 230, 0.8) 100%);
        background-origin: border-box;
        background-clip: padding-box, border-box;
        transition: box-shadow 0.3s;
      }
      :root:not([data-theme="light"]) .zia-input-wrap {
        background-image: linear-gradient(#1a1a2e, #1a1a2e), linear-gradient(180deg, rgba(219, 24, 193, 0.8) 0%, rgba(0, 106, 230, 0.8) 100%);
        box-shadow: 0 2px 12px rgba(0,0,0,0.2);
      }
      .zia-input-wrap:focus-within {
        box-shadow: 0 4px 24px rgba(219, 24, 193, 0.15), 0 2px 12px rgba(0, 106, 230, 0.1);
      }
      .zia-input {
        flex: 1;
        border: none;
        outline: none;
        background: transparent;
        font-size: 14px;
        font-family: 'Inter', sans-serif;
        color: var(--text);
      }
      .zia-input::placeholder { color: #9ca3af; }
      :root:not([data-theme="light"]) .zia-input { color: #e6e6ef; }
      :root:not([data-theme="light"]) .zia-input::placeholder { color: #6b7280; }
      .zia-send-btn {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        border: none;
        background: linear-gradient(180deg, #DB18C1 0%, #006AE6 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        flex-shrink: 0;
        transform: rotate(45deg);
        transition: transform 0.2s, box-shadow 0.2s;
      }
      .zia-send-btn:hover {
        transform: rotate(45deg) scale(1.08);
        box-shadow: 0 4px 16px rgba(219, 24, 193, 0.3);
      }
      .zia-right {
        text-align: left;
      }
      .zia-title {
        font-size: 48px;
        font-weight: 800;
        color: var(--text);
        margin-bottom: 20px;
        line-height: 1.1;
        letter-spacing: -0.02em;
        white-space: nowrap;
      }
      .zia-title span {
        background: linear-gradient(270deg, #DB18C1 0%, #006AE6 100%);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
      }
      :root:not([data-theme="light"]) .zia-title span {
        background: none;
        -webkit-text-fill-color: #fff;
        color: #fff;
      }
      .zia-subtitle {
        font-size: 20px;
        color: var(--text-muted);
        margin-bottom: 36px;
        line-height: 1.6;
        max-width: 480px;
        margin-left: 0;
      }
      :root:not([data-theme="light"]) .zia-subtitle {
        color: rgb(255 255 255 / 77%);
      }
      .zia-cta {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        padding: 14px 40px;
        border-radius: 24px;
        font-size: 16px;
        font-weight: 700;
        color: #fff;
        background: linear-gradient(270deg, #DB18C1 0%, #006AE6 100%);
        text-decoration: none;
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        box-shadow: 0 8px 24px rgba(219, 24, 193, 0.15);
      }
      #zia-section .zia-cta {
        background: linear-gradient(135deg, #0058ff 40%, #3c50ff 30%, #0fd095 100%);
      }
      #zia-section .zia-title span,
      [data-theme="light"] #zia-section .zia-title span,
      :root:not([data-theme="light"]) #zia-section .zia-title span {
        background: linear-gradient(135deg, #0058ff 40%, #3c50ff 30%, #0fd095 100%);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        color: transparent;
      }
      :root:not([data-theme="light"]) #zia-section .llm-diagram text[fill="#1e1b4b"],
      :root:not([data-theme="light"]) #zia-section .llm-diagram g[fill="#1e1b4b"] text {
        fill: #e6e8ec;
      }
      :root:not([data-theme="light"]) #zia-section .llm-diagram rect[fill="#ffffff"] {
        fill: #1a1a2e;
      }
      :root:not([data-theme="light"]) #zia-section .llm-diagram text[fill="#a399c2"] {
        fill: #c7ccde;
      }
      .zia-cta:hover {
        transform: translateY(-4px);
        box-shadow: 0 16px 40px rgba(219, 24, 193, 0.25);
        filter: brightness(1.1);
      }
      :root:not([data-theme="light"]) .zia-section {
        background: transparent !important;
      }

      #zia-section .zia-container,
      [data-theme="light"] #zia-section .zia-container,
      :root:not([data-theme="light"]) #zia-section .zia-container {
        background: linear-gradient(135deg, rgba(59, 130, 246, 0.08), rgba(99, 102, 241, 0.04));
        border: 1px solid var(--border);
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), background 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease;
      }
      #zia-section .zia-container:hover,
      [data-theme="light"] #zia-section .zia-container:hover,
      :root:not([data-theme="light"]) #zia-section .zia-container:hover {
        transform: translateY(-4px);
        border-color: rgba(124, 58, 237, 0.25);
        /* box-shadow: 0 20px 50px rgba(0, 88, 255, 0.12); */
        background: linear-gradient(135deg, rgba(0, 88, 255, 0.1) 40%, rgba(60, 80, 255, 0.1) 30%, rgba(15, 208, 149, 0.1) 100%);
      }

      .llm-diagram { display: block; width: 100%; max-width: 1030px; margin: 0 auto; }

      @media (max-width: 992px) {
        .zia-section { height: auto; padding: 80px 24px; margin-top: 96px; }
        .zia-container { grid-template-columns: 1fr; gap: 56px; text-align: center; padding: 64px 40px; }
        #zia-section .zia-container { gap: 56px !important; padding: 48px 16px !important; }
        .zia-right { text-align: center; order: 1; }
        .zia-left { order: 2; display: flex; justify-content: center; align-items: center; width: 100%; overflow: visible; }
        .zia-title { font-size: 36px; white-space: normal; }
        .zia-subtitle { margin-left: auto; margin-right: auto; }
        .zia-window { width: 100%; max-width: 516px; height: 340px; }
        #zia-section .llm-diagram { transform: scale(1.2) !important; transform-origin: center !important; margin: 0 auto !important; max-width: 100% !important; width: 100% !important; }
      }
      @media (max-width: 768px) {
        #zia-section .llm-diagram { transform: scale(1.15) !important; }
        #zia-section .zia-container { padding: 40px 12px !important; }
      }
      @media (max-width: 480px) {
        #zia-section .llm-diagram { transform: scale(1.08) !important; }
        #zia-section .zia-container { padding: 32px 8px !important; }
      }
      @media (max-width: 768px) {
        .zia-section { padding: 64px 16px; margin-top: 80px; }
        .zia-container { gap: 48px; padding: 64px 24px; border-radius: 20px; }
        .zia-title { font-size: 30px; margin-bottom: 14px; }
        .zia-subtitle { font-size: 16px; margin-bottom: 28px; }
        .zia-cta { padding: 12px 28px; font-size: 15px; }
        .zia-window { height: 300px; border-radius: 14px; }
        .zia-window-bar { padding: 10px 14px; }
        .zia-window-dot { width: 10px; height: 10px; }
        .zia-window-body { gap: 14px; padding: 0 16px; }
        .zia-typing-text { font-size: 16px; white-space: normal; text-align: center; min-height: 24px; }
        .zia-typing-text + .zia-input-wrap { margin-top: 12px; }
        .zia-input-wrap { width: 100%; max-width: 360px; padding: 8px 10px; }
        .zia-input { font-size: 13px; }
        .zia-send-btn { width: 32px; height: 32px; }
      }
      @media (max-width: 480px) {
        .zia-section { padding: 48px 12px; margin-top: 64px; }
        .zia-container { padding: 56px 16px; gap: 40px; border-radius: 16px; }
        .zia-title { font-size: 26px; letter-spacing: -0.01em; }
        .zia-subtitle { font-size: 14.5px; margin-bottom: 22px; }
        .zia-cta { padding: 11px 24px; font-size: 14px; border-radius: 20px; }
        .zia-window { height: 260px; }
        .zia-window-body { gap: 10px; padding: 0 12px; }
        .zia-window-body svg { width: 40px; height: 40px; }
        .zia-typing-text { font-size: 14px; }
        .zia-input-wrap { padding: 6px 8px; border-radius: 10px; }
        .zia-input { font-size: 12.5px; }
        .zia-send-btn { width: 30px; height: 30px; }
        .zia-send-btn svg { width: 15px; height: 15px; }
      }
    </style>

    <div class="zia-container">
      <div class="zia-right">
        <h2 class="zia-title">Designing <span>for Zia</span></h2>
        <p class="zia-subtitle">Patterns and components for AI-powered experiences in UEMS.</p>
        <a href="#" class="zia-cta">Explore Zia patterns</a>
      </div>
      <div class="zia-left">
        <div class="zia-window">
          <div class="zia-window-bar">
            <span class="zia-window-dot" style="background:#ff5f57;"></span>
            <span class="zia-window-dot" style="background:#febc2e;"></span>
            <span class="zia-window-dot" style="background:#28c840;"></span>
          </div>
          <div class="zia-window-body">
