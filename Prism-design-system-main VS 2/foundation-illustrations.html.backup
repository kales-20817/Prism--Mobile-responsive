                    <circle cx="221.047" cy="105.707" r="3.35532" stroke="#E56470" stroke-width="1.83017"/>
                    <circle cx="57.1911" cy="185.394" r="1.96616" stroke="#E56470" stroke-width="1.83017"/>
                  </svg>
                </div>
                <div class="illus-type-body">
                  <div class="illus-type-name">Spot illustrations</div>
                  <div class="illus-type-desc">One clear concept or outcome. Centered compositions used in empty states, success moments, and error recovery.</div>
                  <div class="illus-type-sub">Use for</div>
                  <ul class="illus-type-list">
                    <li>Empty states (no devices, no threats, no patches)</li>
                    <li>Patch completed &middot; Threat resolved</li>
                    <li>Policy not assigned &middot; Missing agent</li>
                    <li>Upgrade available</li>
                    <li>Success celebrations</li>
                  </ul>
                  <div class="illus-type-sub">Rules</div>
                  <ul class="illus-type-list">
                    <li>Must represent one idea only</li>
                    <li>Use centered compositions</li>
                    <li>Keep conceptual metaphor obvious</li>
                    <li>Support adjacent copy</li>
                    <li>Never replace core message text</li>
                  </ul>
                </div>
              </div>

              <!-- Low-fi workflow UI -->
              <div class="illus-type-card" id="low-fi-workflow">
                <div class="illus-type-preview">
