        <!-- Content Guidelines Do/Don't -->
        <div class="doc-section">
          <h3 id="content-guidelines" class="doc-h3">Content Guidelines<span class="h3-badge" style="background: rgba(37,99,235,0.1); color: var(--prism-violet);">Recommended</span></h3>
          <div class="do-dont-grid">
            <div class="do-card"><span class="card-label">Do</span>
              <ul class="doc-list" style="border: none; background: transparent; padding: 0;">
                <li style="border: none; background: transparent; padding-left: 20px;">Use consistent status-to-color mapping throughout the app.</li>
                <li style="border: none; background: transparent; padding-left: 20px;">Always include text label when status meaning isn't obvious.</li>
                <li style="border: none; background: transparent; padding-left: 20px;">Use Small for dense layouts (tables, lists).</li>
                <li style="border: none; background: transparent; padding-left: 20px;">Use semantic statuses consistently (Neutral=idle, Success=online, Warning=degraded, Critical=error, Info=informational).</li>
              </ul>
            </div>
            <div class="dont-card"><span class="card-label">Don't</span>
              <ul class="doc-list" style="border: none; background: transparent; padding: 0;">
                <li style="border: none; background: transparent; padding-left: 20px;">Don't use more than 5 status types in a single view.</li>
                <li style="border: none; background: transparent; padding-left: 20px;">Don't rely solely on dot color -- always include label for accessibility.</li>
                <li style="border: none; background: transparent; padding-left: 20px;">Don't use for numeric counts (use Counter).</li>
                <li style="border: none; background: transparent; padding-left: 20px;">Don't mix sizes within same table column.</li>
              </ul>
            </div>
          </div>
        </div>

