        <script>
          (function(){
            const sel = {
              status: document.getElementById('si-pg-status'),
              size: document.getElementById('si-pg-size'),
              label: document.getElementById('si-pg-label'),
              hover: document.getElementById('si-pg-hover'),
              preview: document.getElementById('si-pg-preview'),
              code: document.getElementById('si-pg-code'),
              copy: document.getElementById('si-pg-copy-btn')
            };
            if (!sel.preview) return;

            function render(){
              const status = sel.status.value;
              const size = sel.size.value;
              const label = sel.label.value || '';
              const hover = sel.hover.value === 'on';
              const classes = ['si-demo', 'si-' + size, 'si-' + status];
              if (hover) classes.push('si-hover-' + status);
              sel.preview.className = classes.join(' ');
              sel.preview.innerHTML = '<div class="si-dot"></div><span></span>';
              sel.preview.querySelector('span').textContent = label;
              const classAttr = classes.join(' ');
              const html = '<span class="tk-punct">&lt;</span><span class="tk-tag">div</span> <span class="tk-attr">class</span><span class="tk-punct">=</span><span class="tk-str">"' + classAttr + '"</span><span class="tk-punct">&gt;</span>\n  <span class="tk-punct">&lt;</span><span class="tk-tag">div</span> <span class="tk-attr">class</span><span class="tk-punct">=</span><span class="tk-str">"si-dot"</span><span class="tk-punct">&gt;&lt;/</span><span class="tk-tag">div</span><span class="tk-punct">&gt;</span>\n  <span class="tk-punct">&lt;</span><span class="tk-tag">span</span><span class="tk-punct">&gt;</span>' + label.replace(/</g,'&lt;').replace(/>/g,'&gt;') + '<span class="tk-punct">&lt;/</span><span class="tk-tag">span</span><span class="tk-punct">&gt;</span>\n<span class="tk-punct">&lt;/</span><span class="tk-tag">div</span><span class="tk-punct">&gt;</span>';
              sel.code.innerHTML = html;
            }
            sel.status.addEventListener('change', render);
            sel.size.addEventListener('change', render);
            sel.label.addEventListener('input', render);
            sel.hover.addEventListener('change', render);
            sel.copy.addEventListener('click', () => {
              const plain = sel.code.innerText;
              navigator.clipboard.writeText(plain).then(() => {
                const orig = sel.copy.innerHTML;
                sel.copy.innerHTML = '<svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg> Copied';
                setTimeout(() => { sel.copy.innerHTML = orig; }, 1800);
              });
            });
            render();
          })();
        </script>

