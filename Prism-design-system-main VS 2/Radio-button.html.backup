    <main class="main-panel">
      <div class="page-header-area">
        <h1 class="page-title">Radio Button</h1>
        <p class="page-desc">A Radio Group presents a set of mutually exclusive options where users can select exactly one. It wraps individual Radio Button items under a shared group label, optional help text, and coordinated validation states.</p>
        <nav class="content-tabs">
          <button class="tab-item active">Overview</button>
          <button class="tab-item">Style</button>
          <button class="tab-item">Usage</button>
          <button class="tab-item">Code</button>
          <button class="tab-item">Accessibility</button>
        </nav>
      </div>

      <div class="main-content-area">
        <div class="main-content-inner">

        <!-- ========== OVERVIEW ========== -->
        <div class="tab-content" id="tab-overview">
          <h3 id="anatomy" class="doc-h3">Anatomy</h3>
          <p class="doc-section-subtitle">The Radio Group is composed of a group label, individual radio buttons, and optional help text.</p>

          <!-- Left layout anatomy -->
          <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Default &#8212; Left layout (web)</h4>
          <div class="anatomy-diagram">
            <div style="display:flex;flex-direction:column;gap:20px;align-items:center;padding:20px 0;">
              <!-- Group label row -->
              <div style="position:relative;display:flex;align-items:center;gap:8px;">
                <div style="position:absolute;right:calc(100% + 6px);top:50%;transform:translateY(-50%);display:flex;align-items:center;gap:6px;"><span class="anat-marker-inline">1</span><div style="width:28px; height:2px; background:#2563eb;"></div></div>
                <span style="font-size:15px;font-weight:600;color:var(--prism-text);">Notification frequency</span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color:var(--prism-text-muted);"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
              </div>
              <!-- Radio options row -->
              <div style="position:relative;display:flex;gap:24px;align-items:center;padding-left:4px;">
                <div style="position:absolute;right:calc(100% + 6px);top:50%;transform:translateY(-50%);display:flex;align-items:center;gap:6px;"><span class="anat-marker-inline">2</span><div style="width:28px; height:2px; background:#2563eb;"></div></div>
                <label class="radio-item radio-size-m" style="cursor:default;">
                  <input type="radio" name="anat-demo" checked disabled>
                  <span class="radio-control"></span>
                  <span class="radio-label">Real-time</span>
                </label>
                <label class="radio-item radio-size-m" style="cursor:default;">
                  <input type="radio" name="anat-demo" disabled>
                  <span class="radio-control"></span>
                  <span class="radio-label">Daily digest</span>
                </label>
                <label class="radio-item radio-size-m" style="cursor:default;">
                  <input type="radio" name="anat-demo" disabled>
                  <span class="radio-control"></span>
                  <span class="radio-label">Weekly summary</span>
                </label>
              </div>
              <!-- Help text row -->
              <div style="position:relative;display:flex;align-items:center;gap:6px;padding-left:4px;">
                <div style="position:absolute;right:calc(100% + 6px);top:50%;transform:translateY(-50%);display:flex;align-items:center;gap:6px;"><span class="anat-marker-inline">3</span><div style="width:28px; height:2px; background:#2563eb;"></div></div>
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color:var(--prism-text-muted);"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                <span style="font-size:13px;color:var(--prism-text-muted);">We'll send alerts based on this preference.</span>
              </div>
            </div>
          </div>
          <div class="anat-legend" style="margin-bottom:40px;">
            <div class="anat-legend-item"><span class="anat-marker-inline">1</span><div><strong>Group Label</strong><span>Title for the option set. Paired with an optional info (tooltip) icon.</span></div></div>
            <div class="anat-legend-item"><span class="anat-marker-inline">2</span><div><strong>Radio Button</strong><span>Individual selectable option. Consists of a radio control + label.</span></div></div>
            <div class="anat-legend-item"><span class="anat-marker-inline">3</span><div><strong>Help Text</strong><span>Supplementary guidance below the options. Uses Text/Text-Secondary in default state, Text/Text-Error in error state.</span></div></div>
          </div>

          <!-- Top layout anatomy -->
          <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Special case &#8212; Top layout (constrained space / long labels)</h4>
          <div class="anatomy-diagram">
            <div style="display:flex;flex-direction:column;gap:14px;align-items:center;padding:20px 0;">
              <div style="position:relative;display:flex;align-items:center;">
                <div style="position:absolute;right:calc(100% + 6px);top:50%;transform:translateY(-50%);display:flex;align-items:center;gap:6px;"><span class="anat-marker-inline">1</span><div style="width:28px; height:2px; background:#2563eb;"></div></div>
                <span style="font-size:15px;font-weight:600;color:var(--prism-text);">Select your preferred data export format</span>
              </div>
              <div style="position:relative;display:flex;flex-direction:column;gap:14px;align-items:flex-start;">
                <div style="position:absolute;right:calc(100% + 6px);top:14px;display:flex;align-items:center;gap:6px;"><span class="anat-marker-inline">2</span><div style="width:28px; height:2px; background:#2563eb;"></div></div>
                <label class="radio-item radio-size-m" style="cursor:default;">
                  <input type="radio" name="anat-top" checked disabled>
                  <span class="radio-control"></span>
                  <span class="radio-label">CSV &#8212; Comma-separated values</span>
                </label>
                <label class="radio-item radio-size-m" style="cursor:default;">
                  <input type="radio" name="anat-top" disabled>
                  <span class="radio-control"></span>
                  <span class="radio-label">JSON &#8212; JavaScript Object Notation</span>
                </label>
                <label class="radio-item radio-size-m" style="cursor:default;">
                  <input type="radio" name="anat-top" disabled>
                  <span class="radio-control"></span>
                  <span class="radio-label">XML &#8212; Extensible Markup Language</span>
                </label>
              </div>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div style="margin-bottom:64px;">
            <h2 id="live-demo" class="doc-section-title" style="margin-bottom:8px;">Preview</h2>
            <p class="doc-section-subtitle" style="margin-bottom:28px;">Explore radio group variants across sizes, states, and layouts.</p>
            <div class="demo-container">
<div class="demo-canvas">
                <!-- Default left layout -->
                <div style="display:flex;flex-direction:column;gap:8px;align-items:flex-start;">
                  <span style="font-size:14px;font-weight:600;color:var(--prism-text);">Size M &#8212; Left layout (default)</span>
                  <div style="display:flex;gap:20px;align-items:center;">
                    <label class="radio-item radio-size-m"><input type="radio" name="demo-left" value="a" checked><span class="radio-control"></span><span class="radio-label">Option A</span></label>
                    <label class="radio-item radio-size-m"><input type="radio" name="demo-left" value="b"><span class="radio-control"></span><span class="radio-label">Option B</span></label>
                    <label class="radio-item radio-size-m"><input type="radio" name="demo-left" value="c"><span class="radio-control"></span><span class="radio-label">Option C</span></label>
                  </div>
                </div>
                <!-- Size row -->
                <div style="display:flex;gap:32px;align-items:flex-end;flex-wrap:wrap;">
                  <div style="display:flex;flex-direction:column;gap:6px;align-items:center;">
                    <label class="radio-item radio-size-s"><input type="radio" name="demo-s" checked><span class="radio-control"></span><span class="radio-label">Small</span></label>
                  </div>
                  <div style="display:flex;flex-direction:column;gap:6px;align-items:center;">
                    <label class="radio-item radio-size-m"><input type="radio" name="demo-m" checked><span class="radio-control"></span><span class="radio-label">Medium</span></label>
                  </div>
                  <div style="display:flex;flex-direction:column;gap:6px;align-items:center;">
                    <label class="radio-item radio-size-l"><input type="radio" name="demo-l" checked><span class="radio-control"></span><span class="radio-label">Large</span></label>
                  </div>
                </div>
                <!-- States row -->
                <div style="display:flex;gap:32px;align-items:flex-start;flex-wrap:wrap;">
                  <div style="display:flex;flex-direction:column;gap:6px;">
                    <span style="font-size:12px;font-weight:600;color:var(--prism-text-muted);text-transform:uppercase;letter-spacing:0.05em;">Disabled</span>
                    <label class="radio-item radio-size-m disabled"><input type="radio" name="demo-dis" disabled checked><span class="radio-control"></span><span class="radio-label" style="opacity:0.5;">Disabled</span></label>
                  </div>
                  <div style="display:flex;flex-direction:column;gap:6px;">
                    <span style="font-size:12px;font-weight:600;color:var(--prism-text-muted);text-transform:uppercase;letter-spacing:0.05em;">Error</span>
                    <label class="radio-item radio-size-m error"><input type="radio" name="demo-err"><span class="radio-control"></span><span class="radio-label">Error state</span></label>
                    <span class="radio-help-text error">Please select an option.</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="doc-section">
            <h3 id="content-guidelines" class="doc-h3">Content Guidelines<span class="h3-badge" style="background:rgba(37,99,235,0.1);color:var(--prism-violet);">Recommended</span></h3>
            <div class="do-dont-grid">
              <div class="do-card"><span class="card-label">Do</span><ul>
                <li>Use a concise group label that frames the decision.</li>
                <li>Always pre-select a sensible default when one exists.</li>
                <li>Keep option labels to 1&#8211;4 words.</li>
                <li>Group semantically related options together.</li>
                <li>Show an error state + help text together.</li>
              </ul></div>
              <div class="dont-card"><span class="card-label">Don't</span><ul>
                <li>Leave the group unlabelled.</li>
                <li>Leave all options unselected if a default makes sense.</li>
                <li>Write full sentences as radio labels.</li>
                <li>Mix unrelated options in a single group.</li>
                <li>Show only a red border without explaining what went wrong.</li>
              </ul></div>
            </div>
          </div>
        </div>

        <!-- ========== STYLE ========== -->
        <div class="tab-content" id="tab-style" style="display:none;padding-top:32px;">
          <h2 id="style-overview" class="doc-section-title">Style</h2>
          <p class="doc-section-subtitle">Design tokens, sizing, spacing, and state mappings that define the Radio Button's visual language.</p>

          <div class="doc-section">
            <h2 id="variants" class="doc-section-title">Variants</h2>
            <p class="doc-section-subtitle">The full component set covers Label Position &times; Size &times; State &times; Direction.</p>
            <table class="size-table">
              <thead><tr><th>Axis</th><th>Values</th><th>Description</th></tr></thead>
              <tbody>
                <tr><td><strong>Label Position</strong></td><td><code>Left</code> (default), <code>Top</code></td><td>Left = horizontal row (web default). Top = vertical stack for constrained space or long labels.</td></tr>
                <tr><td><strong>Size</strong></td><td><code>S</code>, <code>M</code>, <code>L</code>, <code>Mobile</code></td><td>Controls radio control dimensions, label font size, and gap.</td></tr>
                <tr><td><strong>State</strong></td><td><code>Default</code>, <code>Hover</code>, <code>Focused</code>, <code>Disabled</code>, <code>Error</code></td><td>Validation or interaction state for the group or individual items.</td></tr>
                <tr><td><strong>Direction</strong></td><td><code>LTR</code>, <code>RTL</code></td><td>Reading order. RTL controlled via RTL Layout variable collection.</td></tr>
              </tbody>
            </table>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h2 id="variant-matrix" class="doc-section-title">Variant Matrix</h2>
            <p class="doc-section-subtitle">Comprehensive variant counts across all combinations.</p>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:24px;">
              <div style="padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;text-align:center;">
                <div style="font-size:36px;font-weight:700;color:var(--prism-violet);">36</div>
                <div style="font-size:14px;font-weight:600;color:var(--prism-text);margin-top:8px;">Radio Group Variants</div>
                <div style="font-size:12px;color:var(--prism-text-muted);margin-top:4px;">2 positions &times; 3 sizes &times; 3 states &times; 2 directions</div>
              </div>
              <div style="padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;text-align:center;">
                <div style="font-size:36px;font-weight:700;color:var(--prism-violet);">80</div>
                <div style="font-size:14px;font-weight:600;color:var(--prism-text);margin-top:8px;">Radio Button Variants</div>
                <div style="font-size:12px;color:var(--prism-text-muted);margin-top:4px;">4 sizes &times; 5 states &times; 2 selection &times; 2 directions</div>
              </div>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h2 id="states" class="doc-section-title">States</h2>
            <p class="doc-section-subtitle">Radio buttons communicate interaction state through visual cues tied to design tokens.</p>
            <table class="size-table">
              <thead><tr><th>State</th><th>Visual Cue</th><th>Token</th></tr></thead>
              <tbody>
                <tr><td><strong>Default</strong></td><td>Blue filled circle on selected item</td><td><code>Background/BG-Button-Primary</code></td></tr>
                <tr><td><strong>Hover</strong></td><td>Slightly deeper border on unselected</td><td><code>Border/Border-Accent</code></td></tr>
                <tr><td><strong>Focused</strong></td><td>Focus ring around radio control</td><td><code>Border/Border-Accent-Focus</code></td></tr>
                <tr><td><strong>Disabled</strong></td><td>Greyed-out control + label</td><td><code>Background/BG-Disabled</code>, <code>Text/Text-Disabled</code></td></tr>
                <tr><td><strong>Error</strong></td><td>Red border + red help text</td><td><code>Border/Border-Error</code>, <code>Text/Text-Error</code></td></tr>
              </tbody>
            </table>
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:14px;margin-top:24px;">
              <div style="padding:20px 12px;border-radius:14px;background:var(--prism-surface);border:1px solid var(--prism-border);text-align:center;">
                <label class="radio-item radio-size-m" style="justify-content:center;cursor:default;"><input type="radio" name="state-def" checked disabled><span class="radio-control"></span><span class="radio-label">Selected</span></label>
                <div style="font-size:13px;font-weight:600;color:var(--prism-text);margin-top:12px;">Default</div>
              </div>
              <div style="padding:20px 12px;border-radius:14px;background:var(--prism-surface);border:1px solid var(--prism-border);text-align:center;">
                <label class="radio-item radio-size-m" style="justify-content:center;cursor:default;"><input type="radio" name="state-hov" disabled><span class="radio-control show-hover"></span><span class="radio-label">Hover</span></label>
                <div style="font-size:13px;font-weight:600;color:var(--prism-text);margin-top:12px;">Hover</div>
              </div>
              <div style="padding:20px 12px;border-radius:14px;background:var(--prism-surface);border:1px solid var(--prism-border);text-align:center;">
                <label class="radio-item radio-size-m" style="justify-content:center;cursor:default;"><input type="radio" name="state-foc" disabled><span class="radio-control show-focus"></span><span class="radio-label">Focus</span></label>
                <div style="font-size:13px;font-weight:600;color:var(--prism-text);margin-top:12px;">Focused</div>
              </div>
              <div style="padding:20px 12px;border-radius:14px;background:var(--prism-surface);border:1px solid var(--prism-border);text-align:center;">
                <label class="radio-item radio-size-m disabled" style="justify-content:center;cursor:default;"><input type="radio" name="state-dis" disabled><span class="radio-control"></span><span class="radio-label" style="opacity:0.5;">Disabled</span></label>
                <div style="font-size:13px;font-weight:600;color:var(--prism-text);margin-top:12px;">Disabled</div>
              </div>
              <div style="padding:20px 12px;border-radius:14px;background:var(--prism-surface);border:1px solid var(--prism-border);text-align:center;">
                <label class="radio-item radio-size-m error" style="justify-content:center;cursor:default;"><input type="radio" name="state-err" disabled><span class="radio-control"></span><span class="radio-label">Error</span></label>
                <div style="font-size:13px;font-weight:600;color:var(--prism-text);margin-top:12px;">Error</div>
              </div>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h2 id="sizes" class="doc-section-title">Sizes</h2>
            <p class="doc-section-subtitle">Four sizes to fit different layout contexts from dense data tables to mobile touch targets.</p>
            <table class="size-table">
              <thead><tr><th>Size</th><th>Radio Control</th><th>Label Font</th><th>Use Case</th><th>Preview</th></tr></thead>
              <tbody>
                <tr><td><strong>Small (S)</strong></td><td>14 &times; 14 px</td><td>body/Small</td><td>Dense layouts, data tables</td><td><label class="radio-item radio-size-s" style="cursor:default;"><input type="radio" name="sz-s" checked disabled><span class="radio-control"></span><span class="radio-label">Label</span></label></td></tr>
                <tr><td><strong>Medium (M)</strong></td><td>16 &times; 16 px</td><td>body/Default</td><td>Standard forms (default)</td><td><label class="radio-item radio-size-m" style="cursor:default;"><input type="radio" name="sz-m" checked disabled><span class="radio-control"></span><span class="radio-label">Label</span></label></td></tr>
                <tr><td><strong>Large (L)</strong></td><td>20 &times; 20 px</td><td>body/Large</td><td>Comfortable / onboarding flows</td><td><label class="radio-item radio-size-l" style="cursor:default;"><input type="radio" name="sz-l" checked disabled><span class="radio-control"></span><span class="radio-label">Label</span></label></td></tr>
                <tr><td><strong>Mobile</strong></td><td>20 &times; 20 px</td><td>body/Large</td><td>Touch targets on mobile viewports</td><td><label class="radio-item radio-size-mobile" style="cursor:default;"><input type="radio" name="sz-mob" checked disabled><span class="radio-control"></span><span class="radio-label">Label</span></label></td></tr>
              </tbody>
            </table>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="design-tokens" class="doc-h3">Design Tokens<span class="h3-badge" style="background:rgba(37,99,235,0.1);color:var(--prism-violet);">Tokens</span></h3>
            <table class="size-table">
              <thead><tr><th>Token</th><th>Role</th></tr></thead>
              <tbody>
                <tr><td><code>Background/BG-Button-Primary</code></td><td>Selected radio fill (blue dot)</td></tr>
                <tr><td><code>Background/BG-Disabled</code></td><td>Disabled radio background</td></tr>
                <tr><td><code>Border/Border-Primary</code></td><td>Unselected radio border</td></tr>
                <tr><td><code>Border/Border-Accent</code></td><td>Hover radio border</td></tr>
                <tr><td><code>Border/Border-Accent-Focus</code></td><td>Focus ring</td></tr>
                <tr><td><code>Border/Border-Error</code></td><td>Error state border</td></tr>
                <tr><td><code>Border/Border-Disabled</code></td><td>Disabled radio border</td></tr>
                <tr><td><code>Text/Text-Primary</code></td><td>Group label and option label (default)</td></tr>
                <tr><td><code>Text/Text-Secondary</code></td><td>Help text (default)</td></tr>
                <tr><td><code>Text/Text-Disabled</code></td><td>Label colour in disabled state</td></tr>
                <tr><td><code>Text/Text-Error</code></td><td>Help text in error state</td></tr>
                <tr><td><code>Border/Icon/Icon-Primary</code></td><td>Info icon (default)</td></tr>
              </tbody>
            </table>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="spacing-tokens" class="doc-h3">Spacing Tokens</h3>
            <table class="size-table">
              <thead><tr><th>Token</th><th>Value</th><th>Usage</th></tr></thead>
              <tbody>
                <tr><td><code>spacing/8px</code></td><td>8px</td><td>Gap between radio control and label</td></tr>
                <tr><td><code>spacing/12px</code></td><td>12px</td><td>Gap between radio options (S/M)</td></tr>
                <tr><td><code>spacing/16px</code></td><td>16px</td><td>Gap between radio options (L)</td></tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- ========== USAGE ========== -->
        <div class="tab-content" id="tab-usage" style="display:none;padding-top:32px;">
          <div class="doc-section">
            <h2 id="when-to-use" class="doc-section-title">When and Where to Use</h2>
            <p class="doc-section-subtitle">Radio groups let users choose exactly one option from a small, visible set of mutually exclusive choices.</p>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:24px;">
              <div style="padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;">
                <h3 style="font-size:15px;font-weight:600;color:var(--prism-text);margin-bottom:16px;display:flex;align-items:center;gap:8px;"><svg width="20" height="20" fill="none" stroke="#2563eb" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>When to use</h3>
                <ul class="doc-list" style="border:none;background:transparent;padding-left:20px;font-size:14.5px;">
                  <li style="border:none;background:transparent;margin-bottom:8px;">When the user must choose <strong>exactly one</strong> option from a small, finite list (2&#8211;6 options).</li>
                  <li style="border:none;background:transparent;margin-bottom:8px;">When all options need to be visible at once without interaction.</li>
                  <li style="border:none;background:transparent;">For settings or configuration screens where the full set of choices is informative.</li>
                </ul>
              </div>
              <div style="padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;">
                <h3 style="font-size:15px;font-weight:600;color:var(--prism-text);margin-bottom:16px;display:flex;align-items:center;gap:8px;"><svg width="20" height="20" fill="none" stroke="#e42527" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>When NOT to use</h3>
                <ul class="doc-list" style="border:none;background:transparent;padding-left:20px;font-size:14.5px;">
                  <li style="border:none;background:transparent;margin-bottom:8px;"><strong>Multiple selections</strong> &#8212; use Checkbox Group.</li>
                  <li style="border:none;background:transparent;margin-bottom:8px;"><strong>Long lists (7+)</strong> &#8212; use Select Box to save vertical space.</li>
                  <li style="border:none;background:transparent;margin-bottom:8px;"><strong>Binary yes/no with immediate effect</strong> &#8212; use Toggle.</li>
                  <li style="border:none;background:transparent;"><strong>Yes/No inside a form</strong> &#8212; a single Checkbox may suffice.</li>
                </ul>
              </div>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h2 id="layout-guidance" class="doc-section-title">Layout Guidance</h2>
            <p class="doc-section-subtitle">Choose the right layout based on available space and label length.</p>
            <table class="size-table">
              <thead><tr><th>Layout</th><th>Default?</th><th>Description</th></tr></thead>
              <tbody>
                <tr><td><strong>Left</strong></td><td>Yes (web)</td><td>Options are laid out horizontally in a row. Default for all standard responsive web layouts.</td></tr>
                <tr><td><strong>Top</strong></td><td>Special case</td><td>Options stack vertically below the group label. Use only when horizontal space is severely constrained, for mobile viewports, or when options have long labels that wrap.</td></tr>
              </tbody>
            </table>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h2 id="detailed-guidelines" class="doc-section-title">Complete Do's and Don'ts</h2>
            <p class="doc-section-subtitle">Guidelines for effective radio button usage.</p>
            <div class="do-dont-grid">
              <div class="do-card"><span class="card-label">Do</span><ul>
                <li><strong>Concise group label:</strong> Frame the decision clearly with a short group label.</li>
                <li><strong>Pre-select a default:</strong> Always pre-select a sensible default when one exists.</li>
                <li><strong>Use Left layout:</strong> Use the default Left layout for standard web forms.</li>
                <li><strong>Error + help text:</strong> Show an error state and help text together.</li>
                <li><strong>Short labels:</strong> Keep option labels to 1&#8211;4 words.</li>
                <li><strong>Semantic grouping:</strong> Group semantically related options together.</li>
              </ul></div>
              <div class="dont-card"><span class="card-label">Don't</span><ul>
                <li><strong>No unlabelled groups:</strong> Don't leave the group unlabelled.</li>
                <li><strong>No empty selection:</strong> Don't leave all options unselected if a default makes sense.</li>
                <li><strong>Avoid Top layout:</strong> Switch to Top layout only when labels are very long or horizontal space is unavailable.</li>
                <li><strong>No red-only errors:</strong> Don't show only a red border without explaining what went wrong.</li>
                <li><strong>No full sentences:</strong> Don't write full sentences as radio labels.</li>
                <li><strong>No mixed groups:</strong> Don't mix unrelated options in a single group.</li>
              </ul></div>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h2 id="related" class="doc-section-title">Related</h2>
            <p class="doc-section-subtitle">Components that complement or can be used instead of the Radio Button.</p>
            <div class="related-grid">
              <a href="Checkbox.html" class="related-chip"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg> Checkbox</a>
              <a href="Select.html" class="related-chip"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg> Select Box</a>
              <a href="Switch.html" class="related-chip"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="5" width="22" height="14" rx="7"/><circle cx="8" cy="12" r="3"/></svg> Toggle</a>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h2 id="references" class="doc-section-title">References</h2>
            <p class="doc-section-subtitle">Design tokens and resources for implementing the Radio Button component.</p>
            <ul class="doc-list">
              <li><strong>Figma Node (Group):</strong> <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">17901:5086</code> &#8212; Radio Group frame</li>
              <li><strong>Figma Node (Button):</strong> <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">15771:12129</code> &#8212; Radio Button variants</li>
