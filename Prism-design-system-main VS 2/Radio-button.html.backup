        <!-- ========== CODE ========== -->
        <div class="tab-content" id="tab-code" style="display:none;padding-top:32px;">
          <h2 id="live-demo-code" class="doc-section-title">Live demo (Code)</h2>
          <p class="doc-section-subtitle">Configure the Radio Group component and view generated JSX.</p>
          <div class="code-playground">
            <div class="cp-toolbar">
              <div class="cp-control-group"><label class="cp-label">Label Position</label><select class="cp-select" id="pg-layout"><option value="left">Left (default)</option><option value="top">Top</option></select></div>
              <div class="cp-control-group"><label class="cp-label">Size</label><select class="cp-select" id="pg-size"><option value="S">Small</option><option value="M" selected>Medium</option><option value="L">Large</option><option value="Mobile">Mobile</option></select></div>
              <div class="cp-control-group"><label class="cp-label">State</label><select class="cp-select" id="pg-state"><option value="default">Default</option><option value="error">Error</option><option value="disabled">Disabled</option></select></div>
              <div class="cp-control-group"><label class="cp-label">Options</label><select class="cp-select" id="pg-options"><option value="3" selected>3 options</option><option value="2">2 options</option><option value="4">4 options</option></select></div>
            </div>
            <div class="cp-preview" id="pg-preview-area">
              <div id="pg-radio-group"></div>
            </div>
            <div class="cp-code-header">
              <div style="font-size:13.5px;font-weight:600;color:var(--prism-text);">JSX</div>
              <button class="cp-action-btn" id="pg-copy-btn"><svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2"/></svg> Copy code</button>
            </div>
            <div class="cp-code-area" id="pg-code-output"></div>
          </div>
          <script>
          (function(){
            var els={layout:document.getElementById('pg-layout'),size:document.getElementById('pg-size'),state:document.getElementById('pg-state'),options:document.getElementById('pg-options')};
            var groupEl=document.getElementById('pg-radio-group');
            var codeOut=document.getElementById('pg-code-output');
            var copyBtn=document.getElementById('pg-copy-btn');
            var optLabels=['Option A','Option B','Option C','Option D'];
            var optValues=['a','b','c','d'];
            function esc(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
            function update(){
              var layout=els.layout.value,sz=els.size.value,st=els.state.value,count=parseInt(els.options.value);
              var sizeClass='radio-size-'+sz.toLowerCase();
              var isDisabled=st==='disabled';
              var isError=st==='error';
              var dir=layout==='top'?'column':'row';
              var gap=layout==='top'?'10px':'20px';
              var html='<div style="display:flex;flex-direction:column;gap:8px;align-items:flex-start;">';
              html+='<span style="font-size:14px;font-weight:600;color:var(--prism-text);">Notification frequency</span>';
              html+='<div style="display:flex;flex-direction:'+dir+';gap:'+gap+';flex-wrap:wrap;">';
              for(var i=0;i<count;i++){
                var checked=i===0;
                var itemClass='radio-item '+sizeClass;
                if(isDisabled)itemClass+=' disabled';
                if(isError)itemClass+=' error';
                html+='<label class="'+itemClass+'">';
                html+='<input type="radio" name="pg-demo" value="'+optValues[i]+'"'+(checked?' checked':'')+(isDisabled?' disabled':'')+'>';
                html+='<span class="radio-control"></span>';
                html+='<span class="radio-label"'+(isDisabled?' style="opacity:0.5;"':'')+'>'+optLabels[i]+'</span>';
                html+='</label>';
              }
              html+='</div>';
              if(isError)html+='<span class="radio-help-text error">Please select an option before submitting.</span>';
              else html+='<span class="radio-help-text">We\'ll send alerts based on this preference.</span>';
              html+='</div>';
              groupEl.innerHTML=html;

              // Generate JSX code
              var code='<RadioGroup\n';
              code+='  label="Notification frequency"\n';
              if(layout==='top')code+='  labelPosition="top"\n';
              if(sz!=='M')code+='  size="'+sz+'"\n';
              if(st!=='default')code+='  state="'+st+'"\n';
              code+='  defaultValue="'+optValues[0]+'"\n';
              if(isError)code+='  helpText="Please select an option before submitting."\n';
              else code+='  helpText="We\'ll send alerts based on this preference."\n';
              code+='>\n';
              for(var j=0;j<count;j++){
                code+='  <RadioButton value="'+optValues[j]+'" label="'+optLabels[j]+'" />\n';
              }
              code+='</RadioGroup>';
              codeOut.innerHTML=esc(code)
                .replace(/(&lt;\/?)(RadioGroup|RadioButton)/g,'$1<span style="color:#a78bfa;">$2</span>')
                .replace(/(label|labelPosition|size|state|defaultValue|helpText|value)=/g,'<span style="color:#38bdf8;">$1</span>=')
                .replace(/&quot;(.*?)&quot;/g,'<span style="color:#34d399;">"$1"</span>');
            }
            Object.values(els).forEach(function(e){e.addEventListener('change',update);});
            copyBtn.addEventListener('click',function(){
              var r=document.createElement('div');r.innerHTML=codeOut.innerHTML;
              navigator.clipboard.writeText(r.innerText).then(function(){
                var o=copyBtn.innerHTML;copyBtn.innerHTML='<svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Copied!';setTimeout(function(){copyBtn.innerHTML=o;},2000);
              });
            });
            update();
          })();
          </script>

          <hr class="doc-divider"/>
          <div class="doc-section">
            <h3 id="component-api-properties" class="doc-h3">Component API &amp; Properties</h3>
            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">RadioGroup</h4>
            <table class="size-table" style="margin-bottom:32px;">
              <thead><tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
              <tbody>
                <tr><td><code>label</code></td><td>string</td><td>&#8212;</td><td>Group label text displayed above/beside the options.</td></tr>
                <tr><td><code>labelPosition</code></td><td>'top' | 'left'</td><td>'left'</td><td>Controls the layout axis of the options relative to the label.</td></tr>
                <tr><td><code>size</code></td><td>'S' | 'M' | 'L' | 'Mobile'</td><td>'M'</td><td>Applies consistent sizing across all child radio buttons.</td></tr>
                <tr><td><code>state</code></td><td>'default' | 'error' | 'disabled'</td><td>'default'</td><td>Validation or interaction state of the entire group.</td></tr>
                <tr><td><code>helpText</code></td><td>string</td><td>&#8212;</td><td>Supplementary text shown below the options. Turns red on error.</td></tr>
                <tr><td><code>showInfoIcon</code></td><td>boolean</td><td>false</td><td>Shows an info tooltip icon next to the group label.</td></tr>
                <tr><td><code>rtl</code></td><td>boolean</td><td>false</td><td>Switches to right-to-left layout mode.</td></tr>
                <tr><td><code>value</code></td><td>string</td><td>&#8212;</td><td>The value of the currently selected option (controlled).</td></tr>
                <tr><td><code>defaultValue</code></td><td>string</td><td>&#8212;</td><td>Initially selected value (uncontrolled).</td></tr>
                <tr><td><code>onChange</code></td><td>(value: string) =&gt; void</td><td>&#8212;</td><td>Callback fired when the user changes selection.</td></tr>
                <tr><td><code>name</code></td><td>string</td><td>&#8212;</td><td>HTML name attribute shared by all radio inputs in the group.</td></tr>
              </tbody>
            </table>

            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">RadioButton (individual item)</h4>
            <table class="size-table">
              <thead><tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
              <tbody>
                <tr><td><code>label</code></td><td>string</td><td>&#8212;</td><td>Visible label for this option.</td></tr>
                <tr><td><code>value</code></td><td>string</td><td>&#8212;</td><td>Value submitted / passed to onChange when this option is selected.</td></tr>
                <tr><td><code>size</code></td><td>'S' | 'M' | 'L' | 'Mobile'</td><td>Inherited</td><td>Override size for a single item.</td></tr>
                <tr><td><code>disabled</code></td><td>boolean</td><td>false</td><td>Disables only this option within the group.</td></tr>
                <tr><td><code>rtl</code></td><td>boolean</td><td>Inherited</td><td>Override direction for a single item.</td></tr>
              </tbody>
            </table>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="code-examples" class="doc-h3">Code Examples</h3>

            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Basic usage &#8212; Left layout (default, web)</h4>
            <div class="cp-code-area" style="border-radius:12px;margin-bottom:24px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;">
                <span style="color:#94a3b8;">{/* labelPosition defaults to "left" &#8212; no need to set it explicitly */}</span><br>
                <span style="color:#ABB2BF;">&lt;</span><span style="color:#a78bfa;">RadioGroup</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">label</span>=<span style="color:#34d399;">"Notification frequency"</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">defaultValue</span>=<span style="color:#34d399;">"daily"</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">helpText</span>=<span style="color:#34d399;">"We'll send alerts based on this preference."</span><br>
                <span style="color:#ABB2BF;">&gt;</span><br>
                &nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;</span><span style="color:#a78bfa;">RadioButton</span> <span style="color:#38bdf8;">value</span>=<span style="color:#34d399;">"realtime"</span> <span style="color:#38bdf8;">label</span>=<span style="color:#34d399;">"Real-time"</span> <span style="color:#ABB2BF;">/&gt;</span><br>
                &nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;</span><span style="color:#a78bfa;">RadioButton</span> <span style="color:#38bdf8;">value</span>=<span style="color:#34d399;">"daily"</span> <span style="color:#38bdf8;">label</span>=<span style="color:#34d399;">"Daily digest"</span> <span style="color:#ABB2BF;">/&gt;</span><br>
                &nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;</span><span style="color:#a78bfa;">RadioButton</span> <span style="color:#38bdf8;">value</span>=<span style="color:#34d399;">"weekly"</span> <span style="color:#38bdf8;">label</span>=<span style="color:#34d399;">"Weekly summary"</span> <span style="color:#ABB2BF;">/&gt;</span><br>
                <span style="color:#ABB2BF;">&lt;/</span><span style="color:#a78bfa;">RadioGroup</span><span style="color:#ABB2BF;">&gt;</span>
              </div>
            </div>

            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Error state</h4>
            <div class="cp-code-area" style="border-radius:12px;margin-bottom:24px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;">
                <span style="color:#ABB2BF;">&lt;</span><span style="color:#a78bfa;">RadioGroup</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">label</span>=<span style="color:#34d399;">"Assign to"</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">state</span>=<span style="color:#34d399;">"error"</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">helpText</span>=<span style="color:#34d399;">"Please select an assignee before submitting."</span><br>
                <span style="color:#ABB2BF;">&gt;</span><br>
                &nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;</span><span style="color:#a78bfa;">RadioButton</span> <span style="color:#38bdf8;">value</span>=<span style="color:#34d399;">"me"</span> <span style="color:#38bdf8;">label</span>=<span style="color:#34d399;">"Me"</span> <span style="color:#ABB2BF;">/&gt;</span><br>
                &nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;</span><span style="color:#a78bfa;">RadioButton</span> <span style="color:#38bdf8;">value</span>=<span style="color:#34d399;">"team"</span> <span style="color:#38bdf8;">label</span>=<span style="color:#34d399;">"My team"</span> <span style="color:#ABB2BF;">/&gt;</span><br>
                &nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;</span><span style="color:#a78bfa;">RadioButton</span> <span style="color:#38bdf8;">value</span>=<span style="color:#34d399;">"all"</span> <span style="color:#38bdf8;">label</span>=<span style="color:#34d399;">"Everyone"</span> <span style="color:#ABB2BF;">/&gt;</span><br>
                <span style="color:#ABB2BF;">&lt;/</span><span style="color:#a78bfa;">RadioGroup</span><span style="color:#ABB2BF;">&gt;</span>
              </div>
            </div>

            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Top layout (special case)</h4>
            <div class="cp-code-area" style="border-radius:12px;margin-bottom:24px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;">
                <span style="color:#94a3b8;">{/* Use labelPosition="top" only when horizontal space is unavailable</span><br>
                <span style="color:#94a3b8;">&nbsp;&nbsp;&nbsp;or option labels are long enough to cause wrapping in Left layout */}</span><br>
                <span style="color:#ABB2BF;">&lt;</span><span style="color:#a78bfa;">RadioGroup</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">label</span>=<span style="color:#34d399;">"Select your preferred data export format"</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">labelPosition</span>=<span style="color:#34d399;">"top"</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">size</span>=<span style="color:#34d399;">"M"</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">defaultValue</span>=<span style="color:#34d399;">"csv"</span><br>
                <span style="color:#ABB2BF;">&gt;</span><br>
                &nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;</span><span style="color:#a78bfa;">RadioButton</span> <span style="color:#38bdf8;">value</span>=<span style="color:#34d399;">"csv"</span> <span style="color:#38bdf8;">label</span>=<span style="color:#34d399;">"CSV &#8212; Comma-separated values"</span> <span style="color:#ABB2BF;">/&gt;</span><br>
                &nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;</span><span style="color:#a78bfa;">RadioButton</span> <span style="color:#38bdf8;">value</span>=<span style="color:#34d399;">"json"</span> <span style="color:#38bdf8;">label</span>=<span style="color:#34d399;">"JSON &#8212; JavaScript Object Notation"</span> <span style="color:#ABB2BF;">/&gt;</span><br>
                &nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;</span><span style="color:#a78bfa;">RadioButton</span> <span style="color:#38bdf8;">value</span>=<span style="color:#34d399;">"xml"</span> <span style="color:#38bdf8;">label</span>=<span style="color:#34d399;">"XML &#8212; Extensible Markup Language"</span> <span style="color:#ABB2BF;">/&gt;</span><br>
                <span style="color:#ABB2BF;">&lt;/</span><span style="color:#a78bfa;">RadioGroup</span><span style="color:#ABB2BF;">&gt;</span>
              </div>
            </div>

            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">RTL</h4>
            <div class="cp-code-area" style="border-radius:12px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;">
                <span style="color:#ABB2BF;">&lt;</span><span style="color:#a78bfa;">RadioGroup</span> <span style="color:#38bdf8;">label</span>=<span style="color:#34d399;">"&#1575;&#1604;&#1581;&#1580;&#1605;"</span> <span style="color:#38bdf8;">rtl</span> <span style="color:#38bdf8;">defaultValue</span>=<span style="color:#34d399;">"m"</span><span style="color:#ABB2BF;">&gt;</span><br>
                &nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;</span><span style="color:#a78bfa;">RadioButton</span> <span style="color:#38bdf8;">value</span>=<span style="color:#34d399;">"s"</span> <span style="color:#38bdf8;">label</span>=<span style="color:#34d399;">"&#1589;&#1594;&#1610;&#1585;"</span> <span style="color:#ABB2BF;">/&gt;</span><br>
                &nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;</span><span style="color:#a78bfa;">RadioButton</span> <span style="color:#38bdf8;">value</span>=<span style="color:#34d399;">"m"</span> <span style="color:#38bdf8;">label</span>=<span style="color:#34d399;">"&#1605;&#1578;&#1608;&#1587;&#1591;"</span> <span style="color:#ABB2BF;">/&gt;</span><br>
                &nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;</span><span style="color:#a78bfa;">RadioButton</span> <span style="color:#38bdf8;">value</span>=<span style="color:#34d399;">"l"</span> <span style="color:#38bdf8;">label</span>=<span style="color:#34d399;">"&#1603;&#1576;&#1610;&#1585;"</span> <span style="color:#ABB2BF;">/&gt;</span><br>
                <span style="color:#ABB2BF;">&lt;/</span><span style="color:#a78bfa;">RadioGroup</span><span style="color:#ABB2BF;">&gt;</span>
              </div>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="implementation-idea-ember" class="doc-h3">Implementation Idea: Ember</h3>
            <div class="cp-code-area" style="border-radius:12px;margin-top:16px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;">
                <span style="color:#94a3b8;">&lt;!-- radio-group.hbs --&gt;</span><br>
                <span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">UemsRadioGroup</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">@label</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"Notification frequency"</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">@size</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"M"</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">@state</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"default"</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">@value</span><span style="color:#56B6C2;">=</span><span style="color:#C678DD;">{{</span><span style="color:#E5C07B;">this.selectedFrequency</span><span style="color:#C678DD;">}}</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">@onChange</span><span style="color:#56B6C2;">=</span><span style="color:#C678DD;">{{</span><span style="color:#E5C07B;">this.handleChange</span><span style="color:#C678DD;">}}</span><br>
                <span style="color:#ABB2BF;">&gt;</span><br>
                &nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">UemsRadioButton</span> <span style="color:#D19A66;">@value</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"realtime"</span> <span style="color:#D19A66;">@label</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"Real-time"</span> <span style="color:#ABB2BF;">/&gt;</span><br>
                &nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">UemsRadioButton</span> <span style="color:#D19A66;">@value</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"daily"</span> <span style="color:#D19A66;">@label</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"Daily digest"</span> <span style="color:#ABB2BF;">/&gt;</span><br>
                &nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">UemsRadioButton</span> <span style="color:#D19A66;">@value</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"weekly"</span> <span style="color:#D19A66;">@label</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"Weekly summary"</span> <span style="color:#ABB2BF;">/&gt;</span><br>
                <span style="color:#ABB2BF;">&lt;/</span><span style="color:#E06C75;">UemsRadioGroup</span><span style="color:#ABB2BF;">&gt;</span>
              </div>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="rtl-support" class="doc-h3">RTL Support</h3>
            <ul class="doc-list">
              <li>Control and label swap sides automatically when <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">dir="rtl"</code> is set on a parent element.</li>
              <li>The <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">rtl</code> prop on RadioGroup applies right-to-left layout to all child items.</li>
              <li>Individual RadioButton items can override the group's direction via their own <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">rtl</code> prop.</li>
            </ul>
          </div>
        </div>

        <!-- ========== ACCESSIBILITY ========== -->
        <div class="tab-content" id="tab-accessibility" style="display:none;padding-top:32px;">
          <h2 id="accessibility" class="doc-section-title">Accessibility</h2>
          <p class="doc-section-subtitle">Guidelines for ensuring radio button groups are accessible across assistive technologies.</p>

          <div class="doc-section">
            <h3 id="keyboard-interaction" class="doc-h3">Keyboard Interaction</h3>
            <table class="size-table">
              <thead><tr><th>Key</th><th>Action</th></tr></thead>
              <tbody>
                <tr><td><code>Tab</code></td><td>Moves focus into the radio group (to the selected or first option).</td></tr>
                <tr><td><code>Arrow Up / Left</code></td><td>Moves focus and selection to the previous radio option.</td></tr>
                <tr><td><code>Arrow Down / Right</code></td><td>Moves focus and selection to the next radio option.</td></tr>
                <tr><td><code>Space</code></td><td>Selects the currently focused radio option.</td></tr>
              </tbody>
            </table>
            <div style="margin-top:16px;padding:16px 20px;background:rgba(37,99,235,0.05);border:1px solid rgba(37,99,235,0.15);border-radius:12px;">
              <p style="font-size:14px;color:var(--prism-text);line-height:1.6;margin:0;">Tab moves focus into the group; Arrow keys move between options; Space selects the focused option. Focus wraps within the group.</p>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="aria-attributes-screen-reader-guidance" class="doc-h3">ARIA Attributes &amp; Screen Reader Guidance</h3>
            <ul class="doc-list">
              <li><strong>ARIA role:</strong> Wrap with <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;fieldset&gt;</code> + <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;legend&gt;</code> (or <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">role="radiogroup"</code> + <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-labelledby</code>).</li>
              <li><strong>Screen reader:</strong> Each option reads as: "[Label], radio button, [N] of [total], [group label]".</li>
              <li><strong>Error state:</strong> Associate help text via <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-describedby</code> on the group or on each input.</li>
              <li><strong>Disabled state:</strong> Set <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">disabled</code> attribute on <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;input type="radio"&gt;</code>; do not use <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-disabled</code> alone.</li>
              <li><strong>RTL:</strong> Control and label swap sides automatically; <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">dir="rtl"</code> on a parent element is sufficient.</li>
            </ul>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="focus-state-design" class="doc-h3">Focus State Design</h3>
            <ul class="doc-list">
              <li>Focus ring uses <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">Border/Border-Accent-Focus</code> token &#8212; must remain visible and not rely on colour alone.</li>
              <li>Focus is visible as a 3px ring around the radio control circle.</li>
              <li>When a radio option receives focus, it is also selected (following the standard radio group pattern).</li>
            </ul>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="color-contrast-minimums" class="doc-h3">Color Contrast Minimums<span class="h3-badge" style="background:rgba(34,197,94,0.15);color:#16a34a;">WCAG AA Pass</span></h3>
            <p class="doc-section-subtitle">Label text on white background must meet WCAG AA (4.5:1). Text/Text-Primary meets 4.5:1 in both Light and Dark themes.</p>
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px;margin-top:24px;">
              <div style="background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;overflow:hidden;">
                <div style="background:#2563eb;padding:28px 24px;text-align:center;color:#fff;">
                  <div style="display:flex;align-items:center;justify-content:center;gap:10px;">
                    <div style="width:20px;height:20px;border-radius:50%;background:#fff;display:flex;align-items:center;justify-content:center;"><div style="width:9px;height:9px;border-radius:50%;background:#2563eb;"></div></div>
                    <span style="font-size:18px;font-weight:600;">Selected</span>
                  </div>
                </div>
                <div style="padding:16px 24px;display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--prism-border);"><div><div style="font-size:13px;color:var(--prism-text-muted);font-weight:600;">SELECTED STATE</div><div style="font-size:15px;color:var(--prism-text);font-family:monospace;margin-top:4px;">#FFF on #2563EB</div></div><div style="text-align:right;"><div style="display:inline-flex;align-items:center;gap:6px;background:rgba(34,197,94,0.1);color:#16a34a;padding:4px 10px;border-radius:100px;font-size:12px;font-weight:700;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><polyline points="20 6 9 17 4 12"></polyline></svg> 4.6:1</div><div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;font-weight:600;">WCAG AA Pass</div></div></div>
              </div>
              <div style="background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;overflow:hidden;">
                <div style="background:#fff;padding:28px 24px;text-align:center;color:#1a1a2e;">
                  <div style="display:flex;align-items:center;justify-content:center;gap:10px;">
                    <div style="width:20px;height:20px;border-radius:50%;border:2px solid #94a3b8;"></div>
                    <span style="font-size:18px;font-weight:600;">Label text</span>
                  </div>
                </div>
                <div style="padding:16px 24px;display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--prism-border);"><div><div style="font-size:13px;color:var(--prism-text-muted);font-weight:600;">TEXT / LABEL</div><div style="font-size:15px;color:var(--prism-text);font-family:monospace;margin-top:4px;">#1A1A2E on #FFF</div></div><div style="text-align:right;"><div style="display:inline-flex;align-items:center;gap:6px;background:rgba(34,197,94,0.1);color:#16a34a;padding:4px 10px;border-radius:100px;font-size:12px;font-weight:700;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><polyline points="20 6 9 17 4 12"></polyline></svg> 16.8:1</div><div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;font-weight:600;">WCAG AAA Pass</div></div></div>
              </div>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="touch-target-size" class="doc-h3">Touch Target Size</h3>
            <p class="doc-section-subtitle">Each radio option must meet the minimum 44&times;44px touch target on mobile viewports.</p>
            <div style="margin-top:16px;padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;display:flex;align-items:center;gap:24px;">
              <div style="width:44px;height:44px;background:rgba(37,99,235,0.1);border:1px dashed var(--prism-violet);border-radius:8px;display:flex;align-items:center;justify-content:center;color:var(--prism-violet);font-size:13px;font-weight:600;flex-shrink:0;">44px</div>
              <div><div style="font-weight:600;font-size:15px;color:var(--prism-text);">Radio Option: 44&times;44px minimum</div><div style="font-size:14px;color:var(--prism-text-muted);margin-top:4px;">The Mobile size variant uses 20&times;20px radio controls with body/Large labels. The overall tappable area of each option (control + label) should meet the 44px minimum touch target.</div></div>
            </div>
          </div>
        </div>

        </div><!-- main-content-inner -->

