                <div style="width:60px;height:24px;border:2px dashed #006AFF;border-radius:4px;margin:0 auto 16px;display:flex;align-items:center;justify-content:center;background:rgba(0,106,255,0.05);color:#006AFF;font-weight:600;font-size:11px;">4px</div>
                <div style="font-size:14px;font-weight:600;color:var(--prism-text);">border-radius/radius-4</div>
                <div style="font-size:12px;color:var(--prism-text-muted);margin-top:4px;">Value badge corner radius</div>
              </div>
