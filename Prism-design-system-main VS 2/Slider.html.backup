                <div style="width:60px;height:8px;border:2px dashed #006AFF;border-radius:4px;margin:0 auto 16px;background:rgba(0,106,255,0.05);"></div>
                <div style="font-size:14px;font-weight:600;color:var(--prism-text);">Track radius = height/2</div>
