          <div class="doc-section">
            <h3 id="typography-family" class="doc-h3">Typography</h3>
            <p class="doc-section-subtitle">Label and value label typography is identical across all three sizes.</p>
            <table class="size-table">
              <thead><tr><th>Element</th><th>Font</th><th>Size</th><th>Weight</th><th>Line Height</th><th>Token</th></tr></thead>
