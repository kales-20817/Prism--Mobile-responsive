        <!-- ========== CODE ========== -->
        <div class="tab-content" id="tab-code" style="display:none;padding-top:32px;">
          <h2 id="live-demo-code" class="doc-section-title">Live demo (Code)</h2>
          <p class="doc-section-subtitle">Configure the Slider component and view generated code.</p>
          <div class="code-playground">
            <div class="cp-toolbar">
              <div class="cp-control-group"><label class="cp-label">Type</label><select class="cp-select" id="pg-type"><option value="single">Single</option><option value="range">Range</option></select></div>
              <div class="cp-control-group"><label class="cp-label">Size</label><select class="cp-select" id="pg-size"><option value="Small">Small</option><option value="Medium" selected>Medium</option><option value="Large">Large</option></select></div>
              <div class="cp-control-group"><label class="cp-label">State</label><select class="cp-select" id="pg-state"><option value="Default">Default</option><option value="Hover">Hover</option><option value="Focus">Focus</option><option value="Active">Active</option><option value="Disabled">Disabled</option><option value="Error">Error</option></select></div>
              <div class="cp-control-group"><label class="cp-label">Value</label><input class="cp-select" id="pg-value" type="text" value="50" style="width:100%;"></div>
              <div class="cp-control-group"><label class="cp-label">Label</label><input class="cp-select" id="pg-label" type="text" value="Volume" style="width:100%;"></div>
            </div>
            <div class="cp-preview" id="pg-preview-area">
              <div class="slider-demo" id="pg-slider-el" style="max-width:280px;width:100%;">
                <div class="slider-label-row"><span class="slider-label" id="pg-s-label">Volume</span><span class="slider-value-badge" id="pg-s-value">50</span></div>
                <div class="slider-track-row"><div class="slider-track"><div class="slider-active-track" id="pg-s-active" style="width:50%;"></div></div><div class="slider-thumb" id="pg-s-thumb1" style="left:50%;"></div><div class="slider-thumb" id="pg-s-thumb2" style="left:80%;display:none;"></div></div>
                <div class="slider-minmax-row"><span>0</span><span>100</span></div>
              </div>
            </div>
            <div class="cp-code-header">
              <div style="font-size:13.5px;font-weight:600;color:var(--prism-text);">TSX</div>
              <button class="cp-action-btn" id="pg-copy-btn"><svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2"/></svg> Copy code</button>
            </div>
            <div class="cp-code-area" id="pg-code-output"></div>
          </div>
          <script>
          (function(){
            var els = {type:document.getElementById('pg-type'),size:document.getElementById('pg-size'),state:document.getElementById('pg-state'),value:document.getElementById('pg-value'),label:document.getElementById('pg-label')};
            var sliderEl = document.getElementById('pg-slider-el');
            var sLabel = document.getElementById('pg-s-label');
            var sValue = document.getElementById('pg-s-value');
            var sActive = document.getElementById('pg-s-active');
            var sThumb1 = document.getElementById('pg-s-thumb1');
            var sThumb2 = document.getElementById('pg-s-thumb2');
            var codeOut = document.getElementById('pg-code-output');
            var copyBtn = document.getElementById('pg-copy-btn');
            function esc(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
            function update(){
              var tp=els.type.value, sz=els.size.value, st=els.state.value, v=els.value.value||'50', lb=els.label.value||'Label';
              sLabel.textContent=lb;
              var isRange = tp==='range';
              var pct = 50, leftPct = 20, rightPct = 80;
              if(isRange){
                var parts = v.split(/[,\-\s]+/);
                var a = parseInt(parts[0])||20, b = parseInt(parts[1])||80;
                leftPct = Math.max(0,Math.min(100,a));
                rightPct = Math.max(0,Math.min(100,b));
                sValue.textContent = leftPct + ' \u2013 ' + rightPct;
                sActive.style.left = leftPct+'%';
                sActive.style.width = (rightPct-leftPct)+'%';
                sThumb1.style.left = leftPct+'%';
                sThumb1.style.display = '';
                sThumb2.style.left = rightPct+'%';
                sThumb2.style.display = '';
              } else {
                pct = Math.max(0,Math.min(100,parseInt(v)||50));
                sValue.textContent = pct;
                sActive.style.left = '0';
                sActive.style.width = pct+'%';
                sThumb1.style.left = pct+'%';
                sThumb1.style.display = '';
                sThumb2.style.display = 'none';
              }
              sliderEl.className = 'slider-demo';
              if(sz==='Small') sliderEl.classList.add('slider-sm');
              else if(sz==='Large') sliderEl.classList.add('slider-lg');
              var stateMap = {'Hover':'slider-hover','Focus':'slider-focus','Active':'slider-active','Disabled':'slider-disabled','Error':'slider-error'};
              if(stateMap[st]) sliderEl.classList.add(stateMap[st]);
              var code = '<Slider\n';
              if(isRange) code += '  type="Range"\n';
              code += '  label="'+lb+'"\n';
              if(isRange) code += '  value={['+leftPct+', '+rightPct+']}\n';
              else code += '  value={'+pct+'}\n';
              code += '  min={0}\n  max={100}\n';
              if(sz!=='Small') code += '  size="'+sz+'"\n';
              if(st==='Disabled') code += '  disabled\n';
              if(st==='Error') code += '  state="Error"\n';
              code += '  onChange={(val) => setValue(val)}\n';
              if(isRange) code += '  onChangeEnd={(val) => fetchResults(val)}\n';
              code += '/>';
              codeOut.innerHTML = esc(code)
                .replace(/(type|label|value|min|max|size|disabled|state|onChange|onChangeEnd)=/g,'<span style="color:#38bdf8;">$1</span>=')
                .replace(/&lt;(\/?)(Slider)/g,'&lt;$1<span style="color:#a78bfa;">$2</span>')
                .replace(/"([^"]*)"/g,'<span style="color:#34d399;">"$1"</span>')
                .replace(/\{([^}]*)\}/g,'{<span style="color:#fbbf24;">$1</span>}');
            }
            Object.values(els).forEach(function(e){e.addEventListener(e.tagName==='INPUT'?'input':'change',update);});
            copyBtn.addEventListener('click',function(){
              var r=document.createElement('div');r.innerHTML=codeOut.innerHTML;
              navigator.clipboard.writeText(r.innerText).then(function(){
                var o=copyBtn.innerHTML;copyBtn.innerHTML='<svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Copied!';setTimeout(function(){copyBtn.innerHTML=o;},2000);
              });
            });
            update();
          })();
          </script>

          <hr class="doc-divider"/>
          <div class="doc-section">
            <h3 id="component-api-properties" class="doc-h3">Component API &amp; Properties</h3>
            <table class="size-table">
              <thead><tr><th>Property</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
              <tbody>
                <tr><td><code>type</code></td><td><code>'Single' | 'Range'</code></td><td><code>'Single'</code></td><td>Single-value or range (two-thumb) slider.</td></tr>
                <tr><td><code>size</code></td><td><code>'Small' | 'Medium' | 'Large'</code></td><td><code>'Small'</code></td><td>Controls track thickness and thumb size.</td></tr>
                <tr><td><code>state</code></td><td><code>'Default' | 'Hover' | 'Focus' | 'Active' | 'Disabled' | 'Error'</code></td><td><code>'Default'</code></td><td>Interaction or validation state.</td></tr>
                <tr><td><code>value</code></td><td><code>number | [number, number]</code></td><td><code>50</code></td><td>Current value (Single) or [start, end] (Range).</td></tr>
                <tr><td><code>min</code></td><td><code>number</code></td><td><code>0</code></td><td>Minimum value of the track.</td></tr>
                <tr><td><code>max</code></td><td><code>number</code></td><td><code>100</code></td><td>Maximum value of the track.</td></tr>
                <tr><td><code>step</code></td><td><code>number</code></td><td><code>1</code></td><td>Increment step between selectable values.</td></tr>
                <tr><td><code>label</code></td><td><code>string</code></td><td><code>"Label"</code></td><td>Field label text displayed above the track.</td></tr>
                <tr><td><code>showLabel</code></td><td><code>boolean</code></td><td><code>true</code></td><td>Shows or hides the label.</td></tr>
                <tr><td><code>showValueLabel</code></td><td><code>boolean</code></td><td><code>true</code></td><td>Shows or hides the value badge pill.</td></tr>
                <tr><td><code>showMinMaxLabels</code></td><td><code>boolean</code></td><td><code>false</code></td><td>Shows min and max value text at either end of the track.</td></tr>
                <tr><td><code>minLabel</code></td><td><code>string</code></td><td><code>"0"</code></td><td>Text for the minimum end label.</td></tr>
                <tr><td><code>maxLabel</code></td><td><code>string</code></td><td><code>"100"</code></td><td>Text for the maximum end label.</td></tr>
                <tr><td><code>showStepMarkers</code></td><td><code>boolean</code></td><td><code>false</code></td><td>Shows tick marks along the track at each step interval.</td></tr>
                <tr><td><code>showHelperText</code></td><td><code>boolean</code></td><td><code>false</code></td><td>Shows helper text below the slider.</td></tr>
                <tr><td><code>helperText</code></td><td><code>string</code></td><td><code>"Helper text"</code></td><td>Contextual message below the slider.</td></tr>
                <tr><td><code>disabled</code></td><td><code>boolean</code></td><td><code>false</code></td><td>Disables the slider &mdash; non-interactive, all elements greyed out.</td></tr>
                <tr><td><code>onChange</code></td><td><code>(value) =&gt; void</code></td><td>&mdash;</td><td>Fires on every value change.</td></tr>
                <tr><td><code>onChangeEnd</code></td><td><code>(value) =&gt; void</code></td><td>&mdash;</td><td>Fires when the user finishes dragging (mouseup / touchend).</td></tr>
              </tbody>
            </table>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="code-examples" class="doc-h3">Code Examples</h3>

            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:12px;margin-top:24px;">Single slider (default)</h4>
            <div class="cp-code-area" style="border-radius:12px;margin-bottom:24px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;">
                <span style="color:#ABB2BF;">&lt;</span><span style="color:#a78bfa;">Slider</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">label</span>=<span style="color:#34d399;">"Volume"</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">value</span>={<span style="color:#fbbf24;">50</span>}<br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">min</span>={<span style="color:#fbbf24;">0</span>}<br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">max</span>={<span style="color:#fbbf24;">100</span>}<br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">onChange</span>={<span style="color:#fbbf24;">(val) =&gt; setValue(val)</span>}<br>
                <span style="color:#ABB2BF;">/&gt;</span>
              </div>
            </div>

            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:12px;">Range slider</h4>
            <div class="cp-code-area" style="border-radius:12px;margin-bottom:24px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;">
                <span style="color:#ABB2BF;">&lt;</span><span style="color:#a78bfa;">Slider</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">type</span>=<span style="color:#34d399;">"Range"</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">label</span>=<span style="color:#34d399;">"Price range"</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">value</span>={<span style="color:#fbbf24;">[20, 80]</span>}<br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">min</span>={<span style="color:#fbbf24;">0</span>}<br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">max</span>={<span style="color:#fbbf24;">200</span>}<br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">showMinMaxLabels</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">minLabel</span>=<span style="color:#34d399;">"$0"</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">maxLabel</span>=<span style="color:#34d399;">"$200"</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">onChange</span>={<span style="color:#fbbf24;">(val) =&gt; setRange(val)</span>}<br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">onChangeEnd</span>={<span style="color:#fbbf24;">(val) =&gt; fetchResults(val)</span>}<br>
                <span style="color:#ABB2BF;">/&gt;</span>
              </div>
            </div>

            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:12px;">With step markers and helper text</h4>
            <div class="cp-code-area" style="border-radius:12px;margin-bottom:24px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;">
                <span style="color:#ABB2BF;">&lt;</span><span style="color:#a78bfa;">Slider</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">label</span>=<span style="color:#34d399;">"Quality"</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">value</span>={<span style="color:#fbbf24;">3</span>}<br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">min</span>={<span style="color:#fbbf24;">1</span>}<br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">max</span>={<span style="color:#fbbf24;">5</span>}<br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">step</span>={<span style="color:#fbbf24;">1</span>}<br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">showStepMarkers</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">showMinMaxLabels</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">minLabel</span>=<span style="color:#34d399;">"Low"</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">maxLabel</span>=<span style="color:#34d399;">"High"</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">showHelperText</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">helperText</span>=<span style="color:#34d399;">"Affects processing time"</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">size</span>=<span style="color:#34d399;">"Medium"</span><br>
                <span style="color:#ABB2BF;">/&gt;</span>
              </div>
            </div>

            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:12px;">Error state</h4>
            <div class="cp-code-area" style="border-radius:12px;margin-bottom:24px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;">
                <span style="color:#ABB2BF;">&lt;</span><span style="color:#a78bfa;">Slider</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">label</span>=<span style="color:#34d399;">"Timeout (seconds)"</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">value</span>={<span style="color:#fbbf24;">0</span>}<br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">min</span>={<span style="color:#fbbf24;">1</span>}<br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">max</span>={<span style="color:#fbbf24;">60</span>}<br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">state</span>=<span style="color:#34d399;">"Error"</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">showHelperText</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">helperText</span>=<span style="color:#34d399;">"Value must be at least 1 second."</span><br>
                <span style="color:#ABB2BF;">/&gt;</span>
              </div>
            </div>

            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:12px;">Disabled</h4>
            <div class="cp-code-area" style="border-radius:12px;margin-bottom:24px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;">
                <span style="color:#ABB2BF;">&lt;</span><span style="color:#a78bfa;">Slider</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">label</span>=<span style="color:#34d399;">"Concurrency"</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">value</span>={<span style="color:#fbbf24;">4</span>}<br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">min</span>={<span style="color:#fbbf24;">1</span>}<br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">max</span>={<span style="color:#fbbf24;">16</span>}<br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">disabled</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">showHelperText</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">helperText</span>=<span style="color:#34d399;">"Concurrency is managed by your plan."</span><br>
                <span style="color:#ABB2BF;">/&gt;</span>
              </div>
            </div>

            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:12px;">Large size (touch / mobile)</h4>
            <div class="cp-code-area" style="border-radius:12px;margin-bottom:24px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;">
                <span style="color:#ABB2BF;">&lt;</span><span style="color:#a78bfa;">Slider</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">label</span>=<span style="color:#34d399;">"Brightness"</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">value</span>={<span style="color:#fbbf24;">70</span>}<br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">size</span>=<span style="color:#34d399;">"Large"</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">showMinMaxLabels</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">minLabel</span>=<span style="color:#34d399;">"0%"</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">maxLabel</span>=<span style="color:#34d399;">"100%"</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">onChange</span>={<span style="color:#fbbf24;">(val) =&gt; setBrightness(val)</span>}<br>
                <span style="color:#ABB2BF;">/&gt;</span>
              </div>
            </div>
          </div>

          <hr class="doc-divider"/>
          <div class="doc-section">
            <h3 id="implementation-idea" class="doc-h3">Implementation Idea: Ember</h3>
            <div class="cp-code-area" style="border-radius:12px;margin-top:16px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;">
                <span style="color:#94a3b8;">&lt;!-- volume-control.hbs --&gt;</span><br>
                <span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">UemsSlider</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">@type</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"Single"</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">@label</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"Volume"</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">@value</span><span style="color:#56B6C2;">=</span><span style="color:#C678DD;">{{</span><span style="color:#E5C07B;">this.volume</span><span style="color:#C678DD;">}}</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">@min</span><span style="color:#56B6C2;">=</span><span style="color:#C678DD;">{{</span><span style="color:#E5C07B;">0</span><span style="color:#C678DD;">}}</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">@max</span><span style="color:#56B6C2;">=</span><span style="color:#C678DD;">{{</span><span style="color:#E5C07B;">100</span><span style="color:#C678DD;">}}</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">@size</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"Medium"</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">@onChange</span><span style="color:#56B6C2;">=</span><span style="color:#C678DD;">{{</span><span style="color:#E5C07B;">this.updateVolume</span><span style="color:#C678DD;">}}</span><br>
                <span style="color:#ABB2BF;">/&gt;</span>
              </div>
            </div>
          </div>
        </div>

        <!-- ========== ACCESSIBILITY ========== -->
        <div class="tab-content" id="tab-accessibility" style="display:none;padding-top:32px;">
          <h2 id="accessibility" class="doc-section-title">Accessibility</h2>
          <p class="doc-section-subtitle">Guidelines for ensuring the Slider component is accessible across assistive technologies and input methods.</p>

          <div class="doc-section">
            <h3 id="keyboard-interaction" class="doc-h3">Keyboard Interaction</h3>
            <table class="size-table">
              <thead><tr><th>Key</th><th>Action</th></tr></thead>
              <tbody>
                <tr><td><code>Tab</code></td><td>Moves focus to the slider thumb. For Range sliders, Tab moves between the two thumbs.</td></tr>
                <tr><td><code>Arrow Left / Down</code></td><td>Decrements the value by one step.</td></tr>
                <tr><td><code>Arrow Right / Up</code></td><td>Increments the value by one step.</td></tr>
                <tr><td><code>Home</code></td><td>Jumps to the minimum value.</td></tr>
                <tr><td><code>End</code></td><td>Jumps to the maximum value.</td></tr>
              </tbody>
            </table>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="semantic-html" class="doc-h3">Semantic HTML</h3>
            <ul class="doc-list">
              <li><strong>Element:</strong> Use <code>&lt;input type="range"&gt;</code> for native keyboard and screen reader support.</li>
              <li><strong>Label association:</strong> Connect <code>&lt;label for="id"&gt;</code> to the <code>&lt;input id="id"&gt;</code>.</li>
              <li><strong>Range type:</strong> Use two <code>&lt;input type="range"&gt;</code> elements; associate with <code>aria-labelledby</code> and communicate min/max of each thumb via <code>aria-valuemin</code>, <code>aria-valuemax</code>, <code>aria-valuenow</code>.</li>
            </ul>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="aria-attributes-screen-reader-guidance" class="doc-h3">ARIA Attributes &amp; Screen Reader Guidance</h3>
            <ul class="doc-list">
              <li><strong>aria-valuenow:</strong> Set on the input to reflect the current value.</li>
              <li><strong>aria-valuemin / aria-valuemax:</strong> Set the valid range boundaries on the input.</li>
              <li><strong>aria-valuetext:</strong> Use for non-numeric displays (e.g. "Low", "Medium", "High").</li>
              <li><strong>aria-describedby:</strong> Associate error/helper text with the input for screen readers.</li>
              <li><strong>aria-invalid:</strong> Set to <code>"true"</code> on the input when in Error state.</li>
            </ul>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="focus-state-design" class="doc-h3">Focus State Design</h3>
            <ul class="doc-list">
              <li><strong>Focus ring:</strong> Uses <code>Border/Border-Accent-Focus</code> &mdash; must remain visible. Do not suppress <code>:focus-visible</code> outline.</li>
              <li><strong>Focus ring size:</strong> Matches thumb container per size (24 / 28 / 32 px), stroke 2 px.</li>
              <li><strong>Step markers:</strong> If shown, mark the track with <code>aria-label</code> or visually-hidden text describing the step values.</li>
            </ul>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="disabled-state" class="doc-h3">Disabled State</h3>
            <ul class="doc-list">
              <li>Set <code>disabled</code> on <code>&lt;input type="range"&gt;</code>. Disabled sliders are removed from the tab order.</li>
              <li>All elements (track, thumb, labels) are greyed out using disabled tokens.</li>
            </ul>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="color-contrast-minimums" class="doc-h3">Color Contrast Minimums<span class="h3-badge" style="background:rgba(34,197,94,0.15);color:#16a34a;">WCAG AA Pass</span></h3>
            <p class="doc-section-subtitle">Active track vs inactive track must be visually distinguishable beyond colour alone. The size difference between active and inactive tracks satisfies this requirement.</p>
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px;margin-top:24px;">
              <div style="background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;overflow:hidden;">
                <div style="background:#2563eb;padding:28px 24px;text-align:center;color:#fff;"><div style="font-size:20px;font-weight:600;">Active Track</div></div>
                <div style="padding:16px 24px;display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--prism-border);"><div><div style="font-size:13px;color:var(--prism-text-muted);font-weight:600;">BG-Button-Primary</div><div style="font-size:15px;color:var(--prism-text);font-family:monospace;margin-top:4px;">#2563EB</div></div><div style="text-align:right;"><div style="display:inline-flex;align-items:center;gap:6px;background:rgba(34,197,94,0.1);color:#16a34a;padding:4px 10px;border-radius:100px;font-size:12px;font-weight:700;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><polyline points="20 6 9 17 4 12"></polyline></svg> Passes</div><div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;font-weight:600;">WCAG AA</div></div></div>
              </div>
              <div style="background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;overflow:hidden;">
                <div style="background:#e42527;padding:28px 24px;text-align:center;color:#fff;"><div style="font-size:20px;font-weight:600;">Error Track</div></div>
                <div style="padding:16px 24px;display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--prism-border);"><div><div style="font-size:13px;color:var(--prism-text-muted);font-weight:600;">BG-Error-Solid</div><div style="font-size:15px;color:var(--prism-text);font-family:monospace;margin-top:4px;">#E42527</div></div><div style="text-align:right;"><div style="display:inline-flex;align-items:center;gap:6px;background:rgba(34,197,94,0.1);color:#16a34a;padding:4px 10px;border-radius:100px;font-size:12px;font-weight:700;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><polyline points="20 6 9 17 4 12"></polyline></svg> Passes</div><div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;font-weight:600;">WCAG AA</div></div></div>
              </div>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="touch-target-size" class="doc-h3">Touch Target Size</h3>
            <p class="doc-section-subtitle">Thumb container size (24&ndash;32 px) meets minimum 24 px WCAG 2.5.8 target. Use Large size for touch-primary interfaces.</p>
            <div style="margin-top:16px;padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;display:flex;align-items:center;gap:24px;">
              <div style="display:flex;gap:12px;flex-shrink:0;">
                <div style="width:24px;height:24px;background:rgba(37,99,235,0.1);border:1px dashed var(--prism-violet);border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--prism-violet);font-size:10px;font-weight:600;">S</div>
                <div style="width:28px;height:28px;background:rgba(37,99,235,0.1);border:1px dashed var(--prism-violet);border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--prism-violet);font-size:10px;font-weight:600;">M</div>
                <div style="width:32px;height:32px;background:rgba(37,99,235,0.1);border:1px dashed var(--prism-violet);border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--prism-violet);font-size:10px;font-weight:600;">L</div>
              </div>
              <div><div style="font-weight:600;font-size:15px;color:var(--prism-text);">Thumb container: 24 / 28 / 32 px</div><div style="font-size:14px;color:var(--prism-text-muted);margin-top:4px;">All sizes meet WCAG 2.5.8 minimum 24 px target. Use Large (32 px) for touch-primary and mobile interfaces.</div></div>
            </div>
          </div>
        </div>

