    <main class="main-panel">
      <div class="page-header-area">
        <h1 class="page-title">Counter</h1>
        <p class="page-desc">
          The Counter is a compact numeric indicator used to display counts, badges, or notification numbers. Counters are pill-shaped elements that adapt their color and intensity based on semantic state.
        </p>
        <nav class="content-tabs">
          <button class="tab-item active">Overview</button>
          <button class="tab-item">Style</button>
          <button class="tab-item">Usage</button>
          <button class="tab-item">Code</button>
          <button class="tab-item">Accessibility</button>
        </nav>
      </div>
      <div class="main-content-area">
        <div class="main-content-inner">
        <div class="tab-content" id="tab-overview">

        <!-- Anatomy Section -->
        <h3 id="anatomy" class="doc-h3">Anatomy</h3>
        <style>
          .anatomy-diagram { background: var(--prism-surface); border: 1px solid var(--prism-border); border-radius: 16px; padding: 48px 40px; margin-bottom: 28px; position: relative; overflow: hidden; }
          [data-theme="light"] .anatomy-diagram { background: #fff; border: 1px solid rgba(37, 99, 235, 0.07); box-shadow: 0 2px 12px rgba(37, 99, 235, 0.05); }
          .anatomy-diagram::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, #2563eb, #60a5fa, #06b6d4); }
          .anat-marker-inline { width: 22px; height: 22px; border-radius: 50%; flex-shrink: 0; background: linear-gradient(135deg, #2563eb, #3b82f6); color: #fff !important; font-size: 11px; font-weight: 700; display: inline-flex; align-items: center; justify-content: center; box-shadow: 0 2px 10px rgba(37, 99, 235, 0.35); }
          .anat-legend { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
          .anat-legend-item { display: flex; align-items: flex-start; gap: 14px; padding: 20px; background: var(--prism-surface); border: 1px solid var(--prism-border); border-radius: 14px; transition: all 0.25s cubic-bezier(0.4,0,0.2,1); }
          [data-theme="light"] .anat-legend-item { background: #fff; border: 1px solid rgba(37, 99, 235, 0.07); box-shadow: 0 1px 4px rgba(37, 99, 235, 0.04); }
          .anat-legend-item strong { display: block; font-size: 14.5px; font-weight: 600; color: var(--prism-text); margin-bottom: 6px; }
          .anat-legend-item span { font-size: 13px; line-height: 1.55; color: var(--prism-text-muted); }
        </style>

        <div class="anatomy-diagram">
          <div style="display: flex; justify-content: center; margin: 40px 0;">
            <div style="display: inline-flex; align-items: center; justify-content: center; position: relative; padding: 12px 20px; border-radius: 9999px; border: 2px dashed rgba(37,99,235,0.4); font-size: 18px; font-weight: 500; color: var(--prism-text); min-width: 48px; height: 48px; overflow: visible;">
              <!-- 1 Container: marker left of dashed pill, horizontal line to pill edge -->
              <div style="position: absolute; right: calc(100% + 6px); top: 50%; transform: translateY(-50%); display: flex; align-items: center; gap: 6px; z-index: 5;">
                <span class="anat-marker-inline">1</span><div style="width: 28px; height: 2px; background: #2563eb;"></div>
              </div>
              <div style="position: relative; display: inline-flex;">
                <span style="font-family: 'Zoho Puvi', sans-serif; font-weight: 500; font-size: 18px;">57</span>
                <!-- 2 Number Value: marker above the "57" glyph, vertical line down -->
                <div style="position: absolute; left: 50%; bottom: calc(100% + 6px); transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: 4px; z-index: 5;">
                  <span class="anat-marker-inline">2</span><div style="width: 2px; height: 14px; background: #2563eb;"></div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="anat-legend">
          <div class="anat-legend-item"><span class="anat-marker-inline">1</span><div><strong>Container</strong><span>Pill-shaped auto-layout frame with centered content. Min-width ensures circular shape for single digits. Border-radius: 9999px.</span></div></div>
          <div class="anat-legend-item"><span class="anat-marker-inline">2</span><div><strong>Number Value</strong><span>Numeric text. Defaults to "57". Font: Zoho Puvi Medium, centered horizontally and vertically.</span></div></div>
        </div>

        <hr class="doc-divider" />

