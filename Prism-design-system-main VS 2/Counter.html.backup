        <!-- Content Guidelines Do/Don't -->
        <div class="doc-section">
          <h3 id="content-guidelines" class="doc-h3">Content Guidelines<span class="h3-badge" style="background: rgba(37,99,235,0.1); color: var(--prism-violet);">Recommended</span></h3>
          <div class="do-dont-grid">
            <div class="do-card"><span class="card-label">Do</span>
              <ul class="doc-list" style="border: none; background: transparent; padding: 0;">
                <li style="border: none; background: transparent; padding-left: 20px;">Keep numeric values short (1-3 digits, show "99+" for large numbers).</li>
                <li style="border: none; background: transparent; padding-left: 20px;">Use Subtle style for inline contexts where the counter is secondary information.</li>
                <li style="border: none; background: transparent; padding-left: 20px;">Use Intense for high-visibility scenarios (e.g., unread notifications).</li>
                <li style="border: none; background: transparent; padding-left: 20px;">Match state color to semantic meaning (Critical for errors, Success for completions).</li>
              </ul>
            </div>
            <div class="dont-card"><span class="card-label">Don't</span>
              <ul class="doc-list" style="border: none; background: transparent; padding: 0;">
                <li style="border: none; background: transparent; padding-left: 20px;">Don't use counters for non-numeric content (use Badge instead).</li>
                <li style="border: none; background: transparent; padding-left: 20px;">Don't use as a standalone status indicator without context.</li>
                <li style="border: none; background: transparent; padding-left: 20px;">Don't mix Subtle and Intense counters in the same row or group.</li>
                <li style="border: none; background: transparent; padding-left: 20px;">Don't use very large numbers without truncation (e.g., "1542" should be "99+").</li>
              </ul>
            </div>
          </div>
        </div>

      </div> <!-- End tab-overview -->

      <!-- ═══ STYLE TAB ═══ -->
      <div class="tab-content" id="tab-style" style="display: none; padding-top: 32px;">
        <h2 id="style-overview" class="doc-section-title">Style</h2>
        <p class="doc-section-subtitle">Design tokens, color mappings, and sizing specifications that define the Counter's visual language.</p>

        <!-- Variant Axes -->
        <div class="doc-section">
          <h2 id="variant-axes" class="doc-section-title">Variant Axes</h2>
          <p class="doc-section-subtitle">The Counter component is built on three independent variant axes, producing 42 total combinations.</p>

          <table class="size-table">
            <thead>
              <tr>
                <th>Axis</th>
                <th>Options</th>
                <th>Purpose</th>
              </tr>
            </thead>
            <tbody>
              <tr><td><strong>Style</strong></td><td>Subtle, Intense</td><td>Visual emphasis level</td></tr>
              <tr><td><strong>Size</strong></td><td>Small, Medium, Large</td><td>Height and font size scaling</td></tr>
              <tr><td><strong>State</strong></td><td>Active, Critical, Moderate, Important, Success, Default, Acknowledge</td><td>Semantic color assignment</td></tr>
            </tbody>
          </table>
          <p style="font-size: 14px; color: var(--prism-text-muted); margin-top: 16px;">Total: 2 &times; 3 &times; 7 = <strong>42 variants</strong></p>
        </div>

        <hr class="doc-divider" />

        <!-- Subtle Style Colors -->
        <div class="doc-section">
          <h2 id="subtle-style-colors" class="doc-section-title">Subtle Style Colors</h2>
          <p class="doc-section-subtitle">Low-emphasis backgrounds with tinted text for inline and secondary contexts.</p>
          <table class="size-table">
            <thead><tr><th>State</th><th>Background Token</th><th>Background Hex</th><th>Text Token</th><th>Text Hex</th></tr></thead>
            <tbody>
              <tr><td><strong>Active</strong></td><td><code>bg-info-subtle</code></td><td><span style="display:inline-block;width:14px;height:14px;border-radius:4px;background:#D5E0F8;vertical-align:middle;margin-right:6px;border:1px solid rgba(0,0,0,0.1);"></span>#D5E0F8</td><td><code>text-info</code></td><td><span style="display:inline-block;width:14px;height:14px;border-radius:4px;background:#1E52BB;vertical-align:middle;margin-right:6px;border:1px solid rgba(0,0,0,0.1);"></span>#1E52BB</td></tr>
              <tr><td><strong>Critical</strong></td><td><code>bg-error-subtle</code></td><td><span style="display:inline-block;width:14px;height:14px;border-radius:4px;background:#FDEBEB;vertical-align:middle;margin-right:6px;border:1px solid rgba(0,0,0,0.1);"></span>#FDEBEB</td><td><code>text-error</code></td><td><span style="display:inline-block;width:14px;height:14px;border-radius:4px;background:#C1181B;vertical-align:middle;margin-right:6px;border:1px solid rgba(0,0,0,0.1);"></span>#C1181B</td></tr>
              <tr><td><strong>Moderate</strong></td><td><code>bg-warning-subtle</code></td><td><span style="display:inline-block;width:14px;height:14px;border-radius:4px;background:#FEF8EB;vertical-align:middle;margin-right:6px;border:1px solid rgba(0,0,0,0.1);"></span>#FEF8EB</td><td><code>text-warning</code></td><td><span style="display:inline-block;width:14px;height:14px;border-radius:4px;background:#956B11;vertical-align:middle;margin-right:6px;border:1px solid rgba(0,0,0,0.1);"></span>#956B11</td></tr>
              <tr><td><strong>Important</strong></td><td><code>bg-important-subtle</code></td><td><span style="display:inline-block;width:14px;height:14px;border-radius:4px;background:#FFEEE5;vertical-align:middle;margin-right:6px;border:1px solid rgba(0,0,0,0.1);"></span>#FFEEE5</td><td><code>text-important</code></td><td><span style="display:inline-block;width:14px;height:14px;border-radius:4px;background:#BC4200;vertical-align:middle;margin-right:6px;border:1px solid rgba(0,0,0,0.1);"></span>#BC4200</td></tr>
              <tr><td><strong>Success</strong></td><td><code>bg-success-subtle</code></td><td><span style="display:inline-block;width:14px;height:14px;border-radius:4px;background:#E7F3ED;vertical-align:middle;margin-right:6px;border:1px solid rgba(0,0,0,0.1);"></span>#E7F3ED</td><td><code>text-success</code></td><td><span style="display:inline-block;width:14px;height:14px;border-radius:4px;background:#0A7138;vertical-align:middle;margin-right:6px;border:1px solid rgba(0,0,0,0.1);"></span>#0A7138</td></tr>
              <tr><td><strong>Default</strong></td><td><code>bg-neutral-subtle</code></td><td><span style="display:inline-block;width:14px;height:14px;border-radius:4px;background:#F0F2F5;vertical-align:middle;margin-right:6px;border:1px solid rgba(0,0,0,0.1);"></span>#F0F2F5</td><td><code>text-neutral</code></td><td><span style="display:inline-block;width:14px;height:14px;border-radius:4px;background:#2A303D;vertical-align:middle;margin-right:6px;border:1px solid rgba(0,0,0,0.1);"></span>#2A303D</td></tr>
              <tr><td><strong>Acknowledge</strong></td><td><code>bg-acknowledge-subtle</code></td><td><span style="display:inline-block;width:14px;height:14px;border-radius:4px;background:#F1EAF8;vertical-align:middle;margin-right:6px;border:1px solid rgba(0,0,0,0.1);"></span>#F1EAF8</td><td><code>text-acknowledge</code></td><td><span style="display:inline-block;width:14px;height:14px;border-radius:4px;background:#663399;vertical-align:middle;margin-right:6px;border:1px solid rgba(0,0,0,0.1);"></span>#663399</td></tr>
            </tbody>
          </table>
        </div>

        <hr class="doc-divider" />

        <!-- Intense Style Colors -->
        <div class="doc-section">
          <h2 id="intense-style-colors" class="doc-section-title">Intense Style Colors</h2>
          <p class="doc-section-subtitle">High-emphasis solid backgrounds with contrasting text for primary visibility contexts.</p>
          <table class="size-table">
            <thead><tr><th>State</th><th>Background Token</th><th>Background Hex</th><th>Text Token</th><th>Text Hex</th></tr></thead>
            <tbody>
              <tr><td><strong>Active</strong></td><td><code>bg-info-solid</code></td><td><span style="display:inline-block;width:14px;height:14px;border-radius:4px;background:#2C66DD;vertical-align:middle;margin-right:6px;border:1px solid rgba(0,0,0,0.1);"></span>#2C66DD</td><td><code>text-on-solid</code></td><td><span style="display:inline-block;width:14px;height:14px;border-radius:4px;background:#FFFFFF;vertical-align:middle;margin-right:6px;border:1px solid rgba(0,0,0,0.1);"></span>#FFFFFF</td></tr>
              <tr><td><strong>Critical</strong></td><td><code>bg-error-solid</code></td><td><span style="display:inline-block;width:14px;height:14px;border-radius:4px;background:#E42527;vertical-align:middle;margin-right:6px;border:1px solid rgba(0,0,0,0.1);"></span>#E42527</td><td><code>text-on-solid</code></td><td><span style="display:inline-block;width:14px;height:14px;border-radius:4px;background:#FFFFFF;vertical-align:middle;margin-right:6px;border:1px solid rgba(0,0,0,0.1);"></span>#FFFFFF</td></tr>
              <tr><td><strong>Moderate</strong></td><td><code>bg-warning-solid</code></td><td><span style="display:inline-block;width:14px;height:14px;border-radius:4px;background:#F9B21D;vertical-align:middle;margin-right:6px;border:1px solid rgba(0,0,0,0.1);"></span>#F9B21D</td><td><code>text-on-warning</code></td><td><span style="display:inline-block;width:14px;height:14px;border-radius:4px;background:#000000;vertical-align:middle;margin-right:6px;border:1px solid rgba(0,0,0,0.1);"></span>#000000</td></tr>
              <tr><td><strong>Important</strong></td><td><code>bg-important-solid</code></td><td><span style="display:inline-block;width:14px;height:14px;border-radius:4px;background:#E65100;vertical-align:middle;margin-right:6px;border:1px solid rgba(0,0,0,0.1);"></span>#E65100</td><td><code>text-on-solid</code></td><td><span style="display:inline-block;width:14px;height:14px;border-radius:4px;background:#FFFFFF;vertical-align:middle;margin-right:6px;border:1px solid rgba(0,0,0,0.1);"></span>#FFFFFF</td></tr>
              <tr><td><strong>Success</strong></td><td><code>bg-success-solid</code></td><td><span style="display:inline-block;width:14px;height:14px;border-radius:4px;background:#0C8844;vertical-align:middle;margin-right:6px;border:1px solid rgba(0,0,0,0.1);"></span>#0C8844</td><td><code>text-on-solid</code></td><td><span style="display:inline-block;width:14px;height:14px;border-radius:4px;background:#FFFFFF;vertical-align:middle;margin-right:6px;border:1px solid rgba(0,0,0,0.1);"></span>#FFFFFF</td></tr>
              <tr><td><strong>Default</strong></td><td><code>bg-neutral-solid</code></td><td><span style="display:inline-block;width:14px;height:14px;border-radius:4px;background:#5F6C89;vertical-align:middle;margin-right:6px;border:1px solid rgba(0,0,0,0.1);"></span>#5F6C89</td><td><code>text-on-solid</code></td><td><span style="display:inline-block;width:14px;height:14px;border-radius:4px;background:#FFFFFF;vertical-align:middle;margin-right:6px;border:1px solid rgba(0,0,0,0.1);"></span>#FFFFFF</td></tr>
              <tr><td><strong>Acknowledge</strong></td><td><code>bg-acknowledge-solid</code></td><td><span style="display:inline-block;width:14px;height:14px;border-radius:4px;background:#663399;vertical-align:middle;margin-right:6px;border:1px solid rgba(0,0,0,0.1);"></span>#663399</td><td><code>text-on-solid</code></td><td><span style="display:inline-block;width:14px;height:14px;border-radius:4px;background:#FFFFFF;vertical-align:middle;margin-right:6px;border:1px solid rgba(0,0,0,0.1);"></span>#FFFFFF</td></tr>
            </tbody>
          </table>
