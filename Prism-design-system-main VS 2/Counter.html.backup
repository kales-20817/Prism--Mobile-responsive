          <p class="doc-section-subtitle" style="margin-bottom: 28px;">Explore the Counter component across styles, sizes, and semantic states.</p>

          <style>
            .demo-container { border: 1px solid var(--prism-border); border-radius: 16px; overflow: hidden; position: relative; }
            .demo-toolbar { display: flex; align-items: center; justify-content: space-between; padding: 12px 20px; background: var(--prism-surface); border-bottom: 1px solid var(--prism-border); }
            [data-theme="light"] .demo-container { border: 1px solid rgba(37, 99, 235, 0.14); box-shadow: 0 2px 16px rgba(37, 99, 235, 0.08); }
            [data-theme="light"] .demo-toolbar { background: rgba(255, 255, 255, 0.7); border-bottom: 1px solid rgba(37, 99, 235, 0.06); }
            .demo-toolbar-left { display: flex; align-items: center; gap: 12px; }
            .demo-theme-pill { display: flex; align-items: center; gap: 8px; padding: 6px 14px; border-radius: 8px; font-size: 13px; font-weight: 500; background: rgba(37,99,235,0.08); color: var(--prism-violet); border: 1px solid rgba(37,99,235,0.2); cursor: pointer; transition: all 0.2s ease; }
            .demo-theme-pill:hover { background: rgba(37,99,235,0.14); }
            .demo-theme-pill svg { width: 14px; height: 14px; }
            .demo-canvas { padding: 48px; position: relative; background-image: radial-gradient(circle, rgba(255,255,255,0.15) 1px, transparent 1px); background-size: 24px 24px; background-color: #0a0a0c66; display: flex; flex-direction: column; align-items: flex-start; justify-content: center; min-height: 360px; gap: 24px; transition: background-color 0.5s ease; }
            [data-theme="light"] .demo-canvas { background-color: #f4f6fb; background-image: radial-gradient(circle, rgba(37, 99, 235, 0.08) 1px, transparent 1px); }

            /* Counter demo styles */
            .counter-demo { display: inline-flex; align-items: center; justify-content: center; border-radius: 9999px; font-family: 'Zoho Puvi', sans-serif; font-weight: 500; }
            /* Sizes */
            .counter-sm { height: 16px; min-width: 16px; padding: 4px; font-size: 10px; line-height: 14px; }
            .counter-md { height: 20px; min-width: 20px; padding: 4px; font-size: 12px; line-height: 16px; }
            .counter-lg { height: 24px; min-width: 24px; padding: 4px 8px; font-size: 14px; line-height: 20px; }
            /* Subtle styles */
            .counter-subtle-active { background: #D5E0F8; color: #1E52BB; }
            .counter-subtle-critical { background: #FDEBEB; color: #C1181B; }
            .counter-subtle-moderate { background: #FEF8EB; color: #956B11; }
            .counter-subtle-important { background: #FFEEE5; color: #BC4200; }
            .counter-subtle-success { background: #E7F3ED; color: #0A7138; }
            .counter-subtle-default { background: #F0F2F5; color: #2A303D; }
            .counter-subtle-acknowledge { background: #F1EAF8; color: #663399; }
            /* Intense styles */
            .counter-intense-active { background: #2C66DD; color: #FFFFFF; }
            .counter-intense-critical { background: #E42527; color: #FFFFFF; }
            .counter-intense-moderate { background: #F9B21D; color: #000000; }
            .counter-intense-important { background: #E65100; color: #FFFFFF; }
            .counter-intense-success { background: #0C8844; color: #FFFFFF; }
            .counter-intense-default { background: #5F6C89; color: #FFFFFF; }
            .counter-intense-acknowledge { background: #663399; color: #FFFFFF; }

            .demo-row { display: flex; align-items: center; gap: 8px; }
            .demo-row-label { font-size: 13px; font-weight: 600; color: var(--prism-text-muted); min-width: 160px; }
          
  /* ══ Mobile responsive (added globally) ══ */
  .nav-hamburger { display: none; background: transparent; border: none; color: var(--prism-text); padding: 8px; margin-right: 8px; cursor: pointer; border-radius: 8px; align-items: center; justify-content: center; }
  .nav-hamburger:hover { background: var(--prism-surface-hover); }
  .sidebar-backdrop { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 95; opacity: 0; transition: opacity 0.25s ease; }
  .sidebar-backdrop.open { display: block; opacity: 1; }
  .sidebar-mobile-nav { display: none; }

  @media (max-width: 900px) {
    .nav { padding: 0 16px; height: 64px; justify-content: flex-start; gap: 4px; }
    .nav-links { margin-left: auto; }
    .nav-hamburger { display: inline-flex; order: -1; margin-right: 4px; }
