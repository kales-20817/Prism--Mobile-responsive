  </div>

  <script>
    function togCb(label,v){if(label.classList.contains('ci-dis'))return;const bx=label.querySelector('.cb');const isSm=bx.classList.contains('cb-sm');const sz=isSm?'cb-sm':'cb-md';const isE=v==='err';const svW=isSm?10:12,svH=isSm?8:10;
      if(bx.classList.contains('cb-on')||bx.classList.contains('cb-err-on')){bx.className='cb '+sz+(isE?' cb-err-off':' cb-off');bx.innerHTML=''}
      else{bx.className='cb '+sz+(isE?' cb-err-on':' cb-on');bx.innerHTML='<svg width="'+svW+'" height="'+svH+'" fill="none" stroke="#fff" stroke-width="2.5" viewBox="0 0 12 10"><path stroke-linecap="round" stroke-linejoin="round" d="M1 5l3.5 3.5L11 1"/></svg>'}}

    const pgI=[{value:'comments',label:'Comments',checked:true},{value:'mentions',label:'Mentions',checked:false},{value:'reminders',label:'Reminders',checked:false}];
    function togPg(i){if(document.getElementById('pg-state').value==='Disabled')return;pgI[i].checked=!pgI[i].checked;rPg()}
    function rPg(){
      const sz=document.getElementById('pg-size').value,st=document.getElementById('pg-state').value,ly=document.getElementById('pg-layout').value,ht=document.getElementById('pg-help').value;
      const pv=document.getElementById('pg-pv'),co=document.getElementById('pg-co');
      const dk=!document.documentElement.hasAttribute('data-theme');
      const isE=st==='Error',isD=st==='Disabled';
      const bs=sz==='Small'?16:20,lf=sz==='Small'?13:14,gp=sz==='Small'?6:8,svW=sz==='Small'?10:12,svH=sz==='Small'?8:10;
      const bOn=isE?'#E42527':'#006AFF',bOff=isE?'#E42527':isD?(dk?'rgba(255,255,255,.15)':'#C3C9D6'):(dk?'rgba(255,255,255,.35)':'#8893AD');
      const cBgOn=isE?'#E42527':isD?(dk?'rgba(255,255,255,.1)':'#E1E4EB'):'#006AFF';
      const cBgOff=isD?(dk?'rgba(255,255,255,.1)':'#E1E4EB'):'transparent';
      const ckS=isD?(dk?'rgba(255,255,255,.3)':'#8893AD'):'#fff';
      const lC=isD?(dk?'rgba(255,255,255,.3)':'#8893AD'):'var(--prism-text)';
      const hC=isE?'#E42527':isD?(dk?'rgba(255,255,255,.3)':'#8893AD'):'var(--prism-text-muted)';
      const cur=isD?'not-allowed':'pointer',isT=ly==='top';
      const hMsg=isE?'You must grant at least one permission.':'You can change this at any time.';
      const cv=pgI.filter(x=>x.checked).map(x=>'"'+x.value+'"');
      let h='<div style="display:flex;'+(isT?'flex-direction:column;gap:8px;':'align-items:flex-start;gap:16px;')+'">';
      if(!isT)h+='<span style="font-size:13px;color:var(--prism-text-muted);min-width:100px;padding-top:2px">Notify me</span>';
      else h+='<span style="font-size:13px;color:var(--prism-text-muted);margin-bottom:4px">Notify me about</span>';
      const dir=isT?'flex-direction:column;gap:12px;':'gap:16px;';
      h+='<div style="display:flex;flex-direction:column;gap:8px"><div style="display:flex;'+dir+'">';
      pgI.forEach((it,i)=>{const c=it.checked;const hv=isD?'':'onmouseenter="this.style.opacity=0.75" onmouseleave="this.style.opacity=1"';
        h+='<label onclick="togPg('+i+')" style="display:flex;align-items:center;gap:'+gp+'px;cursor:'+cur+';user-select:none;transition:opacity .15s" '+hv+'>';
        h+='<div style="width:'+bs+'px;height:'+bs+'px;border-radius:4px;display:flex;align-items:center;justify-content:center;transition:all .15s ease;';
        if(c){h+='background:'+cBgOn+';border:1.5px solid '+cBgOn+'"><svg width="'+svW+'" height="'+svH+'" fill="none" stroke="'+ckS+'" stroke-width="2.5" viewBox="0 0 12 10"><path stroke-linecap="round" stroke-linejoin="round" d="M1 5l3.5 3.5L11 1"/></svg>'}
        else{h+='border:1.5px solid '+bOff+';background:'+cBgOff+'">'}
        h+='</div><span style="font-size:'+lf+'px;font-weight:500;color:'+lC+'">'+it.label+'</span></label>'});
      h+='</div>';if(ht==='yes')h+='<div style="font-size:13px;color:'+hC+';display:flex;align-items:center;gap:4px;margin-top:4px">'+hMsg+'</div>';
      h+='</div></div>';pv.innerHTML=h;
      let c='&lt;<span style="color:#60a5fa">CheckboxGroup</span>\n';
      c+='  <span style="color:#38bdf8">label</span>=<span style="color:#34d399">"Notify me about"</span>\n';
      if(isT)c+='  <span style="color:#38bdf8">labelPosition</span>=<span style="color:#34d399">"top"</span>\n';
      if(sz!=='Medium')c+='  <span style="color:#38bdf8">size</span>=<span style="color:#34d399">"'+sz+'"</span>\n';
      if(st!=='Default')c+='  <span style="color:#38bdf8">state</span>=<span style="color:#34d399">"'+st+'"</span>\n';
      if(cv.length)c+='  <span style="color:#38bdf8">defaultValue</span>={[<span style="color:#34d399">'+cv.join(', ')+'</span>]}\n';
      else c+='  <span style="color:#38bdf8">defaultValue</span>={[]}\n';
      if(ht==='yes')c+='  <span style="color:#38bdf8">helpText</span>=<span style="color:#34d399">"'+hMsg+'"</span>\n';
      c+='&gt;\n';pgI.forEach(it=>{c+='  &lt;<span style="color:#a78bfa">Checkbox</span> <span style="color:#38bdf8">value</span>=<span style="color:#34d399">"'+it.value+'"</span> <span style="color:#38bdf8">label</span>=<span style="color:#34d399">"'+it.label+'"</span> /&gt;\n'});
      c+='&lt;/<span style="color:#60a5fa">CheckboxGroup</span>&gt;';co.innerHTML='<pre style="margin:0;white-space:pre-wrap">'+c+'</pre>'}
    function cpCode(){const t=document.getElementById('pg-co').innerText;navigator.clipboard.writeText(t).then(()=>{const b=document.getElementById('pg-copy'),o=b.innerHTML;b.innerHTML='<svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Copied!';setTimeout(()=>{b.innerHTML=o},2000)})}
    ['pg-size','pg-state','pg-layout','pg-help'].forEach(id=>{document.getElementById(id).addEventListener('change',rPg)});rPg();

    let _tO=null;
    function uTOC(tid){const tl=document.querySelector('.toc-nav');if(!tl)return;tl.innerHTML='';const ap=document.getElementById(tid);if(!ap)return;ap.querySelectorAll('h2[id],h3[id]').forEach(h=>{if(h.style.display==='none')return;const li=document.createElement('li'),a=document.createElement('a');a.href='#'+h.id;a.className='toc-link';let t=Array.from(h.childNodes).filter(n=>n.nodeType===3).map(n=>n.textContent).join('').trim();if(!t)t=h.innerText;a.textContent=t;a.addEventListener('click',e=>{e.preventDefault();document.getElementById(h.id).scrollIntoView({behavior:'smooth',block:'start'})});li.appendChild(a);tl.appendChild(li)});iSS()}
    function iSS(){if(_tO)_tO.disconnect();const tl=document.querySelectorAll('.toc-link'),ss=Array.from(tl).map(l=>document.getElementById(l.getAttribute('href').slice(1))).filter(Boolean);if(!ss.length)return;_tO=new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting){const id=e.target.getAttribute('id');tl.forEach(l=>l.classList.toggle('active',l.getAttribute('href')==='#'+id))}})},{rootMargin:'-80px 0px -60% 0px',threshold:0});ss.forEach(s=>_tO.observe(s))}
    document.querySelectorAll('.tab-item').forEach(tab=>{tab.addEventListener('click',()=>{document.querySelectorAll('.tab-item').forEach(t=>t.classList.remove('active'));tab.classList.add('active');const m={'Overview':'tab-overview','Usage':'tab-usage','Style':'tab-style','Code':'tab-code','Accessibility':'tab-accessibility'};document.querySelectorAll('.tab-content').forEach(p=>p.style.display='none');const tg=m[tab.textContent.trim()];if(tg){document.getElementById(tg).style.display='block';uTOC(tg)}window.scrollTo({top:0,behavior:'smooth'})})});
    uTOC('tab-overview');
    const themeToggle=document.getElementById('themeToggle'),moonIcon=document.getElementById('moonIcon'),sunIcon=document.getElementById('sunIcon'),currentTheme=localStorage.getItem('theme')||'light';
    if(currentTheme==='dark'){document.documentElement.removeAttribute('data-theme');moonIcon.style.display='block';sunIcon.style.display='none'}
    themeToggle.addEventListener('click',()=>{let th=document.documentElement.getAttribute('data-theme');if(th==='light'){document.documentElement.removeAttribute('data-theme');localStorage.setItem('theme','dark');moonIcon.style.display='block';sunIcon.style.display='none'}else{document.documentElement.setAttribute('data-theme','light');localStorage.setItem('theme','light');moonIcon.style.display='none';sunIcon.style.display='block'}rPg()});

    // Sidebar search filter
    (function(){
      var searchInput = document.querySelector('.sidebar-search input');
      if (!searchInput) return;
      var items = document.querySelectorAll('.sidebar-nav li');
      searchInput.addEventListener('input', function(){
        var q = this.value.toLowerCase().trim();
        items.forEach(function(li){
          var link = li.querySelector('a');
          if (!link) return;
          var text = link.textContent.toLowerCase();
          li.style.display = (!q || text.indexOf(q) !== -1) ? '' : 'none';
        });
      });
      // Cmd+K / Ctrl+K shortcut to focus search
      document.addEventListener('keydown', function(e){
        if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
          e.preventDefault();
          searchInput.focus();
          searchInput.select();
        }
      });
    })();

    // Scroll sidebar to active link on page load
    (function(){
      var active = document.querySelector('.sidebar-link.active');
      if (active) {
        var sidebar = active.closest('.sidebar');
        if (sidebar) {
          var top = active.offsetTop - sidebar.offsetTop - (sidebar.clientHeight / 3);
          sidebar.scrollTop = Math.max(0, top);
        }
      }
    })();

  </script>
<script>
(function(){
  const nav = document.querySelector('.nav');
  if (!nav) return;
  const toggle = () => {
    if (window.scrollY > 10) nav.classList.add('scrolled');
    else nav.classList.remove('scrolled');
  };
  toggle();
  window.addEventListener('scroll', toggle, { passive: true });
})();
</script>
<script>
(function(){
  const hamburger = document.querySelector('.nav-hamburger');
  const sidebar = document.querySelector('.sidebar');
  const backdrop = document.querySelector('.sidebar-backdrop');
  const navLinks = document.querySelector('.nav-links');
  if (!hamburger || !sidebar || !backdrop) return;

  // Build a mobile-only nav section at the top of the sidebar by cloning the nav links
  if (navLinks && !sidebar.querySelector('.sidebar-mobile-nav')) {
    const mobileNav = document.createElement('div');
    mobileNav.className = 'sidebar-mobile-nav';
    const heading = document.createElement('h4');
    heading.textContent = 'Navigate';
    mobileNav.appendChild(heading);
    const ul = document.createElement('ul');
    navLinks.querySelectorAll(':scope > a').forEach(a => {
      const li = document.createElement('li');
      const clone = a.cloneNode(true);
      li.appendChild(clone);
      ul.appendChild(li);
    });
    navLinks.querySelectorAll(':scope > .nav-dropdown > .nav-dropdown-menu > a').forEach(a => {
      const li = document.createElement('li');
      const clone = a.cloneNode(true);
      li.appendChild(clone);
      ul.appendChild(li);
    });
    mobileNav.appendChild(ul);
    sidebar.insertBefore(mobileNav, sidebar.firstChild);
  }

  const open = () => {
    sidebar.classList.add('open');
    backdrop.classList.add('open');
    document.body.classList.add('sidebar-locked');
    hamburger.setAttribute('aria-expanded', 'true');
  };
  const close = () => {
    sidebar.classList.remove('open');
    backdrop.classList.remove('open');
    document.body.classList.remove('sidebar-locked');
    hamburger.setAttribute('aria-expanded', 'false');
  };
  hamburger.addEventListener('click', () => sidebar.classList.contains('open') ? close() : open());
  backdrop.addEventListener('click', close);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && sidebar.classList.contains('open')) close(); });
  sidebar.addEventListener('click', (e) => { if (e.target.closest('a')) close(); });
})();
</script>

<!-- Floating Feedback Button -->
<style>
  .float-cliq-btn {
    position: fixed; bottom: 28px; right: 28px; z-index: 9999;
    display: flex; align-items: center; gap: 10px;
    text-decoration: none;
  }
  .float-cliq-label {
    background: #1a1a2e; color: #fff;
    padding: 7px 14px; border-radius: 8px;
    font-size: 13px; font-weight: 500; white-space: nowrap;
    opacity: 0; transform: translateX(6px);
    transition: opacity 0.2s ease, transform 0.2s ease;
    pointer-events: none; box-shadow: 0 4px 16px rgba(0,0,0,0.25);
  }
  .float-cliq-btn:hover .float-cliq-label {
    opacity: 1; transform: translateX(0);
  }
  .float-cliq-icon {
    width: 52px; height: 52px; border-radius: 50%;
    background: #2563eb; color: #fff;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 4px 20px rgba(37,99,235,0.45);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    flex-shrink: 0;
  }
  .float-cliq-btn:hover .float-cliq-icon {
    transform: translateY(-3px) scale(1.07);
    box-shadow: 0 8px 28px rgba(37,99,235,0.55);
  }
  .float-cliq-btn:active .float-cliq-icon { transform: scale(0.95); }
</style>
