    <div id="feedback" class="feedback-banner" style="display: none;"><div><div class="fb-text">Was this page helpful?</div><div class="fb-sub">Help us improve by sharing your feedback on this component's documentation.</div></div><div style="display:flex;gap:10px"><button class="feedback-btn">Not helpful</button><button class="feedback-btn primary">Yes, helpful</button></div></div>

