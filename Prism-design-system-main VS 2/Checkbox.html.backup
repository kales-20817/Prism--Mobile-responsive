      <div class="page-header-area">
        <h1 class="page-title">Checkbox</h1>
        <p class="page-desc" style="font-size:17px;color:var(--prism-text-muted);line-height:1.7;margin-bottom:28px;max-width:720px">
          A Checkbox Group presents a set of options where users can select one or more items simultaneously. It wraps individual Checkbox items under a shared group label, optional help text, and coordinated validation states.
        </p>
        <nav class="content-tabs">
          <button class="tab-item active">Overview</button>
          <button class="tab-item">Style</button>
          <button class="tab-item">Usage</button>
          <button class="tab-item">Code</button>
          <button class="tab-item">Accessibility</button>
        </nav>
      </div>
      <div class="main-content-area">
        <div class="main-content-inner">

        <!-- ——— OVERVIEW TAB ——— -->
        <div class="tab-content" id="tab-overview">

        <h3 id="anatomy" class="doc-h3">Anatomy</h3>
        <style>
          .anatomy-diagram{background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:16px;padding:48px 40px;margin-bottom:28px;position:relative;overflow:hidden}
          [data-theme="light"] .anatomy-diagram{background:#fff;border:1px solid rgba(37,99,235,.07);box-shadow:0 2px 12px rgba(37,99,235,.05)}
          .anatomy-diagram::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,#2563eb,#60a5fa,#06b6d4)}
          .am{width:24px;height:24px;border-radius:50%;flex-shrink:0;background:linear-gradient(135deg,#2563eb,#3b82f6);color:#fff;font-size:11px;font-weight:700;display:inline-flex;align-items:center;justify-content:center;box-shadow:0 2px 10px rgba(37,99,235,.35);position:absolute;z-index:2}
          .ami{width:22px;height:22px;border-radius:50%;flex-shrink:0;background:linear-gradient(135deg,#2563eb,#3b82f6);color:#fff;font-size:11px;font-weight:700;display:inline-flex;align-items:center;justify-content:center;box-shadow:0 2px 10px rgba(37,99,235,.35)}
          .ac{position:absolute;background:#2563eb}
          .al{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
          .ali{display:flex;align-items:flex-start;gap:14px;padding:20px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:14px;transition:all .25s cubic-bezier(.4,0,.2,1)}
          .ali:hover{border-color:rgba(37,99,235,.3);transform:translateY(-2px);box-shadow:0 6px 20px rgba(37,99,235,.08)}
          [data-theme="light"] .ali{background:#fff;border:1px solid rgba(37,99,235,.07);box-shadow:0 1px 4px rgba(37,99,235,.04)}
          .ali strong{display:block;font-size:14.5px;font-weight:600;color:var(--prism-text);margin-bottom:6px}
          .ali span:not(.ami){font-size:13px;line-height:1.55;color:var(--prism-text-muted)}
          @keyframes apulse{0%,100%{box-shadow:0 2px 10px rgba(37,99,235,.35)}50%{box-shadow:0 2px 16px rgba(37,99,235,.6)}}
          .am:hover{animation:apulse 1.2s ease-in-out infinite}
          .acg{position:relative;border:2px dashed rgba(37,99,235,.25);border-radius:16px;padding:64px 48px;margin:20px auto;max-width:560px}
          .acg::after{content:'Checkbox Group';position:absolute;top:-12px;left:24px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--prism-violet);background:var(--prism-surface);padding:2px 10px;border-radius:4px}
          [data-theme="light"] .acg::after{background:#fff}
          .acb{width:20px;height:20px;border-radius:4px;display:flex;align-items:center;justify-content:center;flex-shrink:0;box-sizing:border-box}
          .acb-on{background:#006AFF}
          .acb-off{border:1.5px solid #8893AD;background:transparent}
          html:not([data-theme="light"]) .acb-off{border-color:rgba(255,255,255,.35)}
        </style>

        <div class="anatomy-diagram" style="padding:64px 80px;">
          <div class="acg" style="overflow:visible;">
            <!-- 1 Group Label — marker left of acg, line points right to label -->
            <span class="am" style="top:56px;left:-64px">1</span>
            <div class="ac" style="top:66px;left:-40px;width:34px;height:2px"></div>

            <!-- 3 Checkbox items — marker right of acg, line points left -->
            <span class="am" style="top:50%;right:-64px;transform:translateY(-50%)">3</span>
            <div class="ac" style="top:50%;right:-40px;width:34px;height:2px;transform:translateY(-50%)"></div>

            <!-- 6 Help text — marker left of acg, line points right -->
            <span class="am" style="bottom:50px;left:-64px">6</span>
            <div class="ac" style="bottom:60px;left:-40px;width:34px;height:2px"></div>

            <div style="display:flex;align-items:center;gap:8px;margin-bottom:44px;position:relative">
              <span style="font-size:14px;font-weight:500;color:var(--prism-text-muted)">Notify me about</span>
              <div style="position:relative;display:inline-flex;align-items:center;">
                <svg width="18" height="18" fill="none" stroke="var(--prism-text-muted)" stroke-width="2" viewBox="0 0 24 24" style="opacity:.5"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
                <!-- 2 Info icon — marker above, line down -->
                <span class="am" style="top:-36px;left:50%;transform:translateX(-50%)">2</span>
                <div class="ac" style="top:-12px;left:calc(50% - 1px);width:2px;height:10px"></div>
              </div>
            </div>

            <div style="display:flex;align-items:center;gap:24px;margin-bottom:44px;position:relative">
              <div style="display:inline-flex;align-items:center;gap:8px;position:relative">
                <div style="position:relative;display:inline-flex;">
                  <div class="acb acb-on"><svg width="12" height="10" fill="none" stroke="#fff" stroke-width="2.5" viewBox="0 0 12 10"><path stroke-linecap="round" stroke-linejoin="round" d="M1 5l3.5 3.5L11 1"/></svg></div>
                  <!-- 4 Checkbox box — marker below, line up -->
                  <span class="am" style="bottom:-36px;left:50%;transform:translateX(-50%)">4</span>
                  <div class="ac" style="bottom:-14px;left:calc(50% - 1px);width:2px;height:10px"></div>
                </div>
                <div style="position:relative;display:inline-flex;">
                  <span style="font-size:14px;font-weight:500;color:var(--prism-text)">Comments</span>
                  <!-- 5 Option label — marker above, line down -->
                  <span class="am" style="top:-36px;left:50%;transform:translateX(-50%)">5</span>
                  <div class="ac" style="top:-12px;left:calc(50% - 1px);width:2px;height:10px"></div>
                </div>
              </div>
              <div style="display:inline-flex;align-items:center;gap:8px"><div class="acb acb-off"></div><span style="font-size:14px;font-weight:500;color:var(--prism-text)">Mentions</span></div>
              <div style="display:inline-flex;align-items:center;gap:8px"><div class="acb acb-off"></div><span style="font-size:14px;font-weight:500;color:var(--prism-text)">Reminders</span></div>
            </div>

            <div style="display:flex;align-items:center;gap:6px;position:relative">
              <svg width="14" height="14" fill="none" stroke="var(--prism-text-muted)" stroke-width="2" viewBox="0 0 24 24" style="opacity:.5"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
              <span style="font-size:13px;color:var(--prism-text-muted)">You can change this at any time in your settings.</span>
            </div>
          </div>
        </div>

        <div class="al">
          <div class="ali"><span class="ami">1</span><div><strong>Group Label</strong><span>Title for the option set. Uses <code style="font-size:12px;padding:1px 6px;border-radius:4px;background:rgba(37,99,235,.06);color:var(--prism-violet)">Text/Text-Tertiary</code>. Frames the choices.</span></div></div>
          <div class="ali"><span class="ami">2</span><div><strong>Info Icon</strong><span>Optional tooltip icon next to the label. Provides additional context on hover or focus.</span></div></div>
          <div class="ali"><span class="ami">3</span><div><strong>Checkbox Items</strong><span>Row of selectable options. Horizontal (Left) or vertical (Top). Multiple can be checked simultaneously.</span></div></div>
          <div class="ali"><span class="ami">4</span><div><strong>Checkbox Box</strong><span>Clickable square. 20 &times; 20 px (Medium) or 16 &times; 16 px (Small). 4 px radius. Blue fill when checked.</span></div></div>
          <div class="ali"><span class="ami">5</span><div><strong>Option Label</strong><span>Text beside each checkbox. Uses <code style="font-size:12px;padding:1px 6px;border-radius:4px;background:rgba(37,99,235,.06);color:var(--prism-violet)">Text/Text-Primary</code>. Keep 1&ndash;5 words.</span></div></div>
          <div class="ali"><span class="ami">6</span><div><strong>Help Text</strong><span>Guidance below options. <code style="font-size:12px;padding:1px 6px;border-radius:4px;background:rgba(37,99,235,.06);color:var(--prism-violet)">Text/Text-Quaternary</code> default, <code style="font-size:12px;padding:1px 6px;border-radius:4px;background:rgba(228,37,39,.08);color:#E42527">Text/Text-Error</code> on error.</span></div></div>
        </div>

        <hr class="doc-divider"/>

        <!-- Live Demo -->
        <div style="margin-bottom:64px">
          <h2 id="live-demo" class="doc-section-title" style="margin-bottom:8px">Preview</h2>
          <p class="doc-section-subtitle" style="margin-bottom:28px">Click any checkbox to toggle it. Multiple items per group can be active simultaneously.</p>
          <style>
            .demo-container{border:1px solid var(--prism-border);border-radius:16px;overflow:hidden}
            .demo-toolbar{display:flex;align-items:center;padding:12px 20px;background:var(--prism-surface);border-bottom:1px solid var(--prism-border)}
            [data-theme="light"] .demo-container{border:1px solid rgba(37,99,235,.14);box-shadow:0 2px 16px rgba(37,99,235,.08)}
            [data-theme="light"] .demo-toolbar{background:rgba(255,255,255,.7);border-bottom:1px solid rgba(37,99,235,.06)}
            .demo-pill{padding:6px 14px;border-radius:8px;font-size:13px;font-weight:500;background:rgba(37,99,235,.08);color:var(--prism-violet);border:1px solid rgba(37,99,235,.2)}
            .demo-canvas{padding:48px 64px;background-color:#0a0a0c66;background-image:radial-gradient(circle,rgba(255,255,255,.15) 1px,transparent 1px);background-size:24px 24px;display:flex;flex-direction:column;gap:48px;min-height:320px;transition:background-color .5s ease}
            [data-theme="light"] .demo-canvas{background-color:#f4f6fb;background-image:radial-gradient(circle,rgba(37,99,235,.08) 1px,transparent 1px)}
            .cg{display:flex;flex-direction:column;gap:8px}
            .cg-title{font-size:13px;font-weight:600;color:var(--prism-text-muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:4px}
            .cg-row{display:flex;align-items:center;gap:16px;flex-wrap:wrap}
            .ci{display:flex;align-items:center;gap:8px;cursor:pointer;user-select:none;transition:opacity .15s}
            .ci:hover{opacity:.8}
            .cb{flex-shrink:0;border-radius:4px;display:flex;align-items:center;justify-content:center;transition:all .2s cubic-bezier(.4,0,.2,1);box-sizing:border-box}
            .cb-md{width:20px;height:20px}.cb-sm{width:16px;height:16px}
            .cb-off{border:1.5px solid #8893AD;background:transparent}
            html:not([data-theme="light"]) .cb-off{border-color:rgba(255,255,255,.35)}
            .cb-on{background:#006AFF;border:1.5px solid #006AFF}
            .cb-err-off{border:1.5px solid #E42527;background:transparent}
            .cb-err-on{background:#E42527;border:1.5px solid #E42527}
            .cb-dis{border:1.5px solid #C3C9D6;background:#E1E4EB;cursor:not-allowed}
            html:not([data-theme="light"]) .cb-dis{border-color:rgba(255,255,255,.15);background:rgba(255,255,255,.1)}
            .cl{font-weight:500;color:var(--prism-text)}
            .cl-md{font-size:14px}.cl-sm{font-size:13px}
            .cl-dis{color:#8893AD;cursor:not-allowed}
            html:not([data-theme="light"]) .cl-dis{color:rgba(255,255,255,.3)}
            .ch{font-size:13px;color:var(--prism-text-muted);display:flex;align-items:center;gap:4px}
            .ch-err{color:#E42527}
            .ci-dis{cursor:not-allowed;opacity:.6}.ci-dis:hover{opacity:.6}
          </style>
          <div class="demo-container">
            <div class="demo-toolbar"><div class="demo-pill">Preview</div></div>
            <div class="demo-canvas">
              <div class="cg"><div class="cg-title">Default &mdash; Medium</div>
                <div class="cg-row">
                  <label class="ci" onclick="togCb(this)"><div class="cb cb-md cb-on"><svg width="12" height="10" fill="none" stroke="#fff" stroke-width="2.5" viewBox="0 0 12 10"><path stroke-linecap="round" stroke-linejoin="round" d="M1 5l3.5 3.5L11 1"/></svg></div><span class="cl cl-md">Comments</span></label>
                  <label class="ci" onclick="togCb(this)"><div class="cb cb-md cb-off"></div><span class="cl cl-md">Mentions</span></label>
                  <label class="ci" onclick="togCb(this)"><div class="cb cb-md cb-off"></div><span class="cl cl-md">Reminders</span></label>
                </div>
                <div class="ch"><svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg> You can change this at any time in your settings.</div>
              </div>
              <div class="cg"><div class="cg-title">Default &mdash; Small</div>
                <div class="cg-row">
                  <label class="ci" onclick="togCb(this)"><div class="cb cb-sm cb-on"><svg width="10" height="8" fill="none" stroke="#fff" stroke-width="2.5" viewBox="0 0 12 10"><path stroke-linecap="round" stroke-linejoin="round" d="M1 5l3.5 3.5L11 1"/></svg></div><span class="cl cl-sm">Read</span></label>
                  <label class="ci" onclick="togCb(this)"><div class="cb cb-sm cb-on"><svg width="10" height="8" fill="none" stroke="#fff" stroke-width="2.5" viewBox="0 0 12 10"><path stroke-linecap="round" stroke-linejoin="round" d="M1 5l3.5 3.5L11 1"/></svg></div><span class="cl cl-sm">Write</span></label>
                  <label class="ci" onclick="togCb(this)"><div class="cb cb-sm cb-off"></div><span class="cl cl-sm">Delete</span></label>
                  <label class="ci" onclick="togCb(this)"><div class="cb cb-sm cb-off"></div><span class="cl cl-sm">Admin</span></label>
                </div>
              </div>
              <div class="cg"><div class="cg-title">Error State</div>
                <div class="cg-row">
                  <label class="ci" onclick="togCb(this,'err')"><div class="cb cb-md cb-err-off"></div><span class="cl cl-md">Read</span></label>
                  <label class="ci" onclick="togCb(this,'err')"><div class="cb cb-md cb-err-off"></div><span class="cl cl-md">Write</span></label>
                  <label class="ci" onclick="togCb(this,'err')"><div class="cb cb-md cb-err-off"></div><span class="cl cl-md">Delete</span></label>
                </div>
                <div class="ch ch-err"><svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg> You must grant at least one permission to continue.</div>
              </div>
              <div class="cg"><div class="cg-title">Disabled State</div>
                <div class="cg-row">
                  <label class="ci ci-dis"><div class="cb cb-md cb-dis"><svg width="12" height="10" fill="none" stroke="#8893AD" stroke-width="2.5" viewBox="0 0 12 10"><path stroke-linecap="round" stroke-linejoin="round" d="M1 5l3.5 3.5L11 1"/></svg></div><span class="cl cl-md cl-dis">Enabled option</span></label>
                  <label class="ci ci-dis"><div class="cb cb-md cb-dis"></div><span class="cl cl-md cl-dis">Disabled option</span></label>
                  <label class="ci ci-dis"><div class="cb cb-md cb-dis"></div><span class="cl cl-md cl-dis">Another option</span></label>
                </div>
                <div class="ch" style="color:#8893AD">This group is currently not editable.</div>
              </div>
            </div>
          </div>
        </div>

        <div class="doc-section">
          <h3 id="content-guidelines" class="doc-h3">Content Guidelines<span class="h3-badge" style="background:rgba(37,99,235,.1);color:var(--prism-violet)">Recommended</span></h3>
          <div class="do-dont-grid">
            <div class="do-card"><span class="card-label"><svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Do</span>
              <ul class="doc-list" style="border:none;background:transparent;padding:0"><li style="border:none;background:transparent;padding-left:20px">Use <code>Left</code> layout (default) for standard web forms.</li><li style="border:none;background:transparent;padding-left:20px">Show a descriptive group label that frames the choices.</li><li style="border:none;background:transparent;padding-left:20px">Use <code>helpText</code> to clarify constraints (e.g. &ldquo;Select up to 3&rdquo;).</li><li style="border:none;background:transparent;padding-left:20px">Keep option labels concise (1&ndash;5 words).</li></ul>
            </div>
            <div class="dont-card"><span class="card-label"><svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg> Don't</span>
              <ul class="doc-list" style="border:none;background:transparent;padding:0"><li style="border:none;background:transparent;padding-left:20px">Leave the group unlabelled.</li><li style="border:none;background:transparent;padding-left:20px">Show only a red border without an error message.</li><li style="border:none;background:transparent;padding-left:20px">Write full sentences as checkbox labels.</li><li style="border:none;background:transparent;padding-left:20px">Pre-check options for commercial/legal consent.</li></ul>
            </div>
          </div>
        </div>
        </div>

        <!-- ——— STYLE TAB ——— -->
        <div class="tab-content" id="tab-style" style="display:none;padding-top:32px">
          <h2 id="style-overview" class="doc-section-title">Style</h2>
          <p class="doc-section-subtitle">Design tokens, color mappings, and spacing tokens that define the Checkbox's visual language.</p>

          <div class="doc-section">
            <h2 id="variants" class="doc-section-title">Variants</h2>
            <p class="doc-section-subtitle">Two label position variants control how the group label relates to checkbox items.</p>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:24px">
              <div style="padding:32px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px">
                <div style="font-size:15px;font-weight:600;color:var(--prism-text);margin-bottom:20px;display:flex;align-items:center;gap:8px"><span style="font-size:11px;font-weight:700;padding:3px 10px;border-radius:999px;background:rgba(37,99,235,.1);color:var(--prism-violet)">DEFAULT</span> Left Layout</div>
                <div style="display:flex;align-items:flex-start;gap:16px"><span style="font-size:13px;color:var(--prism-text-muted);min-width:80px;padding-top:2px">Group Label</span>
                  <div style="display:flex;gap:14px"><div style="display:flex;align-items:center;gap:6px"><div style="width:16px;height:16px;border-radius:3px;background:#006AFF;display:flex;align-items:center;justify-content:center"><svg width="8" height="6" fill="none" stroke="#fff" stroke-width="2.5" viewBox="0 0 12 10"><path d="M1 5l3.5 3.5L11 1"/></svg></div><span style="font-size:12px;color:var(--prism-text)">A</span></div><div style="display:flex;align-items:center;gap:6px"><div style="width:16px;height:16px;border-radius:3px;border:1.5px solid #8893AD"></div><span style="font-size:12px;color:var(--prism-text)">B</span></div><div style="display:flex;align-items:center;gap:6px"><div style="width:16px;height:16px;border-radius:3px;border:1.5px solid #8893AD"></div><span style="font-size:12px;color:var(--prism-text)">C</span></div></div>
                </div>
              </div>
              <div style="padding:32px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px">
                <div style="font-size:15px;font-weight:600;color:var(--prism-text);margin-bottom:20px;display:flex;align-items:center;gap:8px"><span style="font-size:11px;font-weight:700;padding:3px 10px;border-radius:999px;background:rgba(230,81,0,.1);color:#E65100">SPECIAL</span> Top Layout</div>
                <div style="display:flex;flex-direction:column;gap:10px"><span style="font-size:13px;color:var(--prism-text-muted)">Group Label</span>
                  <div style="display:flex;flex-direction:column;gap:8px;padding-left:4px"><div style="display:flex;align-items:center;gap:6px"><div style="width:16px;height:16px;border-radius:3px;background:#006AFF;display:flex;align-items:center;justify-content:center"><svg width="8" height="6" fill="none" stroke="#fff" stroke-width="2.5" viewBox="0 0 12 10"><path d="M1 5l3.5 3.5L11 1"/></svg></div><span style="font-size:12px;color:var(--prism-text)">Option A</span></div><div style="display:flex;align-items:center;gap:6px"><div style="width:16px;height:16px;border-radius:3px;border:1.5px solid #8893AD"></div><span style="font-size:12px;color:var(--prism-text)">Option B</span></div><div style="display:flex;align-items:center;gap:6px"><div style="width:16px;height:16px;border-radius:3px;border:1.5px solid #8893AD"></div><span style="font-size:12px;color:var(--prism-text)">Option C</span></div></div>
                </div>
              </div>
            </div>
          </div>
          <hr class="doc-divider"/>

          <div class="doc-section">
            <h2 id="states" class="doc-section-title">States</h2>
            <p class="doc-section-subtitle">Checkboxes support three group states, each with distinct visual treatments.</p>
            <style>.st-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-top:24px}.st-card{padding:32px 24px;border-radius:14px;background:var(--prism-surface);border:1px solid var(--prism-border);text-align:center;transition:all .25s ease;display:flex;flex-direction:column;align-items:center;gap:16px}[data-theme="light"] .st-card{background:#fff;border:1px solid rgba(37,99,235,.07);box-shadow:0 1px 4px rgba(37,99,235,.04)}.st-card:hover{border-color:rgba(37,99,235,.3);transform:translateY(-3px);box-shadow:0 8px 24px rgba(37,99,235,.08)}.st-t{font-size:14px;font-weight:600;color:var(--prism-text)}.st-d{font-size:12.5px;color:var(--prism-text-muted);line-height:1.5}</style>
            <div class="st-grid">
              <div class="st-card"><div style="display:flex;align-items:center;gap:10px"><div style="width:20px;height:20px;border-radius:4px;background:#006AFF;display:flex;align-items:center;justify-content:center"><svg width="12" height="10" fill="none" stroke="#fff" stroke-width="2.5" viewBox="0 0 12 10"><path stroke-linecap="round" stroke-linejoin="round" d="M1 5l3.5 3.5L11 1"/></svg></div><span style="font-size:14px;font-weight:500;color:var(--prism-text)">Option</span></div><div class="st-t">Default</div><div class="st-d">Blue fill on checked box, white checkmark</div></div>
              <div class="st-card"><div style="display:flex;align-items:center;gap:10px"><div style="width:20px;height:20px;border-radius:4px;border:1.5px solid #E42527"></div><span style="font-size:14px;font-weight:500;color:var(--prism-text)">Option</span></div><div class="st-t">Error</div><div class="st-d">Red fill on checked, red border on unchecked</div></div>
              <div class="st-card"><div style="display:flex;align-items:center;gap:10px"><div style="width:20px;height:20px;border-radius:4px;background:#E1E4EB;border:1.5px solid #C3C9D6"></div><span style="font-size:14px;font-weight:500;color:#8893AD">Option</span></div><div class="st-t">Disabled</div><div class="st-d">Greyed-out box, label, non-interactive</div></div>
            </div>
          </div>
          <hr class="doc-divider"/>

          <div class="doc-section">
            <h2 id="sizes" class="doc-section-title">Sizes</h2>
            <p class="doc-section-subtitle">Two sizes to fit different layout contexts. Both share 4 px border radius.</p>
            <style>.sz-t{width:100%;border-collapse:collapse;font-size:14px}.sz-t th{text-align:left;padding:14px 12px;color:var(--prism-text-muted);font-weight:600;font-size:12px;text-transform:uppercase;letter-spacing:.05em;border-bottom:2px solid var(--prism-border)}.sz-t td{padding:16px 12px;border-bottom:1px solid var(--prism-border);color:var(--prism-text);vertical-align:middle}.sz-t tr:hover td{background:rgba(37,99,235,.02)}.sz-t code{font-family:'JetBrains Mono',monospace;font-size:12.5px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,.06);color:var(--prism-violet)}</style>
            <table class="sz-t"><thead><tr><th>Size</th><th>Box</th><th>Radius</th><th>Label Font</th><th>Box-Label Gap</th><th>Preview</th></tr></thead><tbody>
              <tr><td><strong>Medium</strong></td><td>20 &times; 20 px</td><td>4 px</td><td>body/Default/Medium (14 px)</td><td>8 px</td><td><div style="display:flex;align-items:center;gap:8px"><div style="width:20px;height:20px;border-radius:4px;background:#006AFF;display:flex;align-items:center;justify-content:center"><svg width="12" height="10" fill="none" stroke="#fff" stroke-width="2.5" viewBox="0 0 12 10"><path stroke-linecap="round" stroke-linejoin="round" d="M1 5l3.5 3.5L11 1"/></svg></div><span style="font-size:14px;font-weight:500">Label</span></div></td></tr>
              <tr><td><strong>Small</strong></td><td>16 &times; 16 px</td><td>4 px</td><td>body/Small/Medium (13 px)</td><td>6 px</td><td><div style="display:flex;align-items:center;gap:6px"><div style="width:16px;height:16px;border-radius:4px;background:#006AFF;display:flex;align-items:center;justify-content:center"><svg width="10" height="8" fill="none" stroke="#fff" stroke-width="2.5" viewBox="0 0 12 10"><path stroke-linecap="round" stroke-linejoin="round" d="M1 5l3.5 3.5L11 1"/></svg></div><span style="font-size:13px;font-weight:500">Label</span></div></td></tr>
            </tbody></table>
          </div>
          <hr class="doc-divider"/>

          <div class="doc-section"><h3 id="color-tokens" class="doc-h3">Color Tokens<span class="h3-badge" style="background:rgba(37,99,235,.1);color:var(--prism-violet)">Tokens</span></h3>
            <table class="sz-t"><thead><tr><th>Token</th><th>Role</th><th>Value</th></tr></thead><tbody>
              <tr><td><code>BG-Button-Primary</code></td><td>Checked box fill (Default)</td><td>#006AFF</td></tr>
              <tr><td><code>BG-Error-Solid</code></td><td>Checked box fill (Error)</td><td>#E42527</td></tr>
              <tr><td><code>BG-Primary-alt</code></td><td>Unchecked box fill</td><td>Transparent</td></tr>
              <tr><td><code>BG-Disabled_subtle</code></td><td>Box fill (Disabled)</td><td>#E1E4EB</td></tr>
              <tr><td><code>Text/Text-White</code></td><td>Checkmark stroke</td><td>#FFFFFF</td></tr>
              <tr><td><code>Border/Border-Primary</code></td><td>Unchecked border (Default)</td><td>#8893AD</td></tr>
              <tr><td><code>Border/Border-Error</code></td><td>Unchecked border (Error)</td><td>#E42527</td></tr>
              <tr><td><code>Border/Border-Disabled</code></td><td>Border (Disabled)</td><td>#C3C9D6</td></tr>
              <tr><td><code>Text/Text-Primary</code></td><td>Checkbox label (Default)</td><td>#15181E</td></tr>
              <tr><td><code>Text/Text-Disabled</code></td><td>Label (Disabled)</td><td>#8893AD</td></tr>
              <tr><td><code>Text/Text-Tertiary</code></td><td>Group label colour</td><td>&mdash;</td></tr>
              <tr><td><code>Text/Text-Quaternary</code></td><td>Help text (Default)</td><td>&mdash;</td></tr>
              <tr><td><code>Text/Text-Error</code></td><td>Help text (Error)</td><td>#E42527</td></tr>
            </tbody></table>
          </div>
          <hr class="doc-divider"/>

          <div class="doc-section"><h3 id="spacing-tokens" class="doc-h3">Spacing Tokens</h3>
            <table class="sz-t"><thead><tr><th>Element</th><th>Small</th><th>Medium</th><th>Token</th></tr></thead><tbody>
              <tr><td>Box (checkbox square)</td><td>16 &times; 16 px</td><td>20 &times; 20 px</td><td>&mdash;</td></tr>
              <tr><td>Box corner radius</td><td>4 px</td><td>4 px</td><td><code>radius/4</code></td></tr>
              <tr><td>Box &harr; Label gap</td><td>6 px</td><td>8 px</td><td><code>spacing/6</code> / <code>spacing/8</code></td></tr>
              <tr><td>Gap between items (horizontal)</td><td>16 px</td><td>16 px</td><td><code>spacing/16</code></td></tr>
              <tr><td>Gap between items (vertical)</td><td>12 px</td><td>12 px</td><td><code>spacing/12</code></td></tr>
              <tr><td>Header &harr; Checkbox Items</td><td>8 px</td><td>8 px</td><td><code>spacing/8</code></td></tr>
              <tr><td>Help icon</td><td>20 &times; 20 px</td><td>20 &times; 20 px</td><td>&mdash;</td></tr>
            </tbody></table>
          </div>
          <hr class="doc-divider"/>

          <div class="doc-section"><h3 id="corner-radius-border-radius" class="doc-h3">Corner Radius (Border Radius)</h3>
            <p class="doc-section-subtitle">Checkboxes use a rounded-rectangle with a fixed 4 px corner radius across all sizes.</p>
            <div style="display:flex;gap:24px;flex-wrap:wrap;margin-top:24px">
              <div style="flex:1;min-width:200px;padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;text-align:center">
                <div style="width:48px;height:48px;border:2px dashed #006AFF;border-radius:4px;margin:0 auto 16px;display:flex;align-items:center;justify-content:center;background:rgba(0,106,255,.05);color:#006AFF;font-weight:600;font-size:13px">4px</div>
                <div style="font-size:14px;font-weight:600;color:var(--prism-text)">radius/radius-xxs</div>
                <div style="font-size:12px;color:var(--prism-text-muted);margin-top:4px">Checkbox box (all sizes)</div>
              </div>
              <div style="flex:1;min-width:200px;padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;text-align:center">
                <div style="width:80px;height:40px;border:2px dashed #006AFF;border-radius:8px;margin:0 auto 16px;display:flex;align-items:center;justify-content:center;background:rgba(0,106,255,.05);color:#006AFF;font-weight:600;font-size:13px">8px</div>
                <div style="font-size:14px;font-weight:600;color:var(--prism-text)">radius/radius-s</div>
                <div style="font-size:12px;color:var(--prism-text-muted);margin-top:4px">Group container</div>
              </div>
            </div>
          </div>
          <hr class="doc-divider"/>

          <div class="doc-section"><h3 id="typography-family" class="doc-h3">Typography Family</h3>
            <p class="doc-section-subtitle">The primary font family is <strong>Zoho Puvi</strong>.</p>
            <div style="background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:16px;padding:32px;margin-top:16px">
              <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:24px;border-bottom:1px solid var(--prism-border);padding-bottom:24px">
                <div style="font-size:64px;font-weight:500;line-height:1;color:var(--prism-text);letter-spacing:-2px">Aa</div>
                <div style="text-align:right"><div style="font-size:20px;font-weight:600;color:var(--prism-text)">Zoho Puvi</div><div style="font-size:14px;color:var(--prism-text-muted);margin-top:4px">Primary System Font</div></div>
              </div>
              <table class="sz-t"><thead><tr><th>Size</th><th>Token</th><th>Font Size</th><th>Line Height</th></tr></thead><tbody>
                <tr><td>Medium</td><td><code>body/Default/Medium</code></td><td>14px</td><td>20px</td></tr>
                <tr><td>Small</td><td><code>body/Small/Medium</code></td><td>13px</td><td>18px</td></tr>
              </tbody></table>
            </div>
          </div>
        </div>

        <!-- ——— USAGE TAB ——— -->
        <div class="tab-content" id="tab-usage" style="display:none;padding-top:32px">
          <div class="doc-section">
            <h2 id="when-to-use" class="doc-section-title">When and Where to Use</h2>
            <p class="doc-section-subtitle">A Checkbox Group lets users select none, one, or multiple options from a visible set of choices.</p>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:24px">
              <div style="padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px">
                <h3 id="when-to-use-details" style="font-size:15px;font-weight:600;color:var(--prism-text);margin-bottom:16px;display:flex;align-items:center;gap:8px"><svg width="20" height="20" fill="none" stroke="#2563eb" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> When to use</h3>
                <ul class="doc-list" style="border:none;background:transparent;padding-left:20px;font-size:14.5px"><li style="border:none;background:transparent;margin-bottom:8px">When users may select <strong>none, one, or multiple</strong> options from a list.</li><li style="border:none;background:transparent;margin-bottom:8px">When all options should be visible simultaneously.</li><li style="border:none;background:transparent;margin-bottom:8px">For preference, settings, or filter panels where multiple concurrent selections are valid.</li><li style="border:none;background:transparent">When the number of options is small (2&ndash;8 items).</li></ul>
              </div>
              <div style="padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px">
                <h3 id="when-not-to-use" style="font-size:15px;font-weight:600;color:var(--prism-text);margin-bottom:16px;display:flex;align-items:center;gap:8px"><svg width="20" height="20" fill="none" stroke="#e42527" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg> When NOT to use</h3>
                <ul class="doc-list" style="border:none;background:transparent;padding-left:20px;font-size:14.5px"><li style="border:none;background:transparent;margin-bottom:8px"><strong>Exactly one selection</strong> &rarr; use Radio Group.</li><li style="border:none;background:transparent;margin-bottom:8px"><strong>Binary on/off with immediate effect</strong> &rarr; use Toggle.</li><li style="border:none;background:transparent;margin-bottom:8px"><strong>Long list of options</strong> &rarr; use Multi-select Dropdown.</li><li style="border:none;background:transparent"><strong>Single opt-in</strong> (e.g. &ldquo;I agree&rdquo;) &rarr; standalone Checkbox.</li></ul>
              </div>
            </div>
          </div>
          <hr class="doc-divider"/>
          <div class="doc-section">
            <h2 id="alignment-placement" class="doc-section-title">Alignment &amp; Placement</h2>
            <p class="doc-section-subtitle">Consistent placement makes it easier for users to locate and interact with checkbox groups.</p>
            <ul class="doc-list"><li><strong>Forms:</strong> Place checkbox groups vertically aligned with other form fields. Group label sits at the same level as input labels.</li><li><strong>Settings panels:</strong> Left layout is preferred; each group occupies one row with the label flush-left and a header width of 240 px.</li><li><strong>Mobile viewports:</strong> Switch to Top layout so options stack vertically with larger touch targets.</li><li><strong>Dialogs:</strong> Checkbox groups in dialogs should be top-aligned with the content area. Keep groups compact (max 5&ndash;6 options).</li></ul>
          </div>
          <hr class="doc-divider"/>
          <div class="doc-section">
            <h2 id="detailed-guidelines" class="doc-section-title">Complete Do's and Don'ts</h2>
            <p class="doc-section-subtitle">Visual and interaction guidelines for effective, accessible checkbox groups.</p>
            <div class="do-dont-grid">
              <div class="do-card"><span class="card-label"><svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Do</span>
                <ul class="doc-list" style="border:none;background:transparent;padding:0"><li style="border:none;background:transparent;padding-left:20px"><strong>Default layout:</strong> Use Left layout for standard web forms &mdash; most scannable.</li><li style="border:none;background:transparent;padding-left:20px"><strong>Top for mobile:</strong> Use Top only when horizontal space is severely constrained.</li><li style="border:none;background:transparent;padding-left:20px"><strong>Show help text:</strong> Clarify constraints like &ldquo;Select up to 3&rdquo;.</li><li style="border:none;background:transparent;padding-left:20px"><strong>Error + message:</strong> Always pair Error state with a descriptive message.</li><li style="border:none;background:transparent;padding-left:20px"><strong>Smart defaults:</strong> Pre-check options that apply to most users when appropriate.</li></ul>
              </div>
              <div class="dont-card"><span class="card-label"><svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg> Don't</span>
                <ul class="doc-list" style="border:none;background:transparent;padding:0"><li style="border:none;background:transparent;padding-left:20px"><strong>No Top by default:</strong> Don&rsquo;t use Top layout just because it feels familiar.</li><li style="border:none;background:transparent;padding-left:20px"><strong>No unlabelled groups:</strong> Every checkbox group needs a descriptive label.</li><li style="border:none;background:transparent;padding-left:20px"><strong>No red-only errors:</strong> Don&rsquo;t show only a red border with no error message.</li><li style="border:none;background:transparent;padding-left:20px"><strong>No sentence labels:</strong> Don&rsquo;t write full sentences as checkbox labels.</li><li style="border:none;background:transparent;padding-left:20px"><strong>No pre-checked consent:</strong> Never pre-check for commercial/legal consent.</li></ul>
              </div>
            </div>
          </div>
          <hr class="doc-divider"/>
          <div class="doc-section">
            <h2 id="related" class="doc-section-title">Related</h2>
            <p class="doc-section-subtitle">Components that complement or can be used instead of the Checkbox Group.</p>
            <div class="related-grid">
              <a href="Radio-button.html" class="related-chip"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/></svg> Radio Group</a>
              <a href="Switch.html" class="related-chip"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="5" width="22" height="14" rx="7"/><circle cx="8" cy="12" r="3"/></svg> Toggle</a>
              <a href="Select.html" class="related-chip"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="14" rx="2"/><polyline points="8 10 12 14 16 10"/></svg> Select Box</a>
              <a href="Dropdown.html" class="related-chip"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M8 10l4 4 4-4"/></svg> Multiselect</a>
            </div>
          </div>
          <hr class="doc-divider"/>
          <div class="doc-section">
            <h2 id="references" class="doc-section-title">References</h2>
            <p class="doc-section-subtitle">Design tokens and resources for implementing the Checkbox component.</p>
            <ul class="doc-list">
              <li><strong>Figma Node:</strong> <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,.06);color:var(--prism-violet)">17918:385584</code> &mdash; Checkbox Group component set</li>
              <li><strong>Typography:</strong> Zoho Puvi Medium (weight 500) for labels</li>
              <li><strong>Border Radius:</strong> <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,.06);color:var(--prism-violet)">radius/4px</code></li>
              <li><strong>Group Variants:</strong> 2 &times; 2 &times; 3 &times; 2 = <strong>24 Checkbox Group variants</strong></li>
              <li><strong>Item Variants:</strong> 2 &times; 2 &times; 2 &times; 2 &times; 2 = <strong>32 Checkbox item variants</strong></li>
            </ul>
          </div>
        </div>

        <!-- ——— CODE TAB ——— -->
        <div class="tab-content" id="tab-code" style="display:none;padding-top:32px">
          <h2 id="code-demo" class="doc-section-title">Live demo (Code)</h2>
          <p class="doc-section-subtitle">Configure the Checkbox Group and view generated code. Click checkboxes to toggle &mdash; code updates live.</p>
          <style>.cp{border:1px solid var(--prism-border);border-radius:12px;overflow:hidden;background:var(--prism-surface);margin-bottom:40px}[data-theme="light"] .cp{background:#fff;border:1px solid rgba(37,99,235,.1);box-shadow:0 8px 30px rgba(37,99,235,.08)}.cp-tb{display:flex;flex-wrap:wrap;gap:20px;padding:16px 24px;border-bottom:1px solid var(--prism-border);background:var(--prism-surface-hover)}[data-theme="light"] .cp-tb{background:rgba(248,250,255,.6);border-bottom:1px solid rgba(37,99,235,.1)}.cp-cg{display:flex;flex-direction:column;gap:8px;flex:1;min-width:120px}.cp-lb{font-size:13px;font-weight:600;color:var(--prism-text-muted)}.cp-sl{background:var(--prism-surface);border:1px solid var(--prism-border);color:var(--prism-text);padding:8px 12px;border-radius:8px;outline:none;font-family:inherit;font-size:14px;cursor:pointer;transition:all .2s}[data-theme="light"] .cp-sl{background:#fff;border-color:rgba(37,99,235,.15);color:#1e293b}.cp-sl:focus{border-color:var(--prism-violet);box-shadow:0 0 0 3px rgba(37,99,235,.15)}.cp-pv{padding:48px;min-height:200px;display:flex;align-items:center;justify-content:center;transition:background .3s ease;background-color:#0a0a0c66;background-image:radial-gradient(circle,rgba(255,255,255,.15) 1px,transparent 1px);background-size:20px 20px}[data-theme="light"] .cp-pv{background-color:#f4f6fb;background-image:radial-gradient(circle,rgba(37,99,235,.08) 1px,transparent 1px)}.cp-ca{background:#0a0a0c;padding:24px;overflow-x:auto;font-family:'JetBrains Mono',monospace;font-size:14px;line-height:1.6;color:#e2e8f0}.cp-ch{display:flex;align-items:center;justify-content:space-between;padding:12px 24px;background:var(--prism-surface);border-top:1px solid var(--prism-border);border-bottom:1px solid var(--prism-border)}[data-theme="light"] .cp-ch{background:rgba(248,250,255,.8);border-color:rgba(37,99,235,.1)}.cp-ab{display:flex;align-items:center;gap:8px;background:transparent;border:none;font-family:inherit;font-size:13.5px;font-weight:500;color:var(--prism-text-muted);cursor:pointer;padding:6px 12px;border-radius:6px;transition:all .2s}.cp-ab:hover{background:var(--prism-surface-hover);color:var(--prism-text)}
  /* ══ Mobile responsive (added globally) ══ */
  .nav-hamburger { display: none; background: transparent; border: none; color: var(--prism-text); padding: 8px; margin-right: 8px; cursor: pointer; border-radius: 8px; align-items: center; justify-content: center; }
  .nav-hamburger:hover { background: var(--prism-surface-hover); }
  .sidebar-backdrop { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 95; opacity: 0; transition: opacity 0.25s ease; }
  .sidebar-backdrop.open { display: block; opacity: 1; }
  .sidebar-mobile-nav { display: none; }

  @media (max-width: 900px) {
    .nav { padding: 0 16px; height: 64px; justify-content: flex-start; gap: 4px; }
    .nav-links { margin-left: auto; }
    .nav-hamburger { display: inline-flex; order: -1; margin-right: 4px; }
    .nav-logo-mark { font-size: 22px; }
    .nav-logo-sub { font-size: 9px; }
    .nav-links > a,
    .nav-links > .nav-dropdown,
    .nav-links > div[style] { display: none !important; }
    .nav-links { gap: 0; }

    .components-layout { display: block; padding-top: 64px; grid-template-columns: 1fr; }
    .sidebar { position: fixed; top: 64px; left: 0; width: 300px; max-width: 86vw; height: calc(100vh - 64px); max-height: none; padding: 20px 18px 32px; border-right: 1px solid var(--prism-border); border-bottom: none; overflow-y: auto; transform: translateX(-100%); transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1); z-index: 96; background: var(--prism-black); }
    [data-theme="light"] .sidebar { background: #ffffff; }
    .sidebar.open { transform: translateX(0); box-shadow: 12px 0 40px rgba(0,0,0,0.25); }
    body.sidebar-locked { overflow: hidden; }

    .sidebar-mobile-nav { display: block; margin: 0 -18px 16px; padding: 0 18px 18px; border-bottom: 1px solid var(--prism-border); }
    .sidebar-mobile-nav h4 { font-size: 11px; font-weight: 700; color: var(--prism-text-muted); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 12px; padding-left: 4px; }
    .sidebar-mobile-nav ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 4px; }
    .sidebar-mobile-nav a { display: block; padding: 10px 12px; font-size: 14px; font-weight: 600; color: var(--prism-text); text-decoration: none; border-radius: 8px; transition: all 0.2s ease; }
    .sidebar-mobile-nav a:hover { background: var(--prism-surface-hover); color: var(--prism-violet); }
    .sidebar-mobile-nav a.active { color: var(--prism-violet); background: rgba(37, 99, 235, 0.08); }

    .main-panel { padding: 24px 20px 48px; grid-column: auto; grid-row: auto; }
    /* mobile-width-safety v4 — collapse any inline grid on narrow viewports */
    .main-panel, .main-content-inner, .main-content-area { max-width: 100%; width: 100%; box-sizing: border-box; min-width: 0; }
    .main-content-inner > *, .doc-section, .doc-section > * { max-width: 100%; box-sizing: border-box; min-width: 0; }
    .main-content-inner img, .main-content-inner svg:not(.inline-svg) { max-width: 100%; height: auto; }
    .main-content-inner pre, .main-content-inner code { white-space: pre-wrap; word-break: break-word; }
    .main-content-inner pre { overflow-x: auto; }
    .anatomy-diagram { overflow: visible !important; padding: 48px 40px !important; zoom: 0.82; }
    .anatomy-diagram > * { max-width: 100%; }
    .demo-container { overflow: hidden; }
    .demo-canvas { padding: 32px 20px !important; overflow-x: auto; }
    .code-playground, .cp-code-area { overflow-x: auto; }
    /* Foundation inner-page grids: collapse every multi-column inline grid */
    [style*="grid-template-columns: 1fr 1fr"],
    [style*="grid-template-columns:1fr 1fr"],
    [style*="grid-template-columns: repeat(4, 1fr)"],
    [style*="grid-template-columns: repeat(5, 1fr)"],
    [style*="grid-template-columns: repeat(6, 1fr)"],
    [style*="grid-template-columns: 320px 1fr"],
    [style*="grid-template-columns: 280px 1fr"],
    [style*="grid-template-columns: 240px 1fr"] { grid-template-columns: 1fr !important; }
    /* Flex rows with heavy fixed widths should wrap */
    [style*="display: flex"][style*="gap"] { flex-wrap: wrap; }
    .main-content-area { display: flex; flex-direction: column; grid-template-columns: 1fr; }
    .main-content-inner { padding-bottom: 32px; }
    .toc-sidebar { display: none; }

    .page-header-area .page-title,
    .page-title { font-size: 30px; line-height: 1.15; }
    .page-desc { font-size: 16px; }
    .doc-section h2, .doc-section-title { font-size: 22px; }

    .do-dont-grid,
    .illus-type-grid,
    .comp-grid,
    .density-grid,
    .illus-showcase-grid,
    .pattern-category-grid,
    .tone-grid,
    .voice-traits,
    .principles-grid,
    .theme-grid,
    .message-grid,
    .weight-grid,
    .pattern-grid,
    .collection-grid,
    .anti-pattern-list,
    .dodont-grid,
    .icon-metaphor-grid { grid-template-columns: 1fr !important; }

    table { display: block; overflow-x: auto; }
    .size-table, .token-table, .anatomy-table, .doc-table, .tone-table { display: block; overflow-x: auto; white-space: nowrap; min-width: 0; }

    .feedback-banner { flex-direction: column; align-items: flex-start; gap: 16px; padding: 24px; }
    .illus-type-card { grid-template-columns: 1fr !important; }
    .illus-type-preview { min-height: 180px; padding: 24px 16px; }

    /* Component detail page grids */
    .state-grid,
    .anatomy-grid,
    .usecase-grid,
    .anat-legend,
    /* Zia Experience hub grids */
    .zia-prompt-grid,
    /* Resource hub grids */
    .lib-grid,
    .lib-grid-logo,
    .lib-grid-illust { grid-template-columns: 1fr !important; gap: 12px !important; }

    /* Inline-styled 2- or 3-column grids */
    [style*="grid-template-columns: repeat(3, 1fr)"],
    [style*="grid-template-columns: repeat(2, 1fr)"],
    [style*="grid-template-columns:repeat(3,1fr)"],
    [style*="grid-template-columns:repeat(2,1fr)"] { grid-template-columns: 1fr !important; }

    /* Resource hub outer padding */
    .page-content { padding: 88px 16px 48px !important; }
  }

  @media (max-width: 600px) {
    .nav { padding: 0 12px; height: 60px; }
    .components-layout { padding-top: 60px; }
    .sidebar { top: 60px; height: calc(100vh - 60px); }
    .nav-logo-mark { font-size: 20px; }
    .main-panel { padding: 18px 14px 36px; }
    /* mobile-width-safety v3 */
    .main-panel { padding: 16px 10px 24px !important; }
    .anatomy-diagram { padding: 40px 28px !important; overflow: visible !important; zoom: 0.66; }
    .demo-canvas { padding: 24px 12px !important; }
    .page-header-area .page-title,
    .page-title { font-size: 26px; }
    .page-desc { font-size: 15px; }
    .sidebar-heading { font-size: 10px; }
    .search-shortcut { display: none; }
    .page-content { padding: 72px 12px 32px !important; }
  }
</style>
          <div class="cp">
            <div class="cp-tb">
              <div class="cp-cg"><label class="cp-lb">Size</label><select class="cp-sl" id="pg-size"><option value="Medium">Medium</option><option value="Small">Small</option></select></div>
              <div class="cp-cg"><label class="cp-lb">State</label><select class="cp-sl" id="pg-state"><option value="Default">Default</option><option value="Error">Error</option><option value="Disabled">Disabled</option></select></div>
              <div class="cp-cg"><label class="cp-lb">Layout</label><select class="cp-sl" id="pg-layout"><option value="left">Left (default)</option><option value="top">Top</option></select></div>
              <div class="cp-cg"><label class="cp-lb">Help Text</label><select class="cp-sl" id="pg-help"><option value="yes">Visible</option><option value="no">Hidden</option></select></div>
            </div>
            <div class="cp-pv" id="pg-pv"></div>
            <div class="cp-ch"><div style="font-size:13.5px;font-weight:600;color:var(--prism-text)">TSX</div><button class="cp-ab" id="pg-copy" onclick="cpCode()"><svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2"/></svg> Copy code</button></div>
            <div class="cp-ca" id="pg-co"></div>
          </div>
          <hr class="doc-divider"/>
          <div class="doc-section"><h3 id="component-api-properties" class="doc-h3">Component API &amp; Properties</h3>
            <p class="doc-section-subtitle">Props configuration for integrating the Checkbox Group component.</p>
            <table class="sz-t"><thead><tr><th>Property</th><th>Type</th><th>Default</th><th>Description</th></tr></thead><tbody>
              <tr><td><code>label</code></td><td>string</td><td>&ldquo;Group Label&rdquo;</td><td>Group label text displayed beside or above the options.</td></tr>
              <tr><td><code>labelPosition</code></td><td>'left' | 'top'</td><td>'left'</td><td>Controls layout axis. 'left' for responsive web; 'top' for constrained space.</td></tr>
              <tr><td><code>size</code></td><td>'Small' | 'Medium'</td><td>'Medium'</td><td>Applies consistent sizing across all child checkboxes.</td></tr>
              <tr><td><code>state</code></td><td>'Default' | 'Error' | 'Disabled'</td><td>'Default'</td><td>Validation or interaction state of the entire group.</td></tr>
              <tr><td><code>helpText</code></td><td>string</td><td>&ldquo;Help text&rdquo;</td><td>Supplementary text below options. Turns red on Error.</td></tr>
              <tr><td><code>showCounter</code></td><td>boolean</td><td>false</td><td>Displays a character/selection counter inside the Helper Row.</td></tr>
              <tr><td><code>value</code></td><td>string[]</td><td>[]</td><td>Array of value strings for checked options (controlled).</td></tr>
              <tr><td><code>defaultValue</code></td><td>string[]</td><td>[]</td><td>Initially checked values (uncontrolled).</td></tr>
              <tr><td><code>onChange</code></td><td>(values: string[]) =&gt; void</td><td>&mdash;</td><td>Callback fired when any checkbox changes selection.</td></tr>
              <tr><td><code>rtl</code></td><td>boolean</td><td>false</td><td>Switches to right-to-left layout mode.</td></tr>
            </tbody></table>
          </div>
          <hr class="doc-divider"/>
          <div class="doc-section"><h3 id="implementation-idea-ember-hook-form" class="doc-h3">Implementation Idea: Ember Hook Form</h3>
            <p class="doc-section-subtitle">A common use case in Ember applications involves linking checkboxes to form changeset states.</p>
            <div class="cp-ca" style="border-radius:12px;margin-top:16px"><div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6"><span style="color:#94a3b8">&lt;!-- MyApp/templates/components/permissions-form.hbs --&gt;</span><br><span style="color:#ABB2BF">&lt;</span><span style="color:#E06C75">UemsCheckboxGroup</span><br>&nbsp;&nbsp;<span style="color:#D19A66">@label</span><span style="color:#56B6C2">=</span><span style="color:#98C379">"Permissions"</span><br>&nbsp;&nbsp;<span style="color:#D19A66">@size</span><span style="color:#56B6C2">=</span><span style="color:#98C379">"Medium"</span><br>&nbsp;&nbsp;<span style="color:#D19A66">@value</span><span style="color:#56B6C2">=</span><span style="color:#C678DD">{{</span><span style="color:#E5C07B">this.selectedPermissions</span><span style="color:#C678DD">}}</span><br>&nbsp;&nbsp;<span style="color:#D19A66">@onChange</span><span style="color:#56B6C2">=</span><span style="color:#C678DD">{{</span><span style="color:#61AFEF">fn</span> <span style="color:#E5C07B">this.updatePermissions</span><span style="color:#C678DD">}}</span><br><span style="color:#ABB2BF">&gt;</span><br>&nbsp;&nbsp;<span style="color:#ABB2BF">&lt;</span><span style="color:#E06C75">UemsCheckbox</span> <span style="color:#D19A66">@value</span><span style="color:#56B6C2">=</span><span style="color:#98C379">"read"</span> <span style="color:#D19A66">@label</span><span style="color:#56B6C2">=</span><span style="color:#98C379">"Read"</span> <span style="color:#ABB2BF">/&gt;</span><br>&nbsp;&nbsp;<span style="color:#ABB2BF">&lt;</span><span style="color:#E06C75">UemsCheckbox</span> <span style="color:#D19A66">@value</span><span style="color:#56B6C2">=</span><span style="color:#98C379">"write"</span> <span style="color:#D19A66">@label</span><span style="color:#56B6C2">=</span><span style="color:#98C379">"Write"</span> <span style="color:#ABB2BF">/&gt;</span><br>&nbsp;&nbsp;<span style="color:#ABB2BF">&lt;</span><span style="color:#E06C75">UemsCheckbox</span> <span style="color:#D19A66">@value</span><span style="color:#56B6C2">=</span><span style="color:#98C379">"delete"</span> <span style="color:#D19A66">@label</span><span style="color:#56B6C2">=</span><span style="color:#98C379">"Delete"</span> <span style="color:#ABB2BF">/&gt;</span><br><span style="color:#ABB2BF">&lt;/</span><span style="color:#E06C75">UemsCheckboxGroup</span><span style="color:#ABB2BF">&gt;</span></div></div>
          </div>
          <hr class="doc-divider"/>
          <div class="doc-section"><h3 id="rtl-support" class="doc-h3">RTL Support</h3>
            <ul class="doc-list"><li>When <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,.06);color:var(--prism-violet)">RTL = True</code>, layout direction is mirrored &mdash; checkbox box swaps to the right side of the label.</li><li>Text direction set via <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,.06);color:var(--prism-violet)">dir="rtl"</code> on a parent element. All spacing values mirror automatically. Controlled via <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,.06);color:var(--prism-violet)">RTL Layout</code> variable collection.</li><li>Group label alignment and checkbox order mirror. Help text icon position swaps.</li></ul>
          </div>
        </div>

        <!-- ——— ACCESSIBILITY TAB ——— -->
        <div class="tab-content" id="tab-accessibility" style="display:none;padding-top:32px">
          <h2 id="accessibility" class="doc-section-title">Accessibility</h2>
          <p class="doc-section-subtitle">Guidelines for ensuring all checkbox group interactions are accessible across assistive technologies.</p>
          <div class="doc-section"><h3 id="keyboard-interaction" class="doc-h3">Keyboard Interaction</h3>
            <table class="sz-t"><thead><tr><th>Key</th><th>Action</th></tr></thead><tbody>
              <tr><td><code>Tab</code></td><td>Moves focus between checkboxes in the group.</td></tr>
              <tr><td><code>Space</code></td><td>Toggles the focused checkbox checked/unchecked.</td></tr>
            </tbody></table>
          </div>
          <hr class="doc-divider"/>
          <div class="doc-section"><h3 id="aria-attributes-screen-reader-guidance" class="doc-h3">ARIA Attributes &amp; Screen Reader Guidance</h3>
            <p class="doc-section-subtitle">Ensure checkbox group intent is explicitly communicated to all assistive technologies.</p>
            <ul class="doc-list">
              <li>Use <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,.06);color:var(--prism-violet)">&lt;fieldset&gt;</code> + <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,.06);color:var(--prism-violet)">&lt;legend&gt;</code> (or <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,.06);color:var(--prism-violet)">role="group"</code> + <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,.06);color:var(--prism-violet)">aria-labelledby</code>) to group inputs.</li>
              <li><strong>Disabled State:</strong> Set <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,.06);color:var(--prism-violet)">disabled</code> on <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,.06);color:var(--prism-violet)">&lt;input type="checkbox"&gt;</code>; do not use <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,.06);color:var(--prism-violet)">aria-disabled</code> alone.</li>
              <li><strong>Error State:</strong> Associate help text via <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,.06);color:var(--prism-violet)">aria-describedby</code>; pair with <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,.06);color:var(--prism-violet)">aria-invalid="true"</code>.</li>
              <li><strong>Screen Reader:</strong> Each option reads as: &ldquo;[Label], checkbox, [checked/unchecked], [group label]&rdquo;.</li>
              <li><strong>Indeterminate:</strong> Use <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,.06);color:var(--prism-violet)">aria-checked="mixed"</code> on a parent/select-all checkbox when only some items are checked.</li>
              <li>Don&rsquo;t rely solely on color to communicate checkbox state &mdash; always pair with a visible checkmark or label.</li>
            </ul>
          </div>
          <hr class="doc-divider"/>
          <div class="doc-section"><h3 id="focus-state-design" class="doc-h3">Focus State Design</h3>
            <ul class="doc-list"><li>Focus ring: <strong>2px solid</strong> using <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,.06);color:var(--prism-violet)">Border/Border-Accent-Focus</code>.</li><li>Outline-offset: <strong>2px</strong> from the checkbox box edge.</li><li>The checkbox box retains its current state styling inside the focus ring.</li></ul>
          </div>
          <hr class="doc-divider"/>
          <div class="doc-section"><h3 id="color-contrast-minimums" class="doc-h3">Color Contrast Minimums<span class="h3-badge" style="background:rgba(34,197,94,.15);color:#16a34a">WCAG AA Pass</span></h3>
            <p class="doc-section-subtitle">Checkbox label text and checked indicators must maintain sufficient contrast per WCAG 2.1.</p>
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px;margin-top:24px">
              <div style="background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;overflow:hidden"><div style="background:#006AFF;padding:32px 24px;text-align:center;color:#fff"><div style="font-size:24px;font-weight:600">&#10003; Label</div></div><div style="padding:16px 24px;display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--prism-border)"><div><div style="font-size:13px;color:var(--prism-text-muted);font-weight:600">CHECKMARK</div><div style="font-size:15px;color:var(--prism-text);font-family:monospace;margin-top:4px">#FFF on #006AFF</div></div><div style="text-align:right"><div style="display:inline-flex;align-items:center;gap:6px;background:rgba(34,197,94,.1);color:#16a34a;padding:4px 10px;border-radius:100px;font-size:12px;font-weight:700"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg> 4.5:1</div><div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;font-weight:600">WCAG AA Pass</div></div></div></div>
              <div style="background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;overflow:hidden"><div style="background:#F0F2F5;padding:32px 24px;text-align:center;color:#15181E"><div style="font-size:24px;font-weight:600">&#9744; Label</div></div><div style="padding:16px 24px;display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--prism-border)"><div><div style="font-size:13px;color:var(--prism-text-muted);font-weight:600">LABEL TEXT</div><div style="font-size:15px;color:var(--prism-text);font-family:monospace;margin-top:4px">#15181E on #FFF</div></div><div style="text-align:right"><div style="display:inline-flex;align-items:center;gap:6px;background:rgba(34,197,94,.1);color:#16a34a;padding:4px 10px;border-radius:100px;font-size:12px;font-weight:700"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg> 15.4:1</div><div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;font-weight:600">WCAG AAA Pass</div></div></div></div>
              <div style="background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;overflow:hidden"><div style="background:#E42527;padding:32px 24px;text-align:center;color:#fff"><div style="font-size:24px;font-weight:600">&#9744; Label</div></div><div style="padding:16px 24px;display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--prism-border)"><div><div style="font-size:13px;color:var(--prism-text-muted);font-weight:600">ERROR BORDER</div><div style="font-size:15px;color:var(--prism-text);font-family:monospace;margin-top:4px">#E42527 on #FFF</div></div><div style="text-align:right"><div style="display:inline-flex;align-items:center;gap:6px;background:rgba(34,197,94,.1);color:#16a34a;padding:4px 10px;border-radius:100px;font-size:12px;font-weight:700"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg> 4.8:1</div><div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;font-weight:600">WCAG AA Pass</div></div></div></div>
            </div>
            <div style="margin-top:24px;padding:16px 20px;background:rgba(34,197,94,.05);border:1px solid rgba(34,197,94,.2);border-radius:12px;display:flex;gap:12px;align-items:flex-start"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2" style="flex-shrink:0;margin-top:2px"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg><p style="font-size:14px;color:var(--prism-text);line-height:1.6;margin:0"><strong>WCAG 2.1 Level AA Requires:</strong> A contrast ratio of at least <strong>4.5:1</strong> for normal text and <strong>3.0:1</strong> for UI components. All UEMS checkbox components pass these standards.</p></div>
          </div>
          <hr class="doc-divider"/>
          <div class="doc-section"><h3 id="touch-target-size" class="doc-h3">Touch Target Size</h3>
            <p class="doc-section-subtitle">Mobile and tablet platforms require specific tap areas to prevent accidental clicks.</p>
            <div style="margin-top:16px;padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;display:flex;align-items:center;gap:24px"><div style="width:48px;height:48px;background:rgba(37,99,235,.1);border:1px dashed var(--prism-violet);border-radius:8px;display:flex;align-items:center;justify-content:center;color:var(--prism-violet);font-size:13px;font-weight:600">48px</div><div><div style="font-weight:600;font-size:15px;color:var(--prism-text)">Minimum Target: 48&times;48px</div><div style="font-size:14px;color:var(--prism-text-muted);margin-top:4px">Small variant checkboxes (16px) include invisible padding to meet iOS/Android touch requirements.</div></div></div>
          </div>
        </div>

        </div><!-- main-content-inner -->

