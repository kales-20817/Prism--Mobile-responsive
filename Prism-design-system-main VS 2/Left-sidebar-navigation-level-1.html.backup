                </div>
                <div style="font-size:13px;font-weight:600;color:var(--prism-text);">Default</div>
                <div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;">No icon wrap bg</div>
              </div>
              <div style="padding:24px 16px;border-radius:14px;background:var(--prism-surface);border:1px solid var(--prism-border);text-align:center;">
                <div style="display:flex;justify-content:center;margin-bottom:16px;">
                  <div class="sidebar-nav-demo" style="width:auto;height:auto;border:none;background:none;padding:0;">
                    <button class="nav-item-demo nav-item-demo--active" style="pointer-events:none;">
                      <span class="nav-item-demo__icon-wrap"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1"/></svg></span>
                      <span class="nav-item-demo__label">Item</span>
                    </button>
                  </div>
                </div>
                <div style="font-size:13px;font-weight:600;color:var(--prism-text);">Active</div>
                <div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;">BG-Accent-Subtle + blue</div>
              </div>
              <div style="padding:24px 16px;border-radius:14px;background:var(--prism-surface);border:1px solid var(--prism-border);text-align:center;">
                <div style="display:flex;justify-content:center;margin-bottom:16px;">
                  <div class="sidebar-nav-demo" style="width:auto;height:auto;border:none;background:none;padding:0;">
                    <button class="nav-item-demo" style="pointer-events:none;">
                      <span class="nav-item-demo__icon-wrap" style="background:rgba(255,255,255,0.08);"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1"/></svg></span>
                      <span class="nav-item-demo__label">Item</span>
                    </button>
                  </div>
                </div>
                <div style="font-size:13px;font-weight:600;color:var(--prism-text);">Hover</div>
                <div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;">BG-Secondary-alt</div>
              </div>
              <div style="padding:24px 16px;border-radius:14px;background:var(--prism-surface);border:1px solid var(--prism-border);text-align:center;">
                <div style="display:flex;justify-content:center;margin-bottom:16px;">
                  <div class="sidebar-nav-demo" style="width:auto;height:auto;border:none;background:none;padding:0;">
                    <button class="nav-item-demo nav-item-demo--disabled" style="pointer-events:none;">
                      <span class="nav-item-demo__icon-wrap"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1"/></svg></span>
