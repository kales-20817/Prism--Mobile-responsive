        <!-- ========== CODE ========== -->
        <div class="tab-content" id="tab-code" style="display:none;padding-top:32px;">
          <h2 id="live-demo-code" class="doc-section-title">Live demo (Code)</h2>
          <p class="doc-section-subtitle">Configure the Sidebar Navigation component and view generated HTML.</p>
          <div class="code-playground">
            <div class="cp-toolbar">
              <div class="cp-control-group"><label class="cp-label">Type</label><select class="cp-select" id="pg-type"><option value="expanded" selected>Icon with Text</option><option value="collapsed">Icon Only</option></select></div>
              <div class="cp-control-group"><label class="cp-label">Product</label><select class="cp-select" id="pg-product"><option value="threats" selected>Threats &amp; Patches</option><option value="configurations">Configurations</option><option value="inventory">Inventory</option><option value="mdm">MDM</option><option value="browsers">Browsers</option></select></div>
              <div class="cp-control-group"><label class="cp-label">Active Item</label><select class="cp-select" id="pg-active"><option value="0" selected>Item 1</option><option value="1">Item 2</option><option value="2">Item 3</option><option value="3">Item 4</option><option value="4">Item 5</option></select></div>
              <div class="cp-control-group"><label class="cp-label">Direction</label><select class="cp-select" id="pg-dir"><option value="ltr" selected>LTR</option><option value="rtl">RTL</option></select></div>
            </div>
            <div class="cp-preview" id="pg-preview-area" style="min-height:420px;"></div>
            <div class="cp-code-header">
              <div style="font-size:13.5px;font-weight:600;color:var(--prism-text);">HTML</div>
              <button class="cp-action-btn" id="pg-copy-btn"><svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2"/></svg> Copy code</button>
            </div>
            <div class="cp-code-area" id="pg-code-output"></div>
          </div>
          <script>
          (function(){
            var products = {
              threats: {label:'Threats & Patches', items:['Dashboard','Threats','Patches','Systems','Deployment','Compliance','Reports','Settings']},
              configurations: {label:'Configurations', items:['Add Config','Configurations','Library','Reports','Settings','Trash']},
              inventory: {label:'Inventory', items:['Dashboard','Management','Inventory','Reports','Settings']},
              mdm: {label:'MDM', items:['Dashboard','Domain','Remote Offices','Auto Discovery','Settings']},
              browsers: {label:'Browsers', items:['Dashboard','Manage','Policies','Deployment','Reports','Insights','Alerts','Settings']}
            };
            // Icons mapped to actual asset files from assets/Product Icon/
            var icons = {
              'Dashboard': 'area-chart.svg',
              'Threats': 'file-shield.svg',
              'Patches': 'patch.svg',
              'Systems': 'hard-disk-tools.svg',
              'Deployment': 'expand.svg',
              'Compliance': 'file-scan.svg',
              'Reports': 'file-report.svg',
              'Settings': 'property-settings.svg',
              'Add Config': 'add.svg',
              'Configurations': 'folder-settings.svg',
              'Library': 'archive.svg',
              'Trash': 'delete.svg',
              'Management': 'users.svg',
              'Inventory': 'data-flow-expand.svg',
              'Domain': 'globe.svg',
              'Remote Offices': 'ms-office.svg',
              'Auto Discovery': 'property-search.svg',
              'Manage': 'layout-grid.svg',
              'Policies': 'file-shield.svg',
              'Insights': 'lightbulb-energy.svg',
              'Alerts': 'mobile-notification.svg',
              'Update Now': 'data-flow-expand.svg',
              'Home': 'home.svg'
            };
            var defaultIcon = 'grid.svg';
            var els = {type:document.getElementById('pg-type'),product:document.getElementById('pg-product'),active:document.getElementById('pg-active'),dir:document.getElementById('pg-dir')};
            var previewArea = document.getElementById('pg-preview-area');
            var codeOut = document.getElementById('pg-code-output');
            var copyBtn = document.getElementById('pg-copy-btn');
            function esc(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
            function getIcon(name){ return 'assets/Product Icon/' + (icons[name] || defaultIcon); }
            function slug(name){ return name.toLowerCase().replace(/\s+/g,'-').replace(/[^a-z0-9-]/g,''); }
            function update(){
              var type = els.type.value;
              var prod = products[els.product.value];
              var activeIdx = parseInt(els.active.value);
              var dir = els.dir.value;
              var isCollapsed = type === 'collapsed';
              var w = isCollapsed ? 44 : 72;
              var cls = 'sidebar-nav-demo' + (isCollapsed ? ' collapsed' : '');
              // Preview
              var html = '<div class="'+cls+'" style="height:auto;'+( dir==='rtl'?'direction:rtl;border-right:none;border-left:1px solid;':'')+'"><ul class="sidebar-nav-demo__list">';
              prod.items.forEach(function(name, i){
                var isAdd = (name === 'Add Config');
                var isActive = (i === activeIdx && !isAdd);
                var itemCls = 'nav-item-demo';
                if(isActive) itemCls += ' nav-item-demo--active';
                if(isAdd) itemCls += ' nav-item-demo--add';
                var iconImg = '<img src="'+getIcon(name)+'" alt="'+name+'" width="24" height="24">';
                html += '<li><button class="'+itemCls+'" data-nav="playground" data-idx="'+i+'" title="'+name+'">';
                html += '<span class="nav-item-demo__icon-wrap">'+iconImg+'</span>';
                if(!isCollapsed) html += '<span class="nav-item-demo__label">'+name+'</span>';
                html += '</button></li>';
              });
              var collapseIcon = isCollapsed ? 'chevron-right.svg' : 'chevron-left.svg';
              html += '</ul><div class="sidebar-nav-demo__bottom"><button class="nav-item-demo" title="'+(isCollapsed?'Expand':'Collapse')+'"><span class="nav-item-demo__icon-wrap"><img src="assets/Product Icon/'+collapseIcon+'" alt="'+(isCollapsed?'Expand':'Collapse')+'" width="24" height="24"></span></button></div></div>';
              previewArea.innerHTML = html;
              // Make preview interactive
              previewArea.querySelectorAll('[data-nav="playground"]').forEach(function(btn){
                btn.addEventListener('click', function(){
                  var idx = parseInt(this.getAttribute('data-idx'));
                  if(this.classList.contains('nav-item-demo--add')) return;
                  els.active.value = idx;
                  update();
                });
              });
              // Code output
              var dirAttr = dir === 'rtl' ? '\n  dir="rtl"' : '';
              var navCls = isCollapsed ? 'sidebar-nav sidebar-nav--collapsed' : 'sidebar-nav sidebar-nav--expanded';
              var code = '<nav'+dirAttr+'\n  class="'+navCls+'"\n  aria-label="Main navigation"\n>\n  <ul class="sidebar-nav__list" role="list">\n';
              prod.items.forEach(function(name, i){
                var isActive = (i === activeIdx && name !== 'Add Config');
                var isAdd = (name === 'Add Config');
                var itemCls = 'nav-item';
                if(isActive) itemCls += ' nav-item--active';
                var href = isAdd ? '#' : '/'+slug(name);
                var ariaExtra = isActive ? '\n        aria-current="page"' : '';
                var tag = isAdd ? 'button' : 'a';
                var hrefAttr = isAdd ? '' : '\n        href="'+href+'"';
                code += '    <li class="sidebar-nav__item">\n      <'+tag+hrefAttr+'\n        class="'+itemCls+'"'+ariaExtra+'\n        aria-label="'+name+'"\n      >\n        <span class="nav-item__icon-wrap" aria-hidden="true">\n          <!-- '+name+' icon -->\n        </span>\n'+(isCollapsed?'':'        <span class="nav-item__label">'+name+'</span>\n')+'      </'+tag+'>\n    </li>\n';
              });
              code += '  </ul>\n\n  <div class="sidebar-nav__bottom">\n    <button\n      class="nav-item nav-item--collapse"\n      aria-label="'+(isCollapsed?'Expand':'Collapse')+' navigation"\n      aria-expanded="'+(isCollapsed?'false':'true')+'"\n      aria-controls="sidebar"\n    >\n      <span class="nav-item__icon-wrap" aria-hidden="true">\n        <!-- collapse icon -->\n      </span>\n    </button>\n  </div>\n</nav>';
              codeOut.innerHTML = esc(code)
                .replace(/class=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">class</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/aria-label=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">aria-label</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/aria-current=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">aria-current</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/aria-expanded=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">aria-expanded</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/aria-controls=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">aria-controls</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/aria-hidden=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">aria-hidden</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/role=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">role</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/href=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">href</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/dir=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">dir</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/&lt;(\/?)(nav|ul|li|a|button|span|div)(.*?)&gt;/g,'&lt;$1<span style="color:#a78bfa;">$2</span>$3&gt;')
                .replace(/&lt;!--(.*?)--&gt;/g,'<span style="color:#94a3b8;">&lt;!--$1--&gt;</span>');
            }
            Object.values(els).forEach(function(e){e.addEventListener('change',update);});
            copyBtn.addEventListener('click',function(){
              var r=document.createElement('div');r.innerHTML=codeOut.innerHTML;
              navigator.clipboard.writeText(r.innerText).then(function(){
                var o=copyBtn.innerHTML;copyBtn.innerHTML='<svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Copied!';setTimeout(function(){copyBtn.innerHTML=o;},2000);
              });
            });
            update();
          })();
          </script>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="component-api-properties" class="doc-h3">Component API &amp; Properties</h3>
            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Item Slots (all product sets)</h4>
            <table class="size-table" style="margin-bottom:32px;">
              <thead><tr><th>Property</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
              <tbody>
                <tr><td><code>Item 1</code></td><td>Boolean</td><td>ON</td><td>Show/hide slot 1.</td></tr>
                <tr><td><code>Item 2</code></td><td>Boolean</td><td>ON</td><td>Show/hide slot 2.</td></tr>
                <tr><td><code>Item 3</code></td><td>Boolean</td><td>ON</td><td>Show/hide slot 3.</td></tr>
                <tr><td><code>Item 4</code></td><td>Boolean</td><td>ON</td><td>Show/hide slot 4.</td></tr>
                <tr><td><code>Item 5</code></td><td>Boolean</td><td>ON</td><td>Show/hide slot 5.</td></tr>
                <tr><td><code>Item 6</code></td><td>Boolean</td><td>ON</td><td>Show/hide slot 6.</td></tr>
                <tr><td><code>Item 7</code></td><td>Boolean</td><td>OFF</td><td>Show/hide slot 7 (hidden by default).</td></tr>
                <tr><td><code>Item 8</code></td><td>Boolean</td><td>OFF</td><td>Show/hide slot 8 (hidden by default).</td></tr>
                <tr><td><code>Item 1 Swap</code></td><td>Instance Swap</td><td>Active state item</td><td>Swap slot 1 to any Left Nav Item L1 variant.</td></tr>
                <tr><td><code>Item 2&#8211;8 Swap</code></td><td>Instance Swap</td><td>Default state item</td><td>Swap slots 2&#8211;8 independently.</td></tr>
              </tbody>
            </table>
            <div style="margin-top:16px;padding:16px 20px;background:rgba(37,99,235,0.05);border:1px solid rgba(37,99,235,0.15);border-radius:12px;">
              <p style="font-size:14px;color:var(--prism-text);line-height:1.6;margin:0;"><strong>Note:</strong> Threats &amp; Patches and some other product sets support additional slots (Items 9&#8211;11) to accommodate longer navigation lists.</p>
            </div>

            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;margin-top:32px;">Bottom Section (all product sets)</h4>
            <table class="size-table">
              <thead><tr><th>Property</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
              <tbody>
                <tr><td><code>Bottom Item 1</code></td><td>Boolean</td><td>OFF</td><td>Optional additional bottom action (e.g. home/help).</td></tr>
                <tr><td><code>Bottom Item 1 Swap</code></td><td>Instance Swap</td><td>Default state item</td><td>Swap Bottom Item 1 content.</td></tr>
                <tr><td><code>Bottom Item 2</code></td><td>Boolean</td><td>ON</td><td>The collapse/expand toggle &#8212; always visible by default.</td></tr>
                <tr><td><code>Bottom Item 2 Swap</code></td><td>Instance Swap</td><td>Collapse icon item</td><td>Swap Bottom Item 2 content.</td></tr>
              </tbody>
            </table>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="collapse-toggle-pattern" class="doc-h3">Collapse Toggle Pattern</h3>
            <div class="cp-code-area" style="border-radius:12px;margin-top:16px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;">
                <span style="color:#c678dd;">const</span> <span style="color:#e5c07b;">toggleBtn</span> <span style="color:#56b6c2;">=</span> <span style="color:#e2e8f0;">document.</span><span style="color:#61afef;">querySelector</span><span style="color:#e2e8f0;">(</span><span style="color:#98c379;">'.nav-item--collapse'</span><span style="color:#e2e8f0;">);</span><br>
                <span style="color:#c678dd;">const</span> <span style="color:#e5c07b;">sidebar</span> <span style="color:#56b6c2;">=</span> <span style="color:#e2e8f0;">document.</span><span style="color:#61afef;">getElementById</span><span style="color:#e2e8f0;">(</span><span style="color:#98c379;">'sidebar'</span><span style="color:#e2e8f0;">);</span><br><br>
                <span style="color:#e5c07b;">toggleBtn</span><span style="color:#e2e8f0;">.</span><span style="color:#61afef;">addEventListener</span><span style="color:#e2e8f0;">(</span><span style="color:#98c379;">'click'</span><span style="color:#e2e8f0;">,</span> <span style="color:#c678dd;">()</span> <span style="color:#c678dd;">=&gt;</span> <span style="color:#e2e8f0;">{</span><br>
                &nbsp;&nbsp;<span style="color:#c678dd;">const</span> <span style="color:#e5c07b;">isCollapsed</span> <span style="color:#56b6c2;">=</span> <span style="color:#e5c07b;">sidebar</span><span style="color:#e2e8f0;">.</span><span style="color:#61afef;">classList</span><span style="color:#e2e8f0;">.</span><span style="color:#61afef;">toggle</span><span style="color:#e2e8f0;">(</span><span style="color:#98c379;">'sidebar-nav--collapsed'</span><span style="color:#e2e8f0;">);</span><br>
                &nbsp;&nbsp;<span style="color:#e5c07b;">toggleBtn</span><span style="color:#e2e8f0;">.</span><span style="color:#61afef;">setAttribute</span><span style="color:#e2e8f0;">(</span><span style="color:#98c379;">'aria-expanded'</span><span style="color:#e2e8f0;">,</span> <span style="color:#61afef;">String</span><span style="color:#e2e8f0;">(!</span><span style="color:#e5c07b;">isCollapsed</span><span style="color:#e2e8f0;">));</span><br>
                &nbsp;&nbsp;<span style="color:#e5c07b;">toggleBtn</span><span style="color:#e2e8f0;">.</span><span style="color:#61afef;">setAttribute</span><span style="color:#e2e8f0;">(</span><span style="color:#98c379;">'aria-label'</span><span style="color:#e2e8f0;">,</span><br>
                &nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#e5c07b;">isCollapsed</span> <span style="color:#56b6c2;">?</span> <span style="color:#98c379;">'Expand navigation'</span> <span style="color:#56b6c2;">:</span> <span style="color:#98c379;">'Collapse navigation'</span><br>
                &nbsp;&nbsp;<span style="color:#e2e8f0;">);</span><br>
                <span style="color:#e2e8f0;">});</span>
              </div>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="css-reference" class="doc-h3">CSS Reference</h3>
            <div class="cp-code-area" style="border-radius:12px;margin-top:16px;max-height:400px;overflow-y:auto;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13px;line-height:1.6;">
                <span style="color:#94a3b8;">/* Sidebar container */</span><br>
                <span style="color:#e06c75;">.sidebar-nav</span> {<br>
                &nbsp;&nbsp;<span style="color:#d19a66;">display</span>: <span style="color:#98c379;">flex</span>;<br>
                &nbsp;&nbsp;<span style="color:#d19a66;">flex-direction</span>: <span style="color:#98c379;">column</span>;<br>
                &nbsp;&nbsp;<span style="color:#d19a66;">width</span>: <span style="color:#d19a66;">72px</span>;<br>
                &nbsp;&nbsp;<span style="color:#d19a66;">height</span>: <span style="color:#d19a66;">640px</span>;<br>
                &nbsp;&nbsp;<span style="color:#d19a66;">background</span>: <span style="color:#98c379;">#ffffff</span>;<br>
                &nbsp;&nbsp;<span style="color:#d19a66;">border-right</span>: <span style="color:#d19a66;">1px</span> <span style="color:#98c379;">solid</span> <span style="color:#98c379;">#C3C9D6</span>;<br>
                &nbsp;&nbsp;<span style="color:#d19a66;">padding</span>: <span style="color:#d19a66;">8px 0</span>;<br>
                }<br><br>
                <span style="color:#e06c75;">.sidebar-nav--collapsed</span> { <span style="color:#d19a66;">width</span>: <span style="color:#d19a66;">44px</span>; }<br><br>
                <span style="color:#94a3b8;">/* Nav item */</span><br>
                <span style="color:#e06c75;">.nav-item</span> {<br>
                &nbsp;&nbsp;<span style="color:#d19a66;">display</span>: <span style="color:#98c379;">flex</span>;<br>
                &nbsp;&nbsp;<span style="color:#d19a66;">flex-direction</span>: <span style="color:#98c379;">column</span>;<br>
                &nbsp;&nbsp;<span style="color:#d19a66;">align-items</span>: <span style="color:#98c379;">center</span>;<br>
                &nbsp;&nbsp;<span style="color:#d19a66;">gap</span>: <span style="color:#d19a66;">4px</span>;<br>
                &nbsp;&nbsp;<span style="color:#d19a66;">padding</span>: <span style="color:#d19a66;">8px 0</span>;<br>
                &nbsp;&nbsp;<span style="color:#d19a66;">color</span>: <span style="color:#98c379;">#15181E</span>;<br>
                &nbsp;&nbsp;<span style="color:#d19a66;">cursor</span>: <span style="color:#98c379;">pointer</span>;<br>
                }<br><br>
                <span style="color:#94a3b8;">/* Active state */</span><br>
                <span style="color:#e06c75;">.nav-item--active .nav-item__icon-wrap</span> { <span style="color:#d19a66;">background</span>: <span style="color:#98c379;">#E8F0FE</span>; }<br>
                <span style="color:#e06c75;">.nav-item--active .nav-item__label</span> { <span style="color:#d19a66;">color</span>: <span style="color:#98c379;">#006AFF</span>; }<br>
              </div>
            </div>
          </div>
        </div>

        <!-- ========== ACCESSIBILITY ========== -->
        <div class="tab-content" id="tab-accessibility" style="display:none;padding-top:32px;">
          <h2 id="accessibility" class="doc-section-title">Accessibility</h2>
          <p class="doc-section-subtitle">Guidelines for ensuring Sidebar Navigation Level 1 is accessible across assistive technologies and input methods.</p>

          <div class="doc-section">
            <h3 id="keyboard-interaction" class="doc-h3">Keyboard Interaction</h3>
            <table class="size-table">
              <thead><tr><th>Key</th><th>Action</th></tr></thead>
              <tbody>
                <tr><td><code>Tab</code></td><td>Move focus to the next nav item.</td></tr>
                <tr><td><code>Shift+Tab</code></td><td>Move focus to the previous nav item.</td></tr>
                <tr><td><code>Enter</code> / <code>Space</code></td><td>Activate the focused nav item.</td></tr>
                <tr><td><code>Home</code></td><td>Move focus to the first nav item.</td></tr>
                <tr><td><code>End</code></td><td>Move focus to the last nav item.</td></tr>
                <tr><td><code>Enter</code> on collapse toggle</td><td>Toggle between Icon with Text and Icon Only.</td></tr>
              </tbody>
            </table>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="aria-attributes" class="doc-h3">ARIA Attributes &amp; Screen Reader Guidance</h3>
            <ul class="doc-list">
              <li><strong>Landmark:</strong> Wrap in <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;nav&gt;</code> with <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-label="Main navigation"</code>.</li>
              <li><strong>Current page:</strong> Set <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-current="page"</code> on the active item's <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;a&gt;</code> tag.</li>
              <li><strong>Icon Only mode:</strong> Add <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-label</code> to each nav item containing the full item name. Provide visible tooltip on hover/focus.</li>
              <li><strong>Disabled items:</strong> Set <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-disabled="true"</code> and <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">tabindex="-1"</code>. Include a tooltip explaining unavailability.</li>
              <li><strong>Collapse toggle:</strong> Use <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-expanded</code> (<code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">true</code>/<code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">false</code>) and <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-controls</code> pointing to the sidebar container.</li>
              <li><strong>Icons:</strong> Mark icon SVGs <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-hidden="true"</code> &#8212; labels carry the semantic meaning.</li>
              <li><strong>Add item:</strong> The "Add" state button should be a <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;button&gt;</code> element (not <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;a&gt;</code>), as it opens a creation dialog rather than navigating to a page.</li>
            </ul>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="focus-state-design" class="doc-h3">Focus State Design</h3>
            <ul class="doc-list">
              <li><strong>Focus ring:</strong> Do not remove the default focus outline &#8212; use <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">:focus-visible</code> to style a custom 2px ring matching <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">Border-Accent</code> (<code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">#006AFF</code>).</li>
              <li><strong>Full keyboard navigation:</strong> Full keyboard navigation via <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">Tab</code>/<code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">Shift+Tab</code>; <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">Enter</code>/<code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">Space</code> to activate; <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">Home</code>/<code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">End</code> to jump to first/last item.</li>
            </ul>
            <div style="margin-top:24px;display:flex;gap:16px;align-items:center;padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;">
              <div style="width:36px;height:36px;border-radius:8px;background:rgba(0,106,255,0.12);border:2px solid #006AFF;box-shadow:0 0 0 3px rgba(0,106,255,0.2);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#006AFF" stroke-width="2"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1"/></svg>
              </div>
              <div>
                <div style="font-weight:600;font-size:15px;color:var(--prism-text);">Focus ring: 2px border + 3px shadow</div>
                <div style="font-size:14px;color:var(--prism-text-muted);margin-top:4px;">Border: #006AFF | Shadow: rgba(0,106,255,0.20)</div>
              </div>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="rtl-support" class="doc-h3">RTL Support</h3>
            <ul class="doc-list">
              <li><strong>Direction:</strong> Set <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">dir="rtl"</code> on the <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;nav&gt;</code> element for Arabic/Hebrew layouts; icon wrap and label stack direction invert automatically.</li>
              <li><strong>Border position:</strong> The right border flips to the left side in RTL mode.</li>
              <li><strong>Collapse icon:</strong> The collapse chevron direction should mirror to point towards the sidebar edge.</li>
            </ul>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="color-contrast" class="doc-h3">Color Contrast<span class="h3-badge" style="background:rgba(34,197,94,0.15);color:#16a34a;">WCAG AA Pass</span></h3>
            <p class="doc-section-subtitle">All color combinations meet WCAG 2.1 AA contrast requirements.</p>
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px;margin-top:24px;">
              <div style="background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;overflow:hidden;">
                <div style="background:#fff;padding:28px 24px;text-align:center;border-radius:12px 12px 0 0;">
                  <div style="width:36px;height:36px;border-radius:8px;background:#E8F0FE;margin:0 auto 8px;display:flex;align-items:center;justify-content:center;"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#006AFF" stroke-width="2"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3"/></svg></div>
                  <div style="color:#006AFF;font-size:10px;font-weight:500;">Dashboard</div>
                </div>
                <div style="padding:16px 24px;display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--prism-border);">
                  <div><div style="font-size:13px;color:var(--prism-text-muted);font-weight:600;">ACTIVE ICON ON WHITE</div><div style="font-size:15px;color:var(--prism-text);font-family:monospace;margin-top:4px;">#006AFF on #FFFFFF</div></div>
                  <div style="text-align:right;"><div style="display:inline-flex;align-items:center;gap:6px;background:rgba(34,197,94,0.1);color:#16a34a;padding:4px 10px;border-radius:100px;font-size:12px;font-weight:700;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><polyline points="20 6 9 17 4 12"></polyline></svg> 4.7:1</div><div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;font-weight:600;">WCAG AA Pass</div></div>
                </div>
              </div>
              <div style="background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;overflow:hidden;">
                <div style="background:#fff;padding:28px 24px;text-align:center;border-radius:12px 12px 0 0;">
                  <div style="width:36px;height:36px;border-radius:8px;margin:0 auto 8px;display:flex;align-items:center;justify-content:center;"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#15181E" stroke-width="2"><path d="M12 9v2m0 4h.01M5.07 19H19a2 2 0 001.75-2.96l-6.97-12a2 2 0 00-3.5 0l-6.97 12A2 2 0 005.07 19z"/></svg></div>
                  <div style="color:#15181E;font-size:10px;font-weight:500;">Threats</div>
                </div>
                <div style="padding:16px 24px;display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--prism-border);">
                  <div><div style="font-size:13px;color:var(--prism-text-muted);font-weight:600;">DEFAULT ICON ON WHITE</div><div style="font-size:15px;color:var(--prism-text);font-family:monospace;margin-top:4px;">#15181E on #FFFFFF</div></div>
                  <div style="text-align:right;"><div style="display:inline-flex;align-items:center;gap:6px;background:rgba(34,197,94,0.1);color:#16a34a;padding:4px 10px;border-radius:100px;font-size:12px;font-weight:700;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><polyline points="20 6 9 17 4 12"></polyline></svg> 17.1:1</div><div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;font-weight:600;">WCAG AAA Pass</div></div>
                </div>
              </div>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="touch-target-size" class="doc-h3">Touch Target Size</h3>
            <p class="doc-section-subtitle">Nav items meet the minimum touch target requirements.</p>
            <div style="margin-top:16px;padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;display:flex;align-items:center;gap:24px;">
              <div style="width:72px;height:64px;background:rgba(37,99,235,0.1);border:1px dashed var(--prism-violet);border-radius:8px;display:flex;align-items:center;justify-content:center;color:var(--prism-violet);font-size:11px;font-weight:600;flex-shrink:0;text-align:center;line-height:1.3;">72&times;64px</div>
              <div><div style="font-weight:600;font-size:15px;color:var(--prism-text);">Expanded item: 72&times;~64px &#8212; exceeds minimum</div><div style="font-size:14px;color:var(--prism-text-muted);margin-top:4px;">Both expanded (72px) and collapsed (44px) modes meet the 44px minimum touch target requirement (WCAG 2.5.5). The icon wrap at 36px combined with padding provides adequate target area.</div></div>
            </div>
          </div>
        </div>

        </div><!-- main-content-inner -->

        <aside class="toc-sidebar">
          <h4 class="toc-heading">On this page</h4>
