                    </button>
                  </div>
                </div>
                <div style="font-size:13px;font-weight:600;color:var(--prism-text);">Disabled</div>
                <div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;">Text-Disabled muted</div>
              </div>
              <div style="padding:24px 16px;border-radius:14px;background:var(--prism-surface);border:1px solid var(--prism-border);text-align:center;">
                <div style="display:flex;justify-content:center;margin-bottom:16px;">
                  <div class="sidebar-nav-demo" style="width:auto;height:auto;border:none;background:none;padding:0;">
                    <button class="nav-item-demo nav-item-demo--add" style="pointer-events:none;">
                      <span class="nav-item-demo__icon-wrap"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M12 4v16m8-8H4"/></svg></span>
                      <span class="nav-item-demo__label">Add</span>
                    </button>
                  </div>
                </div>
                <div style="font-size:13px;font-weight:600;color:var(--prism-text);">Add</div>
                <div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;">Blue circle + white icon</div>
              </div>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="color-tokens" class="doc-h3">Color Tokens<span class="h3-badge" style="background:rgba(37,99,235,0.1);color:var(--prism-violet);">Tokens</span></h3>

            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Default State</h4>
            <table class="size-table" style="margin-bottom:32px;">
              <thead><tr><th>Element</th><th>Token</th><th>Resolves (Light)</th></tr></thead>
              <tbody>
                <tr><td>Icon</td><td><code>Border/Icon/Icon-Primary</code></td><td>#15181E</td></tr>
                <tr><td>Label</td><td><code>Text/Text-Primary</code></td><td>#15181E</td></tr>
                <tr><td>Icon wrap bg</td><td>none</td><td>&#8212;</td></tr>
              </tbody>
            </table>

            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Active State</h4>
            <table class="size-table" style="margin-bottom:32px;">
              <thead><tr><th>Element</th><th>Token</th><th>Resolves (Light)</th></tr></thead>
              <tbody>
                <tr><td>Icon wrap bg</td><td><code>Background/BG-Accent-Subtle</code></td><td>~#E8F0FE</td></tr>
                <tr><td>Icon</td><td><code>Border/Icon/Icon-Accent</code></td><td>#006AFF</td></tr>
                <tr><td>Label</td><td><code>Text/Text-Accent-Link</code></td><td>#006AFF</td></tr>
              </tbody>
            </table>

            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Hover State</h4>
            <table class="size-table" style="margin-bottom:32px;">
              <thead><tr><th>Element</th><th>Token</th><th>Resolves (Light)</th></tr></thead>
              <tbody>
                <tr><td>Icon wrap bg</td><td><code>Background/BG-Secondary-alt</code></td><td>#F0F2F5</td></tr>
                <tr><td>Icon</td><td><code>Border/Icon/Icon-Primary</code></td><td>#15181E</td></tr>
                <tr><td>Label</td><td><code>Text/Text-Primary</code></td><td>#15181E</td></tr>
              </tbody>
            </table>

            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Disabled State</h4>
            <table class="size-table" style="margin-bottom:32px;">
              <thead><tr><th>Element</th><th>Token</th><th>Resolves (Light)</th></tr></thead>
              <tbody>
                <tr><td>Icon</td><td><code>Border/Icon/Icon-Disabled</code></td><td>#8893AD</td></tr>
                <tr><td>Label</td><td><code>Text/Text-Disabled</code></td><td>#8893AD</td></tr>
              </tbody>
            </table>

            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Add State</h4>
            <table class="size-table" style="margin-bottom:32px;">
              <thead><tr><th>Element</th><th>Token</th><th>Resolves (Light)</th></tr></thead>
              <tbody>
                <tr><td>Circle bg</td><td><code>Background/BG-Button-Primary</code></td><td>#006AFF</td></tr>
                <tr><td>Plus icon</td><td><code>Border/Icon/Icon-Inverse</code></td><td>#FFFFFF</td></tr>
                <tr><td>Label</td><td><code>Text/Text-Primary</code></td><td>#15181E</td></tr>
              </tbody>
