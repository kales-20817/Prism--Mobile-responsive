            const homeIconSvg = '<svg class="bc-home-icon" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1"></path></svg>';

            const escapeHtml = (s) => s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');

            function updatePlayground() {
              const count = parseInt(pgCount.value);
              const overflow = pgOverflow.value === 'true' && count >= 4;
              const showHome = pgHomeIcon.value === 'true';
              const isRtl = pgDirection.value === 'rtl';
              const labels = isRtl ? rtlLabels : ltrLabels;
              const sep = isRtl ? '\u2039' : '\u203A';

              pgBreadcrumbElement.setAttribute('dir', isRtl ? 'rtl' : 'ltr');

              // Build items
              let items = labels.slice(0, count);
              let displayItems = [];

              if (overflow && count >= 4) {
                displayItems.push({ label: items[0], type: 'default' });
                displayItems.push({ label: '\u00B7\u00B7\u00B7', type: 'collapsed' });
                for (let i = count - 3; i < count - 1; i++) {
                  if (i > 0) displayItems.push({ label: items[i], type: 'default' });
                }
                displayItems.push({ label: items[count - 1], type: 'current' });
              } else {
                for (let i = 0; i < count; i++) {
                  displayItems.push({ label: items[i], type: i === count - 1 ? 'current' : 'default' });
                }
              }

              // Build preview HTML
              let previewHtml = '';
              displayItems.forEach((item, idx) => {
                if (idx > 0) previewHtml += '<li><span class="bc-sep">' + sep + '</span></li>';
                if (item.type === 'current') {
                  previewHtml += '<li><span class="bc-item current" aria-current="page">' + item.label + '</span></li>';
                } else if (item.type === 'collapsed') {
                  previewHtml += '<li><span class="bc-item bc-collapsed" aria-label="More items">' + item.label + '</span></li>';
                } else {
                  let iconHtml = (idx === 0 && showHome) ? homeIconSvg : '';
                  previewHtml += '<li><a class="bc-item" href="#">' + iconHtml + item.label + '</a></li>';
                }
              });
              pgBcNav.innerHTML = previewHtml;

              // Build code string
              let dirAttr = isRtl ? ' dir="rtl"' : '';
              let code = '<nav aria-label="Breadcrumb"' + dirAttr + '>\n  <ol class="bc-nav">\n';
              displayItems.forEach((item, idx) => {
                if (idx > 0) code += '    <li><span class="bc-sep">' + sep + '</span></li>\n';
                if (item.type === 'current') {
                  code += '    <li><span class="bc-item current" aria-current="page">' + item.label + '</span></li>\n';
                } else if (item.type === 'collapsed') {
                  code += '    <li><span class="bc-item bc-collapsed" aria-label="More items">\u00B7\u00B7\u00B7</span></li>\n';
                } else {
                  let iconCode = (idx === 0 && showHome) ? '\n      <svg class="bc-home-icon" width="16" height="16" ...></svg>\n      ' : '';
                  code += '    <li><a class="bc-item" href="#">' + iconCode + item.label + '</a></li>\n';
                }
              });
              code += '  </ol>\n</nav>';

              let highlighted = escapeHtml(code)
                .replace(/&lt;(\/?)(nav|ol|li|span|a|svg|path)(.*?)&gt;/g, '&lt;$1<span class="token-tag">$2</span>$3&gt;')
                .replace(/([a-zA-Z-]+)=&quot;(.*?)&quot;/g, '<span class="token-attr">$1</span>=<span class="token-string">"$2"</span>')
                .replace(/\n/g, '<br/>')
                .replace(/  /g, '&nbsp;&nbsp;');
              pgCodeOutput.innerHTML = highlighted;
            }

            [pgCount, pgOverflow, pgHomeIcon, pgDirection].forEach(el => el.addEventListener('change', updatePlayground));

            pgCopyBtn.addEventListener('click', () => {
              const raw = document.createElement('div');
              raw.innerHTML = pgCodeOutput.innerHTML.replace(/<br[^>]*>/gi, '\n').replace(/&nbsp;/g, ' ');
              navigator.clipboard.writeText(raw.innerText).then(() => {
                const orig = pgCopyBtn.innerHTML;
                pgCopyBtn.innerHTML = '<svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Copied!';
                setTimeout(() => pgCopyBtn.innerHTML = orig, 2000);
              });
            });

            updatePlayground();
          })();
          </script>

