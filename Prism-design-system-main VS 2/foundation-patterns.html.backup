    <main class="main-panel">
      <div class="page-header-area">
        <h1 class="page-title">Patterns</h1>
        <p class="page-desc">Reusable interaction and layout patterns that solve common endpoint management workflows consistently across the UEMS product suite.</p>
      </div>

      <div class="main-content-area">
        <div class="main-content-inner">

          <!-- Intro -->
          <div class="doc-section" style="margin-top: 16px;">
            <p>Patterns are proven solutions to recurring design problems. Unlike components (which are discrete UI elements), patterns describe <strong>how components work together</strong> to solve a user task. They encode decisions about layout, flow, interaction, and feedback that have been validated across UEMS products.</p>
            <p>A strong pattern library reduces inconsistency, accelerates design decisions, and ensures that admins experience predictable behavior across modules.</p>
          </div>

          <hr class="doc-divider">

          <!-- Why patterns matter -->
          <div class="doc-section" id="why-patterns">
            <h2>Why patterns matter</h2>
            <p>Endpoint management products involve complex, multi-step workflows. Admins must configure policies, deploy patches, investigate threats, manage devices, and review compliance -- often under time pressure.</p>
            <p>Without shared patterns:</p>
            <ul class="doc-list">
              <li>Similar tasks feel different across modules</li>
              <li>New features reinvent solved problems</li>
              <li>Onboarding takes longer because nothing feels familiar</li>
              <li>Cognitive load increases as admins context-switch</li>
              <li>Design reviews slow down debating already-resolved decisions</li>
            </ul>
            <p>Patterns create <strong>structural familiarity</strong> -- when an admin learns how policy creation works in one module, the same pattern should apply everywhere.</p>
          </div>

          <hr class="doc-divider">

          <!-- Pattern categories -->
          <div class="doc-section" id="pattern-categories">
            <h2>Pattern categories</h2>
            <p>Prism organizes patterns into six categories based on the type of problem they solve.</p>

            <div class="pattern-category-grid">
              <div class="pattern-category-card">
                <div class="pcc-icon">
                  <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6z"/></svg>
                </div>
                <div class="pcc-name">Layout patterns</div>
                <p class="pcc-desc">Page structures, panel configurations, and responsive strategies for dashboards, list views, and detail panels.</p>
              </div>
              <div class="pattern-category-card">
                <div class="pcc-icon">
                  <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5"/></svg>
                </div>
                <div class="pcc-name">Navigation patterns</div>
                <p class="pcc-desc">Wayfinding systems including sidebar trees, breadcrumbs, tabs, and deep-link URL structures.</p>
              </div>
              <div class="pattern-category-card">
                <div class="pcc-icon">
                  <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10"/></svg>
                </div>
                <div class="pcc-name">Data entry patterns</div>
                <p class="pcc-desc">Forms, wizards, inline editing, and bulk actions for policy creation, device configuration, and rule setup.</p>
              </div>
              <div class="pattern-category-card">
                <div class="pcc-icon">
                  <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5m.75-9l3-3 2.148 2.148A12.061 12.061 0 0116.5 7.605"/></svg>
                </div>
                <div class="pcc-name">Data display patterns</div>
                <p class="pcc-desc">Tables, cards, charts, and detail views for presenting device lists, compliance scores, and threat summaries.</p>
              </div>
              <div class="pattern-category-card">
                <div class="pcc-icon">
                  <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0"/></svg>
                </div>
                <div class="pcc-name">Feedback patterns</div>
                <p class="pcc-desc">Notifications, toasts, progress indicators, empty states, and error recovery for async and real-time workflows.</p>
              </div>
              <div class="pattern-category-card">
                <div class="pcc-icon">
                  <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
                </div>
                <div class="pcc-name">Action patterns</div>
                <p class="pcc-desc">Confirmation dialogs, destructive actions, batch operations, and undo/retry flows for critical endpoint tasks.</p>
              </div>
            </div>
          </div>

          <hr class="doc-divider">

          <!-- Empty states -->
          <div class="doc-section" id="empty-states">
            <h2>Empty states</h2>
            <p>Empty states occur when a view has no data to display. They are the <strong>most common pattern</strong> in endpoint management because admins frequently encounter unconfigured modules, empty device groups, or zero-result searches.</p>

            <h3>Anatomy</h3>
            <p>Every empty state must include these elements in order:</p>
            <table class="anatomy-table">
              <thead>
                <tr><th>Element</th><th>Required</th><th>Description</th></tr>
              </thead>
              <tbody>
                <tr><td><strong>Illustration</strong></td><td>Yes</td><td>Spot illustration from the Prism library. Centered, 200-292px wide.</td></tr>
                <tr><td><strong>Headline</strong></td><td>Yes</td><td>Clear statement of what's missing. Use sentence case, max 8 words.</td></tr>
                <tr><td><strong>Description</strong></td><td>Optional</td><td>Brief context or next step. 1-2 lines max.</td></tr>
                <tr><td><strong>Primary CTA</strong></td><td>Yes</td><td>Single action button to resolve the empty state.</td></tr>
                <tr><td><strong>Secondary link</strong></td><td>Optional</td><td>Learn more or documentation link.</td></tr>
              </tbody>
            </table>

            <h3>Rules</h3>
            <ul class="doc-list">
              <li>Always pair illustration with a clear headline</li>
              <li>CTA must describe the action, not the state (e.g., "Add device" not "No devices")</li>
              <li>Never show a blank white area with no guidance</li>
              <li>Use consistent illustration style from the empty state library</li>
              <li>Dark mode illustrations must maintain the same visual weight</li>
            </ul>

            <div class="do-dont-grid">
              <div class="do-card">
                <div class="card-label">Do</div>
                <p>Illustration + "No configurations yet" + "Create configuration" button</p>
                <p>Guide the admin toward their first action</p>
                <p>Use a relevant spot illustration from the library</p>
              </div>
              <div class="dont-card">
                <div class="card-label">Don't</div>
                <p>Show a blank table with "No data"</p>
                <p>Use generic placeholder text without a CTA</p>
                <p>Show different empty state styles per module</p>
              </div>
            </div>
          </div>

          <hr class="doc-divider">

          <!-- Form patterns -->
          <div class="doc-section" id="form-patterns">
            <h2>Form patterns</h2>
            <p>Forms are central to endpoint configuration. Admins create policies, define rules, set up alerts, and configure deployments through forms. Consistency here directly reduces setup errors.</p>

            <h3>Single-page forms</h3>
            <p>Use for simple tasks with fewer than 8 fields.</p>
            <ul class="doc-list">
              <li>Group related fields with a section header</li>
              <li>Place primary action at bottom-right</li>
              <li>Validate inline on blur, not on submit</li>
              <li>Show required indicator on optional fields, not required ones</li>
            </ul>

            <h3>Multi-step wizards</h3>
            <p>Use for complex configuration with logical phases (e.g., policy creation: define > target > schedule > review).</p>
            <ul class="doc-list">
              <li>Show a step indicator with labels, not just numbers</li>
              <li>Allow backward navigation without losing data</li>
              <li>Include a review step before final submission</li>
              <li>Disable "Next" until required fields are valid</li>
              <li>Save draft state automatically</li>
            </ul>

            <h3>Inline editing</h3>
            <p>Use for quick modifications to existing records (e.g., renaming a policy, changing a threshold).</p>
            <ul class="doc-list">
              <li>Click-to-edit with clear hover affordance</li>
              <li>Save on blur or Enter, cancel on Escape</li>
              <li>Show a subtle confirmation (checkmark) on save</li>
              <li>Never use inline editing for destructive changes</li>
            </ul>
          </div>

          <hr class="doc-divider">

          <!-- Table patterns -->
          <div class="doc-section" id="table-patterns">
            <h2>Table patterns</h2>
            <p>Tables are the primary data display in UEMS. Device lists, patch inventories, compliance reports, and threat logs all use tabular layouts. Consistent table behavior is critical.</p>

            <h3>Standard table anatomy</h3>
            <table class="anatomy-table">
              <thead>
                <tr><th>Element</th><th>Behavior</th></tr>
              </thead>
              <tbody>
                <tr><td><strong>Header row</strong></td><td>Sticky on scroll. Sortable columns show directional arrow.</td></tr>
                <tr><td><strong>Checkbox column</strong></td><td>First column. Select-all in header. Indeterminate state supported.</td></tr>
                <tr><td><strong>Row hover</strong></td><td>Subtle background highlight. Action icons appear on hover.</td></tr>
                <tr><td><strong>Pagination</strong></td><td>Bottom-right. Show total count, page size selector, and page navigation.</td></tr>
                <tr><td><strong>Empty state</strong></td><td>Centered illustration + CTA replacing table body.</td></tr>
                <tr><td><strong>Loading</strong></td><td>Skeleton rows matching column layout. No spinner overlay.</td></tr>
                <tr><td><strong>Bulk actions bar</strong></td><td>Appears above table when rows are selected. Shows count + available actions.</td></tr>
              </tbody>
            </table>

            <h3>Column best practices</h3>
            <ul class="doc-list">
              <li>Name/identifier column is always first (after checkbox)</li>
              <li>Status columns use semantic color badges</li>
              <li>Date columns use relative time ("2 hours ago") with tooltip for absolute</li>
              <li>Action column is always last, right-aligned</li>
              <li>Limit visible columns to 7-8; use column picker for more</li>
            </ul>
          </div>

          <hr class="doc-divider">

          <!-- Confirmation patterns -->
          <div class="doc-section" id="confirmation-patterns">
            <h2>Confirmation patterns</h2>
            <p>Endpoint actions often have significant consequences: remote wipes, policy deployments, device isolation, bulk deletions. The right confirmation pattern prevents costly mistakes.</p>

            <h3>Severity levels</h3>
            <div class="pattern-detail-grid">
              <div class="pattern-detail-card">
                <div class="pdc-title">
                  <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  Low risk
                </div>
                <p class="pdc-desc">Non-destructive, reversible actions.</p>
                <ul class="pdc-list">
                  <li>No confirmation needed</li>
                  <li>Provide undo via toast (5s window)</li>
                  <li>Example: archiving a report, editing a name</li>
                </ul>
              </div>
              <div class="pattern-detail-card">
                <div class="pdc-title">
                  <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"/></svg>
                  Medium risk
                </div>
                <p class="pdc-desc">Impactful but reversible with effort.</p>
                <ul class="pdc-list">
                  <li>Standard confirmation dialog</li>
                  <li>Clear description of what will happen</li>
                  <li>Example: deploying a patch, changing a policy</li>
                </ul>
              </div>
              <div class="pattern-detail-card">
                <div class="pdc-title">
                  <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/></svg>
                  High risk
                </div>
                <p class="pdc-desc">Destructive, irreversible, or affects many endpoints.</p>
                <ul class="pdc-list">
                  <li>Friction confirmation: type entity name to proceed</li>
                  <li>Red destructive button styling</li>
                  <li>Example: remote wipe, bulk delete, revoke certificate</li>
                </ul>
              </div>
              <div class="pattern-detail-card">
                <div class="pdc-title">
                  <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/></svg>
                  Critical
                </div>
                <p class="pdc-desc">Security-sensitive or compliance-affecting.</p>
                <ul class="pdc-list">
                  <li>Multi-factor confirmation (type + re-authenticate)</li>
                  <li>Audit trail entry created automatically</li>
                  <li>Example: disable security policy, wipe all devices in group</li>
                </ul>
              </div>
            </div>
          </div>

          <hr class="doc-divider">

          <!-- Loading patterns -->
          <div class="doc-section" id="loading-patterns">
            <h2>Loading patterns</h2>
            <p>UEMS involves heavy data operations: fetching device inventories, scanning threats, generating compliance reports. Loading patterns must communicate progress without blocking productivity.</p>

            <h3>Pattern selection guide</h3>
            <table class="anatomy-table">
              <thead>
                <tr><th>Duration</th><th>Pattern</th><th>Example</th></tr>
              </thead>
              <tbody>
                <tr><td>&lt; 300ms</td><td>No indicator needed</td><td>Filtering a local list</td></tr>
                <tr><td>300ms - 2s</td><td>Skeleton screen</td><td>Loading device table, dashboard widgets</td></tr>
                <tr><td>2s - 10s</td><td>Progress bar with label</td><td>Patch deployment, report generation</td></tr>
                <tr><td>10s - 60s</td><td>Progress with steps</td><td>Bulk operations, compliance scan</td></tr>
                <tr><td>&gt; 60s</td><td>Background task + notification</td><td>Full inventory sync, OS image creation</td></tr>
              </tbody>
            </table>

            <h3>Rules</h3>
            <ul class="doc-list">
              <li>Never block the entire UI for background operations</li>
              <li>Skeleton screens must match the actual layout shape</li>
              <li>Show estimated time remaining for tasks over 10 seconds</li>
              <li>Allow cancellation for tasks over 5 seconds</li>
              <li>Persist progress state across page navigations</li>
            </ul>
          </div>

          <hr class="doc-divider">

          <!-- Search and filter -->
          <div class="doc-section" id="search-filter">
            <h2>Search and filter</h2>
            <p>Admins managing thousands of endpoints need powerful search and filter tools. These patterns must be fast, predictable, and composable.</p>

            <h3>Search bar</h3>
            <ul class="doc-list">
              <li>Always visible at the top of list/table views</li>
              <li>Keyboard shortcut: <code style="font-size:13px; background:var(--prism-surface); padding:3px 8px; border-radius:6px; color:var(--prism-violet-light); border:1px solid var(--prism-border);">Cmd+K</code> or <code style="font-size:13px; background:var(--prism-surface); padding:3px 8px; border-radius:6px; color:var(--prism-violet-light); border:1px solid var(--prism-border);">/</code> to focus</li>
              <li>Debounce 300ms before querying</li>
              <li>Show result count and clear button</li>
              <li>Preserve search term on navigation back</li>
            </ul>

            <h3>Filter bar</h3>
            <ul class="doc-list">
              <li>Horizontal chip-based filters below search</li>
              <li>Each chip opens a dropdown for value selection</li>
              <li>Applied filters show as removable tags</li>
              <li>Support "Save filter" for frequently used combinations</li>
              <li>"Clear all" link when any filter is active</li>
            </ul>
          </div>

          <hr class="doc-divider">

          <!-- Anti-patterns -->
          <div class="doc-section" id="anti-patterns">
            <h2>Anti-patterns</h2>
            <p>Avoid these common mistakes when implementing patterns:</p>
            <ul class="doc-list">
              <li>Inventing new confirmation flows per module instead of reusing severity levels</li>
              <li>Using spinners for table loading instead of skeleton screens</li>
              <li>Showing blank white space instead of proper empty states</li>
              <li>Putting destructive actions in dropdown menus without confirmation</li>
              <li>Creating custom wizard flows that don't support back navigation</li>
              <li>Using different table layouts across modules for similar data</li>
              <li>Blocking the entire page during background operations</li>
              <li>Not preserving form state when navigating away and returning</li>
              <li>Using inconsistent search behavior (some debounced, some instant)</li>
            </ul>
          </div>

          <hr class="doc-divider">

          <!-- Principle -->
          <div class="doc-section" id="principle">
            <h2>Principle</h2>
            <div class="principle-card">
              <p>In Prism, patterns encode institutional knowledge.</p>
              <p>Every solved interaction problem becomes a reusable pattern. Admins benefit from <strong>predictable behavior</strong>, designers benefit from <strong>faster decisions</strong>, and developers benefit from <strong>consistent implementation</strong>.</p>
            </div>
          </div>

          <!-- Feedback -->
          <div class="feedback-banner" style="display: none;">
            <div>
              <div class="fb-text">Help us improve this page</div>
              <div class="fb-sub">Share your feedback to help shape the Patterns documentation.</div>
            </div>
            <div style="display: flex; gap: 12px;">
              <button class="feedback-btn primary" onclick="window.open('https://cliq.zoho.in/company/60002085329/channels/prismdesignsystembyuemssupportfeedback','_blank')">Give Feedback</button>
            </div>
          </div>

        </div>

        <aside class="toc-sidebar">
          <h4 class="toc-heading">On this page</h4>
          <ul class="toc-nav" id="toc-nav"></ul>
        </aside>
      </div>
    </main>
  </div>

  <script>
// Sidebar search: filter foundation nav links by query
    const sidebarSearchInput = document.querySelector('.sidebar-search input');
    const foundationNavItems = document.querySelectorAll('.foundation-nav li');
    if (sidebarSearchInput && foundationNavItems.length) {
      sidebarSearchInput.addEventListener('input', (e) => {
        const q = e.target.value.trim().toLowerCase();
        foundationNavItems.forEach(li => {
          const text = li.textContent.trim().toLowerCase();
          li.style.display = !q || text.includes(q) ? '' : 'none';
        });
      });
      document.addEventListener('keydown', (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
          e.preventDefault();
          sidebarSearchInput.focus();
        }
        if (e.key === 'Escape' && document.activeElement === sidebarSearchInput) {
          sidebarSearchInput.value = '';
          sidebarSearchInput.dispatchEvent(new Event('input'));
          sidebarSearchInput.blur();
        }
      });
    }

    const themeToggle = document.getElementById('themeToggle');
    const moonIcon = document.getElementById('moonIcon');
    const sunIcon = document.getElementById('sunIcon');
    const currentTheme = localStorage.getItem('theme') || 'light';
    if (currentTheme === 'dark') {
      document.documentElement.removeAttribute('data-theme');
      moonIcon.style.display = 'block'; sunIcon.style.display = 'none';
    }
    themeToggle.addEventListener('click', () => {
      let theme = document.documentElement.getAttribute('data-theme');
      if (theme === 'light') {
        document.documentElement.removeAttribute('data-theme');
        localStorage.setItem('theme', 'dark');
        moonIcon.style.display = 'block'; sunIcon.style.display = 'none';
      } else {
        document.documentElement.setAttribute('data-theme', 'light');
        localStorage.setItem('theme', 'light');
        moonIcon.style.display = 'none'; sunIcon.style.display = 'block';
      }
    });

    // Dynamic TOC with scroll-spy
    (function() {
      const sections = document.querySelectorAll('.doc-section[id]');
      const tocNav = document.getElementById('toc-nav');
      sections.forEach(sec => {
        const h2 = sec.querySelector('h2');
        if (h2) {
          const li = document.createElement('li');
          const a = document.createElement('a');
          a.className = 'toc-link';
          a.href = '#' + sec.id;
          a.textContent = h2.textContent;
          li.appendChild(a);
          tocNav.appendChild(li);
        }
      });
      const obs = new IntersectionObserver(entries => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            document.querySelectorAll('.toc-link').forEach(l => l.classList.remove('active'));
            const link = tocNav.querySelector('a[href="#' + entry.target.id + '"]');
            if (link) link.classList.add('active');
          }
        });
      }, { rootMargin: '-80px 0px -60% 0px', threshold: 0.1 });
      sections.forEach(sec => obs.observe(sec));
    })();
  </script>
<script>
(function(){
  const nav = document.querySelector('.nav');
  if (!nav) return;
  const toggle = () => {
    if (window.scrollY > 10) nav.classList.add('scrolled');
    else nav.classList.remove('scrolled');
  };
  toggle();
  window.addEventListener('scroll', toggle, { passive: true });
})();
</script>
<script>
(function(){
  const hamburger = document.querySelector('.nav-hamburger');
  const sidebar = document.querySelector('.sidebar');
  const backdrop = document.querySelector('.sidebar-backdrop');
  const navLinks = document.querySelector('.nav-links');
  if (!hamburger || !sidebar || !backdrop) return;

  // Build a mobile-only nav section at the top of the sidebar by cloning the nav links
  if (navLinks && !sidebar.querySelector('.sidebar-mobile-nav')) {
    const mobileNav = document.createElement('div');
    mobileNav.className = 'sidebar-mobile-nav';
    const heading = document.createElement('h4');
    heading.textContent = 'Navigate';
    mobileNav.appendChild(heading);
    const ul = document.createElement('ul');
    navLinks.querySelectorAll(':scope > a').forEach(a => {
      const li = document.createElement('li');
      const clone = a.cloneNode(true);
      li.appendChild(clone);
      ul.appendChild(li);
    });
    navLinks.querySelectorAll(':scope > .nav-dropdown > .nav-dropdown-menu > a').forEach(a => {
      const li = document.createElement('li');
      const clone = a.cloneNode(true);
      li.appendChild(clone);
      ul.appendChild(li);
    });
    mobileNav.appendChild(ul);
    sidebar.insertBefore(mobileNav, sidebar.firstChild);
  }

  const open = () => {
    sidebar.classList.add('open');
    backdrop.classList.add('open');
    document.body.classList.add('sidebar-locked');
    hamburger.setAttribute('aria-expanded', 'true');
  };
  const close = () => {
    sidebar.classList.remove('open');
    backdrop.classList.remove('open');
    document.body.classList.remove('sidebar-locked');
    hamburger.setAttribute('aria-expanded', 'false');
  };
  hamburger.addEventListener('click', () => sidebar.classList.contains('open') ? close() : open());
  backdrop.addEventListener('click', close);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && sidebar.classList.contains('open')) close(); });
  sidebar.addEventListener('click', (e) => { if (e.target.closest('a')) close(); });
})();
</script>

