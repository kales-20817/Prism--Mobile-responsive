          <!-- Zia Error -->
          <h2 id="zia-notification">Zia Error</h2>
          <p>AI-powered error detection and resolution suggestions from Zia that help admins quickly identify misconfigurations and apply fixes across their endpoint environment.</p>
          <div id="div-9" class="theme-container" style="border-radius:16px;padding:48px 24px;border:1px solid var(--prism-border);box-shadow:0 4px 24px rgba(0,0,0,0.08);width:100%;display:flex;justify-content:center;margin-bottom:40px;">
            <div class="zia-error-wrap" style="display:flex;flex-direction:column;align-items:flex-start;gap:12px;max-width:560px;width:100%;position:relative;">
              <!-- Input field -->
              <div style="display:flex;align-items:center;gap:16px;width:100%;">
                <label style="font-size:14px;font-weight:500;color:var(--prism-text-muted);white-space:nowrap;">Port (Outgoing)</label>
                <input type="text" value="25" style="flex:1;padding:8px 14px;border:1px solid var(--prism-border);border-radius:6px;background:var(--prism-surface);color:var(--prism-text);font-family:inherit;font-size:14px;outline:none;" />
              </div>
              <!-- Warning message -->
              <div style="display:flex;align-items:center;gap:6px;margin-left:126px;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M12 2L1 21h22L12 2z" fill="#ef4444" opacity="0.15" stroke="#ef4444" stroke-width="1.5" stroke-linejoin="round"/><line x1="12" y1="10" x2="12" y2="14" stroke="#ef4444" stroke-width="2" stroke-linecap="round"/><circle cx="12" cy="17" r="1" fill="#ef4444"/></svg>
                <span style="font-size:13px;font-weight:600;color:#ef4444;">Verify the entered Mail Server Port!</span>
                <svg class="zia-sparkle-icon" width="16" height="16" viewBox="0 0 15.28 15.28" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path class="zia-spark-path1" d="M6.247 3.717l.47 1.307a3.56 3.56 0 0 0 2.114 2.114l1.306.47c.118.043.118.21 0 .252l-1.306.47a3.56 3.56 0 0 0-2.114 2.115l-.47 1.306c-.043.118-.21.118-.252 0l-.47-1.306a3.56 3.56 0 0 0-2.115-2.114l-1.306-.471c-.118-.043-.118-.21 0-.252l1.306-.47A3.56 3.56 0 0 0 5.525 5.024l.47-1.307c.043-.118.21-.118.252 0Z" fill="url(#zia-spark-s1)"/>
                  <path class="zia-spark-path2" d="M12.126.578l.238.661a2.01 2.01 0 0 0 1.177 1.177l.662.238c.06.022.06.106 0 .128l-.662.238a2.01 2.01 0 0 0-1.177 1.177l-.238.661c-.022.06-.106.06-.128 0l-.238-.661a2.01 2.01 0 0 0-1.177-1.177l-.662-.238c-.06-.022-.06-.106 0-.128l.662-.238A2.01 2.01 0 0 0 11.76 1.24l.238-.661c.022-.06.107-.06.128 0Z" fill="url(#zia-spark-s2)"/>
                </svg>
              </div>
              <!-- Zia popover -->
              <div style="position:relative;margin-left:126px;margin-top:4px;width:100%;max-width:400px;">
                <!-- Arrow pointing up to zia-sparkle-icon (end of warning row) -->
                <div class="zia-error-arrow" style="position:absolute;top:-8px;left:262px;width:16px;height:16px;background:#fff;border-left:1px solid #FFC6F7;border-top:1px solid #FFC6F7;border-right:none;border-bottom:none;transform:rotate(45deg);z-index:1;"></div>
                <div class="zia-error-popover" style="position:relative;z-index:2;border:1px solid #FFC6F7;border-radius:10px;background:#fff;padding:20px 24px;width:100%;max-width:400px;box-shadow:0 4px 20px rgba(219,24,193,0.08);">
                  <p style="font-size:13px;line-height:1.65;color:#505564;margin:0 0 14px 0;">The Port (Outgoing) field determines which network port your mail server uses to send emails (SMTP/SMTPS).</p>
                  <p style="font-size:13px;font-weight:700;color:#1a1a2e;margin:0 0 8px 0;">Depending on your configuration:</p>
                  <ul style="margin:0 0 16px 18px;padding:0;font-size:13px;line-height:1.7;color:#505564;">
                    <li>SMTP (non-encrypted): 25 or sometimes 587</li>
                    <li>SMTPS (SSL/TLS): 465</li>
                    <li>STARTTLS: 587</li>
                  </ul>
                  <p style="font-size:13px;font-weight:700;color:#1a1a2e;margin:0 0 8px 0;">Auto Suggestion</p>
                  <div class="zia-fix-btn" style="display:inline-flex;align-items:center;gap:6px;padding:8px 14px;border:1.5px solid transparent;border-radius:8px;cursor:pointer;font-size:13px;color:#505564;transition:all 0.2s;background-image:linear-gradient(var(--zia-fix-bg,#fff),var(--zia-fix-bg,#fff)),linear-gradient(180deg,rgba(219,24,193,0.5),rgba(0,106,230,0.5));background-origin:border-box;background-clip:padding-box,border-box;">
                    <svg class="zia-sparkle-icon" width="14" height="14" viewBox="0 0 15.28 15.28" fill="none"><path class="zia-spark-path1" d="M6.247 3.717l.47 1.307a3.56 3.56 0 0 0 2.114 2.114l1.306.47c.118.043.118.21 0 .252l-1.306.47a3.56 3.56 0 0 0-2.114 2.115l-.47 1.306c-.043.118-.21.118-.252 0l-.47-1.306a3.56 3.56 0 0 0-2.115-2.114l-1.306-.471c-.118-.043-.118-.21 0-.252l1.306-.47A3.56 3.56 0 0 0 5.525 5.024l.47-1.307c.043-.118.21-.118.252 0Z" fill="url(#zia-spark-s1)"/><path class="zia-spark-path2" d="M12.126.578l.238.661a2.01 2.01 0 0 0 1.177 1.177l.662.238c.06.022.06.106 0 .128l-.662.238a2.01 2.01 0 0 0-1.177 1.177l-.238.661c-.022.06-.106.06-.128 0l-.238-.661a2.01 2.01 0 0 0-1.177-1.177l-.662-.238c-.06-.022-.06-.106 0-.128l.662-.238A2.01 2.01 0 0 0 11.76 1.24l.238-.661c.022-.06.107-.06.128 0Z" fill="url(#zia-spark-s2)"/></svg>
                    How to fix this port error
                  </div>
                </div>
              </div>
            </div>
          </div>

          <hr class="doc-divider">

          <!-- Core Principles -->
                      <h2 id="core-principles">Core Principles</h2>

            <div id="tone-grid" class="tone-grid">
              <div id="tone-card" class="tone-card">
                <h4>1. Context-first intelligence</h4>
                <p>Zia must use device, user, policy, patch, vulnerability, and remediation context before generating output.</p>
              </div>
              <div id="tone-card-2" class="tone-card">
                <h4>2. Explainable recommendations</h4>
                <p>Every AI suggestion should answer:</p>
                <ul class="tone-examples">
                  <li>Why this issue matters</li>
                  <li>What caused it</li>
                  <li>What happens next</li>
                  <li>What action is recommended</li>
                </ul>
              </div>
              <div id="tone-card-3" class="tone-card">
                <h4>3. Human-controlled automation</h4>
                <p>Zia assists admins but should never silently apply risky endpoint actions.</p>
              </div>
              <div id="tone-card-4" class="tone-card">
                <h4>4. Workflow acceleration</h4>
                <p>Zia should reduce:</p>
                <ul class="tone-examples">
                  <li>Alert triage time</li>
                  <li>Device troubleshooting time</li>
                  <li>Patch prioritization effort</li>
                  <li>Report generation effort</li>
                  <li>Root-cause analysis time</li>
                </ul>
              </div>
            </div>
          
          <hr class="doc-divider">

          <!-- Usage Guidelines -->
                      <h2 id="usage-guidelines">Usage Guidelines</h2>
            <div id="do-dont-grid" class="do-dont-grid">
              <div id="do-card" class="do-card">
                <div id="card-label" class="card-label"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Do</div>
                <ul>
                  <li>Place Zia near decision-heavy workflows</li>
                  <li>Surface AI only when context is rich</li>
                  <li>Prioritize actionability over verbosity</li>
                  <li>Include confidence and reasoning</li>
                  <li>Keep admins in control</li>
                </ul>
              </div>
              <div id="dont-card" class="dont-card">
                <div id="card-label-2" class="card-label"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg> Don't</div>
                <ul>
                  <li>Use Zia for decorative insights</li>
                  <li>Generate vague recommendations</li>
                  <li>Hide AI-generated decisions</li>
                  <li>Auto-trigger high-risk actions</li>
                  <li>Overwhelm dashboards with chat UI</li>
                </ul>
              </div>
            </div>
          
          <hr class="doc-divider">

          <!-- Content Guidelines -->
                      <h2 id="content-guidelines">Content Guidelines</h2>

            <h3 class="doc-h3">Tone</h3>
            <div id="tone-grid-2" class="tone-grid">
              <div id="tone-card-5" class="tone-card">
                <h4>Operational</h4>
                <p>Language focused on tasks, outcomes, and system state.</p>
              </div>
              <div id="tone-card-6" class="tone-card">
                <h4>Precise</h4>
                <p>Specific numbers, device counts, and clear scope in every message.</p>
              </div>
              <div id="tone-card-7" class="tone-card">
                <h4>Confidence-driven</h4>
                <p>Every recommendation backed by data sources and reasoning.</p>
              </div>
              <div id="tone-card-8" class="tone-card">
                <h4>Minimal ambiguity</h4>
                <p>No vague phrasing. Clear actions with defined impact.</p>
              </div>
            </div>

          <hr class="doc-divider">

          <!-- Accessibility -->
                      <h2 id="accessibility">Accessibility</h2>
            <ul class="doc-list">
              <li>Keyboard-first AI triggers</li>
              <li>Screen-reader labels for AI insights</li>
              <li>Live region announcements for generated responses</li>
              <li>High-contrast AI containers</li>
              <li>Visible focus states</li>
              <li>Readable progress indicators</li>
            </ul>
          
          <hr class="doc-divider">

          <!-- Responsive Behavior -->
