          <!-- Zia Tab -->
          <h2 id="zia-tab">Zia Tab</h2>
          <p>A dedicated Zia tab that provides a centralized AI-powered workspace for managing endpoint tasks, insights, and recommendations within the console.</p>
          <div id="div-8" class="theme-container" style="border-radius:16px;padding:24px;border:1px solid var(--prism-border);box-shadow:0 4px 24px rgba(0,0,0,0.08);width:100%;display:flex;justify-content:center;margin-bottom:40px;">
            <div class="zia-tab-bar">
              <div class="zia-tab-item active">
                <svg class="zia-sparkle-icon" width="16" height="16" viewBox="0 0 15.28 15.28" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path class="zia-spark-path1" d="M6.247 3.717l.47 1.307a3.56 3.56 0 0 0 2.114 2.114l1.306.47c.118.043.118.21 0 .252l-1.306.47a3.56 3.56 0 0 0-2.114 2.115l-.47 1.306c-.043.118-.21.118-.252 0l-.47-1.306a3.56 3.56 0 0 0-2.115-2.114l-1.306-.471c-.118-.043-.118-.21 0-.252l1.306-.47A3.56 3.56 0 0 0 5.525 5.024l.47-1.307c.043-.118.21-.118.252 0Z" fill="url(#zia-spark-s1)"/>
