          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="component-api-properties" class="doc-h3">Component API &amp; Properties</h3>
            <table class="size-table">
              <thead><tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
              <tbody>
                <tr><td><code>type</code></td><td><code>'single' | 'range'</code></td><td><code>'single'</code></td><td>Selection model. Range renders two inputs and a dual calendar.</td></tr>
                <tr><td><code>value</code></td><td><code>Date | null | [Date, Date]</code></td><td><code>null</code></td><td>Controlled value. Single &rarr; Date; Range &rarr; [start, end].</td></tr>
                <tr><td><code>onChange</code></td><td><code>(value) =&gt; void</code></td><td>&mdash;</td><td>Fires when the selection changes (or per-endpoint when no Footer).</td></tr>
                <tr><td><code>label</code></td><td><code>string</code></td><td><code>"Select Date"</code></td><td>Field label text.</td></tr>
                <tr><td><code>required</code></td><td><code>boolean</code></td><td><code>false</code></td><td>Appends a red <code>*</code> to the label.</td></tr>
                <tr><td><code>isDisabled</code></td><td><code>boolean</code></td><td><code>false</code></td><td>Disables the inputs and prevents the popover from opening.</td></tr>
                <tr><td><code>validationState</code></td><td><code>'none' | 'success' | 'error'</code></td><td><code>'none'</code></td><td>Drives border colour and helper-row icon/text.</td></tr>
                <tr><td><code>helperText</code></td><td><code>string</code></td><td>&mdash;</td><td>Helper or validation message below the input.</td></tr>
                <tr><td><code>placeholder</code></td><td><code>string</code></td><td><code>"DD/MM/YYYY"</code></td><td>Input placeholder. For Range, use <code>placeholderStart</code> / <code>placeholderEnd</code>.</td></tr>
                <tr><td><code>format</code></td><td><code>string</code></td><td><code>"DD/MM/YYYY"</code></td><td>Display format for the input value. Locale-aware.</td></tr>
                <tr><td><code>minDate</code></td><td><code>Date</code></td><td>&mdash;</td><td>Earliest selectable date. Days before are disabled in the grid.</td></tr>
                <tr><td><code>maxDate</code></td><td><code>Date</code></td><td>&mdash;</td><td>Latest selectable date.</td></tr>
                <tr><td><code>disabledDates</code></td><td><code>(d: Date) =&gt; boolean</code></td><td>&mdash;</td><td>Predicate to disable specific days (e.g. weekends, holidays).</td></tr>
                <tr><td><code>showPresets</code></td><td><code>boolean</code></td><td><code>false</code></td><td>Show the preset-shortcut column in the popover.</td></tr>
                <tr><td><code>presets</code></td><td><code>Preset[]</code></td><td>Defaults</td><td>Override the default preset list.</td></tr>
                <tr><td><code>showFooter</code></td><td><code>boolean</code></td><td><code>false</code></td><td>Show Apply / Cancel / Clear footer. Enables "staged" selection.</td></tr>
                <tr><td><code>applyLabel / cancelLabel / clearLabel</code></td><td><code>string</code></td><td><code>"Apply" / "Cancel" / "Clear"</code></td><td>Footer button labels.</td></tr>
                <tr><td><code>weekStartsOn</code></td><td><code>0 | 1 | 2 | 3 | 4 | 5 | 6</code></td><td><code>0</code> (Sun)</td><td>First day of the week in the grid.</td></tr>
                <tr><td><code>locale</code></td><td><code>string</code></td><td><code>"en"</code></td><td>BCP 47 locale tag for month / weekday labels.</td></tr>
                <tr><td><code>numberOfMonths</code></td><td><code>1 | 2</code></td><td><code>type === 'range' ? 2 : 1</code></td><td>Override the number of calendar panels shown.</td></tr>
                <tr><td><code>isOpen / onOpenChange</code></td><td><code>boolean / (open) =&gt; void</code></td><td><code>false</code></td><td>Controlled open state.</td></tr>
                <tr><td><code>rtl</code></td><td><code>boolean</code></td><td><code>false</code></td><td>Mirrors the layout for right-to-left reading order.</td></tr>
              </tbody>
            </table>

            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin:24px 0 12px;">Preset shape</h4>
            <table class="size-table">
              <thead><tr><th>Key</th><th>Type</th><th>Description</th></tr></thead>
              <tbody>
                <tr><td><code>id</code></td><td><code>string</code></td><td>Unique preset id.</td></tr>
                <tr><td><code>label</code></td><td><code>string</code></td><td>Visible label (e.g. "Last 7 days").</td></tr>
                <tr><td><code>getRange</code></td><td><code>() =&gt; Date | [Date, Date]</code></td><td>Function returning the preset's value at activation time.</td></tr>
              </tbody>
            </table>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="html-example" class="doc-h3">HTML Example</h3>
            <div class="cp-code-area" style="border-radius:12px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;">
                <span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">div</span> <span style="color:#D19A66;">class</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"dp-wrapper"</span><span style="color:#ABB2BF;">&gt;</span><br>
                &nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">label</span> <span style="color:#D19A66;">for</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"dueDate"</span><span style="color:#ABB2BF;">&gt;</span>Due date <span style="color:#E06C75;">*</span><span style="color:#ABB2BF;">&lt;/</span><span style="color:#E06C75;">label</span><span style="color:#ABB2BF;">&gt;</span><br>
                &nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">div</span> <span style="color:#D19A66;">class</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"dp-input-field"</span><span style="color:#ABB2BF;">&gt;</span><br>
                &nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">span</span> <span style="color:#D19A66;">class</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"dp-cal-icon"</span><span style="color:#ABB2BF;">&gt;</span>&#128197;<span style="color:#ABB2BF;">&lt;/</span><span style="color:#E06C75;">span</span><span style="color:#ABB2BF;">&gt;</span><br>
                &nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">input</span><br>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#D19A66;">id</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"dueDate"</span><br>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#D19A66;">class</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"dp-input"</span><br>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#D19A66;">type</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"text"</span><br>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#D19A66;">inputmode</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"numeric"</span><br>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#D19A66;">placeholder</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"DD/MM/YYYY"</span><br>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#D19A66;">aria-haspopup</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"dialog"</span><br>
                &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#D19A66;">aria-describedby</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"dueDate-help"</span><br>
                &nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#ABB2BF;">/&gt;</span><br>
                &nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;/</span><span style="color:#E06C75;">div</span><span style="color:#ABB2BF;">&gt;</span><br>
                &nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">div</span> <span style="color:#D19A66;">id</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"dueDate-help"</span> <span style="color:#D19A66;">class</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"dp-helper"</span><span style="color:#ABB2BF;">&gt;</span>Please enter a future date.<span style="color:#ABB2BF;">&lt;/</span><span style="color:#E06C75;">div</span><span style="color:#ABB2BF;">&gt;</span><br>
                <span style="color:#ABB2BF;">&lt;/</span><span style="color:#E06C75;">div</span><span style="color:#ABB2BF;">&gt;</span>
              </div>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="react-examples" class="doc-h3">React Examples</h3>

            <h4 style="font-size:15px;font-weight:600;color:var(--prism-text);margin:16px 0 10px;">Basic &mdash; Single date</h4>
            <div class="cp-code-area" style="border-radius:12px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;">
                <span style="color:#C678DD;">const</span> [<span style="color:#E5C07B;">date</span>, <span style="color:#E5C07B;">setDate</span>] = <span style="color:#61AFEF;">useState</span>&lt;<span style="color:#E5C07B;">Date</span> | <span style="color:#C678DD;">null</span>&gt;(<span style="color:#C678DD;">null</span>);<br><br>
                <span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">DatePicker</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">label</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"Due date"</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">value</span><span style="color:#56B6C2;">=</span>{<span style="color:#E5C07B;">date</span>}<br>
                &nbsp;&nbsp;<span style="color:#D19A66;">onChange</span><span style="color:#56B6C2;">=</span>{<span style="color:#E5C07B;">setDate</span>}<br>
                &nbsp;&nbsp;<span style="color:#D19A66;">required</span><br>
                <span style="color:#ABB2BF;">/&gt;</span>
              </div>
            </div>

            <h4 style="font-size:15px;font-weight:600;color:var(--prism-text);margin:24px 0 10px;">Range</h4>
            <div class="cp-code-area" style="border-radius:12px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;">
                <span style="color:#C678DD;">const</span> [<span style="color:#E5C07B;">range</span>, <span style="color:#E5C07B;">setRange</span>] = <span style="color:#61AFEF;">useState</span>&lt;[<span style="color:#E5C07B;">Date</span> | <span style="color:#C678DD;">null</span>, <span style="color:#E5C07B;">Date</span> | <span style="color:#C678DD;">null</span>]&gt;([<span style="color:#C678DD;">null</span>, <span style="color:#C678DD;">null</span>]);<br><br>
                <span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">DatePicker</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">type</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"range"</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">label</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"Report period"</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">value</span><span style="color:#56B6C2;">=</span>{<span style="color:#E5C07B;">range</span>}<br>
                &nbsp;&nbsp;<span style="color:#D19A66;">onChange</span><span style="color:#56B6C2;">=</span>{<span style="color:#E5C07B;">setRange</span>}<br>
                &nbsp;&nbsp;<span style="color:#D19A66;">required</span><br>
                <span style="color:#ABB2BF;">/&gt;</span>
              </div>
            </div>

            <h4 style="font-size:15px;font-weight:600;color:var(--prism-text);margin:24px 0 10px;">With presets + footer (staged commit)</h4>
            <div class="cp-code-area" style="border-radius:12px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;">
                <span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">DatePicker</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">type</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"range"</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">label</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"Report period"</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">value</span><span style="color:#56B6C2;">=</span>{<span style="color:#E5C07B;">range</span>}<br>
                &nbsp;&nbsp;<span style="color:#D19A66;">onChange</span><span style="color:#56B6C2;">=</span>{<span style="color:#E5C07B;">setRange</span>}<br>
                &nbsp;&nbsp;<span style="color:#D19A66;">showPresets</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">showFooter</span><br>
                <span style="color:#ABB2BF;">/&gt;</span>
              </div>
            </div>

            <h4 style="font-size:15px;font-weight:600;color:var(--prism-text);margin:24px 0 10px;">Min / Max bounded</h4>
            <div class="cp-code-area" style="border-radius:12px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;">
                <span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">DatePicker</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">label</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"Appointment date"</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">value</span><span style="color:#56B6C2;">=</span>{<span style="color:#E5C07B;">date</span>}<br>
                &nbsp;&nbsp;<span style="color:#D19A66;">onChange</span><span style="color:#56B6C2;">=</span>{<span style="color:#E5C07B;">setDate</span>}<br>
                &nbsp;&nbsp;<span style="color:#D19A66;">minDate</span><span style="color:#56B6C2;">=</span>{<span style="color:#C678DD;">new</span> <span style="color:#E5C07B;">Date</span>()}<br>
                &nbsp;&nbsp;<span style="color:#D19A66;">maxDate</span><span style="color:#56B6C2;">=</span>{<span style="color:#61AFEF;">addDays</span>(<span style="color:#C678DD;">new</span> <span style="color:#E5C07B;">Date</span>(), <span style="color:#D19A66;">90</span>)}<br>
                <span style="color:#ABB2BF;">/&gt;</span>
              </div>
            </div>

            <h4 style="font-size:15px;font-weight:600;color:var(--prism-text);margin:24px 0 10px;">Weekends disabled</h4>
            <div class="cp-code-area" style="border-radius:12px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;">
                <span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">DatePicker</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">label</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"Working day"</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">value</span><span style="color:#56B6C2;">=</span>{<span style="color:#E5C07B;">date</span>}<br>
                &nbsp;&nbsp;<span style="color:#D19A66;">onChange</span><span style="color:#56B6C2;">=</span>{<span style="color:#E5C07B;">setDate</span>}<br>
                &nbsp;&nbsp;<span style="color:#D19A66;">disabledDates</span><span style="color:#56B6C2;">=</span>{<span style="color:#E5C07B;">d</span> =&gt; [<span style="color:#D19A66;">0</span>, <span style="color:#D19A66;">6</span>].<span style="color:#61AFEF;">includes</span>(<span style="color:#E5C07B;">d</span>.<span style="color:#61AFEF;">getDay</span>())}<br>
                <span style="color:#ABB2BF;">/&gt;</span>
              </div>
            </div>

            <h4 style="font-size:15px;font-weight:600;color:var(--prism-text);margin:24px 0 10px;">Error state</h4>
            <div class="cp-code-area" style="border-radius:12px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;">
                <span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">DatePicker</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">label</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"Due date"</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">value</span><span style="color:#56B6C2;">=</span>{<span style="color:#E5C07B;">date</span>}<br>
                &nbsp;&nbsp;<span style="color:#D19A66;">onChange</span><span style="color:#56B6C2;">=</span>{<span style="color:#E5C07B;">setDate</span>}<br>
                &nbsp;&nbsp;<span style="color:#D19A66;">validationState</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"error"</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">helperText</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"Due date must be in the future."</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">required</span><br>
                <span style="color:#ABB2BF;">/&gt;</span>
              </div>
            </div>

            <h4 style="font-size:15px;font-weight:600;color:var(--prism-text);margin:24px 0 10px;">Localised (German, Monday-first)</h4>
            <div class="cp-code-area" style="border-radius:12px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;">
                <span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">DatePicker</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">label</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"Geburtsdatum"</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">locale</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"de-DE"</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">weekStartsOn</span><span style="color:#56B6C2;">=</span>{<span style="color:#D19A66;">1</span>}<br>
                &nbsp;&nbsp;<span style="color:#D19A66;">format</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"DD.MM.YYYY"</span><br>
                <span style="color:#ABB2BF;">/&gt;</span>
              </div>
            </div>
          </div>
        </div>

        <!-- ========== ACCESSIBILITY ========== -->
        <div class="tab-content" id="tab-accessibility" style="display:none;padding-top:32px;">
          <h2 id="accessibility" class="doc-section-title">Accessibility</h2>
          <p class="doc-section-subtitle">Guidelines for ensuring Date Picker is accessible across assistive technologies and input methods.</p>

          <div class="doc-section">
            <h3 id="keyboard-navigation" class="doc-h3">Keyboard Navigation</h3>
            <p class="doc-section-subtitle" style="margin-bottom:18px;">The input accepts direct typing; the popover grid supports full arrow-key navigation.</p>
            <table class="size-table">
              <thead><tr><th>Target</th><th>Key</th><th>Action</th></tr></thead>
              <tbody>
                <tr><td rowspan="3"><strong>Input</strong></td><td><code>Down Arrow</code> / <code>Space</code></td><td>Opens the calendar popover.</td></tr>
                <tr><td><code>Esc</code></td><td>Closes the popover; returns focus to the input.</td></tr>
                <tr><td>Direct typing</td><td>Type in <code>DD/MM/YYYY</code> format (locale-aware).</td></tr>
                <tr><td rowspan="7"><strong>Day grid</strong></td><td><code>Arrow Left</code> / <code>Arrow Right</code></td><td>Moves focus &plusmn;1 day.</td></tr>
                <tr><td><code>Arrow Up</code> / <code>Arrow Down</code></td><td>Moves focus &plusmn;1 week.</td></tr>
                <tr><td><code>PageUp</code> / <code>PageDown</code></td><td>Moves focus &plusmn;1 month.</td></tr>
                <tr><td><code>Shift+PageUp</code> / <code>Shift+PageDown</code></td><td>Moves focus &plusmn;1 year.</td></tr>
                <tr><td><code>Home</code> / <code>End</code></td><td>Jumps to the start / end of the week.</td></tr>
                <tr><td><code>Enter</code> / <code>Space</code></td><td>Selects the focused day.</td></tr>
                <tr><td><code>Esc</code></td><td>Closes the popover without committing.</td></tr>
              </tbody>
            </table>
            <div style="margin-top:16px;padding:16px 20px;background:rgba(37,99,235,0.05);border:1px solid rgba(37,99,235,0.15);border-radius:12px;">
              <p style="font-size:14px;color:var(--prism-text);line-height:1.6;margin:0;">The popover must trap focus within itself while open. <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">Tab</code> cycles through: grid &rarr; presets &rarr; footer buttons &rarr; back to the grid.</p>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="aria-attributes" class="doc-h3">ARIA Attributes</h3>
            <ul class="doc-list">
              <li><strong>Input element:</strong> Native <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;input type="text"&gt;</code> with pattern mask, or <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;input type="date"&gt;</code> as a progressive-enhancement baseline.</li>
              <li><strong>Popover:</strong> <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">role="dialog" aria-modal="false"</code> anchored to the input.</li>
              <li><strong>Label association:</strong> Connect <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;label for="id"&gt;</code> to the input. For Range, wrap in a <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;fieldset&gt;</code> + <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;legend&gt;</code> with Start / End labelled inputs.</li>
              <li><strong>Calendar grid semantics:</strong> <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">role="grid"</code> on the day grid, <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">role="row"</code> on each week, <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">role="gridcell"</code> on each day, <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">role="columnheader"</code> on weekday abbreviations.</li>
              <li><strong>Current day:</strong> Mark today with <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-current="date"</code>.</li>
              <li><strong>Selected state:</strong> Set <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-selected="true"</code> on selected day cells. For Range, also on days between endpoints.</li>
              <li><strong>Validation:</strong> Set <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-invalid="true"</code> in Error state; link the helper via <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-describedby</code>.</li>
              <li><strong>Range completion:</strong> When the user has a start but no end, set <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-describedby</code> to say "End date required".</li>
            </ul>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="screen-reader-guidance" class="doc-h3">Screen Reader Guidance</h3>
            <ul class="doc-list">
              <li><strong>Month navigation announcement:</strong> On month change, announce the new month/year via <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-live="polite"</code> on a hidden status node.</li>
              <li><strong>Selection announcement:</strong> After the user picks a day, announce the fully-formatted date (e.g. "15 March 2026 selected") via <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-live</code>.</li>
              <li><strong>Visual-only highlight:</strong> Never rely on colour alone &mdash; always pair with <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-selected</code> and live announcements.</li>
              <li><strong>Contrast:</strong> Selected-day text on BG-Accent must meet WCAG AA 4.5:1. Outside-month days use Text-Disabled &mdash; verify against grid background.</li>
              <li><strong>RTL:</strong> Mirror the weekday-row order, chevron direction, and Range input order (end on the left, start on the right).</li>
              <li><strong>Time zones:</strong> Always store UTC internally; format on display. The component must not shift the selected date due to the local time-zone offset.</li>
            </ul>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="focus-management" class="doc-h3">Focus Management</h3>
            <ul class="doc-list">
              <li><strong>On open:</strong> Focus moves to the currently selected day in the grid. If no selection, focus moves to today.</li>
              <li><strong>On close:</strong> Focus returns to the input that opened the popover.</li>
              <li><strong>Tab order inside popover:</strong> Header chevrons &rarr; month/year label &rarr; grid (single focus target, internal arrow-key nav) &rarr; presets &rarr; footer buttons.</li>
              <li><strong>Focus trap:</strong> <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">Tab</code> at the end of the popover wraps to the top; <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">Shift+Tab</code> at the top wraps to the end. Focus must not escape the popover via keyboard while it is open.</li>
              <li><strong>Visible focus indicator:</strong> The focused day cell shows a 2px accent border (WCAG 2.4.7). This must not be overridden.</li>
              <li><strong>Clicking outside:</strong> Dismisses the popover and restores focus to the input.</li>
            </ul>
            <div style="margin-top:24px;padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;">
              <div style="font-weight:600;font-size:15px;color:var(--prism-text);margin-bottom:8px;">Focus ring spec</div>
              <div style="font-size:14px;color:var(--prism-text-muted);line-height:1.6;">Focused day cell: 2px Border-Accent ring. Focused input: 2px Border-Accent + 3px accent shadow (<code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">rgba(0,106,255,0.15)</code>).</div>
            </div>
          </div>
        </div>

        </div><!-- main-content-inner -->

        <aside class="toc-sidebar">
          <h4 class="toc-heading">On this page</h4>
          <ul class="toc-nav" id="toc-nav"></ul>
          <div class="quick-actions-card">
            <div class="quick-actions-title">Resources</div>
            <a href="MD/date-picker.md" download="date-picker.md" class="action-link"><svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg> Download MD</a>
            <a href="https://www.figma.com/design/DahIgbIJrSkzyP3OoHaDaG/UEMS---Design-System-3.0?node-id=17195-1122073" target="_blank" class="action-link"><img src="assets/figma-icon.svg" alt="Figma" width="15" height="15" style="vertical-align:middle;"> Figma Design</a>
          </div>
        </aside>
      </div><!-- main-content-area -->

    <div id="feedback" class="feedback-banner" style="display: none;">
    <div><div class="fb-text">Was this page helpful?</div><div class="fb-sub">Help us improve by sharing your feedback on this component's documentation.</div></div>
    <div style="display:flex;gap:10px;"><button class="feedback-btn">Not helpful</button><button class="feedback-btn primary">Yes, helpful</button></div>
    </div>

    </main>
  </div>

  <script>
    // ========== Date Picker Interactive Component ==========
    var DP_MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
    var DP_WEEKDAYS = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];

    function dpFormatDate(d) {
      if (!d) return '';
      var dd = String(d.getDate()).padStart(2,'0');
      var mm = String(d.getMonth()+1).padStart(2,'0');
      var yyyy = d.getFullYear();
      return dd + '/' + mm + '/' + yyyy;
    }
    function dpSameDay(a, b) { return a && b && a.getFullYear()===b.getFullYear() && a.getMonth()===b.getMonth() && a.getDate()===b.getDate(); }
    function dpInRange(d, s, e) {
      if (!s || !e) return false;
      var ds = new Date(s.getFullYear(),s.getMonth(),s.getDate()).getTime();
      var de = new Date(e.getFullYear(),e.getMonth(),e.getDate()).getTime();
      if (ds > de) { var t=ds; ds=de; de=t; }
      var dt = new Date(d.getFullYear(),d.getMonth(),d.getDate()).getTime();
      return dt > ds && dt < de;
    }

    function createDatePicker(mountEl, opts) {
      opts = opts || {};
      var state = {
        open: false,
        viewDate: new Date(),
        selected: opts.initialSelected || null,
        rangeStart: opts.initialRangeStart || null,
        rangeEnd: opts.initialRangeEnd || null,
        type: opts.type || 'single',
        presets: !!opts.presets,
        footer: !!opts.footer,
        staged: null,
        stagedStart: null,
        stagedEnd: null
      };
      var today = new Date();

      function render() {
        var inputVal = '';
        if (state.type === 'single') {
          inputVal = state.selected ? dpFormatDate(state.selected) : '';
        } else {
          if (state.rangeStart && state.rangeEnd) {
            inputVal = dpFormatDate(state.rangeStart) + ' - ' + dpFormatDate(state.rangeEnd);
          } else if (state.rangeStart) {
            inputVal = dpFormatDate(state.rangeStart) + ' - ...';
          }
        }
        var focusedCls = state.open ? ' focused' : '';
        var popHtml = state.open ? buildPopover() : '';
        mountEl.innerHTML =
          '<div class="dp-input-field' + focusedCls + '" data-dp-toggle>' +
          '  <span class="dp-cal-icon">' +
          '    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>' +
          '  </span>' +
          '  <input class="dp-input" type="text" placeholder="DD/MM/YYYY" readonly value="' + inputVal + '">' +
          '</div>' + popHtml;
        bind();
      }

      function buildPopover() {
        var y = state.viewDate.getFullYear();
        var m = state.viewDate.getMonth();
        var first = new Date(y, m, 1);
        var startDow = first.getDay();
        var daysInMonth = new Date(y, m+1, 0).getDate();
        var daysInPrev = new Date(y, m, 0).getDate();
        var cells = [];
        for (var i = startDow - 1; i >= 0; i--) {
          cells.push({ d: daysInPrev - i, other: true, date: new Date(y, m-1, daysInPrev - i) });
        }
        for (var d = 1; d <= daysInMonth; d++) {
          cells.push({ d: d, other: false, date: new Date(y, m, d) });
        }
        var nextDay = 1;
        while (cells.length < 42) {
          cells.push({ d: nextDay, other: true, date: new Date(y, m+1, nextDay) });
          nextDay++;
        }

        var daysHtml = cells.map(function(c) {
          var cls = 'dp-day';
          if (c.other) cls += ' other-month';
          if (dpSameDay(c.date, today) && !c.other) cls += ' today';
          if (state.type === 'single') {
            var sel = state.footer ? state.staged : state.selected;
            if (sel && dpSameDay(c.date, sel) && !c.other) cls += ' selected';
          } else {
            var s = state.footer ? state.stagedStart : state.rangeStart;
            var e = state.footer ? state.stagedEnd : state.rangeEnd;
            if (s && dpSameDay(c.date, s) && !c.other) cls += ' range-start';
            else if (e && dpSameDay(c.date, e) && !c.other) cls += ' range-end';
            else if (dpInRange(c.date, s, e) && !c.other) cls += ' in-range';
          }
          return '<div class="' + cls + '" data-dp-day="' + c.date.getTime() + '" role="gridcell">' + c.d + '</div>';
        }).join('');

        var presetsHtml = '';
        if (state.presets) {
          presetsHtml =
            '<div class="dp-presets">' +
            '  <button class="dp-preset-btn" data-dp-preset="today">Today</button>' +
            '  <button class="dp-preset-btn" data-dp-preset="yesterday">Yesterday</button>' +
            '  <button class="dp-preset-btn" data-dp-preset="last7">Last 7 days</button>' +
            '  <button class="dp-preset-btn" data-dp-preset="last30">Last 30 days</button>' +
            '  <button class="dp-preset-btn" data-dp-preset="thisMonth">This month</button>' +
            '</div>';
        }
        var footerHtml = '';
        if (state.footer) {
          footerHtml =
            '<div class="dp-footer">' +
            '  <button class="dp-footer-btn secondary" data-dp-footer="clear">Clear</button>' +
            '  <button class="dp-footer-btn secondary" data-dp-footer="cancel">Cancel</button>' +
            '  <button class="dp-footer-btn primary" data-dp-footer="apply">Apply</button>' +
            '</div>';
        }

        return '' +
          '<div class="dp-popover" role="dialog" aria-label="Choose date">' +
          '  <div class="dp-popover-header">' +
          '    <button class="dp-nav-btn" data-dp-nav="-1" aria-label="Previous month"><svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15 18l-6-6 6-6"/></svg></button>' +
          '    <div class="dp-month-year">' + DP_MONTHS[m] + ' ' + y + '</div>' +
          '    <button class="dp-nav-btn" data-dp-nav="1" aria-label="Next month"><svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 6l6 6-6 6"/></svg></button>' +
          '  </div>' +
          '  <div class="dp-weekdays" role="row">' + DP_WEEKDAYS.map(function(w){return '<div role="columnheader">'+w+'</div>';}).join('') + '</div>' +
          '  <div class="dp-days" role="grid">' + daysHtml + '</div>' +
          presetsHtml + footerHtml +
          '</div>';
      }

      function bind() {
        var toggle = mountEl.querySelector('[data-dp-toggle]');
        if (toggle) {
          toggle.addEventListener('click', function(e) {
            e.stopPropagation();
            state.open = !state.open;
            if (state.open && state.footer) {
              state.staged = state.selected;
              state.stagedStart = state.rangeStart;
              state.stagedEnd = state.rangeEnd;
            }
            render();
          });
        }
        mountEl.querySelectorAll('[data-dp-nav]').forEach(function(btn) {
          btn.addEventListener('click', function(e) {
            e.stopPropagation();
            var delta = parseInt(btn.getAttribute('data-dp-nav'));
            state.viewDate = new Date(state.viewDate.getFullYear(), state.viewDate.getMonth() + delta, 1);
            render();
          });
        });
        mountEl.querySelectorAll('[data-dp-day]').forEach(function(cell) {
          cell.addEventListener('click', function(e) {
            e.stopPropagation();
            if (cell.classList.contains('other-month')) return;
            var d = new Date(parseInt(cell.getAttribute('data-dp-day')));
            if (state.type === 'single') {
              if (state.footer) {
                state.staged = d;
              } else {
                state.selected = d;
                state.open = false;
              }
            } else {
              var startKey = state.footer ? 'stagedStart' : 'rangeStart';
              var endKey = state.footer ? 'stagedEnd' : 'rangeEnd';
              if (!state[startKey] || (state[startKey] && state[endKey])) {
                state[startKey] = d;
                state[endKey] = null;
              } else {
                if (d < state[startKey]) {
                  state[endKey] = state[startKey];
                  state[startKey] = d;
                } else {
                  state[endKey] = d;
                }
                if (!state.footer) state.open = false;
              }
            }
            render();
          });
        });
        mountEl.querySelectorAll('[data-dp-preset]').forEach(function(btn) {
          btn.addEventListener('click', function(e) {
            e.stopPropagation();
            var key = btn.getAttribute('data-dp-preset');
            var now = new Date();
            now.setHours(0,0,0,0);
            var s, e1;
            switch(key) {
              case 'today': s = now; e1 = now; break;
              case 'yesterday': s = new Date(now); s.setDate(s.getDate()-1); e1 = new Date(s); break;
              case 'last7': e1 = now; s = new Date(now); s.setDate(s.getDate()-6); break;
              case 'last30': e1 = now; s = new Date(now); s.setDate(s.getDate()-29); break;
              case 'thisMonth': s = new Date(now.getFullYear(), now.getMonth(), 1); e1 = now; break;
            }
            if (state.type === 'single') {
              if (state.footer) state.staged = s;
              else { state.selected = s; state.open = false; }
            } else {
              if (state.footer) { state.stagedStart = s; state.stagedEnd = e1; }
              else { state.rangeStart = s; state.rangeEnd = e1; state.open = false; }
            }
            state.viewDate = new Date(s.getFullYear(), s.getMonth(), 1);
            render();
          });
        });
        mountEl.querySelectorAll('[data-dp-footer]').forEach(function(btn) {
          btn.addEventListener('click', function(e) {
            e.stopPropagation();
            var action = btn.getAttribute('data-dp-footer');
            if (action === 'clear') {
              state.staged = null; state.stagedStart = null; state.stagedEnd = null;
            } else if (action === 'cancel') {
              state.staged = null; state.stagedStart = null; state.stagedEnd = null;
              state.open = false;
            } else if (action === 'apply') {
              state.selected = state.staged;
              state.rangeStart = state.stagedStart;
              state.rangeEnd = state.stagedEnd;
              state.open = false;
            }
            render();
          });
        });
      }

      document.addEventListener('click', function(e) {
        if (state.open && !mountEl.contains(e.target)) {
          state.open = false;
          render();
        }
      });

      render();
      return state;
    }

    // Initialise demo pickers
    (function() {
      var s = document.getElementById('demo-single');
      var r = document.getElementById('demo-range');
      var p = document.getElementById('demo-presets');
      var f = document.getElementById('demo-footer');
      if (s) createDatePicker(s, { type: 'single' });
      if (r) createDatePicker(r, { type: 'range' });
      if (p) createDatePicker(p, { type: 'single', presets: true });
      if (f) createDatePicker(f, { type: 'single', presets: true, footer: true });
    })();

    // Code Playground
    (function() {
      var els = {
        type: document.getElementById('pg-type'),
        presets: document.getElementById('pg-presets'),
        footer: document.getElementById('pg-footer'),
        state: document.getElementById('pg-state')
      };
      if (!els.type) return;
      var previewArea = document.getElementById('pg-preview-area');
      var codeOut = document.getElementById('pg-code-output');
      var copyBtn = document.getElementById('pg-copy-btn');

      function esc(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

      function update() {
        var type = els.type.value;
        var presets = els.presets.value === 'yes';
        var footer = els.footer.value === 'yes';
        var st = els.state.value;

        // Rebuild preview
        previewArea.innerHTML = '';
        if (st === 'disabled') {
          previewArea.innerHTML = '<div class="dp-wrapper"><div class="dp-input-field disabled"><span class="dp-cal-icon"><svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg></span><input class="dp-input" type="text" placeholder="DD/MM/YYYY" disabled readonly></div></div>';
        } else if (st === 'error') {
          previewArea.innerHTML = '<div class="dp-wrapper"><div class="dp-input-field error"><span class="dp-cal-icon"><svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg></span><input class="dp-input" type="text" value="32/13/2026" readonly></div><div class="dp-helper error" style="margin-top:6px;">&#9888; Invalid date. Please enter DD/MM/YYYY.</div></div>';
        } else {
          var mount = document.createElement('div');
          mount.className = 'dp-wrapper';
          previewArea.appendChild(mount);
          var initOpts = { type: type, presets: presets, footer: footer };
          if (st === 'filled') {
            if (type === 'single') {
              initOpts.initialSelected = new Date();
            } else {
              var sd = new Date(); sd.setDate(sd.getDate() - 7);
              initOpts.initialRangeStart = sd;
              initOpts.initialRangeEnd = new Date();
            }
          }
          createDatePicker(mount, initOpts);
        }

        // Build code
        var codeStr = '<div class="dp-wrapper">\n';
        codeStr += '  <label for="dp">Select date</label>\n';
        if (type === 'range') {
          codeStr += '  <fieldset>\n';
          codeStr += '    <legend>Select date range</legend>\n';
          codeStr += '    <div class="dp-input-field' + (st==='error'?' error':'') + (st==='disabled'?' disabled':'') + '">\n';
          codeStr += '      <span class="dp-cal-icon">\u{1F4C5}</span>\n';
          codeStr += '      <input class="dp-input" type="text" inputmode="numeric" placeholder="DD/MM/YYYY" aria-label="Start date"' + (st==='disabled'?' disabled':'') + '>\n';
          codeStr += '    </div>\n';
          codeStr += '    <div class="dp-input-field">\n';
          codeStr += '      <input class="dp-input" type="text" inputmode="numeric" placeholder="DD/MM/YYYY" aria-label="End date">\n';
          codeStr += '    </div>\n';
          codeStr += '  </fieldset>\n';
        } else {
          codeStr += '  <div class="dp-input-field' + (st==='error'?' error':'') + (st==='disabled'?' disabled':'') + '">\n';
          codeStr += '    <span class="dp-cal-icon">\u{1F4C5}</span>\n';
          codeStr += '    <input id="dp" class="dp-input" type="text" inputmode="numeric" placeholder="DD/MM/YYYY" aria-haspopup="dialog"' + (st==='disabled'?' disabled':'') + (st==='error'?' aria-invalid="true"':'') + '>\n';
          codeStr += '  </div>\n';
        }
        if (st === 'error') codeStr += '  <div class="dp-helper error" role="alert">Invalid date. Please enter DD/MM/YYYY.</div>\n';
        codeStr += '  <div class="dp-popover" role="dialog" aria-modal="false">\n';
        codeStr += '    <div class="dp-popover-header">\n';
        codeStr += '      <button class="dp-nav-btn" aria-label="Previous month">\u2039</button>\n';
        codeStr += '      <div class="dp-month-year">March 2026</div>\n';
        codeStr += '      <button class="dp-nav-btn" aria-label="Next month">\u203A</button>\n';
        codeStr += '    </div>\n';
        codeStr += '    <div class="dp-weekdays" role="row"><!-- Sun..Sat --></div>\n';
        codeStr += '    <div class="dp-days" role="grid"><!-- day cells --></div>\n';
        if (presets) {
          codeStr += '    <div class="dp-presets">\n';
          codeStr += '      <button class="dp-preset-btn">Today</button>\n';
          codeStr += '      <button class="dp-preset-btn">Last 7 days</button>\n';
          codeStr += '      <button class="dp-preset-btn">This month</button>\n';
          codeStr += '    </div>\n';
        }
        if (footer) {
          codeStr += '    <div class="dp-footer">\n';
          codeStr += '      <button class="dp-footer-btn secondary">Clear</button>\n';
          codeStr += '      <button class="dp-footer-btn secondary">Cancel</button>\n';
          codeStr += '      <button class="dp-footer-btn primary">Apply</button>\n';
          codeStr += '    </div>\n';
        }
        codeStr += '  </div>\n';
        codeStr += '</div>';

        codeOut.innerHTML = esc(codeStr)
          .replace(/class=&quot;(.*?)&quot;/g, '<span style="color:#38bdf8;">class</span>=<span style="color:#34d399;">"$1"</span>')
          .replace(/type=&quot;(.*?)&quot;/g, '<span style="color:#38bdf8;">type</span>=<span style="color:#34d399;">"$1"</span>')
          .replace(/inputmode=&quot;(.*?)&quot;/g, '<span style="color:#38bdf8;">inputmode</span>=<span style="color:#34d399;">"$1"</span>')
          .replace(/placeholder=&quot;(.*?)&quot;/g, '<span style="color:#38bdf8;">placeholder</span>=<span style="color:#34d399;">"$1"</span>')
          .replace(/id=&quot;(.*?)&quot;/g, '<span style="color:#38bdf8;">id</span>=<span style="color:#34d399;">"$1"</span>')
          .replace(/for=&quot;(.*?)&quot;/g, '<span style="color:#38bdf8;">for</span>=<span style="color:#34d399;">"$1"</span>')
          .replace(/role=&quot;(.*?)&quot;/g, '<span style="color:#38bdf8;">role</span>=<span style="color:#34d399;">"$1"</span>')
          .replace(/aria-label=&quot;(.*?)&quot;/g, '<span style="color:#38bdf8;">aria-label</span>=<span style="color:#34d399;">"$1"</span>')
          .replace(/aria-haspopup=&quot;(.*?)&quot;/g, '<span style="color:#38bdf8;">aria-haspopup</span>=<span style="color:#34d399;">"$1"</span>')
          .replace(/aria-modal=&quot;(.*?)&quot;/g, '<span style="color:#38bdf8;">aria-modal</span>=<span style="color:#34d399;">"$1"</span>')
          .replace(/aria-invalid=&quot;(.*?)&quot;/g, '<span style="color:#38bdf8;">aria-invalid</span>=<span style="color:#34d399;">"$1"</span>')
          .replace(/ disabled/g, ' <span style="color:#f97316;">disabled</span>')
          .replace(/&lt;!--(.*?)--&gt;/g, '<span style="color:#94a3b8;">&lt;!--$1--&gt;</span>')
          .replace(/&lt;(\/?)(div|label|fieldset|legend|input|span|button)(.*?)&gt;/g, '&lt;$1<span style="color:#a78bfa;">$2</span>$3&gt;');
      }

      Object.values(els).forEach(function(e) { e.addEventListener('change', update); });
      copyBtn.addEventListener('click', function() {
        var r = document.createElement('div');
        r.innerHTML = codeOut.innerHTML;
        navigator.clipboard.writeText(r.innerText).then(function() {
          var o = copyBtn.innerHTML;
          copyBtn.innerHTML = '<svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Copied!';
          setTimeout(function() { copyBtn.innerHTML = o; }, 2000);
        });
      });
      update();
    })();
  </script>

  <script>
    let _tocObserver = null;
    function updateTOC(targetId) {
      const tocList = document.querySelector('.toc-nav'); if (!tocList) return; tocList.innerHTML = '';
      const activePanel = document.getElementById(targetId); if (!activePanel) return;
      activePanel.querySelectorAll('h2[id], h3[id]').forEach(h => {
        if (h.style.display === 'none') return;
        const li = document.createElement('li'), a = document.createElement('a');
        a.href = '#' + h.id; a.className = 'toc-link';
        let text = Array.from(h.childNodes).filter(n => n.nodeType === 3).map(n => n.textContent).join('').trim();
        if (!text) text = h.innerText; a.textContent = text;
        a.addEventListener('click', e => { e.preventDefault(); document.getElementById(h.id).scrollIntoView({behavior:'smooth',block:'start'}); });
        li.appendChild(a); tocList.appendChild(li);
      });
      initScrollSpy();
    }
    function initScrollSpy() {
      if (_tocObserver) _tocObserver.disconnect();
      const tocLinks = document.querySelectorAll('.toc-link');
      const sections = Array.from(tocLinks).map(l => document.getElementById(l.getAttribute('href').slice(1))).filter(Boolean);
      if (!sections.length) return;
      _tocObserver = new IntersectionObserver(entries => { entries.forEach(e => { if (e.isIntersecting) { const id = e.target.getAttribute('id'); tocLinks.forEach(l => l.classList.toggle('active', l.getAttribute('href') === '#'+id)); } }); }, {rootMargin:'-80px 0px -60% 0px',threshold:0});
      sections.forEach(s => _tocObserver.observe(s));
    }
    document.querySelectorAll('.tab-item').forEach(tab => {
      tab.addEventListener('click', () => {
        document.querySelectorAll('.tab-item').forEach(t => t.classList.remove('active')); tab.classList.add('active');
        const tabMap = {'Overview':'tab-overview','Usage':'tab-usage','Style':'tab-style','Code':'tab-code','Accessibility':'tab-accessibility'};
        document.querySelectorAll('.tab-content').forEach(p => p.style.display = 'none');
        const target = tabMap[tab.textContent.trim()];
        if (target) { document.getElementById(target).style.display = 'block'; updateTOC(target); }
        window.scrollTo({top:0,behavior:'smooth'});
      });
    });
    updateTOC('tab-overview');
    const themeToggle=document.getElementById('themeToggle'),moonIcon=document.getElementById('moonIcon'),sunIcon=document.getElementById('sunIcon');
    if ((localStorage.getItem('theme')||'light')==='dark') { document.documentElement.removeAttribute('data-theme'); moonIcon.style.display='block'; sunIcon.style.display='none'; }
    themeToggle.addEventListener('click', () => {
      if (document.documentElement.getAttribute('data-theme')==='light') { document.documentElement.removeAttribute('data-theme'); localStorage.setItem('theme','dark'); moonIcon.style.display='block'; sunIcon.style.display='none'; }
      else { document.documentElement.setAttribute('data-theme','light'); localStorage.setItem('theme','light'); moonIcon.style.display='none'; sunIcon.style.display='block'; }
    });

    // Sidebar search filter
    (function(){
      var searchInput = document.querySelector('.sidebar-search input');
      if (!searchInput) return;
      var items = document.querySelectorAll('.sidebar-nav li');
      searchInput.addEventListener('input', function(){
        var q = this.value.toLowerCase().trim();
        items.forEach(function(li){
          var link = li.querySelector('a');
          if (!link) return;
          var text = link.textContent.toLowerCase();
          li.style.display = (!q || text.indexOf(q) !== -1) ? '' : 'none';
        });
      });
      document.addEventListener('keydown', function(e){
        if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
          e.preventDefault();
          searchInput.focus();
          searchInput.select();
        }
      });
    })();

    // Scroll sidebar to active link on page load
    (function(){
      var active = document.querySelector('.sidebar-link.active');
      if (active) {
        var sidebar = active.closest('.sidebar');
        if (sidebar) {
          var top = active.offsetTop - sidebar.offsetTop - (sidebar.clientHeight / 3);
          sidebar.scrollTop = Math.max(0, top);
        }
      }
    })();
  </script>
<script>
(function(){
  const nav = document.querySelector('.nav');
  if (!nav) return;
  const toggle = () => {
    if (window.scrollY > 10) nav.classList.add('scrolled');
    else nav.classList.remove('scrolled');
  };
  toggle();
  window.addEventListener('scroll', toggle, { passive: true });
})();
</script>
<script>
(function(){
  const hamburger = document.querySelector('.nav-hamburger');
  const sidebar = document.querySelector('.sidebar');
  const backdrop = document.querySelector('.sidebar-backdrop');
  const navLinks = document.querySelector('.nav-links');
  if (!hamburger || !sidebar || !backdrop) return;

  // Build a mobile-only nav section at the top of the sidebar by cloning the nav links
  if (navLinks && !sidebar.querySelector('.sidebar-mobile-nav')) {
    const mobileNav = document.createElement('div');
    mobileNav.className = 'sidebar-mobile-nav';
    const heading = document.createElement('h4');
    heading.textContent = 'Navigate';
    mobileNav.appendChild(heading);
    const ul = document.createElement('ul');
    navLinks.querySelectorAll(':scope > a').forEach(a => {
      const li = document.createElement('li');
      const clone = a.cloneNode(true);
      li.appendChild(clone);
      ul.appendChild(li);
    });
    navLinks.querySelectorAll(':scope > .nav-dropdown > .nav-dropdown-menu > a').forEach(a => {
      const li = document.createElement('li');
      const clone = a.cloneNode(true);
      li.appendChild(clone);
      ul.appendChild(li);
    });
    mobileNav.appendChild(ul);
    sidebar.insertBefore(mobileNav, sidebar.firstChild);
  }

  const open = () => {
    sidebar.classList.add('open');
    backdrop.classList.add('open');
    document.body.classList.add('sidebar-locked');
    hamburger.setAttribute('aria-expanded', 'true');
  };
  const close = () => {
    sidebar.classList.remove('open');
    backdrop.classList.remove('open');
    document.body.classList.remove('sidebar-locked');
    hamburger.setAttribute('aria-expanded', 'false');
  };
  hamburger.addEventListener('click', () => sidebar.classList.contains('open') ? close() : open());
  backdrop.addEventListener('click', close);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && sidebar.classList.contains('open')) close(); });
  sidebar.addEventListener('click', (e) => { if (e.target.closest('a')) close(); });
})();
</script>

<!-- Floating Feedback Button -->
<style>
  .float-cliq-btn {
    position: fixed; bottom: 28px; right: 28px; z-index: 9999;
    display: flex; align-items: center; gap: 10px;
    text-decoration: none;
  }
  .float-cliq-label {
    background: #1a1a2e; color: #fff;
    padding: 7px 14px; border-radius: 8px;
    font-size: 13px; font-weight: 500; white-space: nowrap;
    opacity: 0; transform: translateX(6px);
    transition: opacity 0.2s ease, transform 0.2s ease;
    pointer-events: none; box-shadow: 0 4px 16px rgba(0,0,0,0.25);
  }
  .float-cliq-btn:hover .float-cliq-label {
    opacity: 1; transform: translateX(0);
  }
  .float-cliq-icon {
    width: 52px; height: 52px; border-radius: 50%;
    background: #2563eb; color: #fff;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 4px 20px rgba(37,99,235,0.45);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    flex-shrink: 0;
  }
  .float-cliq-btn:hover .float-cliq-icon {
    transform: translateY(-3px) scale(1.07);
    box-shadow: 0 8px 28px rgba(37,99,235,0.55);
  }
  .float-cliq-btn:active .float-cliq-icon { transform: scale(0.95); }
</style>
