                <tr><td><code>BG-Chart-Yellow-Quinary</code></td><td>Quinary</td><td><span class="swatch-light token-swatch"><span class="token-swatch-color" style="background:#fdebc2"></span><span class="token-swatch-hex">#fdebc2</span></span><span class="swatch-dark token-swatch"><span class="token-swatch-color" style="background:#7c590e"></span><span class="token-swatch-hex">#7c590e</span></span></td></tr>
                <tr><td><code>BG-Chart-Yellow-Senary</code></td><td>Senary</td><td><span class="swatch-light token-swatch"><span class="token-swatch-color" style="background:#fef8eb"></span><span class="token-swatch-hex">#fef8eb</span></span><span class="swatch-dark token-swatch"><span class="token-swatch-color" style="background:#4a3509"></span><span class="token-swatch-hex">#4a3509</span></span></td></tr>
                <tr><td><code>BG-Chart-Green-Primary</code></td><td>Primary</td><td><span class="swatch-light token-swatch"><span class="token-swatch-color" style="background:#0c8844"></span><span class="token-swatch-hex">#0c8844</span></span><span class="swatch-dark token-swatch"><span class="token-swatch-color" style="background:#249457"></span><span class="token-swatch-hex">#249457</span></span></td></tr>
