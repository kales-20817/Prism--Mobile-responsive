                <tr><td><code>BG-Chart-Orange-Quaternary</code></td><td>Quaternary</td><td><span class="swatch-light token-swatch"><span class="token-swatch-color" style="background:#ffac80"></span><span class="token-swatch-hex">#ffac80</span></span><span class="swatch-dark token-swatch"><span class="token-swatch-color" style="background:#933300"></span><span class="token-swatch-hex">#933300</span></span></td></tr>
                <tr><td><code>BG-Chart-Orange-Quinary</code></td><td>Quinary</td><td><span class="swatch-light token-swatch"><span class="token-swatch-color" style="background:#ffceb3"></span><span class="token-swatch-hex">#ffceb3</span></span><span class="swatch-dark token-swatch"><span class="token-swatch-color" style="background:#682500"></span><span class="token-swatch-hex">#682500</span></span></td></tr>
                <tr><td><code>BG-Chart-Orange-Senary</code></td><td>Senary</td><td><span class="swatch-light token-swatch"><span class="token-swatch-color" style="background:#ffeee5"></span><span class="token-swatch-hex">#ffeee5</span></span><span class="swatch-dark token-swatch"><span class="token-swatch-color" style="background:#3f1600"></span><span class="token-swatch-hex">#3f1600</span></span></td></tr>
                <tr><td><code>BG-Chart-Charoite-Primary</code></td><td>Primary</td><td><span class="swatch-light token-swatch"><span class="token-swatch-color" style="background:#663399"></span><span class="token-swatch-hex">#663399</span></span><span class="swatch-dark token-swatch"><span class="token-swatch-color" style="background:#7648a3"></span><span class="token-swatch-hex">#7648a3</span></span></td></tr>
