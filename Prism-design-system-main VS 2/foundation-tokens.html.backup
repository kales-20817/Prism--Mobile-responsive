                <tr><td><code>BG-Chart-Charoite-Tertiary</code></td><td>Tertiary</td><td><span class="swatch-light token-swatch"><span class="token-swatch-color" style="background:#9471b8"></span><span class="token-swatch-hex">#9471b8</span></span><span class="swatch-dark token-swatch"><span class="token-swatch-color" style="background:#5c2e89"></span><span class="token-swatch-hex">#5c2e89</span></span></td></tr>
                <tr><td><code>BG-Chart-Charoite-Quaternary</code></td><td>Quaternary</td><td><span class="swatch-light token-swatch"><span class="token-swatch-color" style="background:#b399cd"></span><span class="token-swatch-hex">#b399cd</span></span><span class="swatch-dark token-swatch"><span class="token-swatch-color" style="background:#47246b"></span><span class="token-swatch-hex">#47246b</span></span></td></tr>
                <tr><td><code>BG-Chart-Charoite-Quinary</code></td><td>Quinary</td><td><span class="swatch-light token-swatch"><span class="token-swatch-color" style="background:#d5c0ea"></span><span class="token-swatch-hex">#d5c0ea</span></span><span class="swatch-dark token-swatch"><span class="token-swatch-color" style="background:#33194c"></span><span class="token-swatch-hex">#33194c</span></span></td></tr>
                <tr><td><code>BG-Chart-Charoite-Senary</code></td><td>Senary</td><td><span class="swatch-light token-swatch"><span class="token-swatch-color" style="background:#f1eaf8"></span><span class="token-swatch-hex">#f1eaf8</span></span><span class="swatch-dark token-swatch"><span class="token-swatch-color" style="background:#1e0f2e"></span><span class="token-swatch-hex">#1e0f2e</span></span></td></tr>
                <tr><td><code>BG-Chart-Yellow-Primary</code></td><td>Primary</td><td><span class="swatch-light token-swatch"><span class="token-swatch-color" style="background:#f9b21d"></span><span class="token-swatch-hex">#f9b21d</span></span><span class="swatch-dark token-swatch"><span class="token-swatch-color" style="background:#fac248"></span><span class="token-swatch-hex">#fac248</span></span></td></tr>
                <tr><td><code>BG-Chart-Yellow-Secondary</code></td><td>Secondary</td><td><span class="swatch-light token-swatch"><span class="token-swatch-color" style="background:#fac248"></span><span class="token-swatch-hex">#fac248</span></span><span class="swatch-dark token-swatch"><span class="token-swatch-color" style="background:#f9b21d"></span><span class="token-swatch-hex">#f9b21d</span></span></td></tr>
