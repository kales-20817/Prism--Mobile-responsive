                <tr><td><code>BG-Chart-Green-Tertiary</code></td><td>Tertiary</td><td><span class="swatch-light token-swatch"><span class="token-swatch-color" style="background:#55ac7c"></span><span class="token-swatch-hex">#55ac7c</span></span><span class="swatch-dark token-swatch"><span class="token-swatch-color" style="background:#0a7138"></span><span class="token-swatch-hex">#0a7138</span></span></td></tr>
                <tr><td><code>BG-Chart-Green-Quaternary</code></td><td>Quaternary</td><td><span class="swatch-light token-swatch"><span class="token-swatch-color" style="background:#86c4a2"></span><span class="token-swatch-hex">#86c4a2</span></span><span class="swatch-dark token-swatch"><span class="token-swatch-color" style="background:#085b2d"></span><span class="token-swatch-hex">#085b2d</span></span></td></tr>
                <tr><td><code>BG-Chart-Green-Quinary</code></td><td>Quinary</td><td><span class="swatch-light token-swatch"><span class="token-swatch-color" style="background:#b7dcc7"></span><span class="token-swatch-hex">#b7dcc7</span></span><span class="swatch-dark token-swatch"><span class="token-swatch-color" style="background:#054422"></span><span class="token-swatch-hex">#054422</span></span></td></tr>
                <tr><td><code>BG-Chart-Green-Senary</code></td><td>Senary</td><td><span class="swatch-light token-swatch"><span class="token-swatch-color" style="background:#e7f3ed"></span><span class="token-swatch-hex">#e7f3ed</span></span><span class="swatch-dark token-swatch"><span class="token-swatch-color" style="background:#042d17"></span><span class="token-swatch-hex">#042d17</span></span></td></tr>
              </tbody>
            </table>

            <h3 id="spacing-radius-tokens" class="doc-h3" style="margin-top: 40px;">Spacing, radius, and font-size tokens</h3>
            <div class="collection-grid" style="grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));">
              <div class="collection-card">
                <div class="collection-card-title">Spacing (22)</div>
                <div class="collection-card-desc">0 through 80px in 4px increments</div>
                <div class="code-block" style="margin-top: 12px; font-size: 11.5px;">0, 4, 8, 12, 16, 20, 24, 28, 32, 36, 40, 44, 48, 52, 56, 60, 64, 68, 72, 76, 80</div>
              </div>
              <div class="collection-card">
                <div class="collection-card-title">Radius (7)</div>
                <div class="collection-card-desc">From none to extra-large</div>
                <div class="code-block" style="margin-top: 12px; font-size: 11.5px;">radius-none, radius-xs, radius-default, radius-s, radius-m, radius-l, radius-xl</div>
              </div>
              <div class="collection-card">
                <div class="collection-card-title">Font/Size (21)</div>
                <div class="collection-card-desc">8px through 80px</div>
                <div class="code-block" style="margin-top: 12px; font-size: 11.5px;">8, 9, 10, 11, 12, 13, 14, 16, 18, 20, 24, 28, 32, 36, 40, 48, 56, 64, 72, 80</div>
              </div>
            </div>
          </div>

          <hr class="doc-divider" />

          <!-- UEMS Global Tokens -->
          <div class="doc-section" id="global-tokens">
            <h2 class="doc-section-title">UEMS Global Tokens</h2>
            <p class="doc-section-subtitle">32 component-level tokens for spacing, radius, width, and icon sizing.</p>

            <table class="token-table">
              <thead>
                <tr><th>Group</th><th>Count</th><th>Values</th></tr>
              </thead>
              <tbody>
                <tr><td><code>Spacing</code></td><td>15</td><td>0, 2, 4, 8, 12, 16, 20, 24, 32, 40, 48, 56, 64, 72, 80</td></tr>
                <tr><td><code>Border-radius</code></td><td>8</td><td>radius-2, radius-4, radius-6, radius-8, radius-12, radius-16, radius-20, radius-pill</td></tr>
                <tr><td><code>Border-width</code></td><td>3</td><td>border-width-0, border-width-1, border-width-2</td></tr>
                <tr><td><code>Icon-size</code></td><td>6</td><td>icon-xsmall (12px), icon-small (16px), icon-medium (20px), icon-large (24px), icon-xlarge (32px), icon-2xlarge (48px)</td></tr>
              </tbody>
            </table>
          </div>

          <hr class="doc-divider" />

          <!-- Typography tokens -->
          <div class="doc-section" id="typography-tokens">
            <h2 class="doc-section-title">Typography tokens</h2>
            <p class="doc-section-subtitle">132 tokens across 4 density modes: Default, Large, XLarge, and Small.</p>

            <table class="token-table">
              <thead>
                <tr><th>Category</th><th>Count</th><th>Structure</th></tr>
              </thead>
              <tbody>
                <tr><td><code>body</code></td><td>72</td><td>body/{Default,Large,Small,XSmall}/{Regular,Medium,SemiBold,Bold}/{Font-Family, Font-Weight, font-size, Line-height}</td></tr>
                <tr><td><code>display</code></td><td>36</td><td>display/{Small,Medium,Large}/{Regular,SemiBold,Bold}/{Font-Family, Font-Weight, font-size, Line-height}</td></tr>
                <tr><td><code>Code</code></td><td>24</td><td>Code/{Default,Large}/{Regular,SemiBold,Bold}/{Font-Family, Font-Weight, Font-size, Line-height}</td></tr>
              </tbody>
            </table>

            <h3 id="type-primitives" class="doc-h3" style="margin-top: 40px;">Type primitives (28 tokens)</h3>
            <table class="token-table">
              <thead>
                <tr><th>Group</th><th>Count</th><th>Values</th></tr>
              </thead>
              <tbody>
                <tr><td><code>Font-size</code></td><td>13</td><td>9, 10, 11, 12, 13, 14, 16, 18, 20, 24, 28, 32, 36 px</td></tr>
                <tr><td><code>Font-weight</code></td><td>4</td><td>Regular, Medium, Semibold, Bold</td></tr>
                <tr><td><code>Line-height</code></td><td>11</td><td>9, 10, 12, 14, 16, 18, 20, 24, 28, 32, 36 px</td></tr>
              </tbody>
            </table>

            <h3 id="font-family-tokens" class="doc-h3" style="margin-top: 40px;">Font family (11 tokens, 3 modes)</h3>
            <p style="font-size: 14.5px; color: var(--prism-text-muted); line-height: 1.6; margin-bottom: 16px;">Modes: <code>Zoho Puvi</code>, <code>Lato</code>, <code>Roboto</code>. Tokens: Typeface, Typeface-code, Boolean, Text, Prefix-text, Suffix-text, Prefix, Suffix, Label, String, RTL.</p>
          </div>

          <hr class="doc-divider" />

          <!-- Token naming convention -->
          <div class="doc-section" id="naming-convention">
            <h2 class="doc-section-title">Token naming convention</h2>
            <p class="doc-section-subtitle">Structure: <code>{category}/{group}/{property}</code></p>

            <table class="token-table">
              <thead>
                <tr><th>Example</th><th>Category</th><th>Group</th><th>Property</th></tr>
              </thead>
              <tbody>
                <tr><td><code>Text/Text-Primary</code></td><td>Text</td><td>--</td><td>Text-Primary</td></tr>
                <tr><td><code>Background/BG-Success-Primary</code></td><td>Background</td><td>--</td><td>BG-Success-Primary</td></tr>
                <tr><td><code>Border/Icon/Icon-Accent</code></td><td>Border</td><td>Icon</td><td>Icon-Accent</td></tr>
                <tr><td><code>spacing/16px</code></td><td>spacing</td><td>--</td><td>16px</td></tr>
                <tr><td><code>radius/radius-default</code></td><td>radius</td><td>--</td><td>radius-default</td></tr>
                <tr><td><code>Font/Size/14px</code></td><td>Font</td><td>Size</td><td>14px</td></tr>
              </tbody>
            </table>

            <div style="margin-top: 24px;">
              <h3 class="doc-h3">Naming rules</h3>
              <ul class="doc-list">
                <li>Use sentence case for semantic names</li>
                <li>Use kebab-case for sub-groups</li>
                <li>Never encode values in token names</li>
                <li>Group by purpose, not by visual property</li>
              </ul>
            </div>
          </div>

          <hr class="doc-divider" />

          <!-- Theme modes -->
          <div class="doc-section" id="theme-modes">
            <h2 class="doc-section-title">Theme modes</h2>
            <p class="doc-section-subtitle">4 theme modes in UEMS Theme Tokens. Every semantic token resolves to a different primitive per mode. Component code never needs to know which theme is active.</p>

            <div class="theme-grid">
              <div class="theme-card">
                <div class="theme-card-indicator" style="background: linear-gradient(90deg, #f8faff, #e2e8f0);"></div>
                <div class="theme-card-name">Light theme</div>
                <div class="theme-card-desc">Default mode. Used for standard admin consoles and everyday management workflows.</div>
              </div>
              <div class="theme-card">
                <div class="theme-card-indicator" style="background: linear-gradient(90deg, #1e293b, #0f172a);"></div>
                <div class="theme-card-name">Dark theme</div>
                <div class="theme-card-desc">Low-light environments. Inverts the neutral scale for reduced eye strain.</div>
              </div>
              <div class="theme-card">
                <div class="theme-card-indicator" style="background: linear-gradient(90deg, #0a0a0c, #1a1a2e);"></div>
                <div class="theme-card-name">Night theme</div>
                <div class="theme-card-desc">Maximum contrast reduction. Designed for NOC/SOC dashboards and extended monitoring sessions.</div>
              </div>
              <div class="theme-card">
                <div class="theme-card-indicator" style="background: linear-gradient(90deg, #16a34a, #22c55e);"></div>
                <div class="theme-card-name">Green accent</div>
                <div class="theme-card-desc">Alternate brand theme for sub-products and white-label deployments.</div>
              </div>
            </div>
          </div>

          <hr class="doc-divider" />

          <!-- Anti-patterns -->
          <div class="doc-section" id="anti-patterns">
            <h2 class="doc-section-title">Anti-patterns</h2>
            <p class="doc-section-subtitle">Common mistakes that erode the token system. Avoid these in every module.</p>

            <ul class="anti-pattern-list">
              <li>Hardcoding hex values in component code</li>
              <li>Creating one-off spacing values outside the scale</li>
              <li>Using primitive tokens directly in components (skip the semantic layer)</li>
              <li>Storing theme logic inside component files</li>
              <li>Naming tokens after their visual value instead of purpose</li>
              <li>Skipping dark mode token mappings during development</li>
              <li>Using inconsistent token paths across modules</li>
            </ul>
          </div>

          <hr class="doc-divider" />

          <!-- Principle -->
          <div class="doc-section" id="closing-principle">
            <h2 class="doc-section-title">Principle</h2>
            <div class="principle-card">
              <p>In Prism, tokens are the design system's memory. They encode decisions so teams don't repeat them, enforce consistency so products don't drift, and enable theming so experiences adapt automatically.</p>
            </div>
          </div>

          <div class="feedback-banner" style="display: none;">
            <div>
              <div class="fb-text">Help us improve this page</div>
              <div class="fb-sub">Share your feedback to help shape the Tokens documentation.</div>
            </div>
            <div style="display: flex; gap: 12px;">
              <button class="feedback-btn primary" onclick="window.open('https://cliq.zoho.in/company/60002085329/channels/prismdesignsystembyuemssupportfeedback','_blank')">Give Feedback</button>
            </div>
          </div>

        </div>

        <aside class="toc-sidebar">
          <h4 class="toc-heading">On this page</h4>
          <ul class="toc-nav" id="toc-nav"></ul>
        </aside>
      </div>
    </main>
  </div>

  <script>

    // Dynamic TOC
    let _tocObserver = null;
    function buildTOC() {
      const tocList = document.getElementById('toc-nav');
      if (!tocList) return;
      tocList.innerHTML = '';
      const inner = document.querySelector('.main-content-inner');
      if (!inner) return;
      const headings = inner.querySelectorAll('h2[id], h3[id]');
      const sections = [];
      headings.forEach(h => {
        if (h.style.display === 'none') return;
        const li = document.createElement('li');
        const a = document.createElement('a');
        a.href = '#' + h.id;
        a.className = 'toc-link';
        let text = Array.from(h.childNodes).filter(n => n.nodeType === 3).map(n => n.textContent).join('').trim();
        if (!text) text = h.innerText.replace(/^\d+\.\s*/, '');
        a.textContent = text;
        if (h.tagName === 'H3') { a.style.paddingLeft = '16px'; a.style.fontSize = '12.5px'; }
        a.addEventListener('click', e => { e.preventDefault(); document.getElementById(h.id).scrollIntoView({ behavior: 'smooth', block: 'start' }); });
        li.appendChild(a);
        tocList.appendChild(li);
        sections.push(h);
      });
      if (_tocObserver) _tocObserver.disconnect();
      _tocObserver = new IntersectionObserver(entries => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const id = entry.target.getAttribute('id');
            document.querySelectorAll('.toc-link').forEach(link => {
              link.classList.toggle('active', link.getAttribute('href') === '#' + id);
            });
          }
        });
      }, { rootMargin: '-80px 0px -60% 0px', threshold: 0 });
      sections.forEach(s => _tocObserver.observe(s));
    }
    buildTOC();

// Sidebar search: filter foundation nav links by query
    const sidebarSearchInput = document.querySelector('.sidebar-search input');
    const foundationNavItems = document.querySelectorAll('.foundation-nav li');
    if (sidebarSearchInput && foundationNavItems.length) {
      sidebarSearchInput.addEventListener('input', (e) => {
        const q = e.target.value.trim().toLowerCase();
        foundationNavItems.forEach(li => {
          const text = li.textContent.trim().toLowerCase();
          li.style.display = !q || text.includes(q) ? '' : 'none';
        });
      });
      document.addEventListener('keydown', (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
          e.preventDefault();
          sidebarSearchInput.focus();
        }
        if (e.key === 'Escape' && document.activeElement === sidebarSearchInput) {
          sidebarSearchInput.value = '';
          sidebarSearchInput.dispatchEvent(new Event('input'));
          sidebarSearchInput.blur();
        }
      });
    }

    const themeToggle = document.getElementById('themeToggle');
    const moonIcon = document.getElementById('moonIcon');
    const sunIcon = document.getElementById('sunIcon');
    const currentTheme = localStorage.getItem('theme') || 'light';
    if (currentTheme === 'dark') {
      document.documentElement.removeAttribute('data-theme');
      moonIcon.style.display = 'block'; sunIcon.style.display = 'none';
    }
    themeToggle.addEventListener('click', () => {
      let theme = document.documentElement.getAttribute('data-theme');
      if (theme === 'light') {
        document.documentElement.removeAttribute('data-theme');
        localStorage.setItem('theme', 'dark');
        moonIcon.style.display = 'block'; sunIcon.style.display = 'none';
      } else {
        document.documentElement.setAttribute('data-theme', 'light');
        localStorage.setItem('theme', 'light');
        moonIcon.style.display = 'none'; sunIcon.style.display = 'block';
      }
    });
  </script>
<script>
(function(){
  const nav = document.querySelector('.nav');
  if (!nav) return;
  const toggle = () => {
    if (window.scrollY > 10) nav.classList.add('scrolled');
    else nav.classList.remove('scrolled');
  };
  toggle();
  window.addEventListener('scroll', toggle, { passive: true });
})();
</script>
<script>
(function(){
  const hamburger = document.querySelector('.nav-hamburger');
  const sidebar = document.querySelector('.sidebar');
  const backdrop = document.querySelector('.sidebar-backdrop');
  const navLinks = document.querySelector('.nav-links');
  if (!hamburger || !sidebar || !backdrop) return;

  // Build a mobile-only nav section at the top of the sidebar by cloning the nav links
  if (navLinks && !sidebar.querySelector('.sidebar-mobile-nav')) {
    const mobileNav = document.createElement('div');
    mobileNav.className = 'sidebar-mobile-nav';
    const heading = document.createElement('h4');
    heading.textContent = 'Navigate';
    mobileNav.appendChild(heading);
    const ul = document.createElement('ul');
    navLinks.querySelectorAll(':scope > a').forEach(a => {
      const li = document.createElement('li');
      const clone = a.cloneNode(true);
      li.appendChild(clone);
      ul.appendChild(li);
    });
    navLinks.querySelectorAll(':scope > .nav-dropdown > .nav-dropdown-menu > a').forEach(a => {
      const li = document.createElement('li');
      const clone = a.cloneNode(true);
      li.appendChild(clone);
      ul.appendChild(li);
    });
    mobileNav.appendChild(ul);
    sidebar.insertBefore(mobileNav, sidebar.firstChild);
  }

  const open = () => {
    sidebar.classList.add('open');
    backdrop.classList.add('open');
    document.body.classList.add('sidebar-locked');
    hamburger.setAttribute('aria-expanded', 'true');
  };
  const close = () => {
    sidebar.classList.remove('open');
    backdrop.classList.remove('open');
    document.body.classList.remove('sidebar-locked');
    hamburger.setAttribute('aria-expanded', 'false');
  };
  hamburger.addEventListener('click', () => sidebar.classList.contains('open') ? close() : open());
  backdrop.addEventListener('click', close);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && sidebar.classList.contains('open')) close(); });
  sidebar.addEventListener('click', (e) => { if (e.target.closest('a')) close(); });
})();
</script>

