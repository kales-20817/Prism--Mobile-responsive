      <script>
      (function(){
        var searchInput = document.getElementById('icon-search');
        var catFilter = document.getElementById('icon-category-filter');
        var countEl = document.getElementById('icon-count');
        var grid = document.getElementById('icon-grid');
        var cards = grid.querySelectorAll('.lib-card');
        var searchWrap = document.getElementById('icon-search-wrap');
        searchWrap.addEventListener('click', function(){ searchInput.focus(); });
        searchInput.addEventListener('focus', function(){ searchWrap.style.borderColor = 'var(--prism-violet)'; searchWrap.style.boxShadow = '0 0 0 3px rgba(37,99,235,0.15)'; });
        searchInput.addEventListener('blur', function(){ searchWrap.style.borderColor = ''; searchWrap.style.boxShadow = ''; });
        function filterIcons(){
          var q = searchInput.value.toLowerCase().trim();
          var cat = catFilter.value;
          var catTerms = cat === 'all' ? [] : cat.split(',');
          var visible = 0;
          cards.forEach(function(card){
            var label = card.querySelector('.lib-card-label');
            if(!label) return;
            var name = label.textContent.toLowerCase();
            var matchSearch = !q || name.indexOf(q) !== -1;
            var matchCat = catTerms.length === 0 || catTerms.some(function(t){ return name.indexOf(t.trim()) !== -1; });
            var show = matchSearch && matchCat;
            card.style.display = show ? '' : 'none';
            if(show) visible++;
          });
          countEl.textContent = visible + ' of ' + cards.length;
        }
        searchInput.addEventListener('input', filterIcons);
        catFilter.addEventListener('change', filterIcons);
        filterIcons();
      })();
      </script>
