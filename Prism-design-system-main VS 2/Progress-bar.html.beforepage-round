            function esc(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
            function update(){
              var v=els.variant.value, sz=els.size.value, val=parseInt(els.value.value)||0, lbl=els.label.value||'Progress', showLbl=els.showlabel.value==='true', dis=els.disabled.value==='true';
