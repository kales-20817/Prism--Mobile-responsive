                <span style="color:#E06C75;">.progress-bar__fill</span> {<br>
                &nbsp;&nbsp;<span style="color:#D19A66;">width</span>: <span style="color:#C678DD;">calc(var(--progress-value, 0) * 1%)</span>;<br>
