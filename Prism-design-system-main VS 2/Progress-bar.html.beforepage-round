              var labelRow=barEl.querySelector('.pb-label-row');
              var labelSpan=barEl.querySelector('.pb-label');
              var valueSpan=barEl.querySelector('.pb-value');
              var fill=barEl.querySelector('.pb-fill');
              if(showLbl){
                labelRow.style.display='flex';
                labelSpan.textContent=lbl;
                valueSpan.textContent=isIndet?'\u2014':val+'%';
              } else {
                labelRow.style.display='none';
