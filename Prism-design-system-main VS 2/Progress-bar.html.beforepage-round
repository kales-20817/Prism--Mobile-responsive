              if(!isIndet) ariaAttrs+=' aria-valuenow="'+val+'"';
              ariaAttrs+=' aria-label="'+lbl+'"';
              if(dis) ariaAttrs+=' aria-disabled="true"';
              var valText=isIndet?'\u2014':val+'%';
              var fillW=isIndet?'':' style="width:'+val+'%;"';
              var code='<div class="'+cls+'"'+ariaAttrs+'>\n';
              if(showLbl) code+='  <div class="pb-label-row">\n    <span class="pb-label">'+lbl+'</span>\n    <span class="pb-value">'+valText+'</span>\n  </div>\n';
