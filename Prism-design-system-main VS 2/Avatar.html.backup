          <table class="size-table">
            <thead><tr><th>Property</th><th>Type</th><th>Default</th><th>Options</th></tr></thead>
            <tbody>
              <tr><td><code>size</code></td><td>Enum</td><td>Medium</td><td>Small, Medium, Large</td></tr>
              <tr><td><code>type</code></td><td>Enum</td><td>Image</td><td>Image, Initials, Placeholder Icon, Hover</td></tr>
              <tr><td><code>state</code></td><td>Enum</td><td>Default</td><td>Default, Disabled</td></tr>
