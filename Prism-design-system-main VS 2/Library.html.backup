      <script>
      (function(){
        var searchInput = document.getElementById('icon-search');
        var catFilter = document.getElementById('icon-category-filter');
        var countEl = document.getElementById('icon-count');
        var grid = document.getElementById('icon-grid');
        var cards = grid.querySelectorAll('.lib-card');
        var searchWrap = document.getElementById('icon-search-wrap');
        searchWrap.addEventListener('click', function(){ searchInput.focus(); });
        searchInput.addEventListener('focus', function(){ searchWrap.style.borderColor = 'var(--prism-violet)'; searchWrap.style.boxShadow = '0 0 0 3px rgba(37,99,235,0.15)'; });
        searchInput.addEventListener('blur', function(){ searchWrap.style.borderColor = ''; searchWrap.style.boxShadow = ''; });
        function filterIcons(){
          var q = searchInput.value.toLowerCase().trim();
          var cat = catFilter.value;
          var catTerms = cat === 'all' ? [] : cat.split(',');
          var visible = 0;
          cards.forEach(function(card){
            var label = card.querySelector('.lib-card-label');
            if(!label) return;
            var name = label.textContent.toLowerCase();
            var matchSearch = !q || name.indexOf(q) !== -1;
            var matchCat = catTerms.length === 0 || catTerms.some(function(t){ return name.indexOf(t.trim()) !== -1; });
            var show = matchSearch && matchCat;
            card.style.display = show ? '' : 'none';
            if(show) visible++;
          });
          countEl.textContent = visible + ' of ' + cards.length;
        }
        searchInput.addEventListener('input', filterIcons);
        catFilter.addEventListener('change', filterIcons);
        filterIcons();
      })();
      </script>
    </div>

        <!-- ========== Logo Panel ========== -->
    <div class="lib-panel" id="panel-logos">
      <h2 class="lib-section-title">Product Logo</h2>
      <p class="lib-section-desc">Select a product to view its logo variants. Click to download SVG.</p>
      <div style="display:flex;align-items:center;gap:12px;margin-bottom:32px;padding:16px 20px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;">
        <label style="font-size:13px;font-weight:600;color:var(--prism-text-muted);white-space:nowrap;">Select Product</label>
        <select id="logo-product-filter" style="flex:1;max-width:360px;background:var(--prism-surface-hover);border:1px solid var(--prism-border);color:var(--prism-text);padding:10px 14px;border-radius:8px;font-family:inherit;font-size:14px;font-weight:500;cursor:pointer;outline:none;">
          <option value="all">All Products</option>
          <option value="Application Control Plus">Application Control Plus</option>
          <option value="Browser Security Plus">Browser Security Plus</option>
          <option value="DEX Manager Plus">DEX Manager Plus</option>
          <option value="Device Control Plus">Device Control Plus</option>
          <option value="Endpoint Central">Endpoint Central</option>
          <option value="Endpoint DLP Plus">Endpoint DLP Plus</option>
          <option value="Malware Protection Plus">Malware Protection Plus</option>
          <option value="Mobile Device Manager Plus">Mobile Device Manager Plus</option>
          <option value="Mobile Device Manager Plus MSP">Mobile Device Manager Plus MSP</option>
          <option value="OS Deployer">OS Deployer</option>
          <option value="Patch Connect Plus">Patch Connect Plus</option>
          <option value="Patch Manager Plus">Patch Manager Plus</option>
          <option value="Ransomware Protection Plus">Ransomware Protection Plus</option>
          <option value="Remote Access Plus">Remote Access Plus</option>
          <option value="Vulnerability Manager Plus">Vulnerability Manager Plus</option>
        </select>
