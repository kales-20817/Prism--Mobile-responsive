      <script>
      (function(){
        var select = document.getElementById("logo-product-filter");
        var groups = document.querySelectorAll("#logo-groups-container .lib-logo-group");
        if(groups.length > 0){
          select.value = groups[0].getAttribute("data-product");
          groups.forEach(function(g){ g.style.display = "none"; });
          groups[0].style.display = "";
        }
        select.addEventListener("change", function(){
          var v = this.value;
          groups.forEach(function(g){
            g.style.display = (v === "all" || g.getAttribute("data-product") === v) ? "" : "none";
          });
        });
      })();
      </script>
