        var cards = grid.querySelectorAll('.lib-card');
        var wrap = document.getElementById('illust-search-wrap');
        wrap.addEventListener('click', function(){ searchInput.focus(); });
        searchInput.addEventListener('focus', function(){ wrap.style.borderColor = 'var(--prism-violet)'; wrap.style.boxShadow = '0 0 0 3px rgba(37,99,235,0.15)'; });
        searchInput.addEventListener('blur', function(){ wrap.style.borderColor = ''; wrap.style.boxShadow = ''; });
        function filterIllust(){
          var q = searchInput.value.toLowerCase().trim();
          var visible = 0;
          cards.forEach(function(card){
            var label = card.querySelector('.lib-card-label');
            if(!label) return;
            var name = label.textContent.toLowerCase();
            var show = !q || name.indexOf(q) !== -1;
            card.style.display = show ? '' : 'none';
            if(show) visible++;
          });
          countEl.textContent = visible + ' of ' + cards.length;
        }
        searchInput.addEventListener('input', filterIllust);
        filterIllust();
      })();
      </script>
    </div>
  </main>

  <script>
    // Switch to a panel by name
    function switchPanel(name) {
      document.querySelectorAll('.lib-tab').forEach(function(t) { t.classList.remove('active'); });
      document.querySelectorAll('.lib-panel').forEach(function(p) { p.classList.remove('active'); });
      var tab = document.querySelector('.lib-tab[data-panel="' + name + '"]');
      var panel = document.getElementById('panel-' + name);
      if (tab) tab.classList.add('active');
      if (panel) panel.classList.add('active');
    }

    // Slider tab click
    document.querySelectorAll('.lib-tab').forEach(function(tab) {
      tab.addEventListener('click', function() { switchPanel(tab.getAttribute('data-panel')); });
    });

    // Handle hash on load (e.g. #panel-icons, #panel-logos, #panel-illustrations)
    var hashMap = { 'panel-icons': 'icons', 'panel-logos': 'logos', 'panel-illustrations': 'illustrations' };
    function checkHash() {
      var h = window.location.hash.replace('#', '');
      if (hashMap[h]) switchPanel(hashMap[h]);
    }
    checkHash();
    window.addEventListener('hashchange', checkHash);

    // Theme toggle
    var themeToggle = document.getElementById('themeToggle');
    var moonIcon = document.getElementById('moonIcon');
    var sunIcon = document.getElementById('sunIcon');
    if ((localStorage.getItem('theme') || 'light') === 'dark') {
      document.documentElement.removeAttribute('data-theme');
      moonIcon.style.display = 'block'; sunIcon.style.display = 'none';
    }
    themeToggle.addEventListener('click', function() {
      if (document.documentElement.getAttribute('data-theme') === 'light') {
        document.documentElement.removeAttribute('data-theme');
        localStorage.setItem('theme', 'dark');
        moonIcon.style.display = 'block'; sunIcon.style.display = 'none';
      } else {
        document.documentElement.setAttribute('data-theme', 'light');
        localStorage.setItem('theme', 'light');
        moonIcon.style.display = 'none'; sunIcon.style.display = 'block';
      }
    });
  </script>
<script>
(function(){
  const nav = document.querySelector('.nav');
  if (!nav) return;
  const toggle = () => {
    if (window.scrollY > 10) nav.classList.add('scrolled');
    else nav.classList.remove('scrolled');
  };
  toggle();
  window.addEventListener('scroll', toggle, { passive: true });
})();
</script>
<script>
(function(){
  const hamburger = document.querySelector('.nav-hamburger');
  const sidebar = document.querySelector('.sidebar');
  const backdrop = document.querySelector('.sidebar-backdrop');
  const navLinks = document.querySelector('.nav-links');
  if (!hamburger || !sidebar || !backdrop) return;

  // Build a mobile-only nav section at the top of the sidebar by cloning the nav links
  if (navLinks && !sidebar.querySelector('.sidebar-mobile-nav')) {
    const mobileNav = document.createElement('div');
    mobileNav.className = 'sidebar-mobile-nav';
    const heading = document.createElement('h4');
    heading.textContent = 'Navigate';
    mobileNav.appendChild(heading);
    const ul = document.createElement('ul');
    navLinks.querySelectorAll(':scope > a').forEach(a => {
      const li = document.createElement('li');
      const clone = a.cloneNode(true);
      li.appendChild(clone);
      ul.appendChild(li);
    });
    navLinks.querySelectorAll(':scope > .nav-dropdown > .nav-dropdown-menu > a').forEach(a => {
      const li = document.createElement('li');
      const clone = a.cloneNode(true);
      li.appendChild(clone);
      ul.appendChild(li);
    });
    mobileNav.appendChild(ul);
    sidebar.insertBefore(mobileNav, sidebar.firstChild);
  }

  const open = () => {
    sidebar.classList.add('open');
    backdrop.classList.add('open');
    document.body.classList.add('sidebar-locked');
    hamburger.setAttribute('aria-expanded', 'true');
  };
  const close = () => {
    sidebar.classList.remove('open');
    backdrop.classList.remove('open');
    document.body.classList.remove('sidebar-locked');
    hamburger.setAttribute('aria-expanded', 'false');
  };
  hamburger.addEventListener('click', () => sidebar.classList.contains('open') ? close() : open());
  backdrop.addEventListener('click', close);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && sidebar.classList.contains('open')) close(); });
  sidebar.addEventListener('click', (e) => { if (e.target.closest('a')) close(); });
})();
</script>

