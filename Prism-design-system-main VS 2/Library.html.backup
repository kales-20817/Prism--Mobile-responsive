    <!-- ========== Icons Panel ========== -->
    <div class="lib-panel active" id="panel-icons">
      <h2 class="lib-section-title">Icons</h2>
      <p class="lib-section-desc">Product icons used across the UEMS product suite. 425 icons in SVG format. Hover any card to download.</p>
      <div style="display:flex;align-items:center;gap:12px;margin-bottom:24px;">
        <div style="flex:1;max-width:400px;display:flex;align-items:center;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:10px;padding:10px 16px;gap:8px;transition:all 0.2s;" id="icon-search-wrap">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="flex-shrink:0;color:var(--prism-text-muted);"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.35-4.35"/></svg>
          <input type="text" id="icon-search" placeholder="Search icons..." style="background:transparent;border:none;outline:none;color:var(--prism-text);font-family:inherit;font-size:14px;width:100%;">
        </div>
        <select id="icon-category-filter" style="background:var(--prism-surface-hover);border:1px solid var(--prism-border);color:var(--prism-text);padding:10px 14px;border-radius:8px;font-family:inherit;font-size:13px;font-weight:500;cursor:pointer;outline:none;transition:all 0.2s;">
          <option value="all">All Categories</option>
          <option value="arrow">Arrows</option>
          <option value="chart,graph,area-chart,bar-,donut,pie,funnel">Charts & Graphs</option>
          <option value="file,folder,document,xlsx,pdf,csv,zip,txt">Files & Folders</option>
          <option value="mobile,device,computer,laptop,monitor,tablet,phone">Devices</option>
          <option value="lock,key,shield,security,encrypt,password,bio-metric">Security</option>
          <option value="user,avatar,person,people,team,group">Users & People</option>
          <option value="mail,email,message,chat,inbox,notification,bell,announcement">Communication</option>
          <option value="setting,gear,config,tool,wrench,hammer">Settings & Tools</option>
          <option value="add,edit,delete,remove,trash,close,check,copy,cut,paste,undo,redo,save">Actions</option>
          <option value="search,filter,sort,zoom">Search & Filter</option>
          <option value="cloud,server,database,network,api,antenna,wifi">Infrastructure</option>
          <option value="patch,install,update,deploy,download,upload">Deployment</option>
          <option value="align,layout,grid,column,row,list,table">Layout</option>
          <option value="calendar,clock,time,schedule">Date & Time</option>
          <option value="eye,view,hide,visible">Visibility</option>
        </select>
        <span id="icon-count" style="font-size:12px;font-weight:600;color:var(--prism-text-muted);white-space:nowrap;"></span>
