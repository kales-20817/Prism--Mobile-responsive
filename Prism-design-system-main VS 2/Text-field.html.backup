    <main class="main-panel">
      <div class="page-header-area">
        <h1 class="page-title">Text field</h1>
        <p class="page-desc">
          The Text Input is a form control component that allows users to enter and edit single-line text. It provides labels, placeholder text, prefix/suffix elements, helper text, character counters, validation states, and clear functionality.
        </p>
        <nav class="content-tabs">
          <button class="tab-item active">Overview</button>
          <button class="tab-item">Style</button>
          <button class="tab-item">Usage</button>
          <button class="tab-item">Code</button>
          <button class="tab-item">Accessibility</button>
        </nav>
      </div>
      <div class="main-content-area">
        <div class="main-content-inner">

        <!-- ═══════════════════════════════════════════ -->
        <!-- TAB: OVERVIEW                               -->
        <!-- ═══════════════════════════════════════════ -->
        <div class="tab-content" id="tab-overview">

        <!-- Anatomy Section -->
        <h3 id="anatomy" class="doc-h3">Anatomy</h3>

        <div class="anatomy-diagram" style="overflow:visible;">
          <!-- Label Left (Default) layout -->
          <div style="margin-bottom: 40px; display: flex; justify-content: center;">
            <div style="width: 100%; max-width: 640px;">
              <div style="font-size: 12px; font-weight: 700; color: var(--prism-text-muted); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 20px; text-align: center;">Label Left (Default)</div>
              <div style="display: flex; align-items: center; gap: 12px; position: relative; padding: 16px 0;">
                <div style="position: relative;">
                  <!-- 2 Label: left of Label text -->
                  <div style="position: absolute; right: calc(100% + 6px); top: 50%; transform: translateY(-50%); display: flex; align-items: center; gap: 6px;">
                    <span class="anat-marker-inline">2</span><div style="width: 28px; height: 2px; background: #2563eb;"></div>
                  </div>
                  <span style="font-size: 14px; font-weight: 500; color: var(--prism-text);">Label</span>
                  <span style="color: #C1181B; margin-left: 2px;">*</span>
                </div>
                <div style="display: flex; align-items: center; gap: 8px; padding: 8px 12px; border: 2px dashed rgba(37,99,235,0.4); border-radius: 10px; flex: 1; max-width: 480px; position: relative;">
                  <!-- 1 Container: above, centered over full frame -->
                  <div style="position: absolute; top: -28px; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: 4px;">
                    <span class="anat-marker-inline">1</span><div style="width: 2px; height: 12px; background: #2563eb;"></div>
                  </div>
                  <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color: #5F6C89; flex-shrink: 0;"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
                  <span style="font-size: 13px; color: #5F6C89;">$</span>
                  <span style="font-size: 14px; color: #8B95A9; flex: 1;">Input Text</span>
                  <span style="font-size: 13px; color: #5F6C89;">kg</span>
                  <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color: #5F6C89; flex-shrink: 0;"><path d="M9 5l7 7-7 7"/></svg>
                  <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color: #8B95A9; flex-shrink: 0; cursor: pointer;"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                  <!-- 3 Input Field: right of frame, horizontal line -->
                  <div style="position: absolute; left: calc(100% + 6px); top: 50%; transform: translateY(-50%); display: flex; flex-direction: row-reverse; align-items: center; gap: 6px;">
                    <span class="anat-marker-inline">3</span><div style="width: 28px; height: 2px; background: #2563eb;"></div>
                  </div>
                </div>
              </div>
              <div style="display: flex; align-items: center; gap: 4px; margin-left: 60px; margin-top: 4px; position: relative;">
                <svg width="12" height="12" fill="none" stroke="#5F6C89" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
                <span style="font-size: 12px; color: #5F6C89;">Helper text</span>
                <span style="margin-left: auto; font-size: 12px; color: #8B95A9;">0/100</span>
                <!-- 4 Helper Row: left of row, horizontal line -->
                <div style="position: absolute; right: calc(100% + 6px); top: 50%; transform: translateY(-50%); display: flex; align-items: center; gap: 6px;">
                  <span class="anat-marker-inline">4</span><div style="width: 28px; height: 2px; background: #2563eb;"></div>
                </div>
              </div>
            </div>
          </div>

          <!-- Label Top layout -->
          <div style="display: flex; justify-content: center;">
            <div style="width: 100%; max-width: 640px;">
              <div style="font-size: 12px; font-weight: 700; color: var(--prism-text-muted); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 20px; text-align: center;">Label Top</div>
              <div style="display: flex; flex-direction: column; gap: 6px; max-width: 480px; margin: 0 auto;">
                <div style="display: flex; align-items: center; gap: 2px;">
                  <span style="font-size: 14px; font-weight: 500; color: var(--prism-text);">Label</span>
                  <span style="color: #C1181B;">*</span>
                </div>
                <div style="display: flex; align-items: center; gap: 8px; padding: 8px 12px; border: 2px dashed rgba(37,99,235,0.4); border-radius: 10px;">
                  <span style="font-size: 14px; color: #8B95A9; flex: 1;">Placeholder text</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="anat-legend">
          <div class="anat-legend-item"><span class="anat-marker-inline">1</span><div><strong>Container</strong><span>Holds the input field, borders, background, and all inner elements.</span></div></div>
          <div class="anat-legend-item"><span class="anat-marker-inline">2</span><div><strong>Label</strong><span>Identifies the input field. Includes an optional required indicator (*).</span></div></div>
          <div class="anat-legend-item"><span class="anat-marker-inline">3</span><div><strong>Input Field</strong><span>Contains prefix icon, prefix text, input text/placeholder, suffix text, suffix icon, and clear button.</span></div></div>
          <div class="anat-legend-item"><span class="anat-marker-inline">4</span><div><strong>Helper Row</strong><span>Displays helper icon, helper text, and character counter below the input.</span></div></div>
          <div class="anat-legend-item"><span class="anat-marker-inline" style="background: linear-gradient(135deg, #06b6d4, #0891b2);">5</span><div><strong>Prefix Icon</strong><span>Optional leading icon to provide visual context for the input.</span></div></div>
          <div class="anat-legend-item"><span class="anat-marker-inline" style="background: linear-gradient(135deg, #06b6d4, #0891b2);">6</span><div><strong>Prefix Text</strong><span>Static text before the input (e.g., "$", "https://").</span></div></div>
          <div class="anat-legend-item"><span class="anat-marker-inline" style="background: linear-gradient(135deg, #8b5cf6, #6d28d9);">7</span><div><strong>Suffix Text</strong><span>Static text after the input (e.g., "kg", ".com").</span></div></div>
          <div class="anat-legend-item"><span class="anat-marker-inline" style="background: linear-gradient(135deg, #8b5cf6, #6d28d9);">8</span><div><strong>Suffix Icon</strong><span>Optional trailing icon for secondary context or action.</span></div></div>
          <div class="anat-legend-item"><span class="anat-marker-inline" style="background: linear-gradient(135deg, #f97316, #ea580c);">9</span><div><strong>Clear Button</strong><span>An "X" icon to clear the input field content.</span></div></div>
          <div class="anat-legend-item"><span class="anat-marker-inline" style="background: linear-gradient(135deg, #f97316, #ea580c);">10</span><div><strong>Helper Icon</strong><span>Small icon that accompanies the helper text.</span></div></div>
          <div class="anat-legend-item"><span class="anat-marker-inline" style="background: linear-gradient(135deg, #f97316, #ea580c);">11</span><div><strong>Helper Text</strong><span>Supporting text providing context, validation messages, or formatting guidance.</span></div></div>
          <div class="anat-legend-item"><span class="anat-marker-inline" style="background: linear-gradient(135deg, #ec4899, #db2777);">12</span><div><strong>Counter</strong><span>Character count display showing current/max characters (e.g., "0/100").</span></div></div>
        </div>

        <hr class="doc-divider" />

        <!-- Live Demo Section -->
        <div style="margin-bottom: 64px;">
          <h2 id="live-demo" class="doc-section-title" style="margin-bottom: 8px;">Preview</h2>
          <p class="doc-section-subtitle" style="margin-bottom: 28px;">Interact with the text input variants to explore different states, sizes, and configurations.</p>

          <!-- States -->
          <div class="demo-container" style="margin-bottom: 32px;">
            <div class="demo-toolbar">
              <div class="demo-toolbar-left"><div class="demo-theme-pill">States</div></div>
            </div>
            <div class="demo-canvas" style="flex-wrap: wrap; gap: 24px; align-items: flex-start;">
              <!-- Default -->
