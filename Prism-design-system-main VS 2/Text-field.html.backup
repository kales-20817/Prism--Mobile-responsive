          <!-- Prefix / Suffix -->
          <div class="demo-container" style="margin-bottom: 32px;">
            <div class="demo-toolbar">
              <div class="demo-toolbar-left"><div class="demo-theme-pill">Prefix &amp; Suffix</div></div>
            </div>
            <div class="demo-canvas" style="gap: 24px; align-items: flex-start;">
              <!-- Prefix Icon -->
              <div class="text-input-demo">
                <div class="text-input-row label-left">
                  <span class="text-input-label">Search</span>
                  <div style="flex: 1;">
                    <div class="text-input-field">
                      <span class="text-input-icon"><svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg></span>
                      <input type="text" placeholder="Search items..." />
                    </div>
                  </div>
                </div>
              </div>
              <!-- Prefix Text -->
              <div class="text-input-demo">
                <div class="text-input-row label-left">
                  <span class="text-input-label">Price</span>
                  <div style="flex: 1;">
                    <div class="text-input-field">
                      <span class="text-input-prefix">$</span>
                      <input type="text" placeholder="0.00" />
                    </div>
                  </div>
                </div>
              </div>
              <!-- Suffix Text -->
              <div class="text-input-demo">
                <div class="text-input-row label-left">
                  <span class="text-input-label">Weight</span>
                  <div style="flex: 1;">
                    <div class="text-input-field">
                      <input type="text" placeholder="Enter weight" />
                      <span class="text-input-suffix">kg</span>
                    </div>
                  </div>
                </div>
              </div>
              <!-- Suffix Icon -->
              <div class="text-input-demo">
                <div class="text-input-row label-left">
                  <span class="text-input-label">Date</span>
                  <div style="flex: 1;">
                    <div class="text-input-field">
                      <input type="text" placeholder="Select date" />
                      <span class="text-input-icon"><svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg></span>
                    </div>
                  </div>
                </div>
              </div>
              <!-- Clear Button -->
