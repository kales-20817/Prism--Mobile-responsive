              <!-- Read Only -->
              <div class="text-input-demo">
                <div class="text-input-row label-left">
                  <span class="text-input-label">Label</span>
                  <div style="flex: 1;">
                    <div class="text-input-field readonly">
                      <input type="text" value="Read only value" readonly />
