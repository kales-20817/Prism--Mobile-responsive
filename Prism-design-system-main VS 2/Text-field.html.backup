                <div class="text-input-row label-left">
                  <span class="text-input-label">Label <span class="required">*</span></span>
                  <div style="flex: 1;">
                    <div class="text-input-field" style="border-color: #8B95A9;">
                      <input type="text" placeholder="Placeholder" />
                    </div>
                    <div class="text-input-helper">
                      <span class="text-input-helper-text">Hover state</span>
                    </div>
                  </div>
                </div>
              </div>
              <!-- Focus -->
              <div class="text-input-demo">
                <div class="text-input-row label-left">
                  <span class="text-input-label">Label <span class="required">*</span></span>
                  <div style="flex: 1;">
                    <div class="text-input-field focus">
                      <input type="text" placeholder="Placeholder" />
                    </div>
                    <div class="text-input-helper">
                      <span class="text-input-helper-text">Focus state</span>
                    </div>
                  </div>
                </div>
              </div>
              <!-- Filled -->
              <div class="text-input-demo">
                <div class="text-input-row label-left">
                  <span class="text-input-label">Label <span class="required">*</span></span>
                  <div style="flex: 1;">
                    <div class="text-input-field">
                      <input type="text" value="Entered value" />
                    </div>
                    <div class="text-input-helper">
                      <span class="text-input-helper-text">Filled state</span>
                    </div>
                  </div>
                </div>
              </div>
              <!-- Error -->
              <div class="text-input-demo">
                <div class="text-input-row label-left">
                  <span class="text-input-label">Label <span class="required">*</span></span>
                  <div style="flex: 1;">
                    <div class="text-input-field error">
                      <input type="text" value="Invalid input" />
                    </div>
                    <div class="text-input-helper">
                      <span class="text-input-helper-text error">This field is required</span>
                    </div>
                  </div>
                </div>
              </div>
              <!-- Success -->
              <div class="text-input-demo">
                <div class="text-input-row label-left">
                  <span class="text-input-label">Label <span class="required">*</span></span>
                  <div style="flex: 1;">
                    <div class="text-input-field success">
                      <input type="text" value="Valid input" />
                    </div>
                    <div class="text-input-helper">
                      <span class="text-input-helper-text success">Looks good!</span>
                    </div>
                  </div>
                </div>
              </div>
              <!-- Disabled -->
              <div class="text-input-demo">
                <div class="text-input-row label-left">
                  <span class="text-input-label" style="opacity: 0.6;">Label</span>
                  <div style="flex: 1;">
                    <div class="text-input-field disabled">
                      <input type="text" placeholder="Disabled" disabled />
                    </div>
                    <div class="text-input-helper">
                      <span class="text-input-helper-text" style="opacity: 0.6;">Disabled state</span>
                    </div>
                  </div>
                </div>
