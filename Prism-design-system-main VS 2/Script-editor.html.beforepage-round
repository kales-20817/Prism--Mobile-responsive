              <div style="background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;overflow:hidden;">
                <div style="background:#fff;padding:28px 24px;text-align:center;border-radius:12px 12px 0 0;"><div style="font-size:20px;font-weight:700;font-family:'Fira Code',monospace;color:#15181E;">Props useState Editor</div></div>
                <div style="padding:16px 24px;display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--prism-border);"><div><div style="font-size:13px;color:var(--prism-text-muted);font-weight:600;">TEXT-PRIMARY ON WHITE</div><div style="font-size:15px;color:var(--prism-text);font-family:monospace;margin-top:4px;">#15181E on #FFFFFF</div></div><div style="text-align:right;"><div style="display:inline-flex;align-items:center;gap:6px;background:rgba(34,197,94,0.1);color:#16a34a;padding:4px 10px;border-radius:100px;font-size:12px;font-weight:700;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><polyline points="20 6 9 17 4 12"></polyline></svg> 17.4:1</div><div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;font-weight:600;">WCAG AAA Pass</div></div></div>
