          <script>
          (function(){
            var els = {type:document.getElementById('pg-type'),size:document.getElementById('pg-size'),state:document.getElementById('pg-state')};
            var previewArea = document.getElementById('pg-preview-area');
            var codeOut = document.getElementById('pg-code-output');
            var copyBtn = document.getElementById('pg-copy-btn');

            var sizeMap = {sm:{h:140,fs:11},md:{h:180,fs:13},lg:{h:220,fs:14}};

            var codeLines = [
              'import { useState } from "react";',
              '',
              'interface Props {',
              '  title: string;',
              '  count: number;',
              '}',
              '',
              'export function Editor(props: Props) {',
              '  const [value, setValue] = useState("");',
              '}'
            ];

            function syntaxHL(line) {
              return line
                .replace(/\b(import|export|from|interface|function|const|return)\b/g, '<span class="kw">$1</span>')
                .replace(/"([^"]*)"/g, '<span class="str">"$1"</span>');
            }

            function esc(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}

            function update(){
              var tp = els.type.value;
              var sz = els.size.value;
              var st = els.state.value;
              var s = sizeMap[sz];

              var containerCls = 'se-container';
              if(st==='focus') containerCls += ' focus';
              if(st==='error') containerCls += ' error';
              if(st==='disabled') containerCls += ' disabled';

              var hasTabs = (tp==='WithTabs' || tp==='FullIDE');
              var hasToolbar = (tp==='WithToolbar' || tp==='FullIDE');
              var hasLineNums = (tp==='WithLineNumbers' || tp==='FullIDE');
              var hasMinimap = (tp==='FullIDE');
              var hasTerminal = (tp==='FullIDE');

              // Build preview HTML
              var html = '<div class="'+containerCls+'" style="width:100%;max-width:600px;font-size:'+s.fs+'px;">';

              if(hasTabs) {
                html += '<div class="se-tab-bar"><div class="se-tab active"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg> index.ts</div><div class="se-tab"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg> utils.ts</div></div>';
              }
              if(hasToolbar) {
                html += '<div class="se-toolbar"><span class="se-toolbar-btn">&#9655; Run</span><span class="se-toolbar-btn">&#9633; Stop</span><span class="se-toolbar-btn">&#9112; Copy</span><span class="se-toolbar-btn">&#9881; Settings</span><span class="se-lang-badge">TypeScript</span></div>';
              }

              if(hasMinimap) html += '<div style="display:flex;">';

              html += '<div class="se-code-area" style="min-height:'+s.h+'px;'+(hasMinimap?'flex:1;':'')+'">';
              for(var i=0;i<codeLines.length;i++){
                var ln = codeLines[i];
                var lineHtml = '';
                if(hasLineNums) lineHtml += '<span class="line-nums">'+(i+1)+'</span> ';
                if(i===8) lineHtml += '<span class="active-line">'+syntaxHL(ln)+'</span>';
                else lineHtml += syntaxHL(ln || '&nbsp;');
                html += lineHtml + '<br>';
              }
              if(st==='readonly') html += '<span class="se-readonly-badge">READ ONLY</span>';
              html += '</div>';

              if(hasMinimap) {
                html += '<div class="se-minimap">';
                for(var j=0;j<10;j++) html += '<div class="se-minimap-line'+(j%3===0?' accent':'')+'"></div>';
                html += '</div></div>';
              }

              if(hasTerminal) {
                html += '<div class="se-terminal"><div class="se-terminal-tabs"><div class="se-terminal-tab active">Terminal</div><div class="se-terminal-tab">Problems</div><div class="se-terminal-tab">Output</div></div><div class="se-terminal-output"><span class="prompt">$</span> npm run dev<br>&gt; vite --open<br>VITE v5.2.0 ready in 342ms</div></div>';
              }

              var statusCls = st==='error' ? 'se-status-bar error' : 'se-status-bar';
              var statusLeft = st==='error' ? '2 Errors' : 'TypeScript';
              html += '<div class="'+statusCls+'"><div class="status-left">'+statusLeft+'</div><div class="status-right"><span>Ln 9, Col 38</span><span>UTF-8</span><span>Spaces: 2</span></div></div>';
              html += '</div>';
              previewArea.innerHTML = html;

              // Build code output
              var stateAttr = '';
              if(st==='default') stateAttr = 'default';
              else if(st==='focus') stateAttr = 'focus';
              else if(st==='error') stateAttr = 'error';
              else if(st==='disabled') stateAttr = 'disabled';
              else if(st==='readonly') stateAttr = 'readonly';

              var codeStr = '<div\n  class="script-editor"\n  data-type="'+tp+'"\n  data-state="'+stateAttr+'"\n  data-size="'+sz+'"\n  role="group"\n  aria-label="Script editor"\n>';
              if(hasTabs) codeStr += '\n  <!-- Tab Bar -->\n  <div class="editor-tab-bar">\n    <button class="tab active">index.ts</button>\n    <button class="tab">utils.ts</button>\n  </div>';
              if(hasToolbar) codeStr += '\n  <!-- Toolbar -->\n  <div class="editor-toolbar" role="toolbar" aria-label="Editor actions">\n    <button aria-label="Run script">Run</button>\n    <button aria-label="Stop script">Stop</button>\n    <button aria-label="Copy code">Copy</button>\n    <button aria-label="Settings">Settings</button>\n    <span class="language-badge">TypeScript</span>\n  </div>';
              codeStr += '\n  <!-- Code area -->\n  <div\n    class="editor-code-area"\n    role="textbox"\n    aria-multiline="true"\n    aria-label="Code editor"\n    aria-readonly="'+(st==='readonly'?'true':'false')+'"\n  ></div>';
              if(hasTerminal) codeStr += '\n  <!-- Terminal -->\n  <div class="editor-terminal" role="log" aria-label="Terminal output"></div>';
              codeStr += '\n  <!-- Status bar -->\n  <div class="editor-status-bar" aria-live="polite">\n    <span class="status-language">TypeScript</span>\n    <span class="status-position">Ln 9, Col 38</span>\n    <span class="status-encoding">UTF-8</span>\n    <span class="status-indent">Spaces: 2</span>\n  </div>';
