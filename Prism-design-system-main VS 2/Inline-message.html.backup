    <main class="main-panel">
      <div class="page-header-area">
        <h1 class="page-title">Inline Message</h1>
        <p class="page-desc">A semantic banner that communicates status information within the page flow &#8212; below a form, inside a card, or at the top of a panel. It supports five semantic types, two visual weights, optional title, description, action link, and dismiss control, with full RTL support.</p>
        <nav class="content-tabs">
          <button class="tab-item active">Overview</button>
          <button class="tab-item">Style</button>
          <button class="tab-item">Usage</button>
          <button class="tab-item">Code</button>
          <button class="tab-item">Accessibility</button>
        </nav>
      </div>

      <div class="main-content-area">
        <div class="main-content-inner">

        <!-- ========== OVERVIEW ========== -->
        <div class="tab-content" id="tab-overview">
          <h3 id="anatomy" class="doc-h3">Anatomy</h3>
          <div class="anatomy-diagram">
            <div style="display:flex;justify-content:center;margin:40px 0;">
              <div style="position:relative;display:inline-flex;flex-direction:column;gap:0;max-width:400px;width:100%;">
                <!-- The component -->
                <div class="iam iam-subtle iam-info" style="border:2px dashed rgba(37,99,235,0.4);position:relative;overflow:visible;">
                  <!-- 1 Status Icon: marker left of icon, horizontal line right -->
                  <div style="position:absolute;right:calc(100% + 6px);top:14px;display:flex;align-items:center;gap:6px;z-index:5;"><span class="anat-marker-inline">1</span><div style="width:28px;height:2px;background:#2563eb;"></div></div>
                  <svg class="iam-icon" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/></svg>
                  <div class="iam-content">
                    <!-- 2 Title: marker above, vertical line down -->
                    <div style="position:relative;">
                      <div style="position:absolute;bottom:calc(100% + 6px);left:10px;display:flex;flex-direction:column;align-items:center;gap:4px;z-index:5;"><span class="anat-marker-inline">2</span><div style="width:2px;height:14px;background:#2563eb;"></div></div>
                      <div class="iam-title">Alert Title</div>
                    </div>
                    <!-- 3 Description: marker right, horizontal line left -->
                    <div style="position:relative;">
                      <div style="position:absolute;top:50%;left:calc(100% + 40px);transform:translateY(-50%);display:flex;flex-direction:row-reverse;align-items:center;gap:6px;z-index:5;"><span class="anat-marker-inline">3</span><div style="width:28px;height:2px;background:#2563eb;"></div></div>
                      <div class="iam-desc">This is a description of the alert message that provides additional context for the user.</div>
                    </div>
                    <!-- 4 Action Link: marker left, horizontal line right -->
                    <div style="position:relative;">
                      <div style="position:absolute;top:50%;right:calc(100% + 46px);transform:translateY(-50%);display:flex;align-items:center;gap:6px;z-index:5;"><span class="anat-marker-inline">4</span><div style="width:28px;height:2px;background:#2563eb;"></div></div>
                      <a class="iam-action" href="javascript:void(0)">Action</a>
                    </div>
                  </div>
                  <!-- 5 Dismiss: marker right, horizontal line left -->
                  <div style="position:absolute;left:calc(100% + 6px);top:14px;display:flex;flex-direction:row-reverse;align-items:center;gap:6px;z-index:5;"><span class="anat-marker-inline">5</span><div style="width:28px;height:2px;background:#2563eb;"></div></div>
                  <button class="iam-dismiss" aria-label="Dismiss alert"><svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg></button>
                  <!-- 6 Container: marker below, vertical line up -->
                  <div style="position:absolute;top:calc(100% + 6px);left:50%;transform:translateX(-50%);display:flex;flex-direction:column-reverse;align-items:center;gap:4px;z-index:5;"><span class="anat-marker-inline">6</span><div style="width:2px;height:14px;background:#2563eb;"></div></div>
                </div>
              </div>
            </div>
          </div>
          <div class="anat-legend">
            <div class="anat-legend-item"><span class="anat-marker-inline">1</span><div><strong>Status Icon</strong><span>20&#215;20 px semantic icon indicating alert type (info / check / warning / error). Toggled by Show Icon.</span></div></div>
            <div class="anat-legend-item"><span class="anat-marker-inline">2</span><div><strong>Title</strong><span>Primary alert heading. 14 px / Semibold. Colour varies per Type in Subtle; white/black in Intense. Toggled by Show Title.</span></div></div>
            <div class="anat-legend-item"><span class="anat-marker-inline">3</span><div><strong>Description</strong><span>Supporting body text below the title. 12 px / Regular. Toggled by Show Description.</span></div></div>
            <div class="anat-legend-item"><span class="anat-marker-inline">4</span><div><strong>Action Link</strong><span>Inline TextLink (Standalone, Primary, Small). Instance-swappable. Toggled by Show Action.</span></div></div>
            <div class="anat-legend-item"><span class="anat-marker-inline">5</span><div><strong>Dismiss Icon</strong><span>16&#215;16 px close/X icon in the top-right corner. Toggled by Show Dismiss.</span></div></div>
            <div class="anat-legend-item"><span class="anat-marker-inline">6</span><div><strong>Container</strong><span>Full-width banner with 8 px corner radius, 12 px T/B padding, 16 px L/R padding. Background fills the full component width.</span></div></div>
          </div>

          <hr class="doc-divider"/>

          <div style="margin-bottom:64px;">
            <h2 id="live-demo" class="doc-section-title" style="margin-bottom:8px;">Preview</h2>
            <p class="doc-section-subtitle" style="margin-bottom:28px;">Explore all inline message variants across styles and types.</p>
            <div class="demo-container">
<div class="demo-canvas" style="gap:16px;padding:40px;">
                <!-- Subtle row -->
                <div style="display:flex;flex-direction:column;gap:12px;width:100%;max-width:440px;">
                  <div class="iam iam-subtle iam-info" role="status">
                    <svg class="iam-icon" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/></svg>
                    <div class="iam-content"><div class="iam-title">Sync in progress</div><div class="iam-desc">Your data is being synchronised.</div></div>
                    <button class="iam-dismiss" aria-label="Dismiss alert"><svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg></button>
                  </div>
                  <div class="iam iam-subtle iam-success" role="status">
                    <svg class="iam-icon" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                    <div class="iam-content"><div class="iam-title">Changes saved</div><div class="iam-desc">Your profile has been updated successfully.</div><a class="iam-action" href="javascript:void(0)">View profile</a></div>
                    <button class="iam-dismiss" aria-label="Dismiss alert"><svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg></button>
                  </div>
                  <div class="iam iam-subtle iam-warning" role="alert">
                    <svg class="iam-icon" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
                    <div class="iam-content"><div class="iam-title">Storage almost full</div><div class="iam-desc">You have used 90% of your available storage.</div><a class="iam-action" href="javascript:void(0)">Manage storage</a></div>
                  </div>
                  <div class="iam iam-subtle iam-error" role="alert">
                    <svg class="iam-icon" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>
                    <div class="iam-content"><div class="iam-title">Upload failed</div><div class="iam-desc">The file could not be uploaded due to a network error.</div><a class="iam-action" href="javascript:void(0)">Retry upload</a></div>
                  </div>
                  <div class="iam iam-subtle iam-neutral" role="status">
                    <svg class="iam-icon" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/></svg>
                    <div class="iam-content"><div class="iam-title">No results found</div></div>
                  </div>
                </div>
                <!-- Intense row -->
                <div style="display:flex;flex-direction:column;gap:12px;width:100%;max-width:440px;">
                  <div class="iam iam-intense iam-info" role="status">
                    <svg class="iam-icon" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/></svg>
                    <div class="iam-content"><div class="iam-title">Maintenance scheduled</div><div class="iam-desc">The system will be unavailable on Saturday.</div></div>
                    <button class="iam-dismiss" aria-label="Dismiss alert"><svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg></button>
                  </div>
                  <div class="iam iam-intense iam-error" role="alert">
                    <svg class="iam-icon" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>
                    <div class="iam-content"><div class="iam-title">Upload failed</div><div class="iam-desc">Please try again.</div><a class="iam-action" href="javascript:void(0)">Retry upload</a></div>
                  </div>
                  <div class="iam iam-intense iam-warning" role="alert">
                    <svg class="iam-icon" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
                    <div class="iam-content"><div class="iam-title">Browser unsupported</div><div class="iam-desc">Some features may not work correctly.</div></div>
                    <button class="iam-dismiss" aria-label="Dismiss alert"><svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg></button>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="doc-section">
            <h3 id="content-guidelines" class="doc-h3">Content Guidelines<span class="h3-badge" style="background:rgba(37,99,235,0.1);color:var(--prism-violet);">Recommended</span></h3>
            <div class="do-dont-grid">
              <div class="do-card"><span class="card-label">Do</span><ul>
                <li>Keep the title concise (3&#8211;6 words: "Action Required", "Upload Failed").</li>
                <li>Use description to provide context and explain next steps.</li>
                <li>Use Show Action to link directly to the resolution ("Retry", "View error details").</li>
                <li>Match type to the actual semantic meaning &#8212; Error for failures, Success for completions.</li>
              </ul></div>
              <div class="dont-card"><span class="card-label">Don't</span><ul>
                <li>Write a full sentence as the title &#8212; use description for longer explanatory text.</li>
                <li>Default to Intense for all alerts &#8212; reserve it for high-priority messages.</li>
                <li>Use Warning for errors or Info for success &#8212; mismatched semantics confuse screen readers.</li>
                <li>Put unrelated page-level actions in the alert action slot.</li>
              </ul></div>
            </div>
          </div>
        </div>

        <!-- ========== STYLE ========== -->
        <div class="tab-content" id="tab-style" style="display:none;padding-top:32px;">
          <h2 id="style-overview" class="doc-section-title">Style</h2>
          <p class="doc-section-subtitle">Design tokens, color mappings, and spacing tokens that define the Inline Message's visual language.</p>

          <div class="doc-section">
            <h2 id="variants" class="doc-section-title">Variants</h2>
            <p class="doc-section-subtitle">2 styles &times; 5 types &times; 2 directions = 20 Inline Alert Message variants.</p>
            <table class="size-table">
              <thead><tr><th>Axis</th><th>Values</th><th>Description</th></tr></thead>
              <tbody>
                <tr><td><strong>Style</strong></td><td><code>Subtle</code>, <code>Intense</code></td><td>Subtle = light tinted background with coloured text. Intense = solid fill with white text (black for Warning).</td></tr>
                <tr><td><strong>Type</strong></td><td><code>Info</code>, <code>Success</code>, <code>Warning</code>, <code>Error</code>, <code>Neutral</code></td><td>Semantic alert type controlling background, icon, and title colour.</td></tr>
                <tr><td><strong>RTL</strong></td><td><code>False</code>, <code>True</code></td><td>LTR = Icon &#8594; Content &#8594; Dismiss. RTL = reversed order, right-aligned text.</td></tr>
              </tbody>
            </table>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h2 id="states" class="doc-section-title">Types</h2>
            <p class="doc-section-subtitle">Five semantic types, each available in Subtle and Intense styles.</p>
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:14px;margin-top:24px;">
              <div style="padding:20px 12px;border-radius:14px;background:var(--prism-surface);border:1px solid var(--prism-border);text-align:center;">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="#2563EB" style="margin-bottom:8px;"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/></svg>
                <div style="font-size:13px;font-weight:600;color:var(--prism-text);margin-top:4px;">Info</div><div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;">Guidance / tips</div>
              </div>
              <div style="padding:20px 12px;border-radius:14px;background:var(--prism-surface);border:1px solid var(--prism-border);text-align:center;">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="#0A7138" style="margin-bottom:8px;"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                <div style="font-size:13px;font-weight:600;color:var(--prism-text);margin-top:4px;">Success</div><div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;">Completed action</div>
              </div>
              <div style="padding:20px 12px;border-radius:14px;background:var(--prism-surface);border:1px solid var(--prism-border);text-align:center;">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="#956B11" style="margin-bottom:8px;"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
                <div style="font-size:13px;font-weight:600;color:var(--prism-text);margin-top:4px;">Warning</div><div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;">Caution needed</div>
              </div>
              <div style="padding:20px 12px;border-radius:14px;background:var(--prism-surface);border:1px solid var(--prism-border);text-align:center;">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="#C1181B" style="margin-bottom:8px;"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>
                <div style="font-size:13px;font-weight:600;color:var(--prism-text);margin-top:4px;">Error</div><div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;">Failure / blocked</div>
              </div>
              <div style="padding:20px 12px;border-radius:14px;background:var(--prism-surface);border:1px solid var(--prism-border);text-align:center;">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="#64748b" style="margin-bottom:8px;"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/></svg>
                <div style="font-size:13px;font-weight:600;color:var(--prism-text);margin-top:4px;">Neutral</div><div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;">Low priority</div>
              </div>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h2 id="sizes" class="doc-section-title">Sizing Reference</h2>
            <p class="doc-section-subtitle">The inline alert message uses a single size with auto-height based on content.</p>
            <table class="size-table">
              <thead><tr><th>Property</th><th>Value</th></tr></thead>
              <tbody>
                <tr><td><strong>Width</strong></td><td>100% (fills container)</td></tr>
                <tr><td><strong>Height</strong></td><td>Auto &#8212; hugs content</td></tr>
                <tr><td><strong>Padding Top / Bottom</strong></td><td>12 px</td></tr>
                <tr><td><strong>Padding Left / Right</strong></td><td>16 px</td></tr>
                <tr><td><strong>Corner Radius</strong></td><td>8 px</td></tr>
                <tr><td><strong>Status Icon</strong></td><td>20 &#215; 20 px</td></tr>
                <tr><td><strong>Dismiss Icon</strong></td><td>16 &#215; 16 px</td></tr>
                <tr><td><strong>Icon &#8594; Content &#8594; Dismiss gap</strong></td><td>12 px</td></tr>
                <tr><td><strong>Title &#8594; Description &#8594; Action gap</strong></td><td>4 px</td></tr>
              </tbody>
            </table>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="color-tokens" class="doc-h3">Color Tokens<span class="h3-badge" style="background:rgba(37,99,235,0.1);color:var(--prism-violet);">Tokens</span></h3>
            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Subtle &#8212; Background Tokens</h4>
            <table class="size-table" style="margin-bottom:32px;">
              <thead><tr><th>Type</th><th>Background Token</th></tr></thead>
              <tbody>
                <tr><td><strong>Info</strong></td><td><code>Background/BG-Accent-Primary</code></td></tr>
                <tr><td><strong>Success</strong></td><td><code>Background/BG-Success-Primary</code></td></tr>
                <tr><td><strong>Warning</strong></td><td><code>Background/BG-Alert-Primary</code></td></tr>
                <tr><td><strong>Error</strong></td><td><code>Background/BG-Error-Primary</code></td></tr>
                <tr><td><strong>Neutral</strong></td><td><code>Background/BG-Secondary</code></td></tr>
              </tbody>
            </table>
            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Intense &#8212; Background Tokens</h4>
            <table class="size-table" style="margin-bottom:32px;">
              <thead><tr><th>Type</th><th>Background Token</th></tr></thead>
              <tbody>
                <tr><td><strong>Info</strong></td><td><code>Background/BG-Accent-Secondary-Solid</code></td></tr>
                <tr><td><strong>Success</strong></td><td><code>Background/BG-Success-Solid</code></td></tr>
                <tr><td><strong>Warning</strong></td><td><code>Background/BG-Alert-Solid</code></td></tr>
                <tr><td><strong>Error</strong></td><td><code>Background/BG-Error-Solid</code></td></tr>
                <tr><td><strong>Neutral</strong></td><td><code>Background/BG-Secondary-Solid</code></td></tr>
              </tbody>
            </table>
            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Text Colours &#8212; Subtle</h4>
            <table class="size-table" style="margin-bottom:32px;">
              <thead><tr><th>Element</th><th>Info</th><th>Success</th><th>Warning</th><th>Error</th><th>Neutral</th></tr></thead>
              <tbody>
                <tr><td><strong>Title</strong></td><td><code>Text/Text-Accent-Link</code></td><td><code>Text/Text-Success</code></td><td><code>Text/Text-Alert</code></td><td><code>Text/Text-Error</code></td><td><code>Text/Text-Primary</code></td></tr>
                <tr><td><strong>Description</strong></td><td><code>Text/Text-Primary</code></td><td><code>Text/Text-Primary</code></td><td><code>Text/Text-Primary</code></td><td><code>Text/Text-Primary</code></td><td><code>Text/Text-Secondary</code></td></tr>
              </tbody>
            </table>
            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Text Colours &#8212; Intense</h4>
            <table class="size-table">
              <thead><tr><th>Element</th><th>Info</th><th>Success</th><th>Warning</th><th>Error</th><th>Neutral</th></tr></thead>
              <tbody>
                <tr><td><strong>Title</strong></td><td><code>Text/Text-White</code></td><td><code>Text/Text-White</code></td><td><code>Text/Text-Black</code></td><td><code>Text/Text-White</code></td><td><code>Text/Text-White</code></td></tr>
                <tr><td><strong>Description</strong></td><td><code>Text/Text-White</code></td><td><code>Text/Text-White</code></td><td><code>Text/Text-Black</code></td><td><code>Text/Text-White</code></td><td><code>Text/Text-White</code></td></tr>
              </tbody>
            </table>
            <div style="margin-top:16px;padding:16px 20px;background:rgba(249,178,29,0.08);border:1px solid rgba(249,178,29,0.2);border-radius:12px;">
              <p style="font-size:14px;color:var(--prism-text);line-height:1.6;margin:0;"><strong>Note:</strong> Warning Intense uses <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">Text/Text-Black</code> for both title and description because the amber/yellow background does not provide sufficient contrast for white text.</p>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="spacing-tokens" class="doc-h3">Spacing Tokens</h3>
            <table class="size-table">
              <thead><tr><th>Token</th><th>Value</th><th>Usage</th></tr></thead>
              <tbody>
                <tr><td><code>spacing/12</code></td><td>12 px</td><td>Container top / bottom padding</td></tr>
                <tr><td><code>spacing/16</code></td><td>16 px</td><td>Container left / right padding</td></tr>
                <tr><td><code>spacing/12</code></td><td>12 px</td><td>Gap between Status Icon, Content, and Dismiss Icon (horizontal)</td></tr>
                <tr><td><code>spacing/4</code></td><td>4 px</td><td>Gap between Title, Description, and Action Link (vertical stack)</td></tr>
              </tbody>
            </table>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="corner-radius-border-radius" class="doc-h3">Corner Radius (Border Radius)</h3>
            <p class="doc-section-subtitle">The inline alert message uses a consistent 8 px corner radius.</p>
            <div style="display:flex;gap:24px;flex-wrap:wrap;">
              <div style="flex:1;min-width:200px;padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;text-align:center;">
                <div style="width:64px;height:32px;border:2px dashed #006AFF;border-radius:8px;margin:0 auto 16px;display:flex;align-items:center;justify-content:center;background:rgba(0,106,255,0.05);color:#006AFF;font-weight:600;font-size:11px;">8px</div>
                <div style="font-size:14px;font-weight:600;color:var(--prism-text);">radius/8</div>
                <div style="font-size:12px;color:var(--prism-text-muted);margin-top:4px;">Container corner radius</div>
              </div>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="typography-family" class="doc-h3">Typography</h3>
            <p class="doc-section-subtitle">All inline alert text uses <strong>Zoho Puvi</strong> with semantic weight and size pairings.</p>
            <table class="size-table">
              <thead><tr><th>Element</th><th>Token</th><th>Font Size</th><th>Line Height</th><th>Weight</th></tr></thead>
              <tbody>
                <tr><td>Title</td><td><code>Text/Default/SemiBold</code></td><td>14 px</td><td>20 px</td><td>Semibold (600)</td></tr>
                <tr><td>Description</td><td><code>Text/small/Regular</code></td><td>12 px</td><td>16 px</td><td>Regular (400)</td></tr>
                <tr><td>Action Link</td><td>Via TextLink component</td><td>12 px</td><td>&#8212;</td><td>Medium (500)</td></tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- ========== USAGE ========== -->
        <div class="tab-content" id="tab-usage" style="display:none;padding-top:32px;">
          <div class="doc-section">
            <h2 id="when-to-use" class="doc-section-title">When and Where to Use</h2>
            <p class="doc-section-subtitle">Inline alert messages communicate status or feedback directly within the page content flow.</p>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:24px;">
              <div style="padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;">
                <h3 style="font-size:15px;font-weight:600;color:var(--prism-text);margin-bottom:16px;display:flex;align-items:center;gap:8px;"><svg width="20" height="20" fill="none" stroke="#2563eb" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>When to use</h3>
                <ul class="doc-list" style="border:none;background:transparent;padding-left:20px;font-size:14.5px;">
                  <li style="border:none;background:transparent;margin-bottom:8px;">To communicate a status or feedback message directly within the page content flow.</li>
                  <li style="border:none;background:transparent;margin-bottom:8px;">Use <strong>Info</strong> for neutral guidance, tips, or informational notices.</li>
                  <li style="border:none;background:transparent;margin-bottom:8px;">Use <strong>Success</strong> to confirm a completed action within a page region.</li>
                  <li style="border:none;background:transparent;margin-bottom:8px;">Use <strong>Warning</strong> when the user should proceed with caution.</li>
                  <li style="border:none;background:transparent;margin-bottom:8px;">Use <strong>Error</strong> to report a validation failure or blocked action.</li>
                  <li style="border:none;background:transparent;margin-bottom:8px;">Use <strong>Subtle</strong> (default) for most in-page messages.</li>
                  <li style="border:none;background:transparent;">Use <strong>Intense</strong> when the message demands immediate visual priority.</li>
                </ul>
              </div>
              <div style="padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;">
                <h3 style="font-size:15px;font-weight:600;color:var(--prism-text);margin-bottom:16px;display:flex;align-items:center;gap:8px;"><svg width="20" height="20" fill="none" stroke="#e42527" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>When NOT to use</h3>
                <ul class="doc-list" style="border:none;background:transparent;padding-left:20px;font-size:14.5px;">
                  <li style="border:none;background:transparent;margin-bottom:8px;">Global/system-wide alerts &#8212; use a Toast Message or page-level banner.</li>
                  <li style="border:none;background:transparent;margin-bottom:8px;">Field-level validation messages &#8212; use the form field's built-in helper/error text.</li>
                  <li style="border:none;background:transparent;margin-bottom:8px;">Transient confirmations that auto-dismiss &#8212; use Toast Message.</li>
                  <li style="border:none;background:transparent;margin-bottom:8px;">Blocking modal errors &#8212; use a Dialog / Modal.</li>
                  <li style="border:none;background:transparent;">Progress or loading states &#8212; use Progress Bar or a loading indicator.</li>
                </ul>
              </div>
            </div>
          </div>
          <hr class="doc-divider"/>
          <div class="doc-section">
            <h2 id="alignment-placement" class="doc-section-title">Alignment &amp; Placement</h2>
            <p class="doc-section-subtitle">Consistent placement ensures inline alerts are predictable and scannable.</p>
            <ul class="doc-list">
              <li><strong>Below a form:</strong> Position the alert directly below the form field group, spanning the full width of the form container.</li>
              <li><strong>Inside a card:</strong> Place at the top of the card content area, above the primary content.</li>
              <li><strong>Panel top:</strong> Position at the top of a panel or section, below the header but above content.</li>
              <li><strong>Full width:</strong> The component stretches to 100% of its parent container width.</li>
            </ul>
          </div>
          <hr class="doc-divider"/>
          <div class="doc-section">
            <h2 id="detailed-guidelines" class="doc-section-title">Complete Do's and Don'ts</h2>
            <p class="doc-section-subtitle">Guidelines for effective inline alert message usage.</p>
            <div class="do-dont-grid">
              <div class="do-card"><span class="card-label">Do</span><ul>
                <li><strong>Use Subtle for most inline notifications:</strong> It fits naturally within page content.</li>
                <li><strong>Match type to semantic meaning:</strong> Error for failures, Success for completions.</li>
                <li><strong>Keep the title concise:</strong> 3&#8211;6 words like "Action Required" or "Upload Failed".</li>
                <li><strong>Use description for context:</strong> Explain what happened and next steps.</li>
                <li><strong>Use Show Action:</strong> Link directly to the resolution ("Retry", "View error details").</li>
                <li><strong>Use Show Dismiss:</strong> For temporary, non-critical messages the user can safely ignore.</li>
                <li><strong>Use RTL=True:</strong> For right-to-left pages; set dir="rtl" on the container.</li>
                <li><strong>Stack multiple alerts:</strong> When multiple distinct issues need reporting.</li>
              </ul></div>
              <div class="dont-card"><span class="card-label">Don't</span><ul>
                <li><strong>Don't default to Intense:</strong> Reserve it for high-priority messages that need to stand out.</li>
                <li><strong>Don't mismatch semantics:</strong> Using Warning for errors or Info for success confuses screen readers.</li>
                <li><strong>Don't write full sentences as titles:</strong> Use description for longer explanatory text.</li>
                <li><strong>Don't show only a title:</strong> When the situation requires explanation, add a description.</li>
                <li><strong>Don't put unrelated actions:</strong> In the alert action slot.</li>
                <li><strong>Don't hide dismiss on non-critical:</strong> Allow users to close temporary messages.</li>
                <li><strong>Don't manually mirror layout:</strong> Use the RTL variant instead of CSS overrides.</li>
                <li><strong>Don't repeat the same message:</strong> Consolidate consecutive banners of the same type.</li>
              </ul></div>
            </div>
          </div>
          <hr class="doc-divider"/>
          <div class="doc-section">
            <h2 id="related" class="doc-section-title">Related</h2>
            <p class="doc-section-subtitle">Components that complement or can be used alongside the Inline Message.</p>
            <div class="related-grid">
              <a href="Alert-banner.html" class="related-chip"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg> Alert Banner</a>
              <a href="Snackbar.html" class="related-chip"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="14" rx="3"/></svg> Snackbar</a>
              <a href="Dialog.html" class="related-chip"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/></svg> Dialog</a>
              <a href="Progress-bar.html" class="related-chip"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 12h16M4 12a8 8 0 018-8M4 12a8 8 0 008 8"/></svg> Progress Bar</a>
              <a href="Divider.html" class="related-chip"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 12h16"/></svg> Divider</a>
            </div>
          </div>
          <hr class="doc-divider"/>
          <div class="doc-section">
            <h2 id="references" class="doc-section-title">References</h2>
            <p class="doc-section-subtitle">Design tokens and resources for implementing the Inline Message component.</p>
            <ul class="doc-list">
              <li><strong>Figma Node:</strong> <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">17096:1024469</code> &#8212; Component Set: Inline Alert Message</li>
              <li><strong>Total Variants:</strong> 2 Styles &times; 5 Types &times; 2 Directions = <strong>20 variants</strong></li>
              <li><strong>Typography:</strong> Zoho Puvi Semibold (600) for Title, Regular (400) for Description, Medium (500) for Action</li>
              <li><strong>Corner Radius:</strong> <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">8px</code></li>
            </ul>
          </div>
        </div>

        <!-- ========== CODE ========== -->
        <div class="tab-content" id="tab-code" style="display:none;padding-top:32px;">
          <h2 id="live-demo-code" class="doc-section-title">Live demo (Code)</h2>
          <p class="doc-section-subtitle">Configure the Inline Message component and view generated HTML.</p>
          <div class="code-playground">
            <div class="cp-toolbar">
              <div class="cp-control-group"><label class="cp-label">Style</label><select class="cp-select" id="pg-style"><option value="subtle">Subtle</option><option value="intense">Intense</option></select></div>
              <div class="cp-control-group"><label class="cp-label">Type</label><select class="cp-select" id="pg-type"><option value="info">Info</option><option value="success">Success</option><option value="warning">Warning</option><option value="error">Error</option><option value="neutral">Neutral</option></select></div>
              <div class="cp-control-group"><label class="cp-label">Title</label><input class="cp-select" id="pg-title" type="text" value="Alert Title" style="width:100%;"></div>
              <div class="cp-control-group"><label class="cp-label">Description</label><input class="cp-select" id="pg-desc" type="text" value="This is a description of the alert message." style="width:100%;"></div>
              <div class="cp-control-group"><label class="cp-label">Show Action</label><select class="cp-select" id="pg-action"><option value="true">Yes</option><option value="false">No</option></select></div>
              <div class="cp-control-group"><label class="cp-label">Show Dismiss</label><select class="cp-select" id="pg-dismiss"><option value="true">Yes</option><option value="false">No</option></select></div>
            </div>
            <div class="cp-preview" id="pg-preview-area">
              <div id="pg-alert-el" class="iam iam-subtle iam-info" role="status" style="max-width:440px;width:100%;">
                <svg class="iam-icon" id="pg-icon-el" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/></svg>
                <div class="iam-content">
                  <div class="iam-title" id="pg-title-el">Alert Title</div>
                  <div class="iam-desc" id="pg-desc-el">This is a description of the alert message.</div>
                  <a class="iam-action" id="pg-action-el" href="javascript:void(0)">Action</a>
                </div>
                <button class="iam-dismiss" id="pg-dismiss-el" aria-label="Dismiss alert"><svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg></button>
              </div>
            </div>
            <div class="cp-code-header">
              <div style="font-size:13.5px;font-weight:600;color:var(--prism-text);">HTML</div>
              <button class="cp-action-btn" id="pg-copy-btn"><svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2"/></svg> Copy code</button>
            </div>
            <div class="cp-code-area" id="pg-code-output"></div>
          </div>
          <script>
          (function(){
            var icons = {
              info: '<svg class="iam-icon" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/></svg>',
              success: '<svg class="iam-icon" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>',
              warning: '<svg class="iam-icon" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>',
              error: '<svg class="iam-icon" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>',
              neutral: '<svg class="iam-icon" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/></svg>'
            };
            var els = {style:document.getElementById('pg-style'),type:document.getElementById('pg-type'),title:document.getElementById('pg-title'),desc:document.getElementById('pg-desc'),action:document.getElementById('pg-action'),dismiss:document.getElementById('pg-dismiss')};
            var alertEl = document.getElementById('pg-alert-el');
            var titleEl = document.getElementById('pg-title-el');
            var descEl = document.getElementById('pg-desc-el');
            var actionEl = document.getElementById('pg-action-el');
            var dismissEl = document.getElementById('pg-dismiss-el');
            var codeOut = document.getElementById('pg-code-output');
            var copyBtn = document.getElementById('pg-copy-btn');
            function esc(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
            function update(){
              var s=els.style.value, t=els.type.value, ti=els.title.value, de=els.desc.value, showAct=els.action.value==='true', showDis=els.dismiss.value==='true';
              var role = (t==='error'||t==='warning') ? 'alert' : 'status';
              alertEl.className='iam iam-'+s+' iam-'+t;
              alertEl.setAttribute('role', role);
              alertEl.style.maxWidth='440px';
              alertEl.style.width='100%';
              var oldIcon = alertEl.querySelector('.iam-icon');
              if(oldIcon) alertEl.removeChild(oldIcon);
              var iconWrap = document.createElement('div');
              iconWrap.innerHTML = icons[t];
              var newIcon = iconWrap.firstChild;
              alertEl.insertBefore(newIcon, alertEl.firstChild);
              titleEl.textContent=ti;
              descEl.textContent=de;
              actionEl.style.display=showAct?'':'none';
              dismissEl.style.display=showDis?'flex':'none';
              var code='<div class="iam iam-'+s+' iam-'+t+'" role="'+role+'">\n';
              code+='  <!-- Status Icon -->\n';
              code+='  <svg class="iam-icon" aria-hidden="true">...</svg>\n';
              code+='  <div class="iam-content">\n';
              code+='    <div class="iam-title">'+ti+'</div>\n';
              code+='    <div class="iam-desc">'+de+'</div>\n';
              if(showAct) code+='    <a class="iam-action" href="#">Action</a>\n';
              code+='  </div>\n';
              if(showDis) code+='  <button class="iam-dismiss" aria-label="Dismiss alert">\n    <svg>...</svg>\n  </button>\n';
              code+='</div>';
              codeOut.innerHTML=esc(code).replace(/class=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">class</span>=<span style="color:#34d399;">"$1"</span>').replace(/role=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">role</span>=<span style="color:#34d399;">"$1"</span>').replace(/aria-hidden=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">aria-hidden</span>=<span style="color:#34d399;">"$1"</span>').replace(/aria-label=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">aria-label</span>=<span style="color:#34d399;">"$1"</span>').replace(/href=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">href</span>=<span style="color:#34d399;">"$1"</span>');
            }
            Object.values(els).forEach(function(e){e.addEventListener(e.tagName==='INPUT'?'input':'change',update);});
            copyBtn.addEventListener('click',function(){
              var r=document.createElement('div');r.innerHTML=codeOut.innerHTML;
              navigator.clipboard.writeText(r.innerText).then(function(){
                var o=copyBtn.innerHTML;copyBtn.innerHTML='<svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Copied!';setTimeout(function(){copyBtn.innerHTML=o;},2000);
              });
            });
            update();
          })();
          </script>

          <hr class="doc-divider"/>
          <div class="doc-section">
            <h3 id="component-api-properties" class="doc-h3">Component API &amp; Properties</h3>
            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Variant Props</h4>
            <table class="size-table" style="margin-bottom:32px;">
              <thead><tr><th>Property</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
              <tbody>
                <tr><td><code>style</code></td><td>'Subtle' | 'Intense'</td><td>'Subtle'</td><td>Visual weight &#8212; tinted background vs solid fill.</td></tr>
                <tr><td><code>type</code></td><td>'Info' | 'Success' | 'Warning' | 'Error' | 'Neutral'</td><td>'Info'</td><td>Semantic alert type controlling background, icon, and title colour.</td></tr>
                <tr><td><code>rtl</code></td><td>boolean</td><td>false</td><td>Switches to right-to-left layout.</td></tr>
              </tbody>
            </table>
            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Content Props</h4>
            <table class="size-table" style="margin-bottom:32px;">
              <thead><tr><th>Property</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
              <tbody>
                <tr><td><code>title</code></td><td>string</td><td>"Alert Title"</td><td>Primary alert heading text.</td></tr>
                <tr><td><code>showTitle</code></td><td>boolean</td><td>true</td><td>Shows or hides the title row.</td></tr>
                <tr><td><code>description</code></td><td>string</td><td>"This is a description..."</td><td>Supporting body text below the title.</td></tr>
                <tr><td><code>showDescription</code></td><td>boolean</td><td>true</td><td>Shows or hides the description text.</td></tr>
              </tbody>
            </table>
            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Icon Props</h4>
            <table class="size-table" style="margin-bottom:32px;">
              <thead><tr><th>Property</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
              <tbody>
                <tr><td><code>showIcon</code></td><td>boolean</td><td>true</td><td>Shows or hides the left status icon.</td></tr>
                <tr><td><code>statusIcon</code></td><td>ReactNode</td><td>Semantic icon per type</td><td>Instance-swap slot for the 20&#215;20 px status icon.</td></tr>
                <tr><td><code>showDismiss</code></td><td>boolean</td><td>true</td><td>Shows or hides the dismiss button.</td></tr>
                <tr><td><code>dismissIcon</code></td><td>ReactNode</td><td>Close icon</td><td>Instance-swap slot for the 16&#215;16 px dismiss icon.</td></tr>
                <tr><td><code>onDismiss</code></td><td>() =&gt; void</td><td>&#8212;</td><td>Callback fired when the dismiss icon is clicked.</td></tr>
              </tbody>
            </table>
            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Action Props</h4>
            <table class="size-table">
              <thead><tr><th>Property</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
              <tbody>
                <tr><td><code>showAction</code></td><td>boolean</td><td>true</td><td>Shows or hides the action link.</td></tr>
                <tr><td><code>action</code></td><td>ReactNode</td><td>&lt;TextLink&gt;</td><td>Instance-swap slot &#8212; replace with any link or button component.</td></tr>
              </tbody>
            </table>
          </div>
          <hr class="doc-divider"/>
          <div class="doc-section">
            <h3 id="implementation-idea-ember-hook-form" class="doc-h3">Implementation Idea: Ember</h3>
            <div class="cp-code-area" style="border-radius:12px;margin-top:16px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;">
                <span style="color:#94a3b8;">&lt;!-- inline-alert.hbs --&gt;</span><br>
                <span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">UemsInlineAlert</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">@style</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"subtle"</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">@type</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"error"</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">@title</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"Upload failed"</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">@description</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"The file could not be uploaded."</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">@showAction</span><span style="color:#56B6C2;">=</span><span style="color:#C678DD;">{{</span><span style="color:#E5C07B;">true</span><span style="color:#C678DD;">}}</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">@showDismiss</span><span style="color:#56B6C2;">=</span><span style="color:#C678DD;">{{</span><span style="color:#E5C07B;">false</span><span style="color:#C678DD;">}}</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">@onAction</span><span style="color:#56B6C2;">=</span><span style="color:#C678DD;">{{</span><span style="color:#E5C07B;">this.retryUpload</span><span style="color:#C678DD;">}}</span><br>
                <span style="color:#ABB2BF;">/&gt;</span>
              </div>
            </div>
          </div>
          <hr class="doc-divider"/>
          <div class="doc-section">
            <h3 id="rtl-support" class="doc-h3">RTL Support</h3>
            <ul class="doc-list">
              <li>In RTL mode, the child order is <strong>reversed</strong>: Dismiss Icon &#8594; Content &#8594; Status Icon (right-to-left reading order).</li>
              <li>Title and description text alignment changes to <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">text-align: right</code>.</li>
              <li>Set <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">dir="rtl"</code> on the component or its page container in code.</li>
              <li>Arabic placeholder text is used in the Figma component for RTL variants.</li>
            </ul>
            <div style="margin-top:24px;">
              <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">RTL Preview</h4>
              <div style="max-width:440px;">
                <div class="iam iam-subtle iam-info" dir="rtl" role="status">
                  <button class="iam-dismiss" aria-label="Dismiss alert"><svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg></button>
                  <div class="iam-content" style="text-align:right;"><div class="iam-title">&#1593;&#1606;&#1608;&#1575;&#1606; &#1575;&#1604;&#1578;&#1606;&#1576;&#1610;&#1607;</div><div class="iam-desc">&#1607;&#1584;&#1575; &#1608;&#1589;&#1601; &#1604;&#1585;&#1587;&#1575;&#1604;&#1577; &#1575;&#1604;&#1578;&#1606;&#1576;&#1610;&#1607; &#1610;&#1608;&#1601;&#1585; &#1587;&#1610;&#1575;&#1602;&#1611;&#1575; &#1573;&#1590;&#1575;&#1601;&#1610;&#1611;&#1575; &#1604;&#1604;&#1605;&#1587;&#1578;&#1582;&#1583;&#1605;.</div><a class="iam-action" href="javascript:void(0)">&#1573;&#1580;&#1585;&#1575;&#1569;</a></div>
                  <svg class="iam-icon" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/></svg>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- ========== ACCESSIBILITY ========== -->
        <div class="tab-content" id="tab-accessibility" style="display:none;padding-top:32px;">
          <h2 id="accessibility" class="doc-section-title">Accessibility</h2>
          <p class="doc-section-subtitle">Guidelines for ensuring inline alert messages are accessible across assistive technologies.</p>
          <div class="doc-section">
            <h3 id="keyboard-interaction" class="doc-h3">Keyboard Interaction</h3>
            <table class="size-table">
              <thead><tr><th>Key</th><th>Action</th></tr></thead>
              <tbody>
                <tr><td><code>Tab</code></td><td>Moves focus to the dismiss button (if visible) and action link (if visible).</td></tr>
                <tr><td><code>Enter</code> / <code>Space</code></td><td>Activates the focused dismiss button or action link.</td></tr>
                <tr><td><code>Shift+Tab</code></td><td>Moves focus backwards through interactive elements within the alert.</td></tr>
              </tbody>
            </table>
            <div style="margin-top:16px;padding:16px 20px;background:rgba(37,99,235,0.05);border:1px solid rgba(37,99,235,0.15);border-radius:12px;">
              <p style="font-size:14px;color:var(--prism-text);line-height:1.6;margin:0;">If Show Dismiss is true, the dismiss button must be reachable via Tab and activatable with Enter / Space. The action link must also be keyboard-accessible.</p>
            </div>
          </div>
          <hr class="doc-divider"/>
          <div class="doc-section">
            <h3 id="aria-attributes-screen-reader-guidance" class="doc-h3">ARIA Attributes &amp; Screen Reader Guidance</h3>
            <ul class="doc-list">
              <li><strong>ARIA role:</strong> Render as <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">role="alert"</code> for Error/Warning (live region announced immediately) or <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">role="status"</code> for Info/Success/Neutral (polite announcement).</li>
              <li><strong>Live region:</strong> <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-live="assertive"</code> for Error and Warning; <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-live="polite"</code> for Info, Success, and Neutral.</li>
              <li><strong>Status icon:</strong> The status icon is decorative &#8212; mark it <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-hidden="true"</code>. Semantic meaning is conveyed by the title and role.</li>
              <li><strong>Dismiss button:</strong> Must have a descriptive accessible name: <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-label="Dismiss alert"</code> or equivalent.</li>
              <li><strong>Action link:</strong> The action label "Action" alone may be ambiguous &#8212; use <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-label</code> with context if needed.</li>
              <li><strong>Dynamic injection:</strong> When an alert appears dynamically (e.g., after form submission), inject it into a live region container already in the DOM so screen readers detect the change.</li>
            </ul>
          </div>
          <hr class="doc-divider"/>
          <div class="doc-section">
            <h3 id="focus-state-design" class="doc-h3">Focus State Design</h3>
            <ul class="doc-list">
              <li>The dismiss button and action link receive visible focus rings when navigated via keyboard.</li>
              <li>Focus order within the alert: Action Link &#8594; Dismiss Button (natural DOM order).</li>
              <li>After dismissal, focus should move to the next logical element in the page flow.</li>
            </ul>
          </div>
          <hr class="doc-divider"/>
          <div class="doc-section">
            <h3 id="color-contrast-minimums" class="doc-h3">Color Contrast Minimums<span class="h3-badge" style="background:rgba(34,197,94,0.15);color:#16a34a;">WCAG AA Pass</span></h3>
            <p class="doc-section-subtitle">All style/type combinations meet WCAG 2.1 AA contrast requirements.</p>
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px;margin-top:24px;">
              <div style="background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;overflow:hidden;">
                <div style="background:#2C66DD;padding:28px 24px;text-align:center;color:#fff;"><div style="font-size:18px;font-weight:600;">Intense / Info</div></div>
                <div style="padding:16px 24px;display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--prism-border);"><div><div style="font-size:13px;color:var(--prism-text-muted);font-weight:600;">WHITE ON BLUE</div><div style="font-size:15px;color:var(--prism-text);font-family:monospace;margin-top:4px;">#FFF on #2C66DD</div></div><div style="text-align:right;"><div style="display:inline-flex;align-items:center;gap:6px;background:rgba(34,197,94,0.1);color:#16a34a;padding:4px 10px;border-radius:100px;font-size:12px;font-weight:700;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><polyline points="20 6 9 17 4 12"></polyline></svg> 5.2:1</div><div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;font-weight:600;">WCAG AA Pass</div></div></div>
              </div>
              <div style="background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;overflow:hidden;">
                <div style="background:#F9B21D;padding:28px 24px;text-align:center;color:#000;"><div style="font-size:18px;font-weight:600;">Intense / Warning</div></div>
