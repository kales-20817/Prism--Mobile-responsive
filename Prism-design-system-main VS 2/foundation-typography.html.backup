<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="UTF-8">
  <link rel="icon" type="image/png" href="assets/prism-logo.png">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Typography — Foundation — UEMS Design System</title>
<style>
  @font-face { font-family: 'Zoho Puvi'; src: url('https://fonts.zohowebstatic.com/zohopuvi/3.5/zoho_puvi_thin.woff2') format('woff2'); font-weight: 100; font-style: normal; font-display: swap; }
  @font-face { font-family: 'Zoho Puvi'; src: url('https://fonts.zohowebstatic.com/zohopuvi/3.5/zoho_puvi_extralight.woff2') format('woff2'); font-weight: 200; font-style: normal; font-display: swap; }
  @font-face { font-family: 'Zoho Puvi'; src: url('https://fonts.zohowebstatic.com/zohopuvi/3.5/zoho_puvi_light.woff2') format('woff2'); font-weight: 300; font-style: normal; font-display: swap; }
  @font-face { font-family: 'Zoho Puvi'; src: url('https://fonts.zohowebstatic.com/zohopuvi/3.5/zoho_puvi_regular.woff2') format('woff2'); font-weight: 400; font-style: normal; font-display: swap; }
  @font-face { font-family: 'Zoho Puvi'; src: url('https://fonts.zohowebstatic.com/zohopuvi/3.5/zoho_puvi_medium.woff2') format('woff2'); font-weight: 500; font-style: normal; font-display: swap; }
  @font-face { font-family: 'Zoho Puvi'; src: url('https://fonts.zohowebstatic.com/zohopuvi/3.5/zoho_puvi_semibold.woff2') format('woff2'); font-weight: 600; font-style: normal; font-display: swap; }
  @font-face { font-family: 'Zoho Puvi'; src: url('https://fonts.zohowebstatic.com/zohopuvi/3.5/zoho_puvi_bold.woff2') format('woff2'); font-weight: 700; font-style: normal; font-display: swap; }
  @font-face { font-family: 'Zoho Puvi'; src: url('https://fonts.zohowebstatic.com/zohopuvi/3.5/zoho_puvi_extrabold.woff2') format('woff2'); font-weight: 800; font-style: normal; font-display: swap; }
  @font-face { font-family: 'Zoho Puvi'; src: url('https://fonts.zohowebstatic.com/zohopuvi/3.5/zoho_puvi_black.woff2') format('woff2'); font-weight: 900; font-style: normal; font-display: swap; }
  @font-face { font-family: 'Zoho Puvi'; src: url('https://fonts.zohowebstatic.com/zohopuvi/3.5/zoho_puvi_extrablack.woff2') format('woff2'); font-weight: 950; font-style: normal; font-display: swap; }
  @font-face { font-family: 'Zoho Puvi'; src: url('https://fonts.zohowebstatic.com/zohopuvi/3.5/zoho_puvi_regular_italic.woff2') format('woff2'); font-weight: 400; font-style: italic; font-display: swap; }
  @font-face { font-family: 'Zoho Puvi'; src: url('https://fonts.zohowebstatic.com/zohopuvi/3.5/zoho_puvi_bold_italic.woff2') format('woff2'); font-weight: 700; font-style: italic; font-display: swap; }
  @font-face { font-family: 'Zoho Puvi'; src: url('https://fonts.zohowebstatic.com/zohopuvi/3.5/zoho_puvi_semibold_italic.woff2') format('woff2'); font-weight: 600; font-style: italic; font-display: swap; }

  @import url('https://fonts.googleapis.com/css2?family=Lato:wght@300;400;700;900&display=swap');
  @import url('https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700;900&display=swap');
  @import url('https://fonts.googleapis.com/css2?family=Roboto+Mono:wght@400;500;700&display=swap');

  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --prism-black: #0a0a0c; --prism-violet: #2563eb; --prism-violet-light: #60a5fa;
    --prism-fuchsia: #0ea5e9; --prism-cyan: #06b6d4;
    --prism-surface: rgba(255, 255, 255, 0.05); --prism-surface-hover: rgba(255, 255, 255, 0.09);
    --prism-border: rgba(255, 255, 255, 0.07); --prism-text: rgba(255, 255, 255, 0.92);
    --prism-text-muted: rgba(255, 255, 255, 0.48); --nav-bg: rgba(10,10,12,0.75);
    --nav-link-color: var(--prism-text-muted);
    --logo-gradient: linear-gradient(135deg, #0058ff 40%, #3c50ff 30%, #0fd095 100%);
    --logo-filter: drop-shadow(0 2px 10px rgba(37, 99, 235, 0.3));
  }
  [data-theme="light"] {
    --prism-black: #ffffff; --prism-violet: #2563eb; --prism-violet-light: #1d4ed8;
    --prism-fuchsia: #0284c7; --prism-cyan: #0891b2;
    --prism-surface: rgba(37, 99, 235, 0.028); --prism-surface-hover: rgba(37, 99, 235, 0.055);
    --prism-border: rgba(37, 99, 235, 0.10); --prism-text: #1a1a2e; --prism-text-muted: #64748b;
    --nav-bg: rgba(255, 255, 255, 0.82);
    --logo-gradient: linear-gradient(135deg, #0058ff 40%, #3c50ff 30%, #0fd095 100%);
    --logo-filter: drop-shadow(0 2px 12px rgba(37, 99, 235, 0.25)); --nav-link-color: #475569;
  }
  html { scroll-behavior: smooth; scroll-padding-top: 100px; }
  body { font-family: 'Zoho Puvi', sans-serif; background: var(--prism-black); color: var(--prism-text); transition: background 0.5s cubic-bezier(0.4, 0, 0.2, 1), color 0.4s ease; }
  [data-theme="light"] body { background: linear-gradient(180deg, #ffffff 0%, #f8faff 100%); }
  [data-theme="light"] .nav { background: transparent; border-bottom: 1px solid transparent; box-shadow: none; }
  [data-theme="light"] .nav.scrolled { background: rgba(255, 255, 255, 0.78); border-bottom: 1px solid rgba(37, 99, 235, 0.06); box-shadow: 0 1px 3px rgba(37, 99, 235, 0.04), 0 4px 24px rgba(37, 99, 235, 0.03); }
  .nav.scrolled {
    background: var(--nav-bg);
    backdrop-filter: blur(24px) saturate(1.4);
    -webkit-backdrop-filter: blur(24px) saturate(1.4);
    border-bottom: 1px solid var(--prism-border);
  }
  [data-theme="light"] .sidebar { border-right: 1px solid rgba(37, 99, 235, 0.06); background: linear-gradient(180deg, rgba(248, 250, 255, 0.6) 0%, rgba(255, 255, 255, 0.4) 100%); }
  [data-theme="light"] .foundation-link { color: #64748b; }
  [data-theme="light"] .foundation-link:hover { color: #1e293b; background: rgba(37, 99, 235, 0.05); }
  [data-theme="light"] .foundation-link.active { color: #2563eb; background: rgba(37, 99, 235, 0.06); box-shadow: 0 1px 4px rgba(37, 99, 235, 0.08); }
  [data-theme="light"] .sidebar-search { background: rgba(255, 255, 255, 0.8); border: 1px solid rgba(37, 99, 235, 0.10); box-shadow: 0 1px 4px rgba(37, 99, 235, 0.04); }
  [data-theme="light"] .sidebar-search:focus-within { background: #fff; border-color: #2563eb; box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.10), 0 2px 8px rgba(37, 99, 235, 0.06); }
  [data-theme="light"] .icon-btn { color: #94a3b8; }
  [data-theme="light"] .icon-btn:hover { color: #1e293b; background: rgba(37, 99, 235, 0.06); }

  /* Nav dropdown */
  .nav-dropdown { position: relative; }
  .nav-dropdown > a { display: flex; align-items: center; gap: 4px; }
  .nav-dropdown > a .nav-chevron { width: 12px; height: 12px; transition: transform 0.2s ease; }
  .nav-dropdown:hover > a .nav-chevron { transform: rotate(180deg); }
  .nav-dropdown-menu { position: absolute; top: calc(100% + 8px); right: 0; min-width: 200px; background: var(--prism-black); border: 1px solid var(--prism-border); border-radius: 12px; padding: 6px; opacity: 0; visibility: hidden; transform: translateY(-8px); transition: all 0.25s cubic-bezier(0.4,0,0.2,1); z-index: 200; backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); box-shadow: 0 8px 32px rgba(0,0,0,0.12); }
  .nav-dropdown:hover .nav-dropdown-menu { opacity: 1; visibility: visible; transform: translateY(0); }
  .nav-dropdown-menu a { display: flex; align-items: center; gap: 10px; padding: 10px 14px; border-radius: 8px; font-size: 13.5px; font-weight: 500; color: var(--prism-text-muted); text-decoration: none; transition: all 0.2s ease; background: transparent; }
  .nav-dropdown-menu a:hover { color: var(--prism-text); background: var(--prism-surface-hover); }
  .nav-dropdown-menu a svg { width: 18px; height: 18px; flex-shrink: 0; color: var(--prism-text-muted); opacity: 0.7; }
  .nav-dropdown-menu a:hover svg { color: var(--prism-violet); opacity: 1; }
  [data-theme="light"] .nav-dropdown-menu { background: #fff; border: 1px solid rgba(37,99,235,0.10); box-shadow: 0 8px 32px rgba(37,99,235,0.10), 0 2px 8px rgba(37,99,235,0.06); }
  [data-theme="light"] .nav-dropdown-menu a { color: #64748b; }
  [data-theme="light"] .nav-dropdown-menu a:hover { color: #1e293b; background: rgba(37,99,235,0.05); }
  [data-theme="light"] .nav-dropdown-menu a:hover svg { color: #2563eb; }
  [data-theme="light"] .nav-links a { color: #64748b; }
  [data-theme="light"] .nav-links a:hover { color: #1e293b; background: rgba(37, 99, 235, 0.05); }
  [data-theme="light"] .nav-links a.active { color: #2563eb; background: rgba(37, 99, 235, 0.06); }
  [data-theme="light"] .feedback-banner { background: linear-gradient(135deg, rgba(37, 99, 235, 0.05) 0%, rgba(6, 182, 212, 0.05) 100%); border: 1px solid rgba(37, 99, 235, 0.12); box-shadow: 0 2px 12px rgba(37, 99, 235, 0.06); }
  [data-theme="light"] .feedback-btn { background: #fff; border: 1px solid rgba(37, 99, 235, 0.12); box-shadow: 0 1px 3px rgba(37, 99, 235, 0.04); }
  [data-theme="light"] .feedback-btn.primary { background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%); border-color: transparent; box-shadow: 0 2px 8px rgba(37, 99, 235, 0.25); }
  [data-theme="light"] .doc-list li::before { color: #2563eb; }
  [data-theme="light"] .do-card { background: rgba(37, 99, 235, 0.03); border-color: rgba(16, 185, 129, 0.2); }
  [data-theme="light"] .dont-card { background: rgba(37, 99, 235, 0.03); border-color: rgba(239, 68, 68, 0.2); }
  [data-theme="light"] .toc-sidebar { background: transparent; }

  .nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; padding: 0 32px; height: 72px; display: flex; align-items: center; justify-content: space-between; background: transparent; border-bottom: 1px solid transparent; backdrop-filter: none; -webkit-backdrop-filter: none; transition: background 0.3s ease, backdrop-filter 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease; }
  .nav-logo { display: inline-flex; flex-direction: row; align-items: center; gap: 10px; text-decoration: none; line-height: 1; }
  .nav-logo-img { width: 40px; height: 40px; flex-shrink: 0; display: block; }
  .nav-logo-text { display: inline-flex; flex-direction: column; align-items: flex-start; gap: 0; }
   .nav-logo-mark { font-size: 26px; font-weight: 900; letter-spacing: 0.02em; background: var(--logo-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; padding-right: 0.1em; padding-bottom: 0.05em; line-height: 1; }
  .nav-logo-sub { font-size: 10px; font-weight: 600; color: var(--prism-text-muted); letter-spacing: 0.08em; text-transform: none; margin-top: 2px; }
  .nav-logo-sub .caps { text-transform: uppercase; }
  .nav-links { display: flex; align-items: center; gap: 6px; }
  .nav-links a { color: var(--nav-link-color, var(--prism-text-muted)); text-decoration: none; font-size: 14px; font-weight: 600; padding: 8px 16px; border-radius: 999px; transition: all 0.3s ease; border: none; }
  .nav-links a:hover { color: var(--prism-text); background: var(--prism-surface-hover); }
  .nav-links a.active { color: var(--prism-violet); background: rgba(37, 99, 235, 0.08); border: none; }
  .icon-btn { background: transparent; border: none; cursor: pointer; color: var(--prism-text-muted); padding: 8px; border-radius: 50%; display: flex; align-items: center; justify-content: center; transition: all 0.2s ease; margin-left: 4px; }
  .icon-btn:hover { color: var(--prism-text); background: var(--prism-surface-hover); }

  /* Nav dropdown */
  .nav-dropdown { position: relative; }
  .nav-dropdown > a { display: flex; align-items: center; gap: 4px; }
  .nav-dropdown > a .nav-chevron { width: 12px; height: 12px; transition: transform 0.2s ease; }
  .nav-dropdown:hover > a .nav-chevron { transform: rotate(180deg); }
  .nav-dropdown-menu { position: absolute; top: calc(100% + 8px); right: 0; min-width: 200px; background: var(--prism-black); border: 1px solid var(--prism-border); border-radius: 12px; padding: 6px; opacity: 0; visibility: hidden; transform: translateY(-8px); transition: all 0.25s cubic-bezier(0.4,0,0.2,1); z-index: 200; backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); box-shadow: 0 8px 32px rgba(0,0,0,0.12); }
  .nav-dropdown:hover .nav-dropdown-menu { opacity: 1; visibility: visible; transform: translateY(0); }
  .nav-dropdown-menu a { display: flex; align-items: center; gap: 10px; padding: 10px 14px; border-radius: 8px; font-size: 13.5px; font-weight: 500; color: var(--prism-text-muted); text-decoration: none; transition: all 0.2s ease; background: transparent; }
  .nav-dropdown-menu a:hover { color: var(--prism-text); background: var(--prism-surface-hover); }
  .nav-dropdown-menu a svg { width: 18px; height: 18px; flex-shrink: 0; color: var(--prism-text-muted); opacity: 0.7; }
  .nav-dropdown-menu a:hover svg { color: var(--prism-violet); opacity: 1; }
  [data-theme="light"] .nav-dropdown-menu { background: #fff; border: 1px solid rgba(37,99,235,0.10); box-shadow: 0 8px 32px rgba(37,99,235,0.10), 0 2px 8px rgba(37,99,235,0.06); }
  [data-theme="light"] .nav-dropdown-menu a { color: #64748b; }
  [data-theme="light"] .nav-dropdown-menu a:hover { color: #1e293b; background: rgba(37,99,235,0.05); }
  [data-theme="light"] .nav-dropdown-menu a:hover svg { color: #2563eb; }

  .components-layout { display: grid; grid-template-columns: 260px 1fr; width: 100%; padding-top: 72px; min-height: 100vh; }
  .sidebar { grid-column: 1; grid-row: 1; width: 260px; border-right: 1px solid var(--prism-border); padding: 32px 24px 64px; position: sticky; top: 72px; height: calc(100vh - 72px); overflow-y: auto; }
  .sidebar::-webkit-scrollbar { width: 4px; }
  .sidebar::-webkit-scrollbar-thumb { background: var(--prism-border); border-radius: 4px; }
  .sidebar-heading { font-size: 11px; font-weight: 700; color: var(--prism-text-muted); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 16px; padding-left: 12px; }
  .sidebar, .toc-sidebar { background: transparent; backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px); }
  .sidebar-search { display: flex; align-items: center; background: var(--prism-surface); border: 1px solid var(--prism-border); border-radius: 999px; padding: 8px 16px; margin-bottom: 24px; transition: all 0.2s ease; }
  .sidebar-search:focus-within { border-color: var(--prism-violet); background: transparent; box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.15); }
  .sidebar-search svg { color: var(--prism-text-muted); }
  .sidebar-search input { background: transparent; border: none; outline: none; color: var(--prism-text); font-family: inherit; font-size: 14px; width: 100%; margin-left: 10px; }
  .sidebar-search input::placeholder { color: var(--prism-text-muted); }
  .search-shortcut { font-size: 11px; font-weight: 600; color: var(--prism-text-muted); background: var(--prism-surface-hover); padding: 2px 6px; border-radius: 4px; border: 1px solid var(--prism-border); }

  .main-panel { grid-column: 2; grid-row: 1; padding: 48px 64px 0 64px; display: flex; flex-direction: column; }
  .page-header-area { width: 100%; max-width: none; }
  .page-title { font-size: 48px; font-weight: 800; letter-spacing: -0.03em; margin-bottom: 8px; background: var(--logo-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; display: inline-block; padding-right: 8px; padding-bottom: 4px; }
  .page-desc { color: var(--prism-text); font-size: 20px; font-weight: 400; line-height: 1.5; margin-bottom: 32px; margin-top: 8px; max-width: 900px; }
  .main-content-area { display: grid; grid-template-columns: 1fr 240px; gap: 0; flex: 1; align-items: start; }
  .main-content-inner { padding-bottom: 64px; min-width: 0; }

  .bg-glow { position: fixed; border-radius: 50%; width: 60vw; height: 60vh; filter: blur(140px); z-index: -1; pointer-events: none; opacity: 0.15; transition: opacity 0.6s ease, filter 0.6s ease; }
  .glow-1 { top: -20%; right: -10%; background: var(--prism-violet); }
  .glow-2 { bottom: -20%; left: -10%; background: var(--prism-cyan); }
  [data-theme="light"] .bg-glow { opacity: 0.09; filter: blur(180px); }

  .foundation-nav { list-style: none; display: flex; flex-direction: column; gap: 4px; padding: 0; margin: 0; }
  .foundation-link { display: flex; align-items: center; justify-content: space-between; padding: 10px 12px; font-size: 14px; font-weight: 500; color: var(--prism-text-muted); text-decoration: none; border-radius: 8px; transition: all 0.2s ease; }
  .foundation-link:hover { color: var(--prism-text); background: var(--prism-surface-hover); }
  .foundation-link.active { color: var(--prism-violet); background: rgba(37, 99, 235, 0.08); font-weight: 600; }

  .toc-sidebar { width: 240px; padding: 20px; position: sticky; top: 72px; height: calc(100vh - 72px); overflow-y: auto; align-self: start; }
  .toc-heading { font-size: 11px; font-weight: 700; color: var(--prism-text); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 16px; }
  .toc-nav { list-style: none; display: flex; flex-direction: column; gap: 10px; border-left: 1px solid var(--prism-border); padding-left: 16px; margin-left: 4px; line-height: 1.6; }
  .toc-link { display: block; font-size: 13px; font-weight: 400; color: var(--prism-text-muted); text-decoration: none; transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1); }
  .toc-link:hover { color: var(--prism-text); }
  .toc-link.active { color: var(--prism-violet); font-weight: 600; }
  .quick-actions-card { margin-top: 32px; padding-top: 32px; border-top: 1px solid var(--prism-border); display: flex; flex-direction: column; gap: 4px; }
  .quick-actions-title { font-size: 11px; font-weight: 700; color: var(--prism-text-muted); text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 8px; }
  .action-link { display: inline-flex; align-items: center; gap: 8px; font-size: 13.5px; font-weight: 600; color: var(--prism-text-muted); text-decoration: none; padding: 6px 0; transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1); }
  .action-link:hover { color: var(--prism-text); transform: translateX(2px); }
  .action-link:hover svg { opacity: 1; color: var(--prism-violet); }

  /* Doc content styles */
  .doc-section { margin-top: 48px; }
  .doc-section h2 { font-size: 28px; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 16px; scroll-margin-top: 100px; }
  .doc-section h3 { font-size: 20px; font-weight: 600; margin-top: 32px; margin-bottom: 12px; }
  .doc-section h4 { font-size: 16px; font-weight: 600; margin-top: 24px; margin-bottom: 8px; }
  .doc-section p { font-size: 15px; line-height: 1.7; color: var(--prism-text); margin-bottom: 16px; max-width: 720px; }
  .doc-section strong { font-weight: 600; }
  .doc-divider { border: none; border-top: 1px solid var(--prism-border); margin: 48px 0; }
  .doc-list { list-style: none; padding: 0; margin: 0 0 20px 0; }
  .doc-list li { position: relative; padding-left: 20px; font-size: 14.5px; line-height: 1.7; color: var(--prism-text); margin-bottom: 6px; }
  .doc-list li::before { content: "\2022"; position: absolute; left: 0; color: var(--prism-violet); font-weight: 700; }

  /* Token tables */
  .size-table { width: 100%; border-collapse: collapse; margin: 20px 0 32px; font-size: 14px; }
  .size-table th { text-align: left; padding: 12px 16px; font-weight: 600; font-size: 12px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--prism-text-muted); border-bottom: 2px solid var(--prism-border); }
  .size-table td { padding: 12px 16px; border-bottom: 1px solid var(--prism-border); vertical-align: middle; }
  .size-table td code { font-family: 'SF Mono', 'Fira Code', monospace; font-size: 13px; background: var(--prism-surface); padding: 3px 8px; border-radius: 6px; color: var(--prism-violet-light); border: 1px solid var(--prism-border); }
  .size-table tr:last-child td { border-bottom: none; }
  .size-table tbody tr:hover { background: var(--prism-surface); }

  /* Type preview */
  .type-preview { font-family: 'Zoho Puvi', sans-serif; color: var(--prism-text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 260px; display: inline-block; vertical-align: middle; }
  .mono-preview { font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace; color: var(--prism-text); }

  /* Typeface showcase */
  .typeface-card { padding: 32px; border-radius: 16px; background: var(--prism-surface); border: 1px solid var(--prism-border); margin: 20px 0 24px; }
  .typeface-card .typeface-name { font-size: 36px; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 8px; }
  .typeface-card .typeface-alphabet { font-size: 20px; font-weight: 400; color: var(--prism-text-muted); line-height: 1.6; margin-bottom: 16px; word-spacing: 4px; }
  .typeface-card .typeface-meta { font-size: 13px; color: var(--prism-text-muted); display: flex; gap: 24px; flex-wrap: wrap; }
  .typeface-card .typeface-meta span { display: inline-flex; align-items: center; gap: 6px; }
  .typeface-card .typeface-meta .meta-label { font-weight: 600; color: var(--prism-text); }
  .lato-card, .lato-card .typeface-name, .lato-card .typeface-alphabet { font-family: 'Lato', sans-serif; }
  .roboto-card, .roboto-card .typeface-name, .roboto-card .typeface-alphabet { font-family: 'Roboto', sans-serif; }
  .mono-card { font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace; }
  .mono-card .typeface-name { font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace; }
  .mono-card .typeface-alphabet { font-family: 'SF Mono', 'Fira Code', 'Courier New', monospace; }
  .roboto-mono-card, .roboto-mono-card .typeface-name, .roboto-mono-card .typeface-alphabet { font-family: 'Roboto Mono', monospace; }

  /* Font family mode indicator */
  .mode-indicator { display: inline-flex; align-items: center; gap: 6px; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; padding: 4px 12px; border-radius: 999px; margin-bottom: 12px; }
  .mode-primary { background: rgba(37, 99, 235, 0.1); color: var(--prism-violet); border: 1px solid rgba(37, 99, 235, 0.2); }
  .mode-alt { background: var(--prism-surface); color: var(--prism-text-muted); border: 1px solid var(--prism-border); }

  /* Weight showcase */
  .weight-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin: 20px 0 32px; }
  .weight-card { padding: 20px; border-radius: 12px; background: var(--prism-surface); border: 1px solid var(--prism-border); text-align: center; }
  .weight-card .weight-sample { font-size: 32px; margin-bottom: 8px; line-height: 1.2; }
  .weight-card .weight-name { font-size: 13px; font-weight: 600; color: var(--prism-text); margin-bottom: 2px; }
  .weight-card .weight-value { font-size: 12px; color: var(--prism-text-muted); }

  /* Do / Don't cards */
  .do-dont-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin: 20px 0 32px; }
  .do-card, .dont-card { padding: 24px; border-radius: 12px; border: 1px solid var(--prism-border); }
  .do-card { background: rgba(16, 185, 129, 0.04); border-color: rgba(16, 185, 129, 0.15); }
  .dont-card { background: rgba(239, 68, 68, 0.04); border-color: rgba(239, 68, 68, 0.15); }
  .do-card .card-label { font-size: 13px; font-weight: 700; color: #10b981; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 12px; }
  .dont-card .card-label { font-size: 13px; font-weight: 700; color: #ef4444; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 12px; }
  .do-card p, .dont-card p { font-size: 14px; line-height: 1.6; color: var(--prism-text); margin: 0 0 6px; }

  /* Pattern cards */
  .pattern-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin: 20px 0 32px; }
  .pattern-card { padding: 24px; border-radius: 12px; background: var(--prism-surface); border: 1px solid var(--prism-border); }
  .pattern-card .pattern-title { font-size: 15px; font-weight: 600; margin-bottom: 12px; color: var(--prism-text); }
  .pattern-card .pattern-row { display: flex; justify-content: space-between; align-items: center; padding: 6px 0; font-size: 13px; }
  .pattern-card .pattern-role { color: var(--prism-text-muted); }
  .pattern-card .pattern-spec { color: var(--prism-text); font-weight: 500; font-family: 'SF Mono', 'Fira Code', monospace; font-size: 12px; }

  /* Collection badge */
  .collection-badge { display: inline-flex; align-items: center; gap: 6px; font-size: 12px; font-weight: 600; color: var(--prism-text-muted); background: var(--prism-surface); padding: 4px 12px; border-radius: 999px; border: 1px solid var(--prism-border); margin-bottom: 16px; }
  .collection-badge svg { width: 14px; height: 14px; }

  .feedback-banner { margin-top: 72px; padding: 32px; border-radius: 16px; background: linear-gradient(135deg, rgba(37,99,235,0.06) 0%, rgba(6,182,212,0.06) 100%); border: 1px solid var(--prism-border); display: flex; align-items: center; justify-content: space-between; }
  .feedback-banner .fb-text { font-size: 16px; font-weight: 600; color: var(--prism-text); }
  .feedback-banner .fb-sub { font-size: 13.5px; color: var(--prism-text-muted); margin-top: 4px; }
  .feedback-btn { padding: 10px 28px; border-radius: 999px; font-family: inherit; font-size: 14px; font-weight: 600; cursor: pointer; transition: all 0.2s ease; border: 1px solid var(--prism-border); background: var(--prism-surface); color: var(--prism-text); }
  .feedback-btn.primary { background: var(--prism-violet); color: #fff; border-color: var(--prism-violet); }
  .feedback-btn.primary:hover { background: #1d4ed8; box-shadow: 0 4px 16px rgba(37, 99, 235, 0.3); transform: translateY(-1px); }

  /* ══ Mobile responsive (added globally) ══ */
  .nav-hamburger { display: none; background: transparent; border: none; color: var(--prism-text); padding: 8px; margin-right: 8px; cursor: pointer; border-radius: 8px; align-items: center; justify-content: center; }
  .nav-hamburger:hover { background: var(--prism-surface-hover); }
  .sidebar-backdrop { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 95; opacity: 0; transition: opacity 0.25s ease; }
  .sidebar-backdrop.open { display: block; opacity: 1; }
  .sidebar-mobile-nav { display: none; }

  @media (max-width: 900px) {
    .nav { padding: 0 16px; height: 64px; justify-content: flex-start; gap: 4px; }
    .nav-links { margin-left: auto; }
    .nav-hamburger { display: inline-flex; order: -1; margin-right: 4px; }
    .nav-logo-mark { font-size: 22px; }
    .nav-logo-sub { font-size: 9px; }
    .nav-links > a,
    .nav-links > .nav-dropdown,
    .nav-links > div[style] { display: none !important; }
    .nav-links { gap: 0; }

    .components-layout { display: block; padding-top: 64px; grid-template-columns: 1fr; }
    .sidebar { position: fixed; top: 64px; left: 0; width: 300px; max-width: 86vw; height: calc(100vh - 64px); max-height: none; padding: 20px 18px 32px; border-right: 1px solid var(--prism-border); border-bottom: none; overflow-y: auto; transform: translateX(-100%); transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1); z-index: 96; background: var(--prism-black); }
    [data-theme="light"] .sidebar { background: #ffffff; }
    .sidebar.open { transform: translateX(0); box-shadow: 12px 0 40px rgba(0,0,0,0.25); }
    body.sidebar-locked { overflow: hidden; }

    .sidebar-mobile-nav { display: block; margin: 0 -18px 16px; padding: 0 18px 18px; border-bottom: 1px solid var(--prism-border); }
    .sidebar-mobile-nav h4 { font-size: 11px; font-weight: 700; color: var(--prism-text-muted); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 12px; padding-left: 4px; }
    .sidebar-mobile-nav ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 4px; }
    .sidebar-mobile-nav a { display: block; padding: 10px 12px; font-size: 14px; font-weight: 600; color: var(--prism-text); text-decoration: none; border-radius: 8px; transition: all 0.2s ease; }
    .sidebar-mobile-nav a:hover { background: var(--prism-surface-hover); color: var(--prism-violet); }
    .sidebar-mobile-nav a.active { color: var(--prism-violet); background: rgba(37, 99, 235, 0.08); }

    .main-panel { padding: 24px 20px 48px; grid-column: auto; grid-row: auto; }
    /* mobile-width-safety v4 — collapse any inline grid on narrow viewports */
    .main-panel, .main-content-inner, .main-content-area { max-width: 100%; width: 100%; box-sizing: border-box; min-width: 0; }
    .main-content-inner > *, .doc-section, .doc-section > * { max-width: 100%; box-sizing: border-box; min-width: 0; }
    .main-content-inner img, .main-content-inner svg:not(.inline-svg) { max-width: 100%; height: auto; }
    .main-content-inner pre, .main-content-inner code { white-space: pre-wrap; word-break: break-word; }
    .main-content-inner pre { overflow-x: auto; }
    .anatomy-diagram { overflow: visible !important; padding: 48px 40px !important; zoom: 0.82; }
    .anatomy-diagram > * { max-width: 100%; }
    .demo-container { overflow: hidden; }
    .demo-canvas { padding: 32px 20px !important; overflow-x: auto; }
    .code-playground, .cp-code-area { overflow-x: auto; }
    /* Foundation inner-page grids: collapse every multi-column inline grid */
    [style*="grid-template-columns: 1fr 1fr"],
    [style*="grid-template-columns:1fr 1fr"],
    [style*="grid-template-columns: repeat(4, 1fr)"],
    [style*="grid-template-columns: repeat(5, 1fr)"],
    [style*="grid-template-columns: repeat(6, 1fr)"],
    [style*="grid-template-columns: 320px 1fr"],
    [style*="grid-template-columns: 280px 1fr"],
    [style*="grid-template-columns: 240px 1fr"] { grid-template-columns: 1fr !important; }
    /* Flex rows with heavy fixed widths should wrap */
    [style*="display: flex"][style*="gap"] { flex-wrap: wrap; }
    .main-content-area { display: flex; flex-direction: column; grid-template-columns: 1fr; }
    .main-content-inner { padding-bottom: 32px; }
    .toc-sidebar { display: none; }

    .page-header-area .page-title,
    .page-title { font-size: 30px; line-height: 1.15; }
    .page-desc { font-size: 16px; }
    .doc-section h2, .doc-section-title { font-size: 22px; }

    .do-dont-grid,
    .illus-type-grid,
    .comp-grid,
    .density-grid,
    .illus-showcase-grid,
    .pattern-category-grid,
    .tone-grid,
    .voice-traits,
    .principles-grid,
    .theme-grid,
    .message-grid,
    .weight-grid,
    .pattern-grid,
    .collection-grid,
    .anti-pattern-list,
    .dodont-grid,
    .icon-metaphor-grid { grid-template-columns: 1fr !important; }

    table { display: block; overflow-x: auto; }
    .size-table, .token-table, .anatomy-table, .doc-table, .tone-table { display: block; overflow-x: auto; white-space: nowrap; min-width: 0; }

    .feedback-banner { flex-direction: column; align-items: flex-start; gap: 16px; padding: 24px; }
    .illus-type-card { grid-template-columns: 1fr !important; }
    .illus-type-preview { min-height: 180px; padding: 24px 16px; }

    /* Component detail page grids */
    .state-grid,
    .anatomy-grid,
    .usecase-grid,
    .anat-legend,
    /* Zia Experience hub grids */
    .zia-prompt-grid,
    /* Resource hub grids */
    .lib-grid,
    .lib-grid-logo,
    .lib-grid-illust { grid-template-columns: 1fr !important; gap: 12px !important; }

    /* Inline-styled 2- or 3-column grids */
    [style*="grid-template-columns: repeat(3, 1fr)"],
    [style*="grid-template-columns: repeat(2, 1fr)"],
    [style*="grid-template-columns:repeat(3,1fr)"],
    [style*="grid-template-columns:repeat(2,1fr)"] { grid-template-columns: 1fr !important; }

    /* Resource hub outer padding */
    .page-content { padding: 88px 16px 48px !important; }
  }

  @media (max-width: 600px) {
    .nav { padding: 0 12px; height: 60px; }
    .components-layout { padding-top: 60px; }
    .sidebar { top: 60px; height: calc(100vh - 60px); }
    .nav-logo-mark { font-size: 20px; }
    .main-panel { padding: 18px 14px 36px; }
    /* mobile-width-safety v3 */
    .main-panel { padding: 16px 10px 24px !important; }
    .anatomy-diagram { padding: 40px 28px !important; overflow: visible !important; zoom: 0.66; }
    .demo-canvas { padding: 24px 12px !important; }
    .page-header-area .page-title,
    .page-title { font-size: 26px; }
    .page-desc { font-size: 15px; }
    .sidebar-heading { font-size: 10px; }
    .search-shortcut { display: none; }
    .page-content { padding: 72px 12px 32px !important; }
  }

</style>
</head>
