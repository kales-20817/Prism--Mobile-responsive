            <h4>Lato</h4>
            <div class="weight-grid">
              <div class="weight-card">
                <div class="weight-sample" style="font-family:'Lato',sans-serif;font-weight:300;">Ag</div>
                <div class="weight-name">Light</div>
                <div class="weight-value">300</div>
              </div>
              <div class="weight-card">
                <div class="weight-sample" style="font-family:'Lato',sans-serif;font-weight:400;">Ag</div>
                <div class="weight-name">Regular</div>
                <div class="weight-value">400 &middot; Body text</div>
              </div>
              <div class="weight-card">
                <div class="weight-sample" style="font-family:'Lato',sans-serif;font-weight:700;">Ag</div>
                <div class="weight-name">Bold</div>
                <div class="weight-value">700 &middot; Headings</div>
              </div>
              <div class="weight-card">
                <div class="weight-sample" style="font-family:'Lato',sans-serif;font-weight:900;">Ag</div>
                <div class="weight-name">Black</div>
                <div class="weight-value">900 &middot; KPI emphasis</div>
              </div>
            </div>

            <h4>Roboto</h4>
            <div class="weight-grid">
              <div class="weight-card">
                <div class="weight-sample" style="font-family:'Roboto',sans-serif;font-weight:300;">Ag</div>
                <div class="weight-name">Light</div>
                <div class="weight-value">300</div>
              </div>
              <div class="weight-card">
                <div class="weight-sample" style="font-family:'Roboto',sans-serif;font-weight:400;">Ag</div>
                <div class="weight-name">Regular</div>
                <div class="weight-value">400 &middot; Body text</div>
              </div>
              <div class="weight-card">
                <div class="weight-sample" style="font-family:'Roboto',sans-serif;font-weight:500;">Ag</div>
                <div class="weight-name">Medium</div>
                <div class="weight-value">500 &middot; Labels</div>
              </div>
              <div class="weight-card">
                <div class="weight-sample" style="font-family:'Roboto',sans-serif;font-weight:700;">Ag</div>
                <div class="weight-name">Bold</div>
                <div class="weight-value">700 &middot; Headings</div>
              </div>
            </div>

            <p>Avoid overusing bold in dense dashboards.</p>
          </div>

          <hr class="doc-divider">

          <!-- Usage rules -->
          <div class="doc-section" id="usage-rules">
            <h2>Zoho Puvi usage rules</h2>
            <p>To keep Prism readable and scalable:</p>

            <h3>Rules</h3>
            <ul class="doc-list">
              <li>Default body text must use <strong>Zoho Puvi 14px</strong></li>
              <li>Dense table rows can use <strong>13px</strong></li>
              <li>Never go below <strong>12px</strong></li>
              <li>Use <strong>semibold before increasing size</strong></li>
              <li>Prefer sentence case</li>
              <li>Keep table numerals aligned</li>
              <li>Avoid ultra-light weights in dark mode</li>
              <li>Use consistent heading weights across modules</li>
            </ul>

            <h3>Recommended weights</h3>
            <div class="do-dont-grid">
              <div class="do-card">
                <div class="card-label">Do</div>
                <p>Regular (400) for body text</p>
                <p>Medium (500) for labels</p>
                <p>SemiBold (600) for headings</p>
                <p>Bold (700) for KPI emphasis only</p>
              </div>
              <div class="dont-card">
                <div class="card-label">Don't</div>
                <p>Use Bold for all headings</p>
                <p>Mix more than 2 weights per component</p>
                <p>Use Light/Thin weights in dark mode</p>
                <p>Increase font size when weight would suffice</p>
              </div>
            </div>
          </div>

          <hr class="doc-divider">

          <!-- Endpoint patterns -->
          <div class="doc-section" id="endpoint-patterns">
            <h2>Endpoint-specific typography patterns</h2>

            <div class="pattern-grid">
              <div class="pattern-card">
                <div class="pattern-title">Device inventory</div>
                <div class="pattern-row"><span class="pattern-role">Hostname</span><span class="pattern-spec">14px / medium</span></div>
                <div class="pattern-row"><span class="pattern-role">Metadata</span><span class="pattern-spec">12px / regular</span></div>
                <div class="pattern-row"><span class="pattern-role">Status count</span><span class="pattern-spec">13px / semibold</span></div>
              </div>
              <div class="pattern-card">
                <div class="pattern-title">Security dashboard</div>
                <div class="pattern-row"><span class="pattern-role">KPI</span><span class="pattern-spec">24px / semibold</span></div>
                <div class="pattern-row"><span class="pattern-role">Threat card title</span><span class="pattern-spec">16px / semibold</span></div>
                <div class="pattern-row"><span class="pattern-role">Severity label</span><span class="pattern-spec">13px / medium</span></div>
              </div>
              <div class="pattern-card">
                <div class="pattern-title">Patch workflows</div>
                <div class="pattern-row"><span class="pattern-role">Step title</span><span class="pattern-spec">20px / semibold</span></div>
                <div class="pattern-row"><span class="pattern-role">Description</span><span class="pattern-spec">14px / regular</span></div>
                <div class="pattern-row"><span class="pattern-role">Warning note</span><span class="pattern-spec">13px / medium</span></div>
              </div>
              <div class="pattern-card">
                <div class="pattern-title">AI insights</div>
                <div class="pattern-row"><span class="pattern-role">Line height</span><span class="pattern-spec">relaxed (1.6+)</span></div>
                <div class="pattern-row"><span class="pattern-role">Max width</span><span class="pattern-spec">60-75 chars</span></div>
                <div class="pattern-row"><span class="pattern-role">Emphasis</span><span class="pattern-spec">bold for recs only</span></div>
              </div>
            </div>
          </div>

          <hr class="doc-divider">

          <!-- Anti-patterns -->
          <div class="doc-section" id="anti-patterns">
            <h2>Anti-patterns</h2>
            <div class="do-dont-grid">
              <div class="do-card">
                <div class="card-label">Do</div>
                <p>Use the defined type scale consistently</p>
                <p>Add hierarchy through weight, not size</p>
                <p>Match text styles from Figma exactly</p>
                <p>Use monospace for all technical values</p>
              </div>
              <div class="dont-card">
                <div class="card-label">Don't</div>
                <p>Create arbitrary font sizes (e.g., 15px, 17px)</p>
                <p>Use ALL CAPS for body text</p>
                <p>Nest more than 3 heading levels in a widget</p>
                <p>Use Zoho Puvi for code snippets or logs</p>
              </div>
            </div>
          </div>

          <hr class="doc-divider">

          <!-- Principle -->
          <div class="doc-section" id="principle">
            <h2>Principle</h2>
            <p>In Prism, Zoho Puvi is not just the brand font.</p>
            <p>It is the <strong>reading speed layer</strong> that helps endpoint admins scan faster, compare data safely, and act confidently under pressure.</p>
          </div>

          <!-- Feedback -->
          <div class="feedback-banner" style="display: none;">
            <div>
              <div class="fb-text">Help us improve this page</div>
              <div class="fb-sub">Share your feedback to help shape the Typography documentation.</div>
            </div>
            <div style="display: flex; gap: 12px;">
              <button class="feedback-btn primary" onclick="window.open('https://cliq.zoho.in/company/60002085329/channels/prismdesignsystembyuemssupportfeedback','_blank')">Give Feedback</button>
            </div>
          </div>

        </div>

        <aside class="toc-sidebar">
          <h4 class="toc-heading">On this page</h4>
          <ul class="toc-nav" id="toc-nav"></ul>
        </aside>
      </div>
    </main>
  </div>

  <script>
// Sidebar search: filter foundation nav links by query
    const sidebarSearchInput = document.querySelector('.sidebar-search input');
    const foundationNavItems = document.querySelectorAll('.foundation-nav li');
    if (sidebarSearchInput && foundationNavItems.length) {
      sidebarSearchInput.addEventListener('input', (e) => {
        const q = e.target.value.trim().toLowerCase();
        foundationNavItems.forEach(li => {
          const text = li.textContent.trim().toLowerCase();
          li.style.display = !q || text.includes(q) ? '' : 'none';
        });
      });
      document.addEventListener('keydown', (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
          e.preventDefault();
          sidebarSearchInput.focus();
        }
        if (e.key === 'Escape' && document.activeElement === sidebarSearchInput) {
          sidebarSearchInput.value = '';
          sidebarSearchInput.dispatchEvent(new Event('input'));
          sidebarSearchInput.blur();
        }
      });
    }

    const themeToggle = document.getElementById('themeToggle');
    const moonIcon = document.getElementById('moonIcon');
    const sunIcon = document.getElementById('sunIcon');
    const currentTheme = localStorage.getItem('theme') || 'light';
    if (currentTheme === 'dark') {
      document.documentElement.removeAttribute('data-theme');
      moonIcon.style.display = 'block'; sunIcon.style.display = 'none';
    }
    themeToggle.addEventListener('click', () => {
      let theme = document.documentElement.getAttribute('data-theme');
      if (theme === 'light') {
        document.documentElement.removeAttribute('data-theme');
        localStorage.setItem('theme', 'dark');
        moonIcon.style.display = 'block'; sunIcon.style.display = 'none';
      } else {
        document.documentElement.setAttribute('data-theme', 'light');
        localStorage.setItem('theme', 'light');
        moonIcon.style.display = 'none'; sunIcon.style.display = 'block';
      }
    });

    // Dynamic TOC with scroll-spy
    (function() {
      const sections = document.querySelectorAll('.doc-section[id]');
      const tocNav = document.getElementById('toc-nav');
      sections.forEach(sec => {
        const h2 = sec.querySelector('h2');
        if (h2) {
          const li = document.createElement('li');
          const a = document.createElement('a');
          a.className = 'toc-link';
          a.href = '#' + sec.id;
          a.textContent = h2.textContent;
          li.appendChild(a);
          tocNav.appendChild(li);
        }
      });
      const obs = new IntersectionObserver(entries => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            document.querySelectorAll('.toc-link').forEach(l => l.classList.remove('active'));
            const link = tocNav.querySelector('a[href="#' + entry.target.id + '"]');
            if (link) link.classList.add('active');
          }
        });
      }, { rootMargin: '-80px 0px -60% 0px', threshold: 0.1 });
      sections.forEach(sec => obs.observe(sec));
    })();
  </script>
<script>
(function(){
  const nav = document.querySelector('.nav');
  if (!nav) return;
  const toggle = () => {
    if (window.scrollY > 10) nav.classList.add('scrolled');
    else nav.classList.remove('scrolled');
  };
  toggle();
  window.addEventListener('scroll', toggle, { passive: true });
})();
</script>
<script>
(function(){
  const hamburger = document.querySelector('.nav-hamburger');
  const sidebar = document.querySelector('.sidebar');
  const backdrop = document.querySelector('.sidebar-backdrop');
  const navLinks = document.querySelector('.nav-links');
  if (!hamburger || !sidebar || !backdrop) return;

  // Build a mobile-only nav section at the top of the sidebar by cloning the nav links
  if (navLinks && !sidebar.querySelector('.sidebar-mobile-nav')) {
    const mobileNav = document.createElement('div');
    mobileNav.className = 'sidebar-mobile-nav';
    const heading = document.createElement('h4');
    heading.textContent = 'Navigate';
    mobileNav.appendChild(heading);
    const ul = document.createElement('ul');
    navLinks.querySelectorAll(':scope > a').forEach(a => {
      const li = document.createElement('li');
      const clone = a.cloneNode(true);
      li.appendChild(clone);
      ul.appendChild(li);
    });
    navLinks.querySelectorAll(':scope > .nav-dropdown > .nav-dropdown-menu > a').forEach(a => {
      const li = document.createElement('li');
      const clone = a.cloneNode(true);
      li.appendChild(clone);
      ul.appendChild(li);
    });
    mobileNav.appendChild(ul);
    sidebar.insertBefore(mobileNav, sidebar.firstChild);
  }

  const open = () => {
    sidebar.classList.add('open');
    backdrop.classList.add('open');
    document.body.classList.add('sidebar-locked');
    hamburger.setAttribute('aria-expanded', 'true');
  };
  const close = () => {
    sidebar.classList.remove('open');
    backdrop.classList.remove('open');
    document.body.classList.remove('sidebar-locked');
    hamburger.setAttribute('aria-expanded', 'false');
  };
  hamburger.addEventListener('click', () => sidebar.classList.contains('open') ? close() : open());
  backdrop.addEventListener('click', close);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && sidebar.classList.contains('open')) close(); });
  sidebar.addEventListener('click', (e) => { if (e.target.closest('a')) close(); });
})();
</script>

