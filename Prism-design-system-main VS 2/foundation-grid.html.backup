    <main class="main-panel">
      <div class="page-header-area">
        <h1 class="page-title">Grid</h1>
        <p class="page-desc">Use grid to position content, control layout behavior, and create consistent responsive page structures across endpoint management workflows.</p>
      </div>

      <div class="main-content-area">
        <div class="main-content-inner">

          <!-- Intro -->
          <div class="doc-section" style="margin-top: 16px;">
            <p style="font-size: 16px; line-height: 1.7; color: var(--prism-text-muted); max-width: 760px;">In Prism, grid is the structural foundation behind dashboards, device inventory, patching, policy builders, alert triage, compliance reporting, and remediation experiences.</p>
            <p style="font-size: 16px; line-height: 1.7; color: var(--prism-text-muted); max-width: 760px; margin-top: 12px;">A strong grid system improves scan speed, layout consistency, and engineering predictability across complex enterprise screens.</p>
          </div>

          <!-- Grid anatomy -->
          <div class="doc-section">
            <h2 id="grid-anatomy" class="doc-section-title">Grid anatomy</h2>
            <p class="doc-section-subtitle">Prism grid has three core elements.</p>

            <h3 id="columns" class="doc-h3">Columns</h3>
            <p class="doc-section-subtitle">Columns divide the page into equal vertical sections and organize content zones. Use columns for:</p>
            <ul class="doc-list">
              <li>Dashboard cards</li>
              <li>Table containers</li>
              <li>Form layouts</li>
              <li>Drawer content regions</li>
              <li>Wizard steps</li>
              <li>Analytics widgets</li>
            </ul>

            <!-- Visual diagram -->
            <div style="padding: 32px; border: 2px dashed var(--prism-border); border-radius: 12px; margin-top: 20px; position: relative;">
              <div style="display: flex; align-items: flex-end; gap: 0; position: relative;">
                <div style="font-size: 11px; color: var(--prism-text-muted); writing-mode: vertical-rl; transform: rotate(180deg); margin-right: 12px; font-weight: 600;">Margin</div>
                <div style="flex: 1; display: flex; gap: 4px;">
                  <div style="flex: 1; height: 80px; background: rgba(139, 92, 246, 0.10); border: 1px solid rgba(139, 92, 246, 0.15); border-radius: 4px;"></div>
                  <div style="flex: 1; height: 80px; background: rgba(139, 92, 246, 0.10); border: 1px solid rgba(139, 92, 246, 0.15); border-radius: 4px;"></div>
                  <div style="flex: 1; height: 80px; background: rgba(139, 92, 246, 0.10); border: 1px solid rgba(139, 92, 246, 0.15); border-radius: 4px;"></div>
                  <div style="flex: 1; height: 80px; background: rgba(139, 92, 246, 0.10); border: 1px solid rgba(139, 92, 246, 0.15); border-radius: 4px;"></div>
                  <div style="flex: 1; height: 80px; background: rgba(139, 92, 246, 0.10); border: 1px solid rgba(139, 92, 246, 0.15); border-radius: 4px;"></div>
                  <div style="flex: 1; height: 80px; background: rgba(139, 92, 246, 0.10); border: 1px solid rgba(139, 92, 246, 0.15); border-radius: 4px;"></div>
                  <div style="flex: 1; height: 80px; background: rgba(139, 92, 246, 0.10); border: 1px solid rgba(139, 92, 246, 0.15); border-radius: 4px;"></div>
                  <div style="flex: 1; height: 80px; background: rgba(139, 92, 246, 0.10); border: 1px solid rgba(139, 92, 246, 0.15); border-radius: 4px;"></div>
                  <div style="flex: 1; height: 80px; background: rgba(139, 92, 246, 0.10); border: 1px solid rgba(139, 92, 246, 0.15); border-radius: 4px;"></div>
                  <div style="flex: 1; height: 80px; background: rgba(139, 92, 246, 0.10); border: 1px solid rgba(139, 92, 246, 0.15); border-radius: 4px;"></div>
                  <div style="flex: 1; height: 80px; background: rgba(139, 92, 246, 0.10); border: 1px solid rgba(139, 92, 246, 0.15); border-radius: 4px;"></div>
                  <div style="flex: 1; height: 80px; background: rgba(139, 92, 246, 0.10); border: 1px solid rgba(139, 92, 246, 0.15); border-radius: 4px;"></div>
                </div>
                <div style="font-size: 11px; color: var(--prism-text-muted); writing-mode: vertical-rl; margin-left: 12px; font-weight: 600;">Margin</div>
              </div>
              <div style="text-align: center; margin-top: 12px; font-size: 12px; color: var(--prism-text-muted); font-weight: 600;">Gutter between each column</div>
            </div>

            <h3 id="gutters" class="doc-h3" style="margin-top: 32px;">Gutters</h3>
            <p class="doc-section-subtitle">Gutters are the spaces between columns. They separate content consistently and prevent dense enterprise pages from visually collapsing.</p>

            <h3 id="margins" class="doc-h3" style="margin-top: 32px;">Margins</h3>
            <p class="doc-section-subtitle">Margins define the outer layout boundary. They ensure content never touches viewport edges, especially on:</p>
            <ul class="doc-list">
              <li>Large monitoring screens</li>
              <li>Compact laptops</li>
              <li>Zoomed accessibility states</li>
              <li>Responsive tablet views</li>
            </ul>
          </div>

          <hr class="doc-divider" />

          <!-- Grid types -->
          <div class="doc-section">
            <h2 id="grid-types" class="doc-section-title">Grid types</h2>
            <p class="doc-section-subtitle">Prism supports two grid types based on task density.</p>

            <h3 id="fluid-grid" class="doc-h3"><span style="color: var(--prism-violet); font-weight: 700; margin-right: 4px;">1.</span> Fluid grid</h3>
            <p class="doc-section-subtitle">Fluid grids stretch to fill the available main content area.</p>
            <div style="margin-top: 16px; padding: 20px 24px; background: var(--prism-surface); border: 1px solid var(--prism-border); border-radius: 12px;">
              <div style="font-size: 12px; font-weight: 700; color: var(--prism-text); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 12px;">Best for</div>
              <ul class="doc-list">
                <li>Device inventory</li>
                <li>Threat dashboards</li>
                <li>Patch status boards</li>
                <li>Alert queues</li>
                <li>Analytics views</li>
                <li>Heatmaps</li>
                <li>Compliance matrices</li>
              </ul>
            </div>
            <div style="margin-top: 16px; padding: 16px 20px; background: rgba(37,99,235,0.04); border: 1px solid rgba(37,99,235,0.12); border-radius: 12px;">
              <p style="font-size: 14px; color: var(--prism-text); line-height: 1.6; margin: 0;"><strong>Rule:</strong> Use fluid grid whenever table width, widget count, or live telemetry density is high.</p>
            </div>

            <h3 id="fixed-grid" class="doc-h3" style="margin-top: 32px;"><span style="color: var(--prism-violet); font-weight: 700; margin-right: 4px;">2.</span> Fixed grid</h3>
            <p class="doc-section-subtitle">Fixed grids apply a controlled maximum width. Prism supports <code>fixed.narrow</code> and <code>fixed.wide</code>.</p>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 20px;">
              <div style="padding: 24px; background: var(--prism-surface); border: 1px solid var(--prism-border); border-radius: 12px;">
                <h4 style="font-size: 15px; font-weight: 600; color: var(--prism-text); margin-bottom: 12px;">Fixed narrow</h4>
                <p style="font-size: 13px; color: var(--prism-text-muted); margin-bottom: 12px;">Use for readability-first workflows:</p>
                <ul class="doc-list">
                  <li>Policy creation</li>
                  <li>Step forms</li>
                  <li>AI remediation summaries</li>
                  <li>Guided troubleshooting</li>
                  <li>Documentation panels</li>
                </ul>
              </div>
              <div style="padding: 24px; background: var(--prism-surface); border: 1px solid var(--prism-border); border-radius: 12px;">
                <h4 style="font-size: 15px; font-weight: 600; color: var(--prism-text); margin-bottom: 12px;">Fixed wide</h4>
                <p style="font-size: 13px; color: var(--prism-text-muted); margin-bottom: 12px;">Use for balanced dense pages:</p>
                <ul class="doc-list">
                  <li>Software repository</li>
                  <li>Deployment workflows</li>
                  <li>Audit reports</li>
                  <li>Security investigation pages</li>
                </ul>
              </div>
            </div>
            <div style="margin-top: 16px; padding: 16px 20px; background: rgba(220, 38, 38, 0.04); border: 1px solid rgba(220, 38, 38, 0.12); border-radius: 12px;">
              <p style="font-size: 14px; color: var(--prism-text); line-height: 1.6; margin: 0;">Avoid fixed layouts for real-time dense dashboards.</p>
            </div>
          </div>

          <hr class="doc-divider" />

          <!-- Breakpoints -->
          <div class="doc-section">
            <h2 id="breakpoints" class="doc-section-title">Breakpoints</h2>
            <p class="doc-section-subtitle">Prism follows a 6-breakpoint responsive grid system aligned to enterprise viewport realities.</p>
            <table class="size-table">
              <thead>
                <tr><th>Breakpoint</th><th>Viewport</th><th>Columns</th><th>Gutters</th><th>Margins</th></tr>
              </thead>
              <tbody>
                <tr><td><code>xxs</code></td><td>320&ndash;479px</td><td>2</td><td>12px</td><td>16px</td></tr>
                <tr><td><code>xs</code></td><td>480&ndash;767px</td><td>6</td><td>12px</td><td>16px</td></tr>
                <tr><td><code>s</code></td><td>768&ndash;1023px</td><td>6</td><td>12px</td><td>16px</td></tr>
                <tr><td><code>m</code></td><td>1024&ndash;1439px</td><td>12</td><td>16px</td><td>32px</td></tr>
                <tr><td><code>l</code></td><td>1440&ndash;1767px</td><td>12</td><td>16px</td><td>32px</td></tr>
                <tr><td><code>xl</code></td><td>1768px+</td><td>12</td><td>16px</td><td>32px</td></tr>
              </tbody>
            </table>
          </div>

          <hr class="doc-divider" />

          <!-- Column span rules -->
          <div class="doc-section">
            <h2 id="column-spans" class="doc-section-title">Column span rules</h2>
            <p class="doc-section-subtitle">Prism uses a 12-column layout for desktop enterprise workflows.</p>

            <h3 id="recommended-spans" class="doc-h3">Recommended spans</h3>
            <table class="size-table">
              <thead>
                <tr><th>Pattern</th><th>Span</th></tr>
              </thead>
              <tbody>
                <tr><td>Full-width tables</td><td>12</td></tr>
                <tr><td>Two equal panels</td><td>6 / 6</td></tr>
                <tr><td>KPI dashboard cards</td><td>3 / 3 / 3 / 3</td></tr>
                <tr><td>Primary + inspector</td><td>8 / 4</td></tr>
                <tr><td>Policy form + live preview</td><td>7 / 5</td></tr>
                <tr><td>Chart + insights</td><td>8 / 4</td></tr>
              </tbody>
            </table>

            <!-- Visual demo -->
            <div class="grid-demo-container" style="margin-top: 24px;">
              <div style="font-size: 12px; font-weight: 600; color: var(--prism-text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 16px;">Layout patterns</div>
              <div class="grid-demo-row">
                <div class="grid-col" style="flex: 12;">12</div>
              </div>
              <div class="grid-demo-row">
                <div class="grid-col" style="flex: 8;">8</div>
                <div class="grid-col" style="flex: 4;">4</div>
              </div>
              <div class="grid-demo-row">
                <div class="grid-col" style="flex: 7;">7</div>
                <div class="grid-col" style="flex: 5;">5</div>
              </div>
              <div class="grid-demo-row">
                <div class="grid-col" style="flex: 6;">6</div>
                <div class="grid-col" style="flex: 6;">6</div>
              </div>
              <div class="grid-demo-row">
                <div class="grid-col" style="flex: 3;">3</div>
                <div class="grid-col" style="flex: 3;">3</div>
                <div class="grid-col" style="flex: 3;">3</div>
                <div class="grid-col" style="flex: 3;">3</div>
              </div>
            </div>

            <div style="margin-top: 24px; padding: 16px 20px; background: rgba(37,99,235,0.04); border: 1px solid rgba(37,99,235,0.12); border-radius: 12px;">
              <p style="font-size: 14px; color: var(--prism-text); line-height: 1.6; margin: 0;"><strong>Rule:</strong> Content should span at least 3 columns for readability and structure. Avoid 1-column desktop content blocks except for status rails, timeline markers, and utility action strips.</p>
            </div>
          </div>

          <hr class="doc-divider" />

          <!-- Column offset -->
          <div class="doc-section">
            <h2 id="column-offset" class="doc-section-title">Column offset</h2>
            <p class="doc-section-subtitle">Not every layout must consume all 12 columns. Use offsets to:</p>
            <ul class="doc-list">
              <li>Center onboarding empty states</li>
              <li>Focus critical warnings</li>
              <li>Narrow AI-generated summaries</li>
              <li>Present single-task confirmation flows</li>
              <li>Reduce cognitive load in destructive workflows</li>
            </ul>
            <div style="margin-top: 20px; padding: 20px 24px; background: var(--prism-surface); border: 1px solid var(--prism-border); border-radius: 12px;">
              <div style="font-size: 13px; font-weight: 600; color: var(--prism-text); margin-bottom: 8px;">Example</div>
              <p style="font-size: 14px; color: var(--prism-text-muted); line-height: 1.6; margin: 0;">A policy review screen may span 8 columns with 2-column offsets on each side.</p>
            </div>
          </div>

          <hr class="doc-divider" />

          <!-- Endpoint-specific grid patterns -->
          <div class="doc-section">
            <h2 id="endpoint-patterns" class="doc-section-title">Endpoint-specific grid patterns</h2>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 24px;">
              <div style="padding: 24px; background: var(--prism-surface); border: 1px solid var(--prism-border); border-radius: 12px;">
                <h4 style="font-size: 15px; font-weight: 600; color: var(--prism-text); margin-bottom: 12px;">Device inventory</h4>
                <ul style="list-style: none; padding: 0; margin: 0; font-size: 13.5px; color: var(--prism-text-muted); line-height: 1.8;">
                  <li>Main table &rarr; 12 columns</li>
                  <li>Optional filter rail &rarr; 3 + 9</li>
                  <li>Inspector panel &rarr; 8 + 4</li>
                </ul>
              </div>
              <div style="padding: 24px; background: var(--prism-surface); border: 1px solid var(--prism-border); border-radius: 12px;">
                <h4 style="font-size: 15px; font-weight: 600; color: var(--prism-text); margin-bottom: 12px;">Security dashboard</h4>
                <ul style="list-style: none; padding: 0; margin: 0; font-size: 13.5px; color: var(--prism-text-muted); line-height: 1.8;">
                  <li>KPI row &rarr; 3 / 3 / 3 / 3</li>
                  <li>Threat map + insights &rarr; 8 / 4</li>
                  <li>Full trend charts &rarr; 12</li>
                </ul>
              </div>
              <div style="padding: 24px; background: var(--prism-surface); border: 1px solid var(--prism-border); border-radius: 12px;">
                <h4 style="font-size: 15px; font-weight: 600; color: var(--prism-text); margin-bottom: 12px;">Patch deployment</h4>
                <ul style="list-style: none; padding: 0; margin: 0; font-size: 13.5px; color: var(--prism-text-muted); line-height: 1.8;">
                  <li>Workflow content &rarr; fixed wide</li>
                  <li>Step layout &rarr; 7 / 5</li>
                  <li>Confirmation zone &rarr; centered 8 span</li>
                </ul>
              </div>
              <div style="padding: 24px; background: var(--prism-surface); border: 1px solid var(--prism-border); border-radius: 12px;">
                <h4 style="font-size: 15px; font-weight: 600; color: var(--prism-text); margin-bottom: 12px;">Tree navigation layouts</h4>
                <ul style="list-style: none; padding: 0; margin: 0; font-size: 13.5px; color: var(--prism-text-muted); line-height: 1.8;">
                  <li>Tree &rarr; 3</li>
                  <li>Main workspace &rarr; 9</li>
                </ul>
              </div>
              <div style="padding: 24px; background: var(--prism-surface); border: 1px solid var(--prism-border); border-radius: 12px;">
                <h4 style="font-size: 15px; font-weight: 600; color: var(--prism-text); margin-bottom: 12px;">Remote troubleshooting</h4>
                <ul style="list-style: none; padding: 0; margin: 0; font-size: 13.5px; color: var(--prism-text-muted); line-height: 1.8;">
                  <li>Device summary &rarr; 4</li>
                  <li>Terminal/logs &rarr; 8</li>
                </ul>
              </div>
            </div>
          </div>

          <hr class="doc-divider" />

          <!-- Side panels and rails -->
          <div class="doc-section">
            <h2 id="side-panels" class="doc-section-title">Side panels and rails</h2>
            <p class="doc-section-subtitle">Endpoint products rely heavily on persistent layout rails. Support:</p>
            <ul class="doc-list">
              <li>Left navigation</li>
              <li>Collapsible filter rail</li>
              <li>Right-side inspector</li>
              <li>AI insights aside</li>
              <li>Deployment summary drawer</li>
            </ul>

            <h3 id="panel-rules" class="doc-h3" style="margin-top: 24px;">Rules</h3>
            <ul class="doc-list">
              <li>Main grid spans <strong>only content area</strong></li>
              <li>Side navigation excluded from grid width</li>
              <li>Right asides use standardized widths</li>
              <li>Never create custom rail widths per module</li>
            </ul>
          </div>

          <hr class="doc-divider" />

          <!-- Grid anti-patterns -->
          <div class="doc-section">
            <h2 id="anti-patterns" class="doc-section-title">Grid anti-patterns</h2>
            <p class="doc-section-subtitle">Avoid these common enterprise layout failures:</p>
            <ul class="doc-list">
              <li>Random panel widths</li>
              <li>5-column custom layouts</li>
              <li>Misaligned dashboard cards</li>
              <li>Different table widths across modules</li>
              <li>Filter rails breaking at tablet size</li>
              <li>Full-width readable forms</li>
              <li>Side panels overlapping grid logic</li>
              <li>Dense widgets with no gutter rhythm</li>
            </ul>
          </div>

          <hr class="doc-divider" />

          <!-- Accessibility and responsive behavior -->
          <div class="doc-section">
            <h2 id="accessibility-grid" class="doc-section-title">Accessibility and responsive behavior</h2>
            <p class="doc-section-subtitle">Grid directly impacts accessibility. Ensure:</p>
            <ul class="doc-list">
              <li>Zoom at 200% preserves reflow</li>
              <li>Side rails collapse predictably</li>
              <li>Tables remain horizontally scannable</li>
              <li>Focus order follows visual order</li>
              <li>Drawer layouts preserve hierarchy</li>
              <li>Breakpoints support keyboard-only users</li>
              <li>Monitoring screens scale safely</li>
            </ul>
            <div style="margin-top: 24px; padding: 16px 20px; background: rgba(220, 38, 38, 0.04); border: 1px solid rgba(220, 38, 38, 0.12); border-radius: 12px;">
              <p style="font-size: 14px; color: var(--prism-text); line-height: 1.6; margin: 0;"><strong>A broken grid becomes an operational risk in endpoint management.</strong></p>
            </div>
          </div>

          <hr class="doc-divider" />

          <!-- Closing Principle -->
          <div class="doc-section">
            <div style="padding: 32px 40px; background: linear-gradient(135deg, rgba(37,99,235,0.06) 0%, rgba(6,182,212,0.06) 100%); border: 1px solid rgba(37,99,235,0.15); border-radius: 16px; text-align: center;">
              <h2 id="principle" style="font-size: 24px; font-weight: 700; color: var(--prism-text); margin-bottom: 12px;">Principle</h2>
              <p style="font-size: 17px; color: var(--prism-text-muted); line-height: 1.7; max-width: 640px; margin: 0 auto;">In Prism, grid is decision architecture. A good grid helps admins <strong style="color: var(--prism-text);">scan faster</strong>, <strong style="color: var(--prism-text);">compare states safely</strong>, and <strong style="color: var(--prism-text);">act confidently</strong> across dense endpoint workflows.</p>
            </div>
          </div>

          <!-- Feedback banner -->
          <div class="feedback-banner" style="display: none;">
            <div>
              <div class="fb-text">Help us improve this page</div>
              <div class="fb-sub">Share your feedback to help shape the Grid documentation.</div>
            </div>
            <div style="display: flex; gap: 12px;">
              <button class="feedback-btn primary" onclick="window.open('https://cliq.zoho.in/company/60002085329/channels/prismdesignsystembyuemssupportfeedback','_blank')">Give Feedback</button>
            </div>
          </div>

        </div>

        <aside class="toc-sidebar">
          <h4 class="toc-heading">On this page</h4>
          <ul class="toc-nav" id="toc-nav"></ul>
        </aside>
      </div>
    </main>
  </div>

  <script>

    // Dynamic TOC
    let _tocObserver = null;
    function buildTOC() {
      const tocList = document.getElementById('toc-nav');
      if (!tocList) return;
      tocList.innerHTML = '';
      const inner = document.querySelector('.main-content-inner');
      if (!inner) return;
      const headings = inner.querySelectorAll('h2[id], h3[id]');
      const sections = [];
      headings.forEach(h => {
        if (h.style.display === 'none') return;
        const li = document.createElement('li');
        const a = document.createElement('a');
        a.href = '#' + h.id;
        a.className = 'toc-link';
        let text = Array.from(h.childNodes).filter(n => n.nodeType === 3).map(n => n.textContent).join('').trim();
        if (!text) text = h.innerText.replace(/^\d+\.\s*/, '');
        a.textContent = text;
        if (h.tagName === 'H3') { a.style.paddingLeft = '16px'; a.style.fontSize = '12.5px'; }
        a.addEventListener('click', e => { e.preventDefault(); document.getElementById(h.id).scrollIntoView({ behavior: 'smooth', block: 'start' }); });
        li.appendChild(a);
        tocList.appendChild(li);
        sections.push(h);
      });
      if (_tocObserver) _tocObserver.disconnect();
      _tocObserver = new IntersectionObserver(entries => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const id = entry.target.getAttribute('id');
            document.querySelectorAll('.toc-link').forEach(link => {
              link.classList.toggle('active', link.getAttribute('href') === '#' + id);
            });
          }
        });
      }, { rootMargin: '-80px 0px -60% 0px', threshold: 0 });
      sections.forEach(s => _tocObserver.observe(s));
    }
    buildTOC();

// Sidebar search: filter foundation nav links by query
    const sidebarSearchInput = document.querySelector('.sidebar-search input');
    const foundationNavItems = document.querySelectorAll('.foundation-nav li');
    if (sidebarSearchInput && foundationNavItems.length) {
      sidebarSearchInput.addEventListener('input', (e) => {
        const q = e.target.value.trim().toLowerCase();
        foundationNavItems.forEach(li => {
          const text = li.textContent.trim().toLowerCase();
          li.style.display = !q || text.includes(q) ? '' : 'none';
        });
      });
      document.addEventListener('keydown', (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
          e.preventDefault();
          sidebarSearchInput.focus();
        }
        if (e.key === 'Escape' && document.activeElement === sidebarSearchInput) {
          sidebarSearchInput.value = '';
          sidebarSearchInput.dispatchEvent(new Event('input'));
          sidebarSearchInput.blur();
        }
      });
    }

    const themeToggle = document.getElementById('themeToggle');
    const moonIcon = document.getElementById('moonIcon');
    const sunIcon = document.getElementById('sunIcon');
    const currentTheme = localStorage.getItem('theme') || 'light';
    if (currentTheme === 'dark') {
      document.documentElement.removeAttribute('data-theme');
      moonIcon.style.display = 'block'; sunIcon.style.display = 'none';
    }
    themeToggle.addEventListener('click', () => {
      let theme = document.documentElement.getAttribute('data-theme');
      if (theme === 'light') {
        document.documentElement.removeAttribute('data-theme');
        localStorage.setItem('theme', 'dark');
        moonIcon.style.display = 'block'; sunIcon.style.display = 'none';
      } else {
        document.documentElement.setAttribute('data-theme', 'light');
        localStorage.setItem('theme', 'light');
        moonIcon.style.display = 'none'; sunIcon.style.display = 'block';
      }
    });
  </script>
<script>
(function(){
  const nav = document.querySelector('.nav');
  if (!nav) return;
  const toggle = () => {
    if (window.scrollY > 10) nav.classList.add('scrolled');
    else nav.classList.remove('scrolled');
  };
  toggle();
  window.addEventListener('scroll', toggle, { passive: true });
})();
</script>
<script>
(function(){
  const hamburger = document.querySelector('.nav-hamburger');
  const sidebar = document.querySelector('.sidebar');
  const backdrop = document.querySelector('.sidebar-backdrop');
  const navLinks = document.querySelector('.nav-links');
  if (!hamburger || !sidebar || !backdrop) return;

  // Build a mobile-only nav section at the top of the sidebar by cloning the nav links
  if (navLinks && !sidebar.querySelector('.sidebar-mobile-nav')) {
    const mobileNav = document.createElement('div');
    mobileNav.className = 'sidebar-mobile-nav';
    const heading = document.createElement('h4');
    heading.textContent = 'Navigate';
    mobileNav.appendChild(heading);
    const ul = document.createElement('ul');
    navLinks.querySelectorAll(':scope > a').forEach(a => {
      const li = document.createElement('li');
      const clone = a.cloneNode(true);
      li.appendChild(clone);
      ul.appendChild(li);
    });
    navLinks.querySelectorAll(':scope > .nav-dropdown > .nav-dropdown-menu > a').forEach(a => {
      const li = document.createElement('li');
      const clone = a.cloneNode(true);
      li.appendChild(clone);
      ul.appendChild(li);
    });
    mobileNav.appendChild(ul);
    sidebar.insertBefore(mobileNav, sidebar.firstChild);
  }

  const open = () => {
    sidebar.classList.add('open');
    backdrop.classList.add('open');
    document.body.classList.add('sidebar-locked');
    hamburger.setAttribute('aria-expanded', 'true');
  };
  const close = () => {
    sidebar.classList.remove('open');
    backdrop.classList.remove('open');
    document.body.classList.remove('sidebar-locked');
    hamburger.setAttribute('aria-expanded', 'false');
  };
  hamburger.addEventListener('click', () => sidebar.classList.contains('open') ? close() : open());
  backdrop.addEventListener('click', close);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && sidebar.classList.contains('open')) close(); });
  sidebar.addEventListener('click', (e) => { if (e.target.closest('a')) close(); });
})();
</script>

