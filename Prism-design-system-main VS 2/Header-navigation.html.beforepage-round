                <tr><td><code>Nav 3</code></td><td>Boolean</td><td>ON</td><td>Third nav tab slot</td></tr>
                <tr><td><code>Nav 4</code></td><td>Boolean</td><td>ON</td><td>Fourth nav tab slot</td></tr>
                <tr><td><code>Nav 5</code></td><td>Boolean</td><td>ON</td><td>Fifth nav tab slot</td></tr>
                <tr><td><code>Nav 6</code></td><td>Boolean</td><td>ON</td><td>Sixth nav tab slot</td></tr>
                <tr><td><code>Nav 7</code></td><td>Boolean</td><td>ON</td><td>Seventh nav tab slot</td></tr>
                <tr><td><code>Nav 8</code></td><td>Boolean</td><td>ON</td><td>Eighth nav tab slot</td></tr>
              </tbody>
            </table>
            <p style="font-size:14px;color:var(--prism-text-muted);margin-bottom:32px;padding:12px 16px;background:rgba(37,99,235,0.05);border:1px solid rgba(37,99,235,0.15);border-radius:10px;">Tabs beyond the visible count collapse into the <code style="font-family:monospace;font-size:13px;padding:2px 6px;border-radius:4px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&#8943;</code> overflow menu automatically. Turn off unused slots to reflect the actual link count.</p>

            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Right Utility Cluster</h4>
            <table class="size-table">
              <thead><tr><th>Property</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
              <tbody>
                <tr><td><code>Show Search</code></td><td>Boolean</td><td>ON</td><td>Toggles the search icon / search bar</td></tr>
                <tr><td><code>Show Notifications</code></td><td>Boolean</td><td>ON</td><td>Toggles the bell notification icon</td></tr>
                <tr><td><code>Show Settings</code></td><td>Boolean</td><td>ON</td><td>Toggles the settings gear icon</td></tr>
                <tr><td><code>Show Customer Selector</code></td><td>Boolean</td><td>ON</td><td>Toggles the "All Customers" dropdown</td></tr>
                <tr><td><code>Show Avatar</code></td><td>Boolean</td><td>ON</td><td>Toggles the user avatar</td></tr>
                <tr><td><code>Show Bento</code></td><td>Boolean</td><td>ON</td><td>Toggles the bento grid icon</td></tr>
                <tr><td><code>Show Bookmark</code></td><td>Boolean</td><td>ON</td><td>Toggles the bookmark icon</td></tr>
                <tr><td><code>Show Link</code></td><td>Boolean</td><td>ON</td><td>Toggles the link icon</td></tr>
              </tbody>
            </table>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="implementation-idea-ember-hook-form" class="doc-h3">Implementation Idea: Ember Hook Form</h3>
            <div class="cp-code-area" style="border-radius:12px;margin-top:16px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;">
                <span style="color:#94a3b8;">&lt;!-- header-navigation.hbs --&gt;</span><br>
                <span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">UemsHeaderNav</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">@variant</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"endpoint-central"</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">@showSearch</span><span style="color:#56B6C2;">=</span><span style="color:#C678DD;">{{</span><span style="color:#E5C07B;">true</span><span style="color:#C678DD;">}}</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">@showNotifications</span><span style="color:#56B6C2;">=</span><span style="color:#C678DD;">{{</span><span style="color:#E5C07B;">true</span><span style="color:#C678DD;">}}</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">@showSettings</span><span style="color:#56B6C2;">=</span><span style="color:#C678DD;">{{</span><span style="color:#E5C07B;">true</span><span style="color:#C678DD;">}}</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">@showCustomerSelector</span><span style="color:#56B6C2;">=</span><span style="color:#C678DD;">{{</span><span style="color:#E5C07B;">this.isMultiTenant</span><span style="color:#C678DD;">}}</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">@activeTab</span><span style="color:#56B6C2;">=</span><span style="color:#C678DD;">{{</span><span style="color:#E5C07B;">this.currentRoute</span><span style="color:#C678DD;">}}</span><br>
                <span style="color:#ABB2BF;">&gt;</span><br>
                &nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;:</span><span style="color:#E06C75;">nav</span><span style="color:#ABB2BF;">&gt;</span><br>
                &nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">LinkTo</span> <span style="color:#D19A66;">@route</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"home"</span><span style="color:#ABB2BF;">&gt;</span>Home<span style="color:#ABB2BF;">&lt;/</span><span style="color:#E06C75;">LinkTo</span><span style="color:#ABB2BF;">&gt;</span><br>
                &nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">LinkTo</span> <span style="color:#D19A66;">@route</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"configs"</span><span style="color:#ABB2BF;">&gt;</span>Configs<span style="color:#ABB2BF;">&lt;/</span><span style="color:#E06C75;">LinkTo</span><span style="color:#ABB2BF;">&gt;</span><br>
                &nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;/:</span><span style="color:#E06C75;">nav</span><span style="color:#ABB2BF;">&gt;</span><br>
                <span style="color:#ABB2BF;">&lt;/</span><span style="color:#E06C75;">UemsHeaderNav</span><span style="color:#ABB2BF;">&gt;</span>
              </div>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="rtl-support" class="doc-h3">RTL Support</h3>
            <ul class="doc-list">
              <li>In RTL layouts, the logo zone moves to the far right and the utility cluster to the far left. Tab order is reversed visually.</li>
              <li>The search bar placeholder text and &#8984;K hint badge align correctly in RTL via the <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">dir="rtl"</code> attribute on the header or page root.</li>
              <li>Icon-only utility buttons (Search, Settings, Notifications, etc.) are direction-neutral and require no mirroring.</li>
              <li>The Customer Selector chevron direction should flip to indicate dropdown direction in RTL contexts.</li>
            </ul>
          </div>
        </div>

        <!-- ========== ACCESSIBILITY ========== -->
        <div class="tab-content" id="tab-accessibility" style="display:none;padding-top:32px;">
          <h2 id="accessibility" class="doc-section-title">Accessibility</h2>
          <p class="doc-section-subtitle">Guidelines for ensuring the Header Navigation is accessible across assistive technologies.</p>

          <div class="doc-section">
            <h3 id="keyboard-interaction" class="doc-h3">Keyboard Interaction</h3>
            <table class="size-table">
              <thead><tr><th>Key</th><th>Action</th></tr></thead>
              <tbody>
                <tr><td><code>Tab</code></td><td>Moves focus through interactive elements: logo (home link), nav tabs, utility buttons, avatar.</td></tr>
                <tr><td><code>Shift+Tab</code></td><td>Moves focus backward through the header's interactive elements.</td></tr>
                <tr><td><code>Enter</code></td><td>Activates the focused tab link, utility button, or opens the customer selector dropdown.</td></tr>
                <tr><td><code>Escape</code></td><td>Closes the overflow menu (<code>&#8943;</code>) or customer selector dropdown if open.</td></tr>
              </tbody>
            </table>
            <div style="margin-top:16px;padding:16px 20px;background:rgba(37,99,235,0.05);border:1px solid rgba(37,99,235,0.15);border-radius:12px;">
              <p style="font-size:14px;color:var(--prism-text);line-height:1.6;margin:0;">Provide a visually hidden "Skip to main content" link before the header so keyboard users can bypass the full navigation.</p>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="aria-attributes-screen-reader-guidance" class="doc-h3">ARIA Attributes &amp; Screen Reader Guidance</h3>
            <ul class="doc-list">
              <li><strong>Landmark:</strong> Wrap the header in <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;header role="banner"&gt;</code> for proper landmark identification.</li>
              <li><strong>Nav landmark:</strong> The tab group must be in <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;nav aria-label="Primary navigation"&gt;</code>.</li>
              <li><strong>Active tab:</strong> The active tab link gets <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-current="page"</code>.</li>
              <li><strong>Icon-only buttons:</strong> Settings, Notifications, Bookmark, Link, Bento, and Search icons must each have <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-label</code> describing their purpose.</li>
              <li><strong>Customer Selector:</strong> Must use <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-haspopup="listbox"</code> and <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-expanded</code> on the trigger.</li>
              <li><strong>Overflow menu:</strong> The <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&#8943;</code> button needs <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-label="More navigation items"</code> and <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-expanded</code> toggled.</li>
              <li><strong>Avatar:</strong> Must have <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-label="User menu"</code>; opens a dropdown when activated.</li>
              <li><strong>Skip link:</strong> Provide a visually hidden "Skip to main content" link before the header for keyboard users.</li>
            </ul>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="focus-state-design" class="doc-h3">Focus State Design</h3>
            <ul class="doc-list">
              <li>All interactive items (tabs, utility buttons, avatar, customer selector) must have a visible <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">:focus-visible</code> outline.</li>
              <li>Use a 2px offset focus ring in Brand Blue (#0C66E4) or the system default for high visibility against the white header background.</li>
              <li>Focus order should follow the visual layout: Logo &#8594; Nav tabs / Search &#8594; Utility cluster (left to right).</li>
            </ul>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="color-contrast-minimums" class="doc-h3">Color Contrast Minimums<span class="h3-badge" style="background:rgba(34,197,94,0.15);color:#16a34a;">WCAG AA Pass</span></h3>
            <p class="doc-section-subtitle">Active tab blue (#0C66E4) on white (#FFFFFF) meets WCAG AA for normal text.</p>
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px;margin-top:24px;">
              <div style="background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;overflow:hidden;">
                <div style="background:var(--prism-violet);padding:28px 24px;text-align:center;color:#fff;"><div style="font-size:24px;font-weight:600;">Home</div></div>
                <div style="padding:16px 24px;display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--prism-border);"><div><div style="font-size:13px;color:var(--prism-text-muted);font-weight:600;">ACTIVE TAB</div><div style="font-size:15px;color:var(--prism-text);font-family:monospace;margin-top:4px;">#0C66E4 on #FFF</div></div><div style="text-align:right;"><div style="display:inline-flex;align-items:center;gap:6px;background:rgba(34,197,94,0.1);color:#16a34a;padding:4px 10px;border-radius:100px;font-size:12px;font-weight:700;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><polyline points="20 6 9 17 4 12"></polyline></svg> ~4.6:1</div><div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;font-weight:600;">WCAG AA Pass</div></div></div>
              </div>
              <div style="background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;overflow:hidden;">
                <div style="background:var(--prism-surface);padding:28px 24px;text-align:center;color:var(--prism-text);border-bottom:1px solid var(--prism-border);"><div style="font-size:24px;font-weight:600;">Configs</div></div>
                <div style="padding:16px 24px;display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--prism-border);"><div><div style="font-size:13px;color:var(--prism-text-muted);font-weight:600;">INACTIVE TAB</div><div style="font-size:15px;color:var(--prism-text);font-family:monospace;margin-top:4px;">#292A2E on #FFF</div></div><div style="text-align:right;"><div style="display:inline-flex;align-items:center;gap:6px;background:rgba(34,197,94,0.1);color:#16a34a;padding:4px 10px;border-radius:100px;font-size:12px;font-weight:700;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><polyline points="20 6 9 17 4 12"></polyline></svg> 15.5:1</div><div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;font-weight:600;">WCAG AAA Pass</div></div></div>
              </div>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="touch-target-size" class="doc-h3">Touch Target Size</h3>
            <p class="doc-section-subtitle">All interactive elements in the header must meet minimum touch target guidelines.</p>
            <div style="margin-top:16px;padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;display:flex;align-items:center;gap:24px;">
              <div style="width:44px;height:44px;background:rgba(37,99,235,0.1);border:1px dashed var(--prism-violet);border-radius:8px;display:flex;align-items:center;justify-content:center;color:var(--prism-violet);font-size:13px;font-weight:600;flex-shrink:0;">44px</div>
              <div><div style="font-weight:600;font-size:15px;color:var(--prism-text);">Minimum touch target: 44&times;44px</div><div style="font-size:14px;color:var(--prism-text-muted);margin-top:4px;">Although the header is 40px tall, utility icon buttons should use 44px hit areas (extending above/below the visible icon) to meet WCAG 2.5.5 Target Size requirements. Tab links should have sufficient inline padding.</div></div>
            </div>
          </div>
        </div>

