    <main class="main-panel">
      <div class="page-header-area">
        <h1 class="page-title">Page Header</h1>
        <p class="page-desc">A full-width layout component that anchors every page. It provides a consistent location for the breadcrumb trail, page title, contextual actions, metadata summary, and tab-based navigation. Four Structure variants progressively compose these zones to match page complexity.</p>
        <nav class="content-tabs">
          <button class="tab-item active">Overview</button>
          <button class="tab-item">Style</button>
          <button class="tab-item">Usage</button>
          <button class="tab-item">Code</button>
          <button class="tab-item">Accessibility</button>
        </nav>
      </div>

      <div class="main-content-area">
        <div class="main-content-inner">

        <!-- ========== OVERVIEW ========== -->
        <div class="tab-content" id="tab-overview">
          <h3 id="anatomy" class="doc-h3">Anatomy</h3>
          <div class="anatomy-diagram">
            <div style="display:flex;flex-direction:column;gap:32px;margin:20px 0;">
              <!-- Full variant anatomy -->
              <div style="position:relative;border:2px dashed rgba(37,99,235,0.4);border-radius:12px;padding:16px 0;">
                <!-- Breadcrumb row -->
                <div style="padding:0 20px;margin-bottom:12px;display:flex;align-items:center;gap:4px;">
                  <div style="position:absolute;left:-30px;top:16px;display:flex;align-items:center;gap:6px;"><span class="anat-marker-inline">1</span><div style="width:10px;height:2px;background:#2563eb;"></div></div>
                  <span style="font-size:12px;color:var(--prism-text-muted);">Label</span>
                  <span style="font-size:12px;color:var(--prism-text-muted);opacity:0.5;">&#8250;</span>
                  <span style="font-size:12px;color:var(--prism-text-muted);">Label</span>
                  <span style="font-size:12px;color:var(--prism-text-muted);opacity:0.5;">&#8250;</span>
                  <span style="font-size:12px;color:var(--prism-text);">Current Page</span>
                </div>
                <!-- Title row -->
                <div style="padding:0 20px;margin-bottom:12px;display:flex;align-items:center;gap:8px;">
                  <div style="position:absolute;left:-30px;top:48px;display:flex;align-items:center;gap:6px;"><span class="anat-marker-inline">2</span><div style="width:10px;height:2px;background:#2563eb;"></div></div>
                  <span style="font-size:16px;font-weight:600;color:var(--prism-text);">Page Title</span>
                  <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color:var(--prism-text-muted);"><path d="M6 9l6 6 6-6"/></svg>
                  <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color:var(--prism-text-muted);"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                  <span class="ph-badge ph-badge-success" style="font-size:12px;">Active</span>
                  <div style="flex:1;"></div>
                  <div style="position:absolute;right:-30px;top:48px;display:flex;align-items:center;gap:6px;"><div style="width:10px;height:2px;background:#2563eb;"></div><span class="anat-marker-inline">6</span></div>
                  <span style="font-size:14px;font-weight:500;padding:6px 12px;border-radius:8px;background:var(--prism-surface-hover);color:var(--prism-text);border:1px solid var(--prism-border);">Button</span>
                  <span style="font-size:14px;font-weight:500;padding:6px 12px;border-radius:8px;background:linear-gradient(135deg,#2563eb,#1d4ed8);color:#fff;">Button</span>
                  <span style="font-size:18px;color:var(--prism-text-muted);letter-spacing:2px;">&#8943;</span>
                </div>
                <!-- Summary row -->
                <div style="padding:0 20px;margin-bottom:12px;display:flex;align-items:center;gap:24px;">
                  <div style="position:absolute;left:-30px;top:88px;display:flex;align-items:center;gap:6px;"><span class="anat-marker-inline">7</span><div style="width:10px;height:2px;background:#2563eb;"></div></div>
                  <span style="font-size:12px;display:flex;align-items:center;gap:6px;"><span style="color:var(--prism-text-muted);">Status</span><span class="ph-status-dot ph-status-dot-success"></span><span style="color:var(--prism-text);">Active</span></span>
                  <span style="font-size:12px;"><span style="color:var(--prism-text-muted);">Created</span> <span style="color:var(--prism-text);">Mar 15, 2026</span></span>
                  <span style="font-size:12px;"><span style="color:var(--prism-text-muted);">Owner</span> <span style="color:var(--prism-text);">John Doe</span></span>
                  <span style="font-size:12px;display:flex;align-items:center;gap:6px;"><span style="color:var(--prism-text-muted);">Priority</span><span class="ph-badge ph-badge-error" style="font-size:11px;">Critical</span></span>
                </div>
                <!-- Tab bar -->
                <div style="padding:0 20px;">
                  <div style="position:absolute;left:-30px;bottom:24px;display:flex;align-items:center;gap:6px;"><span class="anat-marker-inline">8</span><div style="width:10px;height:2px;background:#2563eb;"></div></div>
                  <div style="display:flex;gap:0;border-bottom:1px solid var(--prism-border);">
                    <span style="font-size:14px;font-weight:500;padding:8px 12px;color:var(--prism-violet);border-bottom:2px solid var(--prism-violet);">Tab Menu <span style="font-size:10px;padding:0 4px;background:rgba(37,99,235,0.1);border-radius:999px;color:var(--prism-violet);">34</span></span>
                    <span style="font-size:14px;font-weight:500;padding:8px 12px;color:var(--prism-text);">Tab Menu <span style="font-size:10px;padding:0 4px;background:var(--prism-surface-hover);border-radius:999px;color:var(--prism-text-muted);">66</span></span>
                    <span style="font-size:14px;font-weight:500;padding:8px 12px;color:var(--prism-text);">Tab Menu <span style="font-size:10px;padding:0 4px;background:var(--prism-surface-hover);border-radius:999px;color:var(--prism-text-muted);">66</span></span>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="anat-legend">
            <div class="anat-legend-item"><span class="anat-marker-inline">1</span><div><strong>Breadcrumb</strong><span>3-item breadcrumb trail. Ancestors use Text/Text-Quaternary; current page uses Text/Text-Primary.</span></div></div>
            <div class="anat-legend-item"><span class="anat-marker-inline">2</span><div><strong>Page Title</strong><span>Primary h1-level text (16 px Semibold). Accompanied by dropdown chevron, favourite star, and status badge.</span></div></div>
            <div class="anat-legend-item"><span class="anat-marker-inline">3</span><div><strong>Chevron</strong><span>16 x 16 px dropdown indicator for contextual title menus.</span></div></div>
            <div class="anat-legend-item"><span class="anat-marker-inline">4</span><div><strong>Star</strong><span>20 x 20 px favourite / bookmark toggle icon.</span></div></div>
            <div class="anat-legend-item"><span class="anat-marker-inline">5</span><div><strong>Title Badge</strong><span>Status badge component (e.g. Active, Critical) positioned after the star.</span></div></div>
            <div class="anat-legend-item"><span class="anat-marker-inline">6</span><div><strong>Actions</strong><span>Right-aligned row containing a secondary button, primary button, and overflow icon button.</span></div></div>
            <div class="anat-legend-item"><span class="anat-marker-inline">7</span><div><strong>Summary Section</strong><span>Horizontal row of 4 metadata items (Status, Created, Owner, Priority). Visible in With Summary and Full.</span></div></div>
            <div class="anat-legend-item"><span class="anat-marker-inline">8</span><div><strong>Tab Bar</strong><span>Underline-style tab navigation with 5 tabs, each with a label, icon, and count badge. Visible in With Tabs and Full.</span></div></div>
          </div>

          <hr class="doc-divider"/>

          <div style="margin-bottom:64px;">
            <h2 id="live-demo" class="doc-section-title" style="margin-bottom:8px;">Preview</h2>
            <p class="doc-section-subtitle" style="margin-bottom:28px;">Explore all four Page Header structure variants.</p>
            <div class="demo-container">
<div class="demo-canvas" style="flex-direction:column;gap:40px;padding:40px 32px;align-items:stretch;">
                <!-- Default variant -->
                <div>
                  <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--prism-text-muted);margin-bottom:12px;">Default</div>
                  <div class="ph-component">
                    <div class="ph-inner">
                      <div class="ph-breadcrumb"><span class="ph-bc-ancestor">Home</span><span class="ph-bc-sep">&#8250;</span><span class="ph-bc-ancestor">Settings</span><span class="ph-bc-sep">&#8250;</span><span class="ph-bc-current">User Management</span></div>
                      <div class="ph-title-row">
                        <div class="ph-title-left">
                          <div class="ph-title-text">User Management <svg class="ph-chevron" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 9l6 6 6-6"/></svg></div>
                          <svg class="ph-star" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
