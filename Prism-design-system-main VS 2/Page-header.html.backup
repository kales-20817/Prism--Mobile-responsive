                      </div>
                    </div>
                  </div>
                </div>
                <!-- With Summary variant -->
                <div>
                  <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--prism-text-muted);margin-bottom:12px;">With Summary</div>
                  <div class="ph-component">
                    <div class="ph-inner">
                      <div class="ph-breadcrumb"><span class="ph-bc-ancestor">Home</span><span class="ph-bc-sep">&#8250;</span><span class="ph-bc-ancestor">Invoices</span><span class="ph-bc-sep">&#8250;</span><span class="ph-bc-current">Invoice #1042</span></div>
                      <div class="ph-title-row">
