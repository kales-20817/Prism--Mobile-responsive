        <!-- ========== CODE ========== -->
        <div class="tab-content" id="tab-code" style="display:none;padding-top:32px;">
          <h2 id="live-demo-code" class="doc-section-title">Live demo (Code)</h2>
          <p class="doc-section-subtitle">Configure the Page Header component and view generated JSX.</p>
          <div class="code-playground">
            <div class="cp-toolbar">
              <div class="cp-control-group"><label class="cp-label">Structure</label><select class="cp-select" id="pg-structure"><option value="Default">Default</option><option value="With Summary">With Summary</option><option value="With Tabs">With Tabs</option><option value="Full" selected>Full</option></select></div>
              <div class="cp-control-group"><label class="cp-label">Title</label><input class="cp-select" id="pg-title" type="text" value="Page Title" style="width:100%;"></div>
              <div class="cp-control-group"><label class="cp-label">Show Badge</label><select class="cp-select" id="pg-badge"><option value="true">Yes</option><option value="false">No</option></select></div>
              <div class="cp-control-group"><label class="cp-label">Show Star</label><select class="cp-select" id="pg-star"><option value="true">Yes</option><option value="false">No</option></select></div>
            </div>
            <div class="cp-preview" id="pg-preview-area" style="padding:32px;flex-direction:column;align-items:stretch;">
              <div class="ph-component" id="pg-ph-el">
                <div class="ph-inner" id="pg-ph-inner">
                  <div class="ph-breadcrumb" id="pg-ph-bc"><span class="ph-bc-ancestor">Home</span><span class="ph-bc-sep">&#8250;</span><span class="ph-bc-ancestor">Section</span><span class="ph-bc-sep">&#8250;</span><span class="ph-bc-current">Page Title</span></div>
                  <div class="ph-title-row">
                    <div class="ph-title-left">
                      <div class="ph-title-text" id="pg-ph-title">Page Title <svg class="ph-chevron" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 9l6 6 6-6"/></svg></div>
                      <svg class="ph-star" id="pg-ph-star" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                      <span class="ph-badge ph-badge-success" id="pg-ph-badge">Active</span>
                    </div>
                    <div class="ph-actions">
                      <button class="ph-btn ph-btn-secondary">Export</button>
                      <button class="ph-btn ph-btn-primary">Create</button>
                      <button class="ph-btn-overflow">&#8943;</button>
                    </div>
                  </div>
                  <div class="ph-summary" id="pg-ph-summary" style="display:none;">
                    <div class="ph-summary-item"><span class="ph-summary-label">Status</span><span class="ph-status-dot ph-status-dot-success"></span><span class="ph-summary-value">Active</span></div>
                    <div class="ph-summary-item"><span class="ph-summary-label">Created</span><span class="ph-summary-value">Mar 15, 2026</span></div>
                    <div class="ph-summary-item"><span class="ph-summary-label">Owner</span><span class="ph-summary-value">John Doe</span></div>
                    <div class="ph-summary-item"><span class="ph-summary-label">Priority</span><span class="ph-badge ph-badge-error" style="font-size:11px;">Critical</span></div>
                  </div>
                  <div class="ph-divider" id="pg-ph-divider" style="display:none;"></div>
                  <div class="ph-tabbar" id="pg-ph-tabbar" style="display:none;">
                    <div class="ph-tabs">
                      <span class="ph-tab active">Overview <span class="ph-tab-count">34</span></span>
                      <span class="ph-tab">Tasks <span class="ph-tab-count">66</span></span>
                      <span class="ph-tab">Files <span class="ph-tab-count">12</span></span>
                      <span class="ph-tab">Discussion <span class="ph-tab-count">5</span></span>
                      <span class="ph-tab">Timeline <span class="ph-tab-count">66</span></span>
                    </div>
                    <div class="ph-tab-divider"></div>
                  </div>
                </div>
              </div>
            </div>
            <div class="cp-code-header">
              <div style="font-size:13.5px;font-weight:600;color:var(--prism-text);">JSX</div>
              <button class="cp-action-btn" id="pg-copy-btn"><svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2"/></svg> Copy code</button>
            </div>
            <div class="cp-code-area" id="pg-code-output"></div>
          </div>
          <script>
          (function(){
            var els = {structure:document.getElementById('pg-structure'),title:document.getElementById('pg-title'),badge:document.getElementById('pg-badge'),star:document.getElementById('pg-star')};
            var codeOut = document.getElementById('pg-code-output');
            var copyBtn = document.getElementById('pg-copy-btn');
            function esc(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
            function update(){
              var st=els.structure.value, t=els.title.value||'Page Title', b=els.badge.value==='true', s=els.star.value==='true';
              var titleEl=document.getElementById('pg-ph-title');
              titleEl.innerHTML=t+' <svg class="ph-chevron" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 9l6 6 6-6"/></svg>';
              var bcCurrent=document.querySelector('#pg-ph-bc .ph-bc-current');
              if(bcCurrent) bcCurrent.textContent=t;
              document.getElementById('pg-ph-badge').style.display=b?'inline-flex':'none';
              document.getElementById('pg-ph-star').style.display=s?'block':'none';
              var showSummary=st==='With Summary'||st==='Full';
              var showTabs=st==='With Tabs'||st==='Full';
              var showDivider=st==='With Summary';
              document.getElementById('pg-ph-summary').style.display=showSummary?'flex':'none';
              document.getElementById('pg-ph-divider').style.display=showDivider?'block':'none';
              document.getElementById('pg-ph-tabbar').style.display=showTabs?'flex':'none';
              var code='<PageHeader\n  structure="'+st+'"\n  title="'+t+'"';
              if(b) code+='\n  showBadge\n  badge={<Badge status="Success" label="Active" />}';
              if(s) code+='\n  showStar';
              code+='\n  primaryAction={<Button variant="Primary" size="Small">Create</Button>}\n  secondaryAction={<Button variant="Secondary" size="Small">Export</Button>}';
              if(showSummary) code+='\n  summaryItems={[\n    { label: "Status",  value: <StatusIndicator status="Success" label="Active" /> },\n    { label: "Created", value: "Mar 15, 2026" },\n    { label: "Owner",   value: "John Doe" },\n    { label: "Priority", value: <Badge status="Error" label="Critical" /> },\n  ]}';
              if(showTabs) code+='\n  tabs={[\n    { label: "Overview", count: 34, active: true },\n    { label: "Tasks",    count: 66 },\n    { label: "Files",    count: 12 },\n    { label: "Discussion", count: 5 },\n    { label: "Timeline", count: 66 },\n  ]}';
              code+='\n/>';
              codeOut.innerHTML=esc(code).replace(/&lt;(\/?)(PageHeader|Badge|Button|StatusIndicator)/g,'&lt;$1<span style="color:#a78bfa;">$2</span>').replace(/(structure|title|showBadge|showStar|badge|primaryAction|secondaryAction|summaryItems|tabs|variant|status|label|size|count|active|value)=/g,'<span style="color:#38bdf8;">$1</span>=').replace(/&quot;(.*?)&quot;/g,'<span style="color:#34d399;">"$1"</span>');
            }
            Object.values(els).forEach(function(e){e.addEventListener(e.tagName==='INPUT'?'input':'change',update);});
            copyBtn.addEventListener('click',function(){
              var r=document.createElement('div');r.innerHTML=codeOut.innerHTML;
              navigator.clipboard.writeText(r.innerText).then(function(){
                var o=copyBtn.innerHTML;copyBtn.innerHTML='<svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Copied!';setTimeout(function(){copyBtn.innerHTML=o;},2000);
              });
            });
            update();
          })();
          </script>

          <hr class="doc-divider"/>
          <div class="doc-section">
            <h3 id="component-api-properties" class="doc-h3">Component API &amp; Properties</h3>
            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Variant Prop</h4>
            <table class="size-table" style="margin-bottom:32px;">
              <thead><tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
              <tbody>
                <tr><td><code>structure</code></td><td><code>'Default' | 'With Summary' | 'With Tabs' | 'Full'</code></td><td><code>'Default'</code></td><td>Controls which rows are rendered.</td></tr>
              </tbody>
            </table>
            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Title Area Toggles</h4>
            <table class="size-table" style="margin-bottom:32px;">
              <thead><tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
              <tbody>
                <tr><td><code>title</code></td><td>string</td><td><code>"Page Title"</code></td><td>The primary page title text.</td></tr>
                <tr><td><code>showBreadcrumbs</code></td><td>boolean</td><td><code>true</code></td><td>Shows or hides the breadcrumb row.</td></tr>
                <tr><td><code>showBackIcon</code></td><td>boolean</td><td><code>false</code></td><td>Shows a back-navigation icon before the title.</td></tr>
                <tr><td><code>showChevron</code></td><td>boolean</td><td><code>true</code></td><td>Shows the dropdown chevron next to the title.</td></tr>
                <tr><td><code>showStar</code></td><td>boolean</td><td><code>true</code></td><td>Shows the favourite/star icon.</td></tr>
                <tr><td><code>showBadge</code></td><td>boolean</td><td><code>true</code></td><td>Shows the status badge after the star.</td></tr>
                <tr><td><code>showDescription</code></td><td>boolean</td><td><code>false</code></td><td>Shows the optional description subtitle below the title.</td></tr>
                <tr><td><code>description</code></td><td>string</td><td><code>"A brief description..."</code></td><td>Subtitle text, visible only when showDescription=true.</td></tr>
              </tbody>
            </table>
            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Actions</h4>
            <table class="size-table" style="margin-bottom:32px;">
              <thead><tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
              <tbody>
                <tr><td><code>showActions</code></td><td>boolean</td><td><code>true</code></td><td>Shows or hides the entire actions row.</td></tr>
                <tr><td><code>showOverflow</code></td><td>boolean</td><td><code>true</code></td><td>Shows or hides the overflow icon button.</td></tr>
                <tr><td><code>primaryAction</code></td><td>ReactNode</td><td>Primary Button</td><td>Instance-swap slot for the primary action button.</td></tr>
                <tr><td><code>secondaryAction</code></td><td>ReactNode</td><td>Secondary Button</td><td>Instance-swap slot for the secondary action button.</td></tr>
                <tr><td><code>overflowMenu</code></td><td>ReactNode</td><td>Icon Button (Tertiary)</td><td>Instance-swap slot for the overflow menu trigger.</td></tr>
              </tbody>
            </table>
            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Sub-component Instance-swaps</h4>
            <table class="size-table">
              <thead><tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
              <tbody>
                <tr><td><code>badge</code></td><td>ReactNode</td><td>Badge (Success state)</td><td>Instance-swap slot for the title area status badge.</td></tr>
              </tbody>
            </table>
          </div>
          <hr class="doc-divider"/>
          <div class="doc-section">
            <h3 id="code-examples" class="doc-h3">Code Examples</h3>
            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Default &#8212; title with actions</h4>
            <div class="cp-code-area" style="border-radius:12px;margin-bottom:24px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;">
                <span style="color:#ABB2BF;">&lt;</span><span style="color:#a78bfa;">PageHeader</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">structure</span>=<span style="color:#34d399;">"Default"</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">title</span>=<span style="color:#34d399;">"User Management"</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">showBadge</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">badge</span>={&lt;<span style="color:#a78bfa;">Badge</span> <span style="color:#38bdf8;">status</span>=<span style="color:#34d399;">"Success"</span> <span style="color:#38bdf8;">label</span>=<span style="color:#34d399;">"Active"</span> /&gt;}<br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">primaryAction</span>={&lt;<span style="color:#a78bfa;">Button</span> <span style="color:#38bdf8;">variant</span>=<span style="color:#34d399;">"Primary"</span> <span style="color:#38bdf8;">size</span>=<span style="color:#34d399;">"Small"</span>&gt;Create User&lt;/<span style="color:#a78bfa;">Button</span>&gt;}<br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">secondaryAction</span>={&lt;<span style="color:#a78bfa;">Button</span> <span style="color:#38bdf8;">variant</span>=<span style="color:#34d399;">"Secondary"</span> <span style="color:#38bdf8;">size</span>=<span style="color:#34d399;">"Small"</span>&gt;Export&lt;/<span style="color:#a78bfa;">Button</span>&gt;}<br>
                <span style="color:#ABB2BF;">/&gt;</span>
              </div>
            </div>
            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Full &#8212; complex record page</h4>
            <div class="cp-code-area" style="border-radius:12px;margin-bottom:24px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;">
                <span style="color:#ABB2BF;">&lt;</span><span style="color:#a78bfa;">PageHeader</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">structure</span>=<span style="color:#34d399;">"Full"</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">title</span>=<span style="color:#34d399;">"Customer: Acme Corp"</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">badge</span>={&lt;<span style="color:#a78bfa;">Badge</span> <span style="color:#38bdf8;">status</span>=<span style="color:#34d399;">"Success"</span> <span style="color:#38bdf8;">label</span>=<span style="color:#34d399;">"Active"</span> /&gt;}<br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">showStar</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">showChevron</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">primaryAction</span>={&lt;<span style="color:#a78bfa;">Button</span> <span style="color:#38bdf8;">variant</span>=<span style="color:#34d399;">"Primary"</span> <span style="color:#38bdf8;">size</span>=<span style="color:#34d399;">"Small"</span>&gt;New Deal&lt;/<span style="color:#a78bfa;">Button</span>&gt;}<br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">secondaryAction</span>={&lt;<span style="color:#a78bfa;">Button</span> <span style="color:#38bdf8;">variant</span>=<span style="color:#34d399;">"Secondary"</span> <span style="color:#38bdf8;">size</span>=<span style="color:#34d399;">"Small"</span>&gt;Edit&lt;/<span style="color:#a78bfa;">Button</span>&gt;}<br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">summaryItems</span>={[<br>
                &nbsp;&nbsp;&nbsp;&nbsp;{ <span style="color:#38bdf8;">label</span>: <span style="color:#34d399;">"Status"</span>, <span style="color:#38bdf8;">value</span>: &lt;<span style="color:#a78bfa;">StatusIndicator</span> <span style="color:#38bdf8;">status</span>=<span style="color:#34d399;">"Success"</span> <span style="color:#38bdf8;">label</span>=<span style="color:#34d399;">"Active"</span> /&gt; },<br>
                &nbsp;&nbsp;&nbsp;&nbsp;{ <span style="color:#38bdf8;">label</span>: <span style="color:#34d399;">"Created"</span>, <span style="color:#38bdf8;">value</span>: <span style="color:#34d399;">"Jan 10, 2025"</span> },<br>
                &nbsp;&nbsp;&nbsp;&nbsp;{ <span style="color:#38bdf8;">label</span>: <span style="color:#34d399;">"Owner"</span>, <span style="color:#38bdf8;">value</span>: <span style="color:#34d399;">"Jane Smith"</span> },<br>
                &nbsp;&nbsp;&nbsp;&nbsp;{ <span style="color:#38bdf8;">label</span>: <span style="color:#34d399;">"Tier"</span>, <span style="color:#38bdf8;">value</span>: &lt;<span style="color:#a78bfa;">Badge</span> <span style="color:#38bdf8;">status</span>=<span style="color:#34d399;">"Info"</span> <span style="color:#38bdf8;">label</span>=<span style="color:#34d399;">"Enterprise"</span> /&gt; },<br>
                &nbsp;&nbsp;]}<br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">tabs</span>={[<br>
                &nbsp;&nbsp;&nbsp;&nbsp;{ <span style="color:#38bdf8;">label</span>: <span style="color:#34d399;">"Overview"</span>, <span style="color:#38bdf8;">count</span>: <span style="color:#E5C07B;">0</span>, <span style="color:#38bdf8;">active</span>: <span style="color:#C678DD;">true</span> },<br>
                &nbsp;&nbsp;&nbsp;&nbsp;{ <span style="color:#38bdf8;">label</span>: <span style="color:#34d399;">"Contacts"</span>, <span style="color:#38bdf8;">count</span>: <span style="color:#E5C07B;">18</span> },<br>
                &nbsp;&nbsp;&nbsp;&nbsp;{ <span style="color:#38bdf8;">label</span>: <span style="color:#34d399;">"Deals"</span>, <span style="color:#38bdf8;">count</span>: <span style="color:#E5C07B;">7</span> },<br>
                &nbsp;&nbsp;&nbsp;&nbsp;{ <span style="color:#38bdf8;">label</span>: <span style="color:#34d399;">"Activities"</span>, <span style="color:#38bdf8;">count</span>: <span style="color:#E5C07B;">42</span> },<br>
                &nbsp;&nbsp;&nbsp;&nbsp;{ <span style="color:#38bdf8;">label</span>: <span style="color:#34d399;">"Files"</span>, <span style="color:#38bdf8;">count</span>: <span style="color:#E5C07B;">11</span> },<br>
                &nbsp;&nbsp;]}<br>
                <span style="color:#ABB2BF;">/&gt;</span>
              </div>
            </div>
            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Minimal &#8212; no breadcrumb, no badge, no overflow</h4>
            <div class="cp-code-area" style="border-radius:12px;margin-bottom:24px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;">
                <span style="color:#ABB2BF;">&lt;</span><span style="color:#a78bfa;">PageHeader</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">structure</span>=<span style="color:#34d399;">"Default"</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">title</span>=<span style="color:#34d399;">"Settings"</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">showBreadcrumbs</span>={<span style="color:#C678DD;">false</span>}<br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">showBadge</span>={<span style="color:#C678DD;">false</span>}<br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">showStar</span>={<span style="color:#C678DD;">false</span>}<br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">showChevron</span>={<span style="color:#C678DD;">false</span>}<br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">showOverflow</span>={<span style="color:#C678DD;">false</span>}<br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">primaryAction</span>={&lt;<span style="color:#a78bfa;">Button</span> <span style="color:#38bdf8;">variant</span>=<span style="color:#34d399;">"Primary"</span> <span style="color:#38bdf8;">size</span>=<span style="color:#34d399;">"Small"</span>&gt;Save Changes&lt;/<span style="color:#a78bfa;">Button</span>&gt;}<br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">secondaryAction</span>={&lt;<span style="color:#a78bfa;">Button</span> <span style="color:#38bdf8;">variant</span>=<span style="color:#34d399;">"Secondary"</span> <span style="color:#38bdf8;">size</span>=<span style="color:#34d399;">"Small"</span>&gt;Cancel&lt;/<span style="color:#a78bfa;">Button</span>&gt;}<br>
                <span style="color:#ABB2BF;">/&gt;</span>
              </div>
            </div>
            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">With back icon (no breadcrumb)</h4>
            <div class="cp-code-area" style="border-radius:12px;margin-bottom:24px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;">
                <span style="color:#ABB2BF;">&lt;</span><span style="color:#a78bfa;">PageHeader</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">structure</span>=<span style="color:#34d399;">"Default"</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">title</span>=<span style="color:#34d399;">"Edit Profile"</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">showBreadcrumbs</span>={<span style="color:#C678DD;">false</span>}<br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">showBackIcon</span><br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">showBadge</span>={<span style="color:#C678DD;">false</span>}<br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">showChevron</span>={<span style="color:#C678DD;">false</span>}<br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">showStar</span>={<span style="color:#C678DD;">false</span>}<br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">primaryAction</span>={&lt;<span style="color:#a78bfa;">Button</span> <span style="color:#38bdf8;">variant</span>=<span style="color:#34d399;">"Primary"</span> <span style="color:#38bdf8;">size</span>=<span style="color:#34d399;">"Small"</span>&gt;Save&lt;/<span style="color:#a78bfa;">Button</span>&gt;}<br>
                &nbsp;&nbsp;<span style="color:#38bdf8;">secondaryAction</span>={&lt;<span style="color:#a78bfa;">Button</span> <span style="color:#38bdf8;">variant</span>=<span style="color:#34d399;">"Secondary"</span> <span style="color:#38bdf8;">size</span>=<span style="color:#34d399;">"Small"</span>&gt;Discard&lt;/<span style="color:#a78bfa;">Button</span>&gt;}<br>
                <span style="color:#ABB2BF;">/&gt;</span>
              </div>
            </div>
          </div>
          <hr class="doc-divider"/>
          <div class="doc-section">
            <h3 id="child-layer-structure" class="doc-h3">Child Layer Structure</h3>
            <div class="cp-code-area" style="border-radius:12px;margin-top:16px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13px;line-height:1.7;color:#e2e8f0;">
                <span style="color:#a78bfa;">Page Header</span> <span style="color:#94a3b8;">(VERTICAL, paddingTop/Bottom: 12 px, gap: 12 px)</span><br>
                <span style="color:#94a3b8;">&#9492;&#9472;&#9472;</span> <span style="color:#a78bfa;">Content</span> <span style="color:#94a3b8;">(VERTICAL, FILL width, gap: 12 px)</span><br>
                &nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#94a3b8;">&#9500;&#9472;&#9472;</span> <span style="color:#38bdf8;">Breadcrumbs row</span> <span style="color:#94a3b8;">(HORIZONTAL, paddingL/R: 20 px)</span><br>
                &nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#94a3b8;">&#9500;&#9472;&#9472;</span> <span style="color:#38bdf8;">page title content</span> <span style="color:#94a3b8;">(HORIZONTAL, FILL, paddingL/R: 20 px, gap: 8 px)</span><br>
                &nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#94a3b8;">&#9474;</span>&nbsp;&nbsp;&nbsp;<span style="color:#94a3b8;">&#9500;&#9472;&#9472;</span> Title Row <span style="color:#94a3b8;">(gap: 4 px)</span><br>
                &nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#94a3b8;">&#9474;</span>&nbsp;&nbsp;&nbsp;<span style="color:#94a3b8;">&#9492;&#9472;&#9472;</span> Actions <span style="color:#94a3b8;">(HORIZONTAL, HUG, gap: 8 px)</span><br>
                &nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#94a3b8;">&#9500;&#9472;&#9472;</span> <span style="color:#34d399;">Summary Section</span> <span style="color:#94a3b8;">[With Summary + Full]</span><br>
                &nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#94a3b8;">&#9500;&#9472;&#9472;</span> <span style="color:#34d399;">Divider</span> <span style="color:#94a3b8;">[1 px, Border-Tertiary &#8212; With Summary]</span><br>
                &nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#94a3b8;">&#9492;&#9472;&#9472;</span> <span style="color:#34d399;">Tab bar</span> <span style="color:#94a3b8;">[With Tabs + Full]</span>
              </div>
            </div>
          </div>
          <hr class="doc-divider"/>
          <div class="doc-section">
            <h3 id="rtl-support" class="doc-h3">RTL Support</h3>
            <ul class="doc-list">
              <li>RTL is handled at sub-component level (Breadcrumb, Tab Bar, Buttons each have RTL variant properties).</li>
              <li>Set <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">dir="rtl"</code> on the page <code>&lt;html&gt;</code> or <code>&lt;header&gt;</code> element.</li>
              <li>No additional variant axes exist on the Page Header component set itself for RTL.</li>
            </ul>
          </div>
        </div>

        <!-- ========== ACCESSIBILITY ========== -->
        <div class="tab-content" id="tab-accessibility" style="display:none;padding-top:32px;">
          <h2 id="accessibility" class="doc-section-title">Accessibility</h2>
          <p class="doc-section-subtitle">Guidelines for ensuring the Page Header component is accessible across assistive technologies.</p>
          <div class="doc-section">
            <h3 id="landmark-semantics" class="doc-h3">Landmark &amp; Semantic Structure</h3>
            <ul class="doc-list">
              <li><strong>Landmark:</strong> Wrap the Page Header in <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;header&gt;</code> for page-level landmark semantics.</li>
              <li><strong>Heading level:</strong> The page title should render as <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;h1&gt;</code>. There must be exactly one <code>&lt;h1&gt;</code> per page.</li>
              <li><strong>Skip link:</strong> Provide a "Skip to main content" link that jumps past the Page Header for keyboard and screen reader users.</li>
            </ul>
          </div>
          <hr class="doc-divider"/>
          <div class="doc-section">
            <h3 id="aria-attributes-screen-reader-guidance" class="doc-h3">ARIA Attributes &amp; Screen Reader Guidance</h3>
            <table class="size-table">
              <thead><tr><th>Element</th><th>Requirement</th></tr></thead>
              <tbody>
                <tr><td><strong>Breadcrumb</strong></td><td>Wrap in <code>&lt;nav aria-label="Breadcrumb"&gt;</code>. Mark the current page item with <code>aria-current="page"</code>.</td></tr>
                <tr><td><strong>Actions</strong></td><td>Each button must have a visible label or <code>aria-label</code>. The overflow button needs <code>aria-label="More actions"</code> and <code>aria-haspopup="true"</code>.</td></tr>
                <tr><td><strong>Chevron</strong></td><td>If the title chevron opens a menu, use <code>aria-haspopup="menu"</code> and <code>aria-expanded</code> on the trigger.</td></tr>
                <tr><td><strong>Star / Favourite</strong></td><td>Use <code>aria-label="Add to favourites"</code> / <code>aria-pressed</code> (toggle button).</td></tr>
                <tr><td><strong>Tabs</strong></td><td>Use <code>role="tablist"</code>, <code>role="tab"</code>, <code>aria-selected</code>, and <code>aria-controls</code>. Active tab must have <code>aria-selected="true"</code>.</td></tr>
                <tr><td><strong>Count badges</strong></td><td>Associate count text with tabs via <code>aria-label</code>, e.g. <code>aria-label="Tab Menu, 34 items"</code>.</td></tr>
                <tr><td><strong>Summary labels</strong></td><td>Use <code>&lt;dl&gt;</code> / <code>&lt;dt&gt;</code> / <code>&lt;dd&gt;</code> structure for metadata key-value pairs.</td></tr>
              </tbody>
            </table>
          </div>
          <hr class="doc-divider"/>
          <div class="doc-section">
            <h3 id="keyboard-interaction" class="doc-h3">Keyboard Interaction &amp; Focus Order</h3>
            <table class="size-table">
              <thead><tr><th>Key</th><th>Action</th></tr></thead>
              <tbody>
                <tr><td><code>Tab</code></td><td>Moves focus through interactive elements in reading order: breadcrumb links &#8594; title chevron &#8594; star toggle &#8594; action buttons &#8594; tab items.</td></tr>
                <tr><td><code>Enter / Space</code></td><td>Activates the focused interactive element (button, link, tab, toggle).</td></tr>
                <tr><td><code>Arrow Left / Right</code></td><td>Navigates between tabs when the tablist is focused.</td></tr>
              </tbody>
            </table>
            <div style="margin-top:16px;padding:16px 20px;background:rgba(37,99,235,0.05);border:1px solid rgba(37,99,235,0.15);border-radius:12px;">
              <p style="font-size:14px;color:var(--prism-text);line-height:1.6;margin:0;">Tab order should follow visual reading order: breadcrumb &#8594; title actions (chevron, star) &#8594; buttons &#8594; tabs.</p>
            </div>
          </div>
          <hr class="doc-divider"/>
          <div class="doc-section">
            <h3 id="color-contrast-minimums" class="doc-h3">Color Contrast Minimums<span class="h3-badge" style="background:rgba(34,197,94,0.15);color:#16a34a;">WCAG AA</span></h3>
            <p class="doc-section-subtitle">All text and interactive elements must meet WCAG 2.1 AA contrast requirements.</p>
            <ul class="doc-list">
              <li><strong>Text/Text-Quaternary</strong> (breadcrumb ancestors) must meet WCAG AA 4.5:1 on the page background.</li>
              <li>Primary button: white text on blue gradient meets AAA contrast.</li>
              <li>Active tab label and underline use accent colour tokens with sufficient contrast.</li>
              <li>Badge text colours (success green, error red) are validated against their respective background tints.</li>
            </ul>
          </div>
          <hr class="doc-divider"/>
          <div class="doc-section">
            <h3 id="rtl-accessibility" class="doc-h3">RTL Support</h3>
            <ul class="doc-list">
              <li>RTL is handled at sub-component level &#8212; Breadcrumb, Tab Bar, and Buttons each have RTL variant properties.</li>
              <li>Set <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">dir="rtl"</code> on the page <code>&lt;html&gt;</code> or <code>&lt;header&gt;</code> element.</li>
            </ul>
          </div>
        </div>

        </div><!-- main-content-inner -->

