                <div>
                  <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--prism-text-muted);margin-bottom:12px;">With Tabs</div>
                  <div class="ph-component">
                    <div class="ph-inner">
                      <div class="ph-breadcrumb"><span class="ph-bc-ancestor">Home</span><span class="ph-bc-sep">&#8250;</span><span class="ph-bc-ancestor">Projects</span><span class="ph-bc-sep">&#8250;</span><span class="ph-bc-current">Project Alpha</span></div>
