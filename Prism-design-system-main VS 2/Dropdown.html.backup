    <main class="main-panel">
      <div class="page-header-area">
        <h1 class="page-title">Dropdown Menu</h1>
        <p class="page-desc">A floating panel that presents a list of selectable options triggered by a parent control (button, field, etc.). Supports single selection, multi-selection with confirm/clear actions, and grouped sections.</p>
        <nav class="content-tabs">
          <button class="tab-item active">Overview</button>
          <button class="tab-item">Style</button>
          <button class="tab-item">Usage</button>
          <button class="tab-item">Code</button>
          <button class="tab-item">Accessibility</button>
        </nav>
      </div>

      <div class="main-content-area">
        <div class="main-content-inner">

        <!-- ========== OVERVIEW ========== -->
        <div class="tab-content" id="tab-overview">
          <h3 id="anatomy" class="doc-h3">Anatomy</h3>
          <div class="anatomy-diagram" style="padding:72px 100px;">
            <div style="display:flex;gap:60px;align-items:flex-start;justify-content:center;flex-wrap:wrap;margin:20px 0;">
              <!-- Single Select anatomy -->
              <div style="position:relative;">
                <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--prism-text-muted);margin-bottom:10px;text-align:center;">Single Select</div>
                <div class="dd-panel" style="position:relative;overflow:visible;">
                  <!-- 1 Panel Container: marker left of panel, horizontal line right -->
                  <div style="position:absolute;right:calc(100% + 6px);top:10px;display:flex;align-items:center;gap:6px;z-index:5;"><span class="anat-marker-inline">1</span><div style="width:28px;height:2px;background:#2563eb;"></div></div>
                  <div class="dd-item" style="position:relative;">
                    <!-- 2 Action Item: marker right of Edit row, horizontal line left -->
                    <div style="position:absolute;left:calc(100% + 6px);top:50%;transform:translateY(-50%);display:flex;flex-direction:row-reverse;align-items:center;gap:6px;z-index:5;"><span class="anat-marker-inline">2</span><div style="width:28px;height:2px;background:#2563eb;"></div></div>
                    <svg class="dd-item-icon" viewBox="0 0 24 24" fill="none" stroke="#626870" stroke-width="2"><circle cx="12" cy="12" r="3"/></svg>
                    <span>Edit</span>
                  </div>
                  <div class="dd-item">
                    <svg class="dd-item-icon" viewBox="0 0 24 24" fill="none" stroke="#626870" stroke-width="2"><path d="M16 4h2a2 2 0 012 2v14a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2h2"/><rect x="8" y="2" width="8" height="4" rx="1"/></svg>
                    <span>Duplicate</span>
                  </div>
                  <div class="dd-item">
                    <svg class="dd-item-icon" viewBox="0 0 24 24" fill="none" stroke="#626870" stroke-width="2"><path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
                    <span>Share</span>
                  </div>
                </div>
              </div>
              <!-- Multi Select anatomy -->
              <div style="position:relative;">
                <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--prism-text-muted);margin-bottom:10px;text-align:center;">Multi Select</div>
                <div class="dd-panel" style="position:relative;overflow:visible;">
                  <div class="dd-header" style="position:relative;">
                    <!-- 6 Header: marker above, vertical line down -->
                    <div style="position:absolute;left:20px;bottom:calc(100% + 6px);display:flex;flex-direction:column;align-items:center;gap:4px;z-index:5;"><span class="anat-marker-inline">6</span><div style="width:2px;height:14px;background:#2563eb;"></div></div>
                    <span>Select Options</span>
                    <svg class="dd-header-dismiss" viewBox="0 0 24 24" fill="none" stroke="#626870" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                  </div>
                  <div class="dd-item" style="position:relative;">
                    <!-- 3 Checkbox Item: marker right of Option A, horizontal line left -->
                    <div style="position:absolute;left:calc(100% + 6px);top:50%;transform:translateY(-50%);display:flex;flex-direction:row-reverse;align-items:center;gap:6px;z-index:5;"><span class="anat-marker-inline">3</span><div style="width:28px;height:2px;background:#2563eb;"></div></div>
                    <div class="dd-item-check checked"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></div>
                    <span>Option A</span>
                  </div>
                  <div class="dd-item">
                    <div class="dd-item-check"></div>
                    <span>Option B</span>
                  </div>
                  <div class="dd-item">
                    <div class="dd-item-check"></div>
                    <span>Option C</span>
                  </div>
                  <div class="dd-footer" style="position:relative;">
                    <!-- 7 Footer: marker below, vertical line up -->
                    <div style="position:absolute;right:20px;top:calc(100% + 6px);display:flex;flex-direction:column-reverse;align-items:center;gap:4px;z-index:5;"><span class="anat-marker-inline">7</span><div style="width:2px;height:14px;background:#2563eb;"></div></div>
                    <button class="dd-clear-btn">Clear All</button>
                    <button class="dd-apply-btn">Apply</button>
                  </div>
                </div>
              </div>
              <!-- With Sections anatomy -->
              <div style="position:relative;">
                <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--prism-text-muted);margin-bottom:10px;text-align:center;">With Sections</div>
                <div class="dd-panel" style="position:relative;overflow:visible;">
                  <div class="dd-section-heading" style="position:relative;">
                    Actions
                    <!-- 4 Section Heading: marker right, horizontal line left -->
                    <div style="position:absolute;left:calc(100% + 6px);top:50%;transform:translateY(-50%);display:flex;flex-direction:row-reverse;align-items:center;gap:6px;z-index:5;"><span class="anat-marker-inline">4</span><div style="width:28px;height:2px;background:#2563eb;"></div></div>
                  </div>
                  <div class="dd-item">
                    <svg class="dd-item-icon" viewBox="0 0 24 24" fill="none" stroke="#626870" stroke-width="2"><circle cx="12" cy="12" r="3"/></svg>
                    <span>Edit</span>
                  </div>
                  <div class="dd-item">
                    <svg class="dd-item-icon" viewBox="0 0 24 24" fill="none" stroke="#626870" stroke-width="2"><path d="M16 4h2a2 2 0 012 2v14a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2h2"/><rect x="8" y="2" width="8" height="4" rx="1"/></svg>
                    <span>Duplicate</span>
                  </div>
                  <div class="dd-divider" style="position:relative;">
                    <!-- 5 Divider: marker right, horizontal line left -->
                    <div style="position:absolute;left:calc(100% + 6px);top:50%;transform:translateY(-50%);display:flex;flex-direction:row-reverse;align-items:center;gap:6px;z-index:5;"><span class="anat-marker-inline">5</span><div style="width:28px;height:2px;background:#2563eb;"></div></div>
                  </div>
                  <div class="dd-section-heading">More</div>
                  <div class="dd-item">
                    <svg class="dd-item-icon" viewBox="0 0 24 24" fill="none" stroke="#626870" stroke-width="2"><path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
                    <span>Share</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="anat-legend">
            <div class="anat-legend-item"><span class="anat-marker-inline">1</span><div><strong>Panel Container</strong><span>White background (#FFFFFF), 8px border-radius, elevation shadow, 240px min-width, 4px vertical padding.</span></div></div>
            <div class="anat-legend-item"><span class="anat-marker-inline">2</span><div><strong>Action Item</strong><span>Icon + label row. Used in Single Select and With Sections. Closes menu on click.</span></div></div>
            <div class="anat-legend-item"><span class="anat-marker-inline">3</span><div><strong>Checkbox Item</strong><span>Checkbox + label row. Used in Multi Select. Toggles selection without closing.</span></div></div>
            <div class="anat-legend-item"><span class="anat-marker-inline">4</span><div><strong>Section Heading</strong><span>Uppercase muted label for grouping items. Used in With Sections type.</span></div></div>
            <div class="anat-legend-item"><span class="anat-marker-inline">5</span><div><strong>Divider</strong><span>1px horizontal rule separating groups in the With Sections type.</span></div></div>
            <div class="anat-legend-item"><span class="anat-marker-inline">6</span><div><strong>Header Bar</strong><span>Title text + dismiss button. Shown in Multi Select when Show Header is ON.</span></div></div>
            <div class="anat-legend-item"><span class="anat-marker-inline">7</span><div><strong>Footer Bar</strong><span>Clear All text button + Apply primary button. Shown in Multi Select when Show Footer is ON.</span></div></div>
          </div>

          <hr class="doc-divider"/>

          <div style="margin-bottom:64px;">
            <h2 id="live-demo" class="doc-section-title" style="margin-bottom:8px;">Preview</h2>
            <p class="doc-section-subtitle" style="margin-bottom:28px;">Explore all three dropdown menu types rendered as static panels.</p>
            <div class="demo-container">
<div class="demo-canvas">
                <!-- Single Select -->
                <div style="text-align:center;">
                  <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--prism-text-muted);margin-bottom:10px;">Single Select</div>
                  <div class="dd-panel">
                    <div class="dd-item">
                      <svg class="dd-item-icon" viewBox="0 0 24 24" fill="none" stroke="#626870" stroke-width="2"><circle cx="12" cy="12" r="3"/></svg>
                      <span>Edit</span>
                    </div>
                    <div class="dd-item active">
                      <svg class="dd-item-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 4h2a2 2 0 012 2v14a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2h2"/><rect x="8" y="2" width="8" height="4" rx="1"/></svg>
                      <span>Duplicate</span>
                    </div>
                    <div class="dd-item">
                      <svg class="dd-item-icon" viewBox="0 0 24 24" fill="none" stroke="#626870" stroke-width="2"><path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
                      <span>Share</span>
                    </div>
                    <div class="dd-item">
                      <svg class="dd-item-icon" viewBox="0 0 24 24" fill="none" stroke="#626870" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
                      <span>Delete</span>
                    </div>
                    <div class="dd-item disabled">
                      <svg class="dd-item-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                      <span>Archive</span>
                    </div>
                  </div>
                </div>
                <!-- Multi Select -->
                <div style="text-align:center;">
                  <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--prism-text-muted);margin-bottom:10px;">Multi Select</div>
                  <div class="dd-panel">
                    <div class="dd-header">
                      <span>Select Options</span>
                      <svg class="dd-header-dismiss" viewBox="0 0 24 24" fill="none" stroke="#626870" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                    </div>
                    <div class="dd-item">
                      <div class="dd-item-check checked"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></div>
                      <span>Priority: High</span>
                    </div>
                    <div class="dd-item">
                      <div class="dd-item-check checked"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></div>
                      <span>Priority: Medium</span>
                    </div>
                    <div class="dd-item">
                      <div class="dd-item-check"></div>
                      <span>Priority: Low</span>
                    </div>
                    <div class="dd-item">
                      <div class="dd-item-check"></div>
                      <span>Priority: None</span>
                    </div>
                    <div class="dd-footer">
                      <button class="dd-clear-btn">Clear All</button>
                      <button class="dd-apply-btn">Apply</button>
                    </div>
                  </div>
                </div>
                <!-- With Sections -->
                <div style="text-align:center;">
                  <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--prism-text-muted);margin-bottom:10px;">With Sections</div>
                  <div class="dd-panel">
                    <div class="dd-section-heading">Actions</div>
                    <div class="dd-item">
                      <svg class="dd-item-icon" viewBox="0 0 24 24" fill="none" stroke="#626870" stroke-width="2"><circle cx="12" cy="12" r="3"/></svg>
                      <span>Edit</span>
                    </div>
                    <div class="dd-item">
                      <svg class="dd-item-icon" viewBox="0 0 24 24" fill="none" stroke="#626870" stroke-width="2"><path d="M16 4h2a2 2 0 012 2v14a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2h2"/><rect x="8" y="2" width="8" height="4" rx="1"/></svg>
                      <span>Duplicate</span>
                    </div>
                    <div class="dd-item active">
                      <svg class="dd-item-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
                      <span>Share</span>
                    </div>
                    <div class="dd-divider"></div>
                    <div class="dd-section-heading">Danger Zone</div>
                    <div class="dd-item">
                      <svg class="dd-item-icon" viewBox="0 0 24 24" fill="none" stroke="#626870" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
                      <span>Delete</span>
                    </div>
                    <div class="dd-item">
                      <svg class="dd-item-icon" viewBox="0 0 24 24" fill="none" stroke="#626870" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                      <span>Archive</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="doc-section">
            <h3 id="content-guidelines" class="doc-h3">Content Guidelines<span class="h3-badge" style="background:rgba(37,99,235,0.1);color:var(--prism-violet);">Recommended</span></h3>
            <div class="do-dont-grid">
              <div class="do-card"><span class="card-label">Do</span><ul>
                <li>Keep item labels short and scannable (1&#8211;4 words).</li>
                <li>Use Multi Select when the user needs to confirm before applying.</li>
                <li>Use With Sections when 2+ logical groupings exist with 3+ items each.</li>
              </ul></div>
              <div class="dont-card"><span class="card-label">Don't</span><ul>
                <li>Use sentence-long descriptions as item labels.</li>
                <li>Use Multi Select for single-pick scenarios (creates unnecessary friction).</li>
                <li>Add a section with only 1 item &#8212; just place it in the flat list.</li>
              </ul></div>
            </div>
          </div>
        </div>

        <!-- ========== STYLE ========== -->
        <div class="tab-content" id="tab-style" style="display:none;padding-top:32px;">
