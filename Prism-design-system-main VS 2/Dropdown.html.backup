            <h3 id="typography-family" class="doc-h3">Typography Family</h3>
            <p class="doc-section-subtitle">All dropdown text uses <strong>Zoho Puvi</strong>.</p>
            <table class="size-table">
              <thead><tr><th>Element</th><th>Font Size</th><th>Weight</th><th>Line Height</th><th>Notes</th></tr></thead>
              <tbody>
                <tr><td>Item Label</td><td>13px</td><td>400</td><td>1.4</td><td>Primary text for all item types</td></tr>
                <tr><td>Section Heading</td><td>11px</td><td>600</td><td>1.4</td><td>Uppercase, letter-spacing 0.06em</td></tr>
                <tr><td>Header Title</td><td>13px</td><td>600</td><td>1.4</td><td>Semi-bold for header bar text</td></tr>
                <tr><td>Apply Button</td><td>12px</td><td>600</td><td>1.4</td><td>Primary action in footer</td></tr>
                <tr><td>Clear All</td><td>12px</td><td>500</td><td>1.4</td><td>Text button in footer</td></tr>
