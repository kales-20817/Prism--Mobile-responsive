          <div class="doc-section">
            <h3 id="corner-radius-border-radius" class="doc-h3">Corner Radius (Border Radius)</h3>
            <p class="doc-section-subtitle">Dropdown panels and buttons use consistent rounded corners.</p>
            <div style="display:flex;gap:24px;flex-wrap:wrap;">
              <div style="flex:1;min-width:200px;padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;text-align:center;">
                <div style="width:60px;height:40px;border:2px dashed #006AFF;border-radius:8px;margin:0 auto 16px;display:flex;align-items:center;justify-content:center;background:rgba(0,106,255,0.05);color:#006AFF;font-weight:600;font-size:11px;">8px</div>
                <div style="font-size:14px;font-weight:600;color:var(--prism-text);">Panel Container</div>
                <div style="font-size:12px;color:var(--prism-text-muted);margin-top:4px;">border-radius: 8px</div>
              </div>
              <div style="flex:1;min-width:200px;padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;text-align:center;">
                <div style="width:60px;height:28px;border:2px dashed #006AFF;border-radius:8px;margin:0 auto 16px;display:flex;align-items:center;justify-content:center;background:rgba(0,106,255,0.05);color:#006AFF;font-weight:600;font-size:11px;">8px</div>
                <div style="font-size:14px;font-weight:600;color:var(--prism-text);">Apply Button</div>
                <div style="font-size:12px;color:var(--prism-text-muted);margin-top:4px;">border-radius: 8px</div>
              </div>
            </div>
