    <main class="main-panel">
      <div class="page-header-area">
        <h1 class="page-title">Iconography</h1>
        <p class="page-desc">Use icons to accelerate recognition, reinforce hierarchy, and support safe decision-making across endpoint workflows.</p>
      </div>

      <div class="main-content-area">
        <div class="main-content-inner">

          <!-- Intro -->
          <div class="doc-section" style="margin-top: 16px;">
            <p>In Prism, icons are not decoration. They represent device states, OS platforms, severity levels, remote actions, navigation structures, automation states, and system feedback.</p>
            <p>A strong iconography system helps admins scan faster, reduce cognitive load, and act confidently in high-density enterprise environments.</p>
          </div>

          <hr class="doc-divider">

          <!-- Iconography principles -->
          <div class="doc-section" id="principles">
            <h2>Iconography principles</h2>
            <p>Prism iconography follows the same system logic as the reference: universal meaning, simplicity, harmony, and intentional use.</p>

            <!-- Principle 1 -->
            <h3 id="universal-understanding">1. Design for universal understanding</h3>
            <p>Use familiar metaphors that are immediately recognizable.</p>

            <div class="icon-metaphor-grid">
              <div class="icon-metaphor-card">
                <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
                <div class="icon-label">Shield</div>
                <div class="icon-meaning">Security</div>
              </div>
              <div class="icon-metaphor-card">
                <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25"/></svg>
                <div class="icon-label">Laptop</div>
                <div class="icon-meaning">Device</div>
              </div>
              <div class="icon-metaphor-card">
                <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 01-3-3m3 3a3 3 0 100 6h13.5a3 3 0 100-6m-16.5-3a3 3 0 013-3h13.5a3 3 0 013 3m-19.5 0a4.5 4.5 0 01.9-2.7L5.737 5.1a3.375 3.375 0 012.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 01.9 2.7m0 0a3 3 0 01-3 3m0 3h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008zm-3 6h.008v.008h-.008v-.008zm0-6h.008v.008h-.008v-.008z"/></svg>
                <div class="icon-label">Server</div>
                <div class="icon-meaning">Endpoint</div>
              </div>
              <div class="icon-metaphor-card">
                <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/></svg>
                <div class="icon-label">Warning</div>
                <div class="icon-meaning">Attention</div>
              </div>
              <div class="icon-metaphor-card">
                <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182"/></svg>
                <div class="icon-label">Refresh</div>
                <div class="icon-meaning">Retry sync</div>
              </div>
              <div class="icon-metaphor-card">
                <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/></svg>
                <div class="icon-label">Search</div>
                <div class="icon-meaning">Lookup</div>
              </div>
              <div class="icon-metaphor-card">
                <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
                <div class="icon-label">Chevron</div>
                <div class="icon-meaning">Expand node</div>
              </div>
              <div class="icon-metaphor-card">
                <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/></svg>
                <div class="icon-label">Lock</div>
                <div class="icon-meaning">Policy</div>
              </div>
              <div class="icon-metaphor-card">
                <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>
                <div class="icon-label">Bolt</div>
                <div class="icon-meaning">Automation</div>
              </div>
              <div class="icon-metaphor-card">
                <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>
                <div class="icon-label">Spark</div>
                <div class="icon-meaning">AI insight</div>
              </div>
            </div>

            <p>Avoid culturally specific or abstract symbols.</p>

            <!-- Principle 2 -->
            <h3 id="simplicity-detail">2. Balance simplicity and detail</h3>
            <p>Icons must remain legible at dense table sizes.</p>

            <h4>Rules</h4>
            <ul class="doc-list">
              <li>Use minimum detail required</li>
              <li>Avoid decorative inner shapes</li>
              <li>Avoid micro details below 16px</li>
              <li>Prefer outline-first metaphors</li>
              <li>Use filled icons only for status emphasis</li>
              <li>Avoid mixed icon styles</li>
            </ul>
            <p>The icon must remain recognizable in <strong>one quick glance</strong>.</p>

            <!-- Principle 3 -->
            <h3 id="visual-harmony">3. Maintain visual harmony</h3>
            <p>Prism icons must align visually with Zoho Puvi typography and rounded interface primitives.</p>

            <h4>Style rules</h4>
            <table class="size-table">
              <thead>
                <tr><th>Property</th><th>Value</th></tr>
              </thead>
              <tbody>
                <tr><td>Stroke width</td><td><strong>1.5px</strong></td></tr>
                <tr><td>Corner radius</td><td>Soft rounded outer corners</td></tr>
                <tr><td>Interior cuts</td><td>Sharp for precision</td></tr>
                <tr><td>Line terminals</td><td>Square</td></tr>
                <tr><td>Optical alignment</td><td>Centered</td></tr>
                <tr><td>Visual weight</td><td>Consistent across all modules</td></tr>
              </tbody>
            </table>

            <!-- Principle 4 -->
            <h3 id="intentional-use">4. Use icons intentionally</h3>
            <p>Icons should improve recognition -- not replace clarity.</p>

            <h4>Rules</h4>
            <ul class="doc-list">
              <li>Pair icons with labels in navigation</li>
              <li>Use labels for destructive CTAs</li>
              <li>Never use icon-only table actions without tooltip</li>
              <li>Use standalone icons only for universally known actions</li>
              <li>Avoid redundant icon + same visual status nearby</li>
            </ul>

            <div class="do-dont-grid">
              <div class="do-card">
                <div class="card-label">Good</div>
                <p>Shield + "Threat detected"</p>
                <p>Laptop + hostname</p>
                <p>Chevron + expandable node</p>
              </div>
              <div class="dont-card">
                <div class="card-label">Bad</div>
                <p>Unknown glyph with no label</p>
                <p>Three different warning icons for same meaning</p>
                <p>Icon-only destructive action without tooltip</p>
              </div>
            </div>
          </div>

          <hr class="doc-divider">

          <!-- Icon sizes -->
          <div class="doc-section" id="icon-sizes">
            <h2>Icon sizes</h2>
            <p>Prism uses <strong>16px as the default operational icon size</strong>. All size tokens are from the <strong>UEMS Global Tokens</strong> collection with <code style="font-size:12px; background:var(--prism-surface); padding:2px 6px; border-radius:4px; border:1px solid var(--prism-border); color:var(--prism-violet-light);">WIDTH_HEIGHT</code> scope.</p>

            <div class="collection-badge">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 7V4h16v3M9 20h6M12 4v16"/></svg>
              UEMS Global Tokens &middot; icon-size/* &middot; 6 tokens
            </div>

            <table class="size-table">
              <thead>
                <tr><th>Token</th><th>Size</th><th>Preview</th><th>Usage</th></tr>
              </thead>
              <tbody>
                <tr>
                  <td><code>icon-size/icon-xsmall</code></td><td>12px</td>
                  <td><div class="icon-size-preview"><svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg></div></td>
                  <td>Badges, validation, compact tables, tree chevrons</td>
                </tr>
                <tr>
                  <td><code>icon-size/icon-small</code></td><td>16px</td>
                  <td><div class="icon-size-preview"><svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg></div></td>
                  <td>Default UI, navigation, tables, form inputs</td>
                </tr>
                <tr>
                  <td><code>icon-size/icon-medium</code></td><td>20px</td>
                  <td><div class="icon-size-preview"><svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg></div></td>
                  <td>Cards, widgets, KPI labels</td>
                </tr>
                <tr>
                  <td><code>icon-size/icon-large</code></td><td>24px</td>
                  <td><div class="icon-size-preview"><svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg></div></td>
                  <td>Empty states, onboarding, AI tiles</td>
                </tr>
                <tr>
                  <td><code>icon-size/icon-xlarge</code></td><td>32px</td>
                  <td><div class="icon-size-preview"><svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg></div></td>
                  <td>Feature highlights, hero sections</td>
                </tr>
                <tr>
                  <td><code>icon-size/icon-2xlarge</code></td><td>48px</td>
                  <td><div class="icon-size-preview"><svg width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg></div></td>
                  <td>Splash screens, zero-state illustrations</td>
                </tr>
              </tbody>
            </table>

            <h3>Size rules</h3>
            <ul class="doc-list">
              <li>Default all app icons to <strong>16px</strong> (<code style="font-size:12px; background:var(--prism-surface); padding:2px 6px; border-radius:4px; border:1px solid var(--prism-border); color:var(--prism-violet-light);">icon-small</code>)</li>
              <li>Use <strong>12px only for dense support roles</strong> (badges, tree chevrons)</li>
              <li>Never scale icons manually -- use token sizes only</li>
              <li>Tree chevrons should always use <strong>12px</strong></li>
            </ul>
          </div>

          <hr class="doc-divider">

          <!-- Token-first system -->
          <div class="doc-section" id="token-system">
            <h2>Token-first icon system</h2>
            <p>Never use raw SVG sizes or custom strokes. Always reference tokens.</p>

            <h3>Token structure</h3>
            <div class="code-block">icon.{category}.{size}.{state}

Examples:
icon.navigation.small.default
icon.status.xsmall.active
icon.action.medium.disabled
icon.platform.large.hover</div>

            <h3>Categories</h3>
            <table class="size-table">
              <thead>
                <tr><th>Category</th><th>Description</th><th>Examples</th></tr>
              </thead>
              <tbody>
                <tr><td><code>navigation</code></td><td>Wayfinding and tree structure</td><td>Chevron, hamburger, back, close</td></tr>
                <tr><td><code>action</code></td><td>User-triggered operations</td><td>Edit, delete, refresh, download</td></tr>
                <tr><td><code>status</code></td><td>State and severity indicators</td><td>Check, warning, error, info</td></tr>
                <tr><td><code>platform</code></td><td>OS and device types</td><td>Windows, macOS, Linux, mobile</td></tr>
                <tr><td><code>security</code></td><td>Threat and compliance</td><td>Shield, lock, key, vulnerability</td></tr>
                <tr><td><code>ai</code></td><td>AI and automation</td><td>Spark, bolt, brain, wand</td></tr>
              </tbody>
            </table>
          </div>

          <hr class="doc-divider">

          <!-- Anti-patterns -->
          <div class="doc-section" id="anti-patterns">
            <h2>Anti-patterns</h2>
            <div class="do-dont-grid">
              <div class="do-card">
                <div class="card-label">Do</div>
                <p>Use token sizes consistently</p>
                <p>Pair icons with text labels</p>
                <p>Use 1.5px stroke width</p>
                <p>Match icon style across modules</p>
                <p>Use tooltips for icon-only actions</p>
              </div>
              <div class="dont-card">
                <div class="card-label">Don't</div>
                <p>Scale icons with CSS transform</p>
                <p>Mix outline and filled styles</p>
                <p>Use different stroke widths</p>
                <p>Add decorative icons to dense tables</p>
                <p>Use icon-only for destructive actions</p>
              </div>
            </div>
          </div>

          <hr class="doc-divider">

          <!-- Principle -->
          <div class="doc-section" id="principle">
            <h2>Principle</h2>
            <div class="principle-card">
              <p>In Prism, icons are not visual embellishment.</p>
              <p>They are the <strong>recognition layer</strong> that helps endpoint admins identify states instantly, navigate complex trees confidently, and distinguish safe actions from destructive ones -- all at a glance.</p>
            </div>
          </div>

          <!-- Feedback -->
          <div class="feedback-banner" style="display: none;">
            <div>
              <div class="fb-text">Help us improve this page</div>
              <div class="fb-sub">Share your feedback to help shape the Iconography documentation.</div>
            </div>
            <div style="display: flex; gap: 12px;">
              <button class="feedback-btn primary" onclick="window.open('https://cliq.zoho.in/company/60002085329/channels/prismdesignsystembyuemssupportfeedback','_blank')">Give Feedback</button>
            </div>
          </div>

        </div>

        <aside class="toc-sidebar">
          <h4 class="toc-heading">On this page</h4>
          <ul class="toc-nav" id="toc-nav"></ul>
        </aside>
      </div>
    </main>
  </div>

  <script>
// Sidebar search: filter foundation nav links by query
    const sidebarSearchInput = document.querySelector('.sidebar-search input');
    const foundationNavItems = document.querySelectorAll('.foundation-nav li');
    if (sidebarSearchInput && foundationNavItems.length) {
      sidebarSearchInput.addEventListener('input', (e) => {
        const q = e.target.value.trim().toLowerCase();
        foundationNavItems.forEach(li => {
          const text = li.textContent.trim().toLowerCase();
          li.style.display = !q || text.includes(q) ? '' : 'none';
        });
      });
      document.addEventListener('keydown', (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
          e.preventDefault();
          sidebarSearchInput.focus();
        }
        if (e.key === 'Escape' && document.activeElement === sidebarSearchInput) {
          sidebarSearchInput.value = '';
          sidebarSearchInput.dispatchEvent(new Event('input'));
          sidebarSearchInput.blur();
        }
      });
    }

    const themeToggle = document.getElementById('themeToggle');
    const moonIcon = document.getElementById('moonIcon');
    const sunIcon = document.getElementById('sunIcon');
    const currentTheme = localStorage.getItem('theme') || 'light';
    if (currentTheme === 'dark') {
      document.documentElement.removeAttribute('data-theme');
      moonIcon.style.display = 'block'; sunIcon.style.display = 'none';
    }
    themeToggle.addEventListener('click', () => {
      let theme = document.documentElement.getAttribute('data-theme');
      if (theme === 'light') {
        document.documentElement.removeAttribute('data-theme');
        localStorage.setItem('theme', 'dark');
        moonIcon.style.display = 'block'; sunIcon.style.display = 'none';
      } else {
        document.documentElement.setAttribute('data-theme', 'light');
        localStorage.setItem('theme', 'light');
        moonIcon.style.display = 'none'; sunIcon.style.display = 'block';
      }
    });

    // Dynamic TOC with scroll-spy
    (function() {
      const sections = document.querySelectorAll('.doc-section[id]');
      const tocNav = document.getElementById('toc-nav');
      sections.forEach(sec => {
        const h2 = sec.querySelector('h2');
        if (h2) {
          const li = document.createElement('li');
          const a = document.createElement('a');
          a.className = 'toc-link';
          a.href = '#' + sec.id;
          a.textContent = h2.textContent;
          li.appendChild(a);
          tocNav.appendChild(li);
        }
      });
      const obs = new IntersectionObserver(entries => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            document.querySelectorAll('.toc-link').forEach(l => l.classList.remove('active'));
            const link = tocNav.querySelector('a[href="#' + entry.target.id + '"]');
            if (link) link.classList.add('active');
          }
        });
      }, { rootMargin: '-80px 0px -60% 0px', threshold: 0.1 });
      sections.forEach(sec => obs.observe(sec));
    })();
  </script>
<script>
(function(){
  const nav = document.querySelector('.nav');
  if (!nav) return;
  const toggle = () => {
    if (window.scrollY > 10) nav.classList.add('scrolled');
    else nav.classList.remove('scrolled');
  };
  toggle();
  window.addEventListener('scroll', toggle, { passive: true });
})();
</script>
<script>
(function(){
  const hamburger = document.querySelector('.nav-hamburger');
  const sidebar = document.querySelector('.sidebar');
  const backdrop = document.querySelector('.sidebar-backdrop');
  const navLinks = document.querySelector('.nav-links');
  if (!hamburger || !sidebar || !backdrop) return;

  // Build a mobile-only nav section at the top of the sidebar by cloning the nav links
  if (navLinks && !sidebar.querySelector('.sidebar-mobile-nav')) {
    const mobileNav = document.createElement('div');
    mobileNav.className = 'sidebar-mobile-nav';
    const heading = document.createElement('h4');
    heading.textContent = 'Navigate';
    mobileNav.appendChild(heading);
    const ul = document.createElement('ul');
    navLinks.querySelectorAll(':scope > a').forEach(a => {
      const li = document.createElement('li');
      const clone = a.cloneNode(true);
      li.appendChild(clone);
      ul.appendChild(li);
    });
    navLinks.querySelectorAll(':scope > .nav-dropdown > .nav-dropdown-menu > a').forEach(a => {
      const li = document.createElement('li');
      const clone = a.cloneNode(true);
      li.appendChild(clone);
      ul.appendChild(li);
    });
    mobileNav.appendChild(ul);
    sidebar.insertBefore(mobileNav, sidebar.firstChild);
  }

  const open = () => {
    sidebar.classList.add('open');
    backdrop.classList.add('open');
    document.body.classList.add('sidebar-locked');
    hamburger.setAttribute('aria-expanded', 'true');
  };
  const close = () => {
    sidebar.classList.remove('open');
    backdrop.classList.remove('open');
    document.body.classList.remove('sidebar-locked');
    hamburger.setAttribute('aria-expanded', 'false');
  };
  hamburger.addEventListener('click', () => sidebar.classList.contains('open') ? close() : open());
  backdrop.addEventListener('click', close);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && sidebar.classList.contains('open')) close(); });
  sidebar.addEventListener('click', (e) => { if (e.target.closest('a')) close(); });
})();
</script>

