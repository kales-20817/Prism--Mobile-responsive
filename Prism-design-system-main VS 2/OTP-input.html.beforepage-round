                <div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;">Border-Secondary stroke</div>
              </div>
              <div style="padding:24px 16px;border-radius:14px;background:var(--prism-surface);border:1px solid var(--prism-border);text-align:center;">
                <div style="display:flex;gap:6px;justify-content:center;margin-bottom:16px;"><div class="otp-box focus" style="width:32px;height:32px;font-size:14px;">|</div><div class="otp-box" style="width:32px;height:32px;font-size:14px;">0</div></div>
                <div style="font-size:13px;font-weight:600;color:var(--prism-text);">Focus</div>
                <div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;">2px blue border + shadow</div>
              </div>
              <div style="padding:24px 16px;border-radius:14px;background:var(--prism-surface);border:1px solid var(--prism-border);text-align:center;">
                <div style="display:flex;gap:6px;justify-content:center;margin-bottom:16px;"><div class="otp-box filled" style="width:32px;height:32px;font-size:14px;">4</div><div class="otp-box filled" style="width:32px;height:32px;font-size:14px;">8</div></div>
                <div style="font-size:13px;font-weight:600;color:var(--prism-text);">Filled</div>
