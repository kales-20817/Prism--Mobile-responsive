                <td><span style="display:inline-flex;align-items:center;gap:8px;"><span style="width:12px;height:12px;border-radius:9999px;background:#E65100;display:inline-block;"></span> #E65100</span></td>
                <td><span style="display:inline-flex;align-items:center;gap:8px;"><span style="width:12px;height:12px;border-radius:9999px;background:#FFDECC;display:inline-block;"></span> #FFDECC</span></td>
