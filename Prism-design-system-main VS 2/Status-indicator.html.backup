              <tr><td><strong>Disabled</strong></td><td><span style="display:inline-flex;align-items:center;gap:8px;"><span style="width:12px;height:12px;border-radius:3px;background:#8893AD;display:inline-block;"></span> Muted text</span></td><td><code>#8893AD</code></td></tr>
