          <table class="size-table">
            <thead><tr><th>Size</th><th>Dot</th><th>Icon</th><th>Font Size</th><th>Line Height</th><th>Padding</th><th>Gap</th><th>Typography Token</th></tr></thead>
            <tbody>
              <tr><td><strong>Small</strong></td><td>6x6</td><td>12x12</td><td>10px</td><td>14px</td><td>4px</td><td>4px</td><td><code>body/XSmall/Medium</code></td></tr>
              <tr><td><strong>Medium</strong></td><td>6x6</td><td>14x14</td><td>12px</td><td>16px</td><td>4px</td><td>4px</td><td><code>body/Small/Medium</code></td></tr>
              <tr><td><strong>Large</strong></td><td>8x8</td><td>16x16</td><td>14px</td><td>20px</td><td>4px</td><td>4px</td><td><code>body/Default/Medium</code></td></tr>
