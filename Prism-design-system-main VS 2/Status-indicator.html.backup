        <!-- Hover Background -->
        <div class="doc-section">
          <h2 id="hover-background" class="doc-section-title">Hover Background</h2>
          <p class="doc-section-subtitle">Container background tint applied on hover per status.</p>
          <table class="size-table">
            <thead><tr><th>Status</th><th>Hover Background</th><th>Preview</th></tr></thead>
            <tbody>
              <tr><td><strong>Neutral</strong></td><td><code>#F0F2F5</code></td><td><span style="display:inline-block;width:48px;height:24px;border-radius:6px;background:#F0F2F5;border:1px solid #ddd;"></span></td></tr>
              <tr><td><strong>Success</strong></td><td><code>#E7F3ED</code></td><td><span style="display:inline-block;width:48px;height:24px;border-radius:6px;background:#E7F3ED;border:1px solid #ddd;"></span></td></tr>
              <tr><td><strong>Warning</strong></td><td><code>#FFEEE5</code></td><td><span style="display:inline-block;width:48px;height:24px;border-radius:6px;background:#FFEEE5;border:1px solid #ddd;"></span></td></tr>
              <tr><td><strong>Critical</strong></td><td><code>#FDEBEB</code></td><td><span style="display:inline-block;width:48px;height:24px;border-radius:6px;background:#FDEBEB;border:1px solid #ddd;"></span></td></tr>
              <tr><td><strong>Info</strong></td><td><code>#EAF0FC</code></td><td><span style="display:inline-block;width:48px;height:24px;border-radius:6px;background:#EAF0FC;border:1px solid #ddd;"></span></td></tr>
            </tbody>
