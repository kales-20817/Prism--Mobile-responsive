              <div class="state-card-desc">Standard resting state, transparent background</div>
            </div>
            <div class="state-card">
              <div class="si-demo si-lg si-success si-hover-success" style="justify-content: center;"><div class="si-dot"></div><span>Online</span></div>
              <div class="state-card-title">Hover</div>
              <div class="state-card-desc">Subtle tinted background per status</div>
