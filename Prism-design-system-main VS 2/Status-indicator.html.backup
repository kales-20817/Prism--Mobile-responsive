                <td><span style="display:inline-flex;align-items:center;gap:8px;"><span style="width:12px;height:12px;border-radius:9999px;background:#0C8844;display:inline-block;"></span> #0C8844</span></td>
                <td><span style="display:inline-flex;align-items:center;gap:8px;"><span style="width:12px;height:12px;border-radius:9999px;background:#CEE7DA;display:inline-block;"></span> #CEE7DA</span></td>
              </tr>
