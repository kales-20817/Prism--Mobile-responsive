                </div>
              </span>
              <div style="position: absolute; left: -60px; top: 50%; transform: translateY(-50%); display: flex; align-items: center; gap: 8px;">
                <span class="anat-marker-inline">4</span><div style="width: 30px; height: 2px; background: #2563eb;"></div>
