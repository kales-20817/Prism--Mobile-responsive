          <!-- Side panels and rails -->
          <div class="doc-section">
            <h2 id="side-panels" class="doc-section-title">Side panels and rails</h2>
            <p class="doc-section-subtitle">Endpoint products rely heavily on persistent layout rails. Support:</p>
            <ul class="doc-list">
              <li>Left navigation</li>
              <li>Collapsible filter rail</li>
              <li>Right-side inspector</li>
              <li>AI insights aside</li>
              <li>Deployment summary drawer</li>
            </ul>

            <h3 id="panel-rules" class="doc-h3" style="margin-top: 24px;">Rules</h3>
