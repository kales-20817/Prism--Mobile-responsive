        <!-- Content Guidelines -->
        <div class="doc-section">
          <h3 id="content-guidelines" class="doc-h3">Content Guidelines<span class="h3-badge" style="background: rgba(37,99,235,0.1); color: var(--prism-violet);">Recommended</span></h3>
          <div class="do-dont-grid">
            <div class="do-card"><span class="card-label">Do</span>
              <ul class="doc-list" style="border: none; background: transparent; padding: 0;">
                <li style="border: none; background: transparent; padding-left: 20px;">Use Split Button for a primary action that has related secondary options (e.g., "Save" + "Save As...", "Save &amp; Close").</li>
                <li style="border: none; background: transparent; padding-left: 20px;">Always pair with an Action Dropdown or menu that opens from the Chevron Part.</li>
                <li style="border: none; background: transparent; padding-left: 20px;">Keep the primary action label concise (1-2 words).</li>
                <li style="border: none; background: transparent; padding-left: 20px;">Use the prefix icon to reinforce the primary action meaning (e.g., "+" for create/add).</li>
                <li style="border: none; background: transparent; padding-left: 20px;">Position the Split Button where you would normally place a Primary button.</li>
              </ul>
            </div>
            <div class="dont-card"><span class="card-label">Don't</span>
              <ul class="doc-list" style="border: none; background: transparent; padding: 0;">
                <li style="border: none; background: transparent; padding-left: 20px;">Don't use Split Button when there is no secondary action -- use a standard Primary button instead.</li>
                <li style="border: none; background: transparent; padding-left: 20px;">Don't use more than one Split Button per view/section.</li>
                <li style="border: none; background: transparent; padding-left: 20px;">Don't use Split Button for navigation actions.</li>
                <li style="border: none; background: transparent; padding-left: 20px;">Don't hide the only/critical action behind the chevron -- the primary action should always be the most common one.</li>
                <li style="border: none; background: transparent; padding-left: 20px;">Don't use the Loading state without disabling the dropdown interaction.</li>
                <li style="border: none; background: transparent; padding-left: 20px;">Don't mix Split Button with other Primary-styled buttons in the same button group.</li>
              </ul>
            </div>
          </div>
        </div>

        </div> <!-- End tab-overview -->


        <!-- ═══ STYLE TAB ═══ -->
        <div class="tab-content" id="tab-style" style="display: none; padding-top: 32px;">
          <h2 id="style-overview" class="doc-section-title">Style</h2>
          <p class="doc-section-subtitle">Design tokens, color mappings, and spacing tokens that define the Split Button's visual language.</p>

          <!-- Color & Style Tokens -->
          <div class="doc-section">
            <h2 id="color-style-tokens" class="doc-section-title">Color &amp; Style Tokens</h2>
            <p class="doc-section-subtitle">Token mappings for each interactive state of the Split Button component.</p>

            <style>
              .size-table { width: 100%; border-collapse: collapse; font-size: 14px; }
              .size-table th { text-align: left; padding: 14px 12px; color: var(--prism-text-muted); font-weight: 600; font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 2px solid var(--prism-border); }
              .size-table td { padding: 16px 12px; border-bottom: 1px solid var(--prism-border); color: var(--prism-text); vertical-align: middle; }
              .size-table tr:hover td { background: rgba(37,99,235,0.02); }
              .size-table code { font-family: 'JetBrains Mono', monospace; font-size: 12.5px; padding: 2px 8px; border-radius: 6px; background: rgba(37,99,235,0.06); color: var(--prism-violet); }
            </style>

            <h3 id="default-state-tokens" class="doc-h3">Default State</h3>
            <table class="size-table">
              <thead><tr><th>Part</th><th>Property</th><th>Token</th><th>Value</th></tr></thead>
              <tbody>
                <tr><td><strong>Button Part</strong></td><td>Background</td><td><code>Gradients/Primary</code></td><td>linear-gradient(#006AFF -> #1E52BB)</td></tr>
                <tr><td><strong>Chevron Part</strong></td><td>Background</td><td><code>bg-button-primary</code></td><td>#006AFF (solid)</td></tr>
                <tr><td><strong>Divider</strong></td><td>Border</td><td><code>border-accent-secondary</code></td><td>1px solid #6B94E7</td></tr>
                <tr><td><strong>Label</strong></td><td>Color</td><td><code>text/text-white</code></td><td>white</td></tr>
                <tr><td><strong>Icons</strong></td><td>Color</td><td>White</td><td>Matches label</td></tr>
              </tbody>
            </table>

            <hr class="doc-divider" />

            <h3 id="hover-state-tokens" class="doc-h3">Hover State</h3>
            <table class="size-table">
              <thead><tr><th>Part</th><th>Property</th><th>Token</th><th>Value</th></tr></thead>
              <tbody>
                <tr><td><strong>Button Part</strong></td><td>Background</td><td><code>Gradients/Primary</code></td><td>Same gradient as Default (unchanged)</td></tr>
                <tr><td><strong>Chevron Part</strong></td><td>Background</td><td><code>bg-button-primary-hover</code></td><td>#1E52BB (darker)</td></tr>
                <tr><td><strong>Divider</strong></td><td>Border</td><td><code>border-accent-secondary</code></td><td>1px solid #6B94E7</td></tr>
                <tr><td><strong>Label</strong></td><td>Color</td><td><code>text/text-white</code></td><td>white</td></tr>
              </tbody>
            </table>

            <hr class="doc-divider" />

            <h3 id="focus-state-tokens" class="doc-h3">Focus State</h3>
            <table class="size-table">
              <thead><tr><th>Part</th><th>Property</th><th>Token</th><th>Value</th></tr></thead>
              <tbody>
                <tr><td><strong>Outer Ring</strong></td><td>Border</td><td><code>bg-button-primary</code></td><td>2px solid #006AFF</td></tr>
                <tr><td><strong>Outer Ring</strong></td><td>Border Radius</td><td>--</td><td>12px</td></tr>
                <tr><td><strong>Outer Ring</strong></td><td>Padding</td><td><code>spacing/4px</code></td><td>4px gap between ring and container</td></tr>
                <tr><td><strong>Button Part</strong></td><td>Background</td><td><code>Gradients/Primary</code></td><td>Same gradient as Default</td></tr>
                <tr><td><strong>Chevron Part</strong></td><td>Background</td><td><code>bg-button-primary</code></td><td>#006AFF</td></tr>
              </tbody>
            </table>

            <hr class="doc-divider" />

            <h3 id="loading-state-tokens" class="doc-h3">Loading State</h3>
            <p class="doc-section-subtitle">Both Button Part and Chevron Part are replaced by a centered Spinner-Round loading indicator. The container maintains the same width as the Default state to prevent layout shift.</p>

            <hr class="doc-divider" />

            <h3 id="disabled-state-tokens" class="doc-h3">Disabled State</h3>
            <table class="size-table">
              <thead><tr><th>Part</th><th>Property</th><th>Token</th><th>Value</th></tr></thead>
              <tbody>
                <tr><td><strong>Button Part</strong></td><td>Background</td><td><code>bg-disabled</code></td><td>#E1E4EB</td></tr>
                <tr><td><strong>Chevron Part</strong></td><td>Background</td><td><code>bg-disabled</code></td><td>#E1E4EB</td></tr>
                <tr><td><strong>Divider</strong></td><td>Border</td><td><code>border-secondary</code></td><td>1px solid #C3C9D6</td></tr>
                <tr><td><strong>Label</strong></td><td>Color</td><td><code>text-disabled</code></td><td>#8893AD</td></tr>
                <tr><td><strong>Icons</strong></td><td>Color</td><td>Disabled grey</td><td>Matches label</td></tr>
              </tbody>
            </table>
          </div>

          <hr class="doc-divider" />

          <!-- States Visual Grid -->
          <div class="doc-section">
            <h2 id="states" class="doc-section-title">States</h2>
            <p class="doc-section-subtitle">Split Buttons cycle through five states, each with distinct visual treatments to communicate interactivity.</p>
            <style>
              .state-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 14px; margin-top: 24px; }
              .state-card { padding: 24px 16px; border-radius: 14px; background: var(--prism-surface); border: 1px solid var(--prism-border); text-align: center; transition: all 0.25s ease; }
              [data-theme="light"] .state-card { background: #fff; border: 1px solid rgba(37,99,235,0.07); box-shadow: 0 1px 4px rgba(37,99,235,0.04); }
              .state-card:hover { border-color: rgba(37,99,235,0.3); transform: translateY(-3px); box-shadow: 0 8px 24px rgba(37,99,235,0.08); }
              .state-card-title { font-size: 13px; font-weight: 600; color: var(--prism-text); margin-top: 16px; }
              .state-card-desc { font-size: 12px; color: var(--prism-text-muted); margin-top: 6px; line-height: 1.5; }
              @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
            </style>
            <div class="state-grid">
              <div class="state-card">
                <div class="uems-split-btn sb-s" style="justify-content: center;">
                  <button class="split-btn-part split-btn-action"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"></path></svg> Save</button>
                  <button class="split-btn-part split-btn-chevron"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path></svg></button>
                </div>
                <div class="state-card-title">Default</div>
                <div class="state-card-desc">Standard resting state</div>
              </div>
              <div class="state-card">
                <div class="uems-split-btn sb-s" style="justify-content: center;">
                  <button class="split-btn-part split-btn-action"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"></path></svg> Save</button>
                  <button class="split-btn-part split-btn-chevron" style="background: #1E52BB;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path></svg></button>
                </div>
                <div class="state-card-title">Hover</div>
                <div class="state-card-desc">Chevron darkens to #1E52BB</div>
              </div>
              <div class="state-card">
                <div class="uems-split-btn sb-s" style="justify-content: center; outline: 2px solid #006AFF; outline-offset: 4px; border-radius: 12px;">
                  <button class="split-btn-part split-btn-action"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"></path></svg> Save</button>
                  <button class="split-btn-part split-btn-chevron"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path></svg></button>
                </div>
                <div class="state-card-title">Focus</div>
                <div class="state-card-desc">2px ring wraps entire component</div>
              </div>
              <div class="state-card">
                <div class="uems-split-btn sb-s" style="justify-content: center;">
                  <button class="split-btn-part split-btn-action" style="pointer-events:none; background: linear-gradient(135deg, #006AFF, #1E52BB);">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round"><path d="M12 2v4m0 12v4m-7.07-3.93l2.83-2.83m8.48-8.48l2.83-2.83M2 12h4m12 0h4M4.93 4.93l2.83 2.83m8.48 8.48l2.83 2.83" style="animation: spin 1s linear infinite; transform-origin: center;"/></svg>
                  </button>
                  <button class="split-btn-part split-btn-chevron" style="pointer-events:none;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="opacity: 0;"><path d="M19 9l-7 7-7-7"></path></svg></button>
                </div>
                <div class="state-card-title">Loading</div>
                <div class="state-card-desc">Spinner replaces content</div>
              </div>
              <div class="state-card">
                <div class="uems-split-btn sb-s split-btn-disabled" style="justify-content: center;">
                  <button class="split-btn-part split-btn-action" disabled><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"></path></svg> Save</button>
                  <button class="split-btn-part split-btn-chevron" disabled><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path></svg></button>
                </div>
                <div class="state-card-title">Disabled</div>
                <div class="state-card-desc">#E1E4EB bg, no interaction</div>
              </div>
            </div>
          </div>

          <hr class="doc-divider" />

          <!-- Sizes -->
          <div class="doc-section">
            <h2 id="sizes" class="doc-section-title">Sizes</h2>
            <p class="doc-section-subtitle">Four sizes to fit different layout contexts. Button Part has left-side 8px radius, Chevron Part has right-side 8px radius.</p>
            <table class="size-table">
              <thead><tr><th>Size</th><th>Height</th><th>Button Padding</th><th>Chevron Padding</th><th>Font</th><th>Icon</th><th>Preview</th></tr></thead>
              <tbody>
                <tr>
