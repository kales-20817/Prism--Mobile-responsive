              </div>
              <div style="flex: 1; min-width: 200px; padding: 24px; background: var(--prism-surface); border: 1px solid var(--prism-border); border-radius: 12px; text-align: center;">
                <div style="width: 100%; height: 48px; border: 2px dashed #006AFF; border-radius: 0 8px 8px 0; margin-bottom: 16px; display: flex; align-items: center; justify-content: center; background: rgba(0, 106, 255, 0.05); color: #006AFF; font-weight: 600;">8px right</div>
