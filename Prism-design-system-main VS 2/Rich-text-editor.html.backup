                </div>

                <!-- Focus state -->
                <div class="rte-wrapper">
                  <span class="rte-label">Comment <span style="font-size:11px;font-weight:500;color:var(--prism-text-muted);margin-left:4px;">(Focus)</span></span>
                  <div class="rte-frame focus">
                    <div class="rte-toolbar">
                      <button class="rte-toolbar-dropdown">Normal &#9662;</button>
                      <span class="rte-toolbar-sep"></span>
                      <button class="rte-toolbar-btn active" title="Bold"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4h8a4 4 0 014 4 4 4 0 01-4 4H6z"/><path d="M6 12h9a4 4 0 014 4 4 4 0 01-4 4H6z"/></svg></button>
                      <button class="rte-toolbar-btn" title="Italic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="4" x2="10" y2="4"/><line x1="14" y1="20" x2="5" y2="20"/><line x1="15" y1="4" x2="9" y2="20"/></svg></button>
                      <button class="rte-toolbar-btn" title="Underline"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3v7a6 6 0 006 6 6 6 0 006-6V3"/><line x1="4" y1="21" x2="20" y2="21"/></svg></button>
                    </div>
                    <div class="rte-body" style="min-height:80px;">
                      <span style="color:var(--prism-text);">The quick brown <strong>fox jumps</strong> over the lazy dog.</span>
                    </div>
                  </div>
                  <span class="rte-helper">&#9432; Markdown shortcuts supported</span>
                </div>

                <!-- Error state -->
                <div class="rte-wrapper">
                  <span class="rte-label">Announcement body <span style="font-size:11px;font-weight:500;color:var(--prism-text-muted);margin-left:4px;">(Error)</span></span>
                  <div class="rte-frame error">
                    <div class="rte-toolbar">
                      <button class="rte-toolbar-dropdown">Normal &#9662;</button>
                      <span class="rte-toolbar-sep"></span>
                      <button class="rte-toolbar-btn" title="Bold"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4h8a4 4 0 014 4 4 4 0 01-4 4H6z"/><path d="M6 12h9a4 4 0 014 4 4 4 0 01-4 4H6z"/></svg></button>
                      <button class="rte-toolbar-btn" title="Italic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="4" x2="10" y2="4"/><line x1="14" y1="20" x2="5" y2="20"/><line x1="15" y1="4" x2="9" y2="20"/></svg></button>
                      <button class="rte-toolbar-btn" title="Underline"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3v7a6 6 0 006 6 6 6 0 006-6V3"/><line x1="4" y1="21" x2="20" y2="21"/></svg></button>
                    </div>
                    <div class="rte-body" style="min-height:80px;">
                      <span class="placeholder">Start typing...</span>
                    </div>
                  </div>
                  <span class="rte-helper error">&#10007; Announcement body is required.</span>
                </div>

                <!-- Disabled state -->
                <div class="rte-wrapper">
                  <span class="rte-label" style="opacity:0.5;">Body <span style="font-size:11px;font-weight:500;margin-left:4px;">(Disabled)</span></span>
                  <div class="rte-frame disabled">
                    <div class="rte-body" style="min-height:60px;">
                      <span style="color:var(--prism-text-muted);opacity:0.5;">Draft content here...</span>
                    </div>
                  </div>
                  <span class="rte-helper" style="opacity:0.5;">&#9432; Type $ to add variables</span>
                </div>
              </div>
            </div>
          </div>

          <div class="doc-section">
            <h3 id="content-guidelines" class="doc-h3">Content Guidelines<span class="h3-badge" style="background:rgba(37,99,235,0.1);color:var(--prism-violet);">Recommended</span></h3>
            <div class="do-dont-grid">
              <div class="do-card"><span class="card-label">Do</span><ul>
                <li>Keep the editor at 640 px or wider so the Fixed toolbar fits on one row.</li>
                <li>Use <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">Floating</code> toolbar for compact inline editors (comments, chat).</li>
                <li>Pair <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">Error</code> state with a helper-row message that explains the problem.</li>
                <li>Use <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">Read Only</code> to display rich content outside an edit flow.</li>
                <li>Persist formatting in a structured format (HTML or editor JSON).</li>
              </ul></div>
              <div class="dont-card"><span class="card-label">Don't</span><ul>
                <li>Shrink below 640 px &#8212; the Fixed toolbar will wrap; switch to <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">Floating</code> instead.</li>
                <li>Use <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">Fixed</code> inside a narrow side panel or drawer.</li>
                <li>Show the red error border without helper text.</li>
                <li>Use <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">Disabled</code> to show read-only content &#8212; it communicates "cannot interact right now".</li>
                <li>Allow arbitrary HTML and inline <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;script&gt;</code> from pasted content.</li>
              </ul></div>
            </div>
          </div>
        </div>

        <!-- ========== STYLE ========== -->
        <div class="tab-content" id="tab-style" style="display:none;padding-top:32px;">
          <h2 id="style-overview" class="doc-section-title">Style</h2>
          <p class="doc-section-subtitle">Design tokens, size specifications, and visual states that define the Rich Text Editor's appearance.</p>

          <div class="doc-section">
            <h2 id="variants" class="doc-section-title">Variants</h2>
            <p class="doc-section-subtitle">36 variants across State (6) &times; Toolbar (3) &times; RTL (2).</p>
            <table class="size-table">
              <thead><tr><th>Axis</th><th>Values</th><th>Description</th></tr></thead>
              <tbody>
                <tr><td><strong>State</strong></td><td><code>Default</code>, <code>Focus</code>, <code>Filled</code>, <code>Error</code>, <code>Disabled</code>, <code>Read Only</code></td><td>Interaction / validation state of the editor.</td></tr>
                <tr><td><strong>Toolbar</strong></td><td><code>Fixed</code>, <code>Floating</code>, <code>Hidden</code></td><td>Toolbar presentation style.</td></tr>
                <tr><td><strong>RTL</strong></td><td><code>False</code>, <code>True</code></td><td>Right-to-left layout for Arabic / Hebrew.</td></tr>
              </tbody>
            </table>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h2 id="states" class="doc-section-title">States</h2>
            <p class="doc-section-subtitle">Rich Text Editor has six interaction states controlling borders, shadows, and content appearance.</p>
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(170px,1fr));gap:14px;margin-top:24px;">
              <div style="padding:24px 16px;border-radius:14px;background:var(--prism-surface);border:1px solid var(--prism-border);text-align:center;">
                <div style="width:100%;height:48px;border:1px solid var(--prism-border);border-radius:6px;margin-bottom:16px;display:flex;align-items:center;justify-content:center;background:var(--prism-surface);font-size:11px;color:var(--prism-text-muted);">Start typing...</div>
                <div style="font-size:13px;font-weight:600;color:var(--prism-text);">Default</div>
                <div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;">Border-Secondary stroke</div>
              </div>
              <div style="padding:24px 16px;border-radius:14px;background:var(--prism-surface);border:1px solid var(--prism-border);text-align:center;">
                <div style="width:100%;height:48px;border:2px solid #2563eb;border-radius:6px;margin-bottom:16px;display:flex;align-items:center;justify-content:center;background:var(--prism-surface);box-shadow:0 0 0 3px rgba(37,99,235,0.15);font-size:11px;color:var(--prism-text);">|</div>
                <div style="font-size:13px;font-weight:600;color:var(--prism-text);">Focus</div>
                <div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;">2px accent border + shadow</div>
              </div>
              <div style="padding:24px 16px;border-radius:14px;background:var(--prism-surface);border:1px solid var(--prism-border);text-align:center;">
                <div style="width:100%;height:48px;border:1px solid var(--prism-border);border-radius:6px;margin-bottom:16px;display:flex;align-items:center;justify-content:center;background:var(--prism-surface);font-size:11px;color:var(--prism-text);">Content here</div>
                <div style="font-size:13px;font-weight:600;color:var(--prism-text);">Filled</div>
                <div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;">Border-Secondary, content visible</div>
              </div>
              <div style="padding:24px 16px;border-radius:14px;background:var(--prism-surface);border:1px solid var(--prism-border);text-align:center;">
                <div style="width:100%;height:48px;border:2px solid #ef4444;border-radius:6px;margin-bottom:16px;display:flex;align-items:center;justify-content:center;background:var(--prism-surface);box-shadow:0 0 0 3px rgba(239,68,68,0.15);font-size:11px;color:#ef4444;">Required</div>
                <div style="font-size:13px;font-weight:600;color:var(--prism-text);">Error</div>
                <div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;">Red border + error shadow</div>
              </div>
              <div style="padding:24px 16px;border-radius:14px;background:var(--prism-surface);border:1px solid var(--prism-border);text-align:center;">
                <div style="width:100%;height:48px;border:1px solid var(--prism-border);border-radius:6px;margin-bottom:16px;display:flex;align-items:center;justify-content:center;background:var(--prism-surface);opacity:0.5;font-size:11px;color:var(--prism-text-muted);">Disabled</div>
                <div style="font-size:13px;font-weight:600;color:var(--prism-text);">Disabled</div>
                <div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;">50% opacity, BG-Disabled</div>
              </div>
              <div style="padding:24px 16px;border-radius:14px;background:var(--prism-surface);border:1px solid var(--prism-border);text-align:center;">
                <div style="width:100%;height:48px;border:1px solid var(--prism-border);border-radius:6px;margin-bottom:16px;display:flex;align-items:center;justify-content:center;background:var(--prism-surface-hover);font-size:11px;color:var(--prism-text);">Read only</div>
                <div style="font-size:13px;font-weight:600;color:var(--prism-text);">Read Only</div>
                <div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;">BG-Secondary, no toolbar</div>
              </div>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="color-tokens" class="doc-h3">Color Tokens<span class="h3-badge" style="background:rgba(37,99,235,0.1);color:var(--prism-violet);">Tokens</span></h3>

            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Background</h4>
            <table class="size-table" style="margin-bottom:32px;">
              <thead><tr><th>Role</th><th>Token</th></tr></thead>
              <tbody>
                <tr><td>Editor body (Default, Focus, Filled, Error)</td><td><code>Background/BG-Primary-alt</code></td></tr>
                <tr><td>Fixed toolbar / Floating toolbar</td><td><code>Background/BG-Base-White</code></td></tr>
                <tr><td>Editor body (Read Only)</td><td><code>Background/BG-Secondary</code></td></tr>
                <tr><td>Editor body + toolbar (Disabled)</td><td><code>Background/BG-Disabled</code></td></tr>
              </tbody>
            </table>

            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Border</h4>
            <table class="size-table" style="margin-bottom:32px;">
              <thead><tr><th>State</th><th>Token</th></tr></thead>
              <tbody>
                <tr><td>Default, Filled</td><td><code>Border/Border-Secondary</code></td></tr>
                <tr><td>Focus (2 px stroke)</td><td><code>Border/Border-Accent</code></td></tr>
                <tr><td>Error</td><td><code>Border/Border-Error</code></td></tr>
                <tr><td>Disabled, Read Only</td><td><code>Border/Border-Disabled</code></td></tr>
              </tbody>
            </table>

            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Text</h4>
            <table class="size-table" style="margin-bottom:32px;">
              <thead><tr><th>Role</th><th>Token</th></tr></thead>
              <tbody>
                <tr><td>Editor content text</td><td><code>Text/Text-Primary</code></td></tr>
                <tr><td>Placeholder text</td><td><code>Text/Text-Placeholder</code></td></tr>
                <tr><td>Label, helper text (default)</td><td><code>Text/Text-Tertiary</code></td></tr>
                <tr><td>Label, helper text, content (Disabled)</td><td><code>Text/Text-Disabled</code></td></tr>
                <tr><td>Helper text (Error)</td><td><code>Text/Text-Error</code></td></tr>
              </tbody>
            </table>

            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Shadow</h4>
            <table class="size-table">
              <thead><tr><th>State</th><th>Token</th></tr></thead>
              <tbody>
                <tr><td>Focus ring on editor frame</td><td><code>Shadow/Shadow-Focus-Blue</code></td></tr>
                <tr><td>Error glow on editor frame</td><td><code>Shadow/Shadow-Focus-Red</code></td></tr>
                <tr><td>Floating toolbar drop shadow</td><td><code>Shadow/Shadow-Medium</code></td></tr>
              </tbody>
            </table>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="spacing-tokens" class="doc-h3">Spacing Tokens</h3>
            <table class="size-table">
              <thead><tr><th>Token</th><th>Value</th><th>Usage</th></tr></thead>
              <tbody>
                <tr><td><code>spacing/4</code></td><td>4 px</td><td>Toolbar button gap</td></tr>
                <tr><td><code>spacing/8</code></td><td>8 px</td><td>Root vertical gap (label / editor / helper)</td></tr>
                <tr><td><code>spacing/16</code></td><td>16 px</td><td>Editor body padding</td></tr>
              </tbody>
            </table>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="corner-radius" class="doc-h3">Corner Radius</h3>
            <table class="size-table">
              <thead><tr><th>Token</th><th>Value</th><th>Usage</th></tr></thead>
              <tbody>
                <tr><td><code>border-radius/radius-8</code></td><td>8 px</td><td>Editor frame corners</td></tr>
                <tr><td><code>border-radius/radius-6</code></td><td>6 px</td><td>Floating toolbar popover corners</td></tr>
                <tr><td><code>border-radius/radius-4</code></td><td>4 px</td><td>Toolbar icon-button corners</td></tr>
              </tbody>
            </table>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="typography" class="doc-h3">Typography</h3>
            <table class="size-table">
              <thead><tr><th>Element</th><th>Size</th><th>Weight</th><th>Line Height</th><th>Token</th></tr></thead>
              <tbody>
                <tr><td>Label</td><td>13 px</td><td>Semibold (600)</td><td>20 px</td><td><code>body/Small/Medium</code></td></tr>
                <tr><td>Editor content</td><td>14 px</td><td>Regular (400)</td><td>22 px</td><td><code>body/Default/Regular</code></td></tr>
                <tr><td>Placeholder</td><td>14 px</td><td>Regular (400)</td><td>22 px</td><td><code>body/Default/Regular</code></td></tr>
                <tr><td>Helper text</td><td>12 px</td><td>Regular (400)</td><td>16 px</td><td><code>body/Small/Default</code></td></tr>
                <tr><td>Toolbar block-style label</td><td>13 px</td><td>Regular (400)</td><td>20 px</td><td><code>body/Small/Default</code></td></tr>
                <tr><td>Heading 1 (inside editor)</td><td>24 px</td><td>Semibold (600)</td><td>32 px</td><td><code>heading/H1</code></td></tr>
                <tr><td>Heading 2 (inside editor)</td><td>20 px</td><td>Semibold (600)</td><td>28 px</td><td><code>heading/H2</code></td></tr>
                <tr><td>Heading 3 (inside editor)</td><td>16 px</td><td>Semibold (600)</td><td>24 px</td><td><code>heading/H3</code></td></tr>
              </tbody>
            </table>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="sizing-reference" class="doc-h3">Spacing &amp; Sizing Reference</h3>
            <table class="size-table">
              <thead><tr><th>Property</th><th>Value</th></tr></thead>
              <tbody>
                <tr><td>Editor frame min-width</td><td><strong>640 px</strong></td></tr>
                <tr><td>Editor body min-height</td><td><strong>160 px</strong></td></tr>
                <tr><td>Editor body padding</td><td>16 px</td></tr>
                <tr><td>Fixed toolbar height</td><td>40 px</td></tr>
                <tr><td>Fixed toolbar padding</td><td>8 px horizontal / 4 px vertical</td></tr>
                <tr><td>Floating toolbar padding</td><td>4 px</td></tr>
                <tr><td>Floating toolbar arrow size</td><td>6 px</td></tr>
                <tr><td>Toolbar icon-button size</td><td>28 &times; 28 px</td></tr>
                <tr><td>Toolbar group separator</td><td>1 px &times; 16 px</td></tr>
                <tr><td>Corner radius (frame)</td><td>8 px</td></tr>
                <tr><td>Corner radius (toolbar button)</td><td>4 px</td></tr>
                <tr><td>Default border stroke</td><td>1 px</td></tr>
                <tr><td>Focus border stroke</td><td><strong>2 px</strong></td></tr>
                <tr><td>Root vertical gap</td><td>8 px</td></tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- ========== USAGE ========== -->
        <div class="tab-content" id="tab-usage" style="display:none;padding-top:32px;">
          <div class="doc-section">
            <h2 id="when-to-use" class="doc-section-title">When and Where to Use</h2>
            <p class="doc-section-subtitle">Rich Text Editor is designed for long-form, formatted content authoring.</p>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:24px;">
              <div style="padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;">
                <h3 style="font-size:15px;font-weight:600;color:var(--prism-text);margin-bottom:16px;display:flex;align-items:center;gap:8px;"><svg width="20" height="20" fill="none" stroke="#2563eb" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>When to use</h3>
                <ul class="doc-list" style="border:none;background:transparent;padding-left:20px;font-size:14.5px;">
                  <li style="border:none;background:transparent;margin-bottom:8px;">For <strong>long-form, formatted content</strong> &#8212; descriptions, knowledge-base articles, announcements, email bodies, release notes.</li>
                  <li style="border:none;background:transparent;margin-bottom:8px;">When users need <strong>inline styles</strong> (bold/italic), <strong>block structures</strong> (headings, lists, quotes), or <strong>embedded objects</strong> (links, images, tables).</li>
                  <li style="border:none;background:transparent;margin-bottom:8px;">When content must be <strong>rendered later</strong> in a non-editable view.</li>
                  <li style="border:none;background:transparent;">When variable/token insertion (<code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">$variable$</code>) is part of the authoring flow.</li>
                </ul>
              </div>
              <div style="padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;">
                <h3 style="font-size:15px;font-weight:600;color:var(--prism-text);margin-bottom:16px;display:flex;align-items:center;gap:8px;"><svg width="20" height="20" fill="none" stroke="#e42527" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>When NOT to use</h3>
                <ul class="doc-list" style="border:none;background:transparent;padding-left:20px;font-size:14.5px;">
                  <li style="border:none;background:transparent;margin-bottom:8px;"><strong>Short single-line input</strong> &#8212; use Text Input Field.</li>
                  <li style="border:none;background:transparent;margin-bottom:8px;"><strong>Plain multi-line free text</strong> without formatting &#8212; use Text Area.</li>
                  <li style="border:none;background:transparent;margin-bottom:8px;"><strong>Code or scripting input</strong> with syntax highlighting &#8212; use Script Editor.</li>
                  <li style="border:none;background:transparent;"><strong>Markdown-only</strong> input where live preview is required &#8212; use a dedicated markdown editor pattern.</li>
                </ul>
              </div>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h2 id="toolbar-decision" class="doc-section-title">Toolbar Style Decision</h2>
            <p class="doc-section-subtitle">Choose the right toolbar based on the editing context.</p>
            <table class="size-table">
              <thead><tr><th>Situation</th><th>Recommended Toolbar</th></tr></thead>
              <tbody>
                <tr><td>Dedicated authoring surface (article editor, compose screen)</td><td><code>Fixed</code></td></tr>
                <tr><td>Inline edit zone inside a form with many other fields</td><td><code>Floating</code></td></tr>
                <tr><td>Comments / chat / reply boxes where chrome is distracting</td><td><code>Floating</code> or <code>Hidden</code></td></tr>
                <tr><td>Read-only rendering of rich content</td><td><code>Hidden</code> + <code>state="Read Only"</code></td></tr>
                <tr><td>Mobile / very narrow viewport</td><td><code>Floating</code> (Fixed toolbar wraps below 640 px)</td></tr>
              </tbody>
            </table>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h2 id="detailed-guidelines" class="doc-section-title">Complete Do's and Don'ts</h2>
            <p class="doc-section-subtitle">Guidelines for effective Rich Text Editor usage.</p>
            <div class="do-dont-grid">
              <div class="do-card"><span class="card-label">Do</span><ul>
                <li>Keep the editor at 640 px or wider so the Fixed toolbar fits on one row.</li>
                <li>Use <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">Floating</code> toolbar for compact inline editors (comments, chat).</li>
                <li>Pair <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">Error</code> state with a helper-row message that explains the problem.</li>
                <li>Use <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">Read Only</code> to display rich content outside an edit flow.</li>
                <li>Persist formatting in a structured format (HTML or editor JSON).</li>
                <li>Allow vertical resize for long-form editing.</li>
                <li>Use the Floating toolbar's arrow to point at the active selection.</li>
                <li>Localise the placeholder, label, and helper strings in RTL mode.</li>
                <li>Sanitise and paste-clean external content (strip styles, scripts).</li>
              </ul></div>
              <div class="dont-card"><span class="card-label">Don't</span><ul>
                <li>Shrink below 640 px &#8212; the Fixed toolbar will wrap; switch to <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">Floating</code> instead.</li>
                <li>Use <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">Fixed</code> inside a narrow side panel or drawer.</li>
                <li>Show the red error border without helper text.</li>
                <li>Use <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">Disabled</code> to show read-only content &#8212; it communicates "cannot interact right now".</li>
                <li>Store pasted rich content as raw HTML without sanitisation.</li>
                <li>Allow horizontal resize &#8212; widths should be layout-driven.</li>
                <li>Leave the Floating toolbar arrow floating over unrelated content when selection is cleared.</li>
                <li>Force English chrome inside an Arabic/Hebrew layout.</li>
                <li>Allow arbitrary HTML and inline <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;script&gt;</code> from pasted content.</li>
              </ul></div>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h2 id="related" class="doc-section-title">Related</h2>
            <p class="doc-section-subtitle">Components that complement or can be used alongside Rich Text Editor.</p>
            <div class="related-grid">
              <a href="Text-area.html" class="related-chip"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/></svg> Text Area</a>
              <a href="Text-field.html" class="related-chip"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 7V4h16v3M9 20h6M12 4v16"/></svg> Text Input</a>
              <a href="Script-editor.html" class="related-chip"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg> Script Editor</a>
              <a href="Inline-message.html" class="related-chip"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg> Inline Alert Message</a>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h2 id="references" class="doc-section-title">References</h2>
            <p class="doc-section-subtitle">Design tokens and resources for implementing the Rich Text Editor component.</p>
            <ul class="doc-list">
              <li><strong>Figma Node:</strong> <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">18028:832135</code> &#8212; Component Set: Rich Text Editor</li>
              <li><strong>Total Variants:</strong> 6 States &times; 3 Toolbar Styles &times; 2 RTL = <strong>36 variants</strong></li>
              <li><strong>Typography:</strong> Zoho Puvi Regular (400) for content, Semibold (600) for labels and headings</li>
              <li><strong>Sub-component:</strong> Form Field Helper Row, Fixed Toolbar, Floating Toolbar</li>
            </ul>
          </div>

        </div>

        <!-- ========== CODE ========== -->
        <div class="tab-content" id="tab-code" style="display:none;padding-top:32px;">
          <h2 id="live-demo-code" class="doc-section-title">Live demo (Code)</h2>
          <p class="doc-section-subtitle">Configure the Rich Text Editor component and view generated HTML. Toolbar buttons are interactive &#8212; click Bold, Italic, or Underline to toggle active state.</p>
          <div class="code-playground">
            <div class="cp-toolbar">
              <div class="cp-control-group"><label class="cp-label">Toolbar</label><select class="cp-select" id="pg-toolbar"><option value="fixed" selected>Fixed</option><option value="floating">Floating</option><option value="hidden">Hidden</option></select></div>
              <div class="cp-control-group"><label class="cp-label">State</label><select class="cp-select" id="pg-state"><option value="default" selected>Default</option><option value="focus">Focus</option><option value="filled">Filled</option><option value="error">Error</option><option value="disabled">Disabled</option><option value="readonly">Read Only</option></select></div>
              <div class="cp-control-group"><label class="cp-label">Direction</label><select class="cp-select" id="pg-dir"><option value="ltr" selected>LTR</option><option value="rtl">RTL</option></select></div>
              <div class="cp-control-group"><label class="cp-label">Label</label><select class="cp-select" id="pg-label"><option value="show" selected>Show</option><option value="hide">Hide</option></select></div>
              <div class="cp-control-group"><label class="cp-label">Helper Row</label><select class="cp-select" id="pg-helper"><option value="show" selected>Show</option><option value="hide">Hide</option></select></div>
            </div>
            <div class="cp-preview" id="pg-preview-area"></div>
            <div class="cp-code-header">
              <div style="font-size:13.5px;font-weight:600;color:var(--prism-text);">HTML</div>
              <button class="cp-action-btn" id="pg-copy-btn"><svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2"/></svg> Copy code</button>
            </div>
            <div class="cp-code-area" id="pg-code-output"></div>
          </div>
          <script>
          (function(){
            var els = {toolbar:document.getElementById('pg-toolbar'),state:document.getElementById('pg-state'),dir:document.getElementById('pg-dir'),label:document.getElementById('pg-label'),helper:document.getElementById('pg-helper')};
            var previewArea = document.getElementById('pg-preview-area');
            var codeOut = document.getElementById('pg-code-output');
            var copyBtn = document.getElementById('pg-copy-btn');
            var activeFormats = {bold:false,italic:false,underline:false};

            function esc(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}

            function svgBold(){ return '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4h8a4 4 0 014 4 4 4 0 01-4 4H6z"/><path d="M6 12h9a4 4 0 014 4 4 4 0 01-4 4H6z"/></svg>'; }
            function svgItalic(){ return '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="4" x2="10" y2="4"/><line x1="14" y1="20" x2="5" y2="20"/><line x1="15" y1="4" x2="9" y2="20"/></svg>'; }
            function svgUnderline(){ return '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3v7a6 6 0 006 6 6 6 0 006-6V3"/><line x1="4" y1="21" x2="20" y2="21"/></svg>'; }
            function svgStrike(){ return '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4c-1.5-1-3.5-1-5 0s-2.5 3-1 5"/><path d="M3 12h18"/><path d="M8 20c1.5 1 3.5 1 5 0s2.5-3 1-5"/></svg>'; }
            function svgList(){ return '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><circle cx="4" cy="6" r="1" fill="currentColor"/><circle cx="4" cy="12" r="1" fill="currentColor"/><circle cx="4" cy="18" r="1" fill="currentColor"/></svg>'; }
            function svgLink(){ return '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>'; }
            function svgImage(){ return '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>'; }
            function svgTable(){ return '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/><line x1="9" y1="3" x2="9" y2="21"/><line x1="15" y1="3" x2="15" y2="21"/></svg>'; }
            function svgDivider(){ return '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="3" y1="12" x2="21" y2="12"/></svg>'; }
            function svgAlign(){ return '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="15" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>'; }

            function update(){
              var tb = els.toolbar.value;
              var st = els.state.value;
              var dir = els.dir.value;
              var showLabel = els.label.value === 'show';
              var showHelper = els.helper.value === 'show';
              var isRTL = dir === 'rtl';
              var label = isRTL ? '\u0627\u0644\u062A\u0633\u0645\u064A\u0629' : 'Description';
              var placeholder = isRTL ? '\u0627\u0628\u062F\u0623 \u0627\u0644\u0643\u062A\u0627\u0628\u0629...' : 'Start typing...';
              var helper = isRTL ? '\u0627\u0643\u062A\u0628 $ \u0644\u0625\u0636\u0627\u0641\u0629 \u0627\u0644\u0645\u062A\u063A\u064A\u0631\u0627\u062A' : 'Type $ to add variables';
              if(st==='error') helper = isRTL ? '\u0627\u0644\u062D\u0642\u0644 \u0645\u0637\u0644\u0648\u0628' : 'This field is required.';

              var frameCls = 'rte-frame';
              if(st==='focus') frameCls += ' focus';
              else if(st==='error') frameCls += ' error';
              else if(st==='disabled') frameCls += ' disabled';
              else if(st==='readonly') frameCls += ' readonly';

              var isDisabled = st === 'disabled';
              var isReadOnly = st === 'readonly';
              var showToolbar = (tb !== 'hidden') && !isDisabled && !isReadOnly;
              var isFloating = tb === 'floating';

              var html = '<div class="rte-wrapper" style="'+(isRTL?'direction:rtl;':'')+'">';
              if(showLabel) html += '<span class="rte-label" style="'+(isDisabled?'opacity:0.5;':'')+'">'+label+'</span>';
              html += '<div class="'+frameCls+'">';

              // Fixed toolbar
              if(showToolbar && !isFloating){
                html += '<div class="rte-toolbar" data-pg-toolbar>';
                html += '<span class="rte-toolbar-dropdown">Normal &#9662;</span>';
                html += '<span class="rte-toolbar-sep"></span>';
                html += '<button class="rte-toolbar-btn'+(activeFormats.bold?' active':'')+'" data-format="bold" title="Bold">'+svgBold()+'</button>';
                html += '<button class="rte-toolbar-btn'+(activeFormats.italic?' active':'')+'" data-format="italic" title="Italic">'+svgItalic()+'</button>';
                html += '<button class="rte-toolbar-btn'+(activeFormats.underline?' active':'')+'" data-format="underline" title="Underline">'+svgUnderline()+'</button>';
                html += '<button class="rte-toolbar-btn" data-format="strikethrough" title="Strikethrough">'+svgStrike()+'</button>';
                html += '<span class="rte-toolbar-sep"></span>';
                html += '<button class="rte-toolbar-btn" title="Bullet List">'+svgList()+'</button>';
                html += '<button class="rte-toolbar-btn" title="Align">'+svgAlign()+'</button>';
                html += '<span class="rte-toolbar-sep"></span>';
                html += '<button class="rte-toolbar-btn" title="Link">'+svgLink()+'</button>';
                html += '<button class="rte-toolbar-btn" title="Image">'+svgImage()+'</button>';
                html += '<button class="rte-toolbar-btn" title="Table">'+svgTable()+'</button>';
                html += '<button class="rte-toolbar-btn" title="Divider">'+svgDivider()+'</button>';
                html += '</div>';
              }

              // Editor body
              var bodyContent = '';
              if(st==='filled' || st==='readonly'){
                bodyContent = '<span style="color:var(--prism-text);">The quick brown fox jumps over the lazy dog. ';
                if(activeFormats.bold) bodyContent = '<strong>' + bodyContent + '</strong>';
                if(activeFormats.italic) bodyContent = '<em>' + bodyContent + '</em>';
                if(activeFormats.underline) bodyContent = '<u>' + bodyContent + '</u>';
                bodyContent += '</span>';
              } else if(isDisabled){
                bodyContent = '<span style="color:var(--prism-text-muted);opacity:0.5;">Draft content here...</span>';
              } else {
                bodyContent = '<span class="placeholder">'+placeholder+'</span>';
              }
              html += '<div class="rte-body" style="min-height:120px;'+(isDisabled?'opacity:0.5;':'')+'">'+bodyContent;

              // Floating toolbar inside body
              if(showToolbar && isFloating && (st==='focus' || st==='filled')){
                html += '<div class="rte-floating-toolbar" style="margin-top:16px;position:relative;">';
                html += '<button class="rte-toolbar-btn" title="Link">'+svgLink()+'</button>';
                html += '<span class="rte-toolbar-sep"></span>';
                html += '<button class="rte-toolbar-btn'+(activeFormats.bold?' active':'')+'" data-format="bold" title="Bold">'+svgBold()+'</button>';
                html += '<button class="rte-toolbar-btn'+(activeFormats.italic?' active':'')+'" data-format="italic" title="Italic">'+svgItalic()+'</button>';
                html += '<button class="rte-toolbar-btn'+(activeFormats.underline?' active':'')+'" data-format="underline" title="Underline">'+svgUnderline()+'</button>';
                html += '<span class="rte-toolbar-sep"></span>';
                html += '<span class="rte-toolbar-dropdown">Normal &#9662;</span>';
                html += '</div>';
              }

              html += '</div>'; // rte-body
              html += '</div>'; // rte-frame
              if(showHelper) html += '<span class="rte-helper'+(st==='error'?' error':'')+'" style="'+(isDisabled?'opacity:0.5;':'')+'">'+(st==='error'?'&#10007; ':'&#9432; ')+helper+'</span>';
              html += '</div>'; // rte-wrapper
              previewArea.innerHTML = html;

              // Attach toggle events to format buttons
              previewArea.querySelectorAll('[data-format]').forEach(function(btn){
                btn.addEventListener('click', function(e){
                  e.preventDefault();
                  var fmt = btn.getAttribute('data-format');
                  if(activeFormats.hasOwnProperty(fmt)){
                    activeFormats[fmt] = !activeFormats[fmt];
                    update();
                  }
                });
              });

              // Build code output
              var dirAttr = isRTL ? ' dir="rtl"' : '';
              var codeStr = '<div class="rte-editor"'+dirAttr+'>\n';
              if(showLabel) codeStr += '  <label id="rte-label">'+label+'</label>\n';
              codeStr += '  <div class="rte-frame'+(st==='error'?' rte-error':'')+'"'+(isDisabled?' aria-disabled="true"':'')+(isReadOnly?' aria-readonly="true"':'')+'>\n';
              if(showToolbar && !isFloating){
                codeStr += '    <div class="rte-toolbar" role="toolbar" aria-label="Formatting options">\n';
                codeStr += '      <select aria-label="Block style"><option>Normal</option><option>H1</option><option>H2</option><option>H3</option></select>\n';
                codeStr += '      <button aria-pressed="'+(activeFormats.bold?'true':'false')+'" title="Bold">B</button>\n';
                codeStr += '      <button aria-pressed="'+(activeFormats.italic?'true':'false')+'" title="Italic">I</button>\n';
                codeStr += '      <button aria-pressed="'+(activeFormats.underline?'true':'false')+'" title="Underline">U</button>\n';
                codeStr += '      <button title="Strikethrough">S</button>\n';
                codeStr += '      <button title="Bullet list">List</button>\n';
                codeStr += '      <button title="Link">Link</button>\n';
                codeStr += '      <button title="Image">Image</button>\n';
                codeStr += '    </div>\n';
              }
              codeStr += '    <div\n      role="textbox"\n      aria-multiline="true"\n      aria-labelledby="rte-label"\n      contenteditable="'+(isDisabled||isReadOnly?'false':'true')+'"\n      data-placeholder="'+placeholder+'"\n      style="min-height: 160px;"\n';
              if(st==='error') codeStr += '      aria-invalid="true"\n      aria-describedby="rte-helper"\n';
              codeStr += '    ></div>\n';
              codeStr += '  </div>\n';
              if(showHelper){
                codeStr += '  <div id="rte-helper" class="rte-helper'+(st==='error'?' error':'')+'" aria-live="'+(st==='error'?'assertive':'polite')+'">\n';
                codeStr += '    '+helper+'\n  </div>\n';
              }
              codeStr += '</div>';

              codeOut.innerHTML = esc(codeStr)
                .replace(/class=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">class</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/role=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">role</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/aria-multiline=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">aria-multiline</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/aria-labelledby=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">aria-labelledby</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/aria-label=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">aria-label</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/aria-pressed=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">aria-pressed</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/aria-invalid=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">aria-invalid</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/aria-describedby=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">aria-describedby</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/aria-disabled=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">aria-disabled</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/aria-readonly=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">aria-readonly</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/aria-live=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">aria-live</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/contenteditable=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">contenteditable</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/data-placeholder=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">data-placeholder</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/style=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">style</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/id=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">id</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/title=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">title</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/dir=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">dir</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/ disabled/g,' <span style="color:#f97316;">disabled</span>')
                .replace(/&lt;(\/?)(div|label|button|select|option|span)(.*?)&gt;/g,'&lt;$1<span style="color:#a78bfa;">$2</span>$3&gt;');
            }
            Object.values(els).forEach(function(e){e.addEventListener('change',function(){ activeFormats={bold:false,italic:false,underline:false}; update(); });});
            copyBtn.addEventListener('click',function(){
              var r=document.createElement('div');r.innerHTML=codeOut.innerHTML;
              navigator.clipboard.writeText(r.innerText).then(function(){
                var o=copyBtn.innerHTML;copyBtn.innerHTML='<svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Copied!';setTimeout(function(){copyBtn.innerHTML=o;},2000);
              });
            });
            update();
          })();
          </script>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="component-api" class="doc-h3">Component API &amp; Properties</h3>
            <table class="size-table">
              <thead><tr><th>Property</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
              <tbody>
                <tr><td><code>state</code></td><td><code>'Default' | 'Focus' | 'Filled' | 'Error' | 'Disabled' | 'Read Only'</code></td><td><code>'Default'</code></td><td>Interaction / validation state of the editor.</td></tr>
                <tr><td><code>toolbar</code></td><td><code>'fixed' | 'floating' | 'hidden'</code></td><td><code>'fixed'</code></td><td>Toolbar presentation style.</td></tr>
                <tr><td><code>rtl</code></td><td><code>boolean</code></td><td><code>false</code></td><td>Switches to right-to-left layout mode.</td></tr>
                <tr><td><code>showLabel</code></td><td><code>boolean</code></td><td><code>true</code></td><td>Shows or hides the label row.</td></tr>
                <tr><td><code>label</code></td><td><code>string</code></td><td><code>"Label"</code></td><td>Field label text.</td></tr>
                <tr><td><code>placeholder</code></td><td><code>string</code></td><td><code>"Start typing..."</code></td><td>Placeholder shown when the editor is empty.</td></tr>
                <tr><td><code>showHelperRow</code></td><td><code>boolean</code></td><td><code>true</code></td><td>Shows or hides the helper text row below the editor.</td></tr>
                <tr><td><code>helperText</code></td><td><code>string</code></td><td><code>"Type $ to add variables"</code></td><td>Contextual hint / validation message in the helper row.</td></tr>
                <tr><td><code>value</code></td><td><code>string</code> (HTML/JSON)</td><td><code>""</code></td><td>Controlled value of the editor.</td></tr>
                <tr><td><code>onChange</code></td><td><code>(value: string) =&gt; void</code></td><td>&#8212;</td><td>Fires whenever the document changes.</td></tr>
                <tr><td><code>onFocus</code></td><td><code>() =&gt; void</code></td><td>&#8212;</td><td>Fires on editor focus.</td></tr>
                <tr><td><code>onBlur</code></td><td><code>() =&gt; void</code></td><td>&#8212;</td><td>Fires on editor blur.</td></tr>
                <tr><td><code>minHeight</code></td><td><code>number</code></td><td><code>160</code></td><td>Minimum height (px) of the editor body.</td></tr>
                <tr><td><code>minWidth</code></td><td><code>number</code></td><td><code>640</code></td><td>Minimum width (px) of the editor frame.</td></tr>
                <tr><td><code>resizable</code></td><td><code>boolean</code></td><td><code>true</code></td><td>Allows vertical drag-resize via the bottom-right grip.</td></tr>
                <tr><td><code>readOnly</code></td><td><code>boolean</code></td><td><code>false</code></td><td>Convenience alias for <code>state="Read Only"</code>.</td></tr>
                <tr><td><code>isDisabled</code></td><td><code>boolean</code></td><td><code>false</code></td><td>Convenience alias for <code>state="Disabled"</code>.</td></tr>
              </tbody>
            </table>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="code-examples" class="doc-h3">Code Examples</h3>

            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;margin-top:32px;">Basic usage &#8212; Fixed toolbar</h4>
            <div class="cp-code-area" style="border-radius:12px;margin-bottom:24px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;">
                <span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">RichTextEditor</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">label</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"Description"</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">placeholder</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"Start typing..."</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">helperText</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"Type $ to add variables"</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">toolbar</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"fixed"</span><br>
                <span style="color:#ABB2BF;">/&gt;</span>
              </div>
            </div>

            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Floating toolbar (inline / compact)</h4>
            <div class="cp-code-area" style="border-radius:12px;margin-bottom:24px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;">
                <span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">RichTextEditor</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">label</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"Comment"</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">toolbar</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"floating"</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">placeholder</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"Write a reply..."</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">helperText</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"Markdown shortcuts supported"</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">minHeight</span><span style="color:#56B6C2;">=</span><span style="color:#C678DD;">{</span><span style="color:#D19A66;">96</span><span style="color:#C678DD;">}</span><br>
                <span style="color:#ABB2BF;">/&gt;</span>
              </div>
            </div>

            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Error state</h4>
            <div class="cp-code-area" style="border-radius:12px;margin-bottom:24px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;">
                <span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">RichTextEditor</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">label</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"Announcement body"</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">state</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"Error"</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">helperText</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"Announcement body is required."</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">toolbar</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"fixed"</span><br>
                <span style="color:#ABB2BF;">/&gt;</span>
              </div>
            </div>

            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Controlled value with variables</h4>
            <div class="cp-code-area" style="border-radius:12px;margin-bottom:24px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;">
                <span style="color:#C678DD;">const</span> <span style="color:#ABB2BF;">[</span><span style="color:#E5C07B;">body</span><span style="color:#ABB2BF;">,</span> <span style="color:#E5C07B;">setBody</span><span style="color:#ABB2BF;">]</span> <span style="color:#56B6C2;">=</span> <span style="color:#E5C07B;">useState</span><span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">string</span><span style="color:#ABB2BF;">&gt;(</span><span style="color:#98C379;">""</span><span style="color:#ABB2BF;">);</span><br><br>
                <span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">RichTextEditor</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">label</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"Email body"</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">toolbar</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"fixed"</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">value</span><span style="color:#56B6C2;">=</span><span style="color:#C678DD;">{</span><span style="color:#E5C07B;">body</span><span style="color:#C678DD;">}</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">onChange</span><span style="color:#56B6C2;">=</span><span style="color:#C678DD;">{</span><span style="color:#E5C07B;">setBody</span><span style="color:#C678DD;">}</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">helperText</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"Type $ to add variables"</span><br>
                <span style="color:#ABB2BF;">/&gt;</span>
              </div>
            </div>

            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">RTL</h4>
            <div class="cp-code-area" style="border-radius:12px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;">
                <span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">RichTextEditor</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">rtl</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">label</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"&#x627;&#x644;&#x62A;&#x633;&#x645;&#x64A;&#x629;"</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">placeholder</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"&#x627;&#x628;&#x62F;&#x623; &#x627;&#x644;&#x643;&#x62A;&#x627;&#x628;&#x629;..."</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">helperText</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"&#x627;&#x643;&#x62A;&#x628; $ &#x644;&#x625;&#x636;&#x627;&#x641;&#x629; &#x627;&#x644;&#x645;&#x62A;&#x63A;&#x64A;&#x631;&#x627;&#x62A;"</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">toolbar</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"fixed"</span><br>
                <span style="color:#ABB2BF;">/&gt;</span>
              </div>
            </div>
          </div>
        </div>

        <!-- ========== ACCESSIBILITY ========== -->
        <div class="tab-content" id="tab-accessibility" style="display:none;padding-top:32px;">
          <h2 id="accessibility" class="doc-section-title">Accessibility</h2>
          <p class="doc-section-subtitle">Guidelines for ensuring the Rich Text Editor is accessible across assistive technologies and input methods.</p>

          <div class="doc-section">
            <h3 id="editor-runtime" class="doc-h3">Editor Runtime</h3>
            <ul class="doc-list">
              <li>Use a proper editor runtime (ProseMirror, Lexical, TipTap, Slate). A bare <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">contenteditable</code> div without a framework will not meet WCAG.</li>
              <li>The editable region should expose <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">role="textbox"</code> with <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-multiline="true"</code>.</li>
              <li>Connect the visible label to the editable region via <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-labelledby</code>. Do not rely on <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;label for&gt;</code> &#8212; <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">contenteditable</code> is not a form control.</li>
            </ul>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="keyboard-interaction" class="doc-h3">Keyboard Interaction</h3>
            <table class="size-table">
              <thead><tr><th>Action</th><th>Result</th></tr></thead>
              <tbody>
                <tr><td><code>Tab</code></td><td>Moves focus into the editor.</td></tr>
                <tr><td><code>&#8984;/Ctrl+B</code></td><td>Toggle bold.</td></tr>
                <tr><td><code>&#8984;/Ctrl+I</code></td><td>Toggle italic.</td></tr>
                <tr><td><code>&#8984;/Ctrl+U</code></td><td>Toggle underline.</td></tr>
                <tr><td><code>&#8984;/Ctrl+K</code></td><td>Insert / edit link.</td></tr>
                <tr><td><code>Enter</code></td><td>New paragraph.</td></tr>
                <tr><td><code>Shift+Enter</code></td><td>Soft break (line break within paragraph).</td></tr>
                <tr><td><code>Alt+F10</code></td><td>Focus the toolbar. <code>Esc</code> returns to the editor.</td></tr>
                <tr><td><code>Tab</code> inside lists</td><td>Indent list item (does <strong>not</strong> trap focus by default).</td></tr>
              </tbody>
            </table>
            <div style="margin-top:16px;padding:16px 20px;background:rgba(37,99,235,0.05);border:1px solid rgba(37,99,235,0.15);border-radius:12px;">
              <p style="font-size:14px;color:var(--prism-text);line-height:1.6;margin:0;"><strong>Note:</strong> <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">Tab</code> inside the editor should <strong>not</strong> trap focus by default &#8212; use it to indent lists only when a list item has focus.</p>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="aria-attributes" class="doc-h3">ARIA Attributes &amp; Screen Reader Guidance</h3>
            <ul class="doc-list">
              <li><strong>Validation:</strong> Set <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-invalid="true"</code> in Error state; link the helper-row message via <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-describedby</code>.</li>
              <li><strong>Read Only:</strong> Set <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-readonly="true"</code> and remove edit controls. Use <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">contenteditable="false"</code>.</li>
              <li><strong>Disabled:</strong> Set <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-disabled="true"</code> and remove from the tab sequence. The editor is announced as "disabled" and cannot be focused.</li>
              <li><strong>Toolbar buttons:</strong> Toolbar buttons must be keyboard-reachable via <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">Alt+F10</code>. Buttons expose <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-pressed="true"</code> when the current selection has that format applied.</li>
              <li><strong>Floating toolbar:</strong> When the floating toolbar appears, it must not steal focus. Announce only when the user explicitly opens it.</li>
              <li><strong>Semantic output:</strong> Expose headings as <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">role="heading"</code> with the correct <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-level</code>, lists as <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">role="list"</code>/<code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">role="listitem"</code>. Verify your editor emits semantic HTML.</li>
              <li><strong>RTL:</strong> Set <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">dir="rtl"</code> on the root; the editor runtime must mirror toolbar order, list markers, and cursor movement.</li>
            </ul>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="contrast" class="doc-h3">Color Contrast<span class="h3-badge" style="background:rgba(34,197,94,0.15);color:#16a34a;">WCAG AA Pass</span></h3>
            <p class="doc-section-subtitle">All color combinations meet WCAG 2.1 AA contrast requirements.</p>
            <ul class="doc-list">
              <li><strong>Placeholder contrast:</strong> <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">Text/Text-Placeholder</code> &#8805; 4.5:1 against <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">BG-Primary-alt</code>.</li>
              <li><strong>Focus border:</strong> <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">Border/Border-Accent</code> (2 px) must be visible independent of colour.</li>
              <li><strong>Focus ring:</strong> The 2 px accent border + blue focus shadow serves as the focus indicator. Do not remove either.</li>
            </ul>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="focus-state-design" class="doc-h3">Focus State Design</h3>
            <div style="margin-top:16px;display:flex;gap:16px;align-items:center;padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;">
              <div style="width:200px;height:60px;border:2px solid #2563eb;border-radius:8px;box-shadow:0 0 0 3px rgba(37,99,235,0.15);display:flex;align-items:center;justify-content:center;background:var(--prism-surface);font-size:12px;color:var(--prism-text);flex-shrink:0;">Editor body</div>
              <div>
                <div style="font-weight:600;font-size:15px;color:var(--prism-text);">Focus ring: 2px border + 3px shadow</div>
                <div style="font-size:14px;color:var(--prism-text-muted);margin-top:4px;">Border: Border-Accent | Shadow: Shadow-Focus-Blue</div>
              </div>
            </div>
          </div>
        </div>

        </div><!-- main-content-inner -->

