    <main class="main-panel">
      <div class="page-header-area">
        <h1 class="page-title">Rich Text Editor</h1>
        <p class="page-desc">A Rich Text Editor lets users write and format long-form content with inline styles (bold, italic, underline, strikethrough), headings, lists, links, images, and tables. Supports Fixed, Floating, and Hidden toolbar styles plus six interaction states.</p>
        <nav class="content-tabs">
          <button class="tab-item active">Overview</button>
          <button class="tab-item">Style</button>
          <button class="tab-item">Usage</button>
          <button class="tab-item">Code</button>
          <button class="tab-item">Accessibility</button>
        </nav>
      </div>

      <div class="main-content-area">
        <div class="main-content-inner">

        <!-- ========== OVERVIEW ========== -->
        <div class="tab-content" id="tab-overview">
          <h3 id="anatomy" class="doc-h3">Anatomy</h3>
          <div class="anatomy-diagram">
            <div style="display:flex;flex-direction:column;align-items:center;gap:0;margin:20px 0;">
              <!-- Label row -->
              <div style="position:relative;display:flex;align-items:center;gap:6px;margin-bottom:8px;width:100%;max-width:540px;">
                <span class="anat-marker-inline">1</span>
                <div style="width:28px; height:2px; background:#2563eb;"></div>
                <span style="font-size:13px;font-weight:600;color:var(--prism-text);margin-left:2px;">Label</span>
              </div>
              <!-- Editor frame -->
              <div style="width:100%;max-width:540px;border-radius:8px;border:1px solid var(--prism-border);overflow:visible;position:relative;">
                <!-- Fixed Toolbar -->
                <div style="display:flex;align-items:center;gap:4px;padding:4px 8px;background:var(--prism-surface);border-bottom:1px solid var(--prism-border);min-height:40px;position:relative;">
                  <div style="position:absolute;right:calc(100% + 6px);top:50%;transform:translateY(-50%);display:flex;align-items:center;gap:6px;"><span class="anat-marker-inline">3</span><div style="width:28px; height:2px; background:#2563eb;"></div></div>
                  <span style="font-size:13px;color:var(--prism-text-muted);padding:0 8px;">Normal &#9662;</span>
                  <span style="width:1px;height:16px;background:var(--prism-border);margin:0 4px;"></span>
                  <span style="font-weight:700;font-size:14px;color:var(--prism-text);width:28px;height:28px;display:flex;align-items:center;justify-content:center;">B</span>
                  <span style="font-style:italic;font-size:14px;color:var(--prism-text-muted);width:28px;height:28px;display:flex;align-items:center;justify-content:center;">I</span>
                  <span style="text-decoration:underline;font-size:14px;color:var(--prism-text-muted);width:28px;height:28px;display:flex;align-items:center;justify-content:center;">U</span>
                  <span style="text-decoration:line-through;font-size:14px;color:var(--prism-text-muted);width:28px;height:28px;display:flex;align-items:center;justify-content:center;">S</span>
                  <span style="width:1px;height:16px;background:var(--prism-border);margin:0 4px;"></span>
                  <span style="font-size:13px;color:var(--prism-text-muted);padding:0 4px;">A &#9662;</span>
                  <span style="width:1px;height:16px;background:var(--prism-border);margin:0 4px;"></span>
                  <span style="font-size:13px;color:var(--prism-text-muted);padding:0 4px;">&#8226; &#9662;</span>
                  <span style="font-size:13px;color:var(--prism-text-muted);padding:0 4px;">&#8801; &#9662;</span>
                </div>
                <!-- Editor Body -->
                <div style="min-height:120px;padding:16px;background:var(--prism-surface);position:relative;">
                  <div style="position:absolute;right:calc(100% + 6px);top:16px;display:flex;align-items:center;gap:6px;"><span class="anat-marker-inline">5</span><div style="width:28px; height:2px; background:#2563eb;"></div></div>
                  <span style="font-size:14px;color:var(--prism-text-muted);opacity:0.5;">Start typing...</span>
                  <!-- Resize grip -->
                  <div style="position:absolute;bottom:4px;right:4px;opacity:0.3;display:flex;align-items:center;gap:6px;">
                    <span class="anat-marker-inline" style="width:18px;height:18px;font-size:9px;">6</span>
                    <div style="width:10px; height:2px; background:#2563eb;"></div>
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor" style="color:var(--prism-text-muted);"><path d="M11 11H9v-2h2v2zm0-4H7v-2h2v2h2v2zm-4 4H5v-2h2v2z"/></svg>
                  </div>
                </div>
              </div>
              <div style="position:relative;width:100%;max-width:540px;">
                <div style="position:absolute;right:calc(100% + 6px);top:0;display:flex;align-items:center;gap:6px;"><span class="anat-marker-inline">2</span><div style="width:28px; height:2px; background:#2563eb;"></div></div>
              </div>
              <!-- Helper row -->
              <div style="position:relative;display:flex;align-items:center;gap:6px;margin-top:8px;width:100%;max-width:540px;">
                <span class="anat-marker-inline">7</span>
                <div style="width:28px; height:2px; background:#2563eb;"></div>
                <span style="font-size:12px;color:var(--prism-text-muted);display:flex;align-items:center;gap:4px;margin-left:2px;">&#9432; Type $ to add variables</span>
              </div>
            </div>
          </div>
          <div class="anat-legend" style="grid-template-columns:repeat(2,1fr);">
            <div class="anat-legend-item"><span class="anat-marker-inline">1</span><div><strong>Label Row</strong><span>Field label. Semibold, 13 px. Toggleable via <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">Show Label</code>.</span></div></div>
            <div class="anat-legend-item"><span class="anat-marker-inline">2</span><div><strong>Editor Frame</strong><span>Outer container: 640 px min-width, 8 px corner radius, 1 px border, overflow hidden.</span></div></div>
            <div class="anat-legend-item"><span class="anat-marker-inline">3</span><div><strong>Fixed Toolbar</strong><span>Persistent formatting controls pinned to the top of the editor frame. Full width, bottom border, BG-Base-White.</span></div></div>
            <div class="anat-legend-item"><span class="anat-marker-inline">5</span><div><strong>Editor Body</strong><span>The editable content surface. BG-Primary-alt, 16 px padding, 160 px min-height. Holds placeholder text or user content.</span></div></div>
            <div class="anat-legend-item"><span class="anat-marker-inline">6</span><div><strong>Resize Grip</strong><span>Diagonal handle at the bottom-right corner for vertical drag-resize (CSS <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">resize: vertical</code>).</span></div></div>
            <div class="anat-legend-item"><span class="anat-marker-inline">7</span><div><strong>Helper Row</strong><span>Instance of Form Field Helper Row below the editor. Icon + helper text. Toggleable via <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">Show Helper Row</code>.</span></div></div>
          </div>

          <hr class="doc-divider"/>

          <div style="margin-bottom:64px;">
            <h2 id="live-demo" class="doc-section-title" style="margin-bottom:8px;">Preview</h2>
            <p class="doc-section-subtitle" style="margin-bottom:28px;">Explore the Rich Text Editor across toolbar styles and states.</p>
            <div class="demo-container">
<div class="demo-canvas" style="align-items:flex-start;gap:40px;padding:48px 64px;">
                <!-- Fixed toolbar - Default -->
                <div class="rte-wrapper" id="demo-rte-fixed">
                  <span class="rte-label">Description</span>
                  <div class="rte-frame">
                    <div class="rte-toolbar" id="demo-toolbar-fixed">
                      <button class="rte-toolbar-dropdown">Normal &#9662;</button>
                      <span class="rte-toolbar-sep"></span>
                      <button class="rte-toolbar-btn" data-format="bold" title="Bold"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4h8a4 4 0 014 4 4 4 0 01-4 4H6z"/><path d="M6 12h9a4 4 0 014 4 4 4 0 01-4 4H6z"/></svg></button>
                      <button class="rte-toolbar-btn" data-format="italic" title="Italic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="4" x2="10" y2="4"/><line x1="14" y1="20" x2="5" y2="20"/><line x1="15" y1="4" x2="9" y2="20"/></svg></button>
                      <button class="rte-toolbar-btn" data-format="underline" title="Underline"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 3v7a6 6 0 006 6 6 6 0 006-6V3"/><line x1="4" y1="21" x2="20" y2="21"/></svg></button>
                      <button class="rte-toolbar-btn" data-format="strikethrough" title="Strikethrough"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4c-1.5-1-3.5-1-5 0s-2.5 3-1 5"/><path d="M3 12h18"/><path d="M8 20c1.5 1 3.5 1 5 0s2.5-3 1-5"/></svg></button>
                      <span class="rte-toolbar-sep"></span>
                      <button class="rte-toolbar-btn" title="Text Color"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9.5 2L5 14h4l-1 7 9-11h-5l3-8z"/></svg></button>
                      <span class="rte-toolbar-sep"></span>
                      <button class="rte-toolbar-btn" title="Bullet List"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><circle cx="4" cy="6" r="1" fill="currentColor"/><circle cx="4" cy="12" r="1" fill="currentColor"/><circle cx="4" cy="18" r="1" fill="currentColor"/></svg></button>
                      <button class="rte-toolbar-btn" title="Align"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="15" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg></button>
                      <span class="rte-toolbar-sep"></span>
                      <button class="rte-toolbar-btn" title="Link"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg></button>
                      <button class="rte-toolbar-btn" title="Image"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg></button>
                      <button class="rte-toolbar-btn" title="Table"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/><line x1="9" y1="3" x2="9" y2="21"/><line x1="15" y1="3" x2="15" y2="21"/></svg></button>
                      <button class="rte-toolbar-btn" title="Divider"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="3" y1="12" x2="21" y2="12"/></svg></button>
