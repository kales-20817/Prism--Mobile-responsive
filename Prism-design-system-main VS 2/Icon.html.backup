      </div> <!-- close main-content-area -->

    <div id="feedback" class="feedback-banner" style="display: none;">
    <div><div class="fb-text">Was this page helpful?</div><div class="fb-sub">Help us improve by sharing your feedback on this component's documentation.</div></div>
    <div style="display: flex; gap: 10px;"><button class="feedback-btn">Not helpful</button><button class="feedback-btn primary">Yes, helpful</button></div>
    </div>

    </main>
  </div>


  <script>
    // ── Scroll-spy observer reference ──
    let _tocObserver = null;

    // ── Dynamic TOC ──
    function updateTOC(targetId) {
      const tocList = document.querySelector('.toc-nav');
      if (!tocList) return;
      tocList.innerHTML = '';
      const activePanel = document.getElementById(targetId);
      if (!activePanel) return;

      const headings = activePanel.querySelectorAll('h2[id], h3[id]');
      headings.forEach(h => {
        if (h.style.display === 'none') return;
        const li = document.createElement('li');
        const a = document.createElement('a');
        a.href = '#' + h.id;
        a.className = 'toc-link';
        let text = Array.from(h.childNodes).filter(n => n.nodeType === 3).map(n => n.textContent).join('').trim();
        if (!text) text = h.innerText;
        a.textContent = text;
        a.addEventListener('click', (e) => {
          e.preventDefault();
          document.getElementById(h.id).scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
        li.appendChild(a);
        tocList.appendChild(li);
      });

      // Re-init scroll-spy
      initScrollSpy();
    }

    function initScrollSpy() {
      // Disconnect previous observer
      if (_tocObserver) _tocObserver.disconnect();

      const tocLinks = document.querySelectorAll('.toc-link');
      const sectionIds = Array.from(tocLinks).map(link => link.getAttribute('href').slice(1));
      const sections = sectionIds.map(id => document.getElementById(id)).filter(Boolean);
      if (sections.length === 0) return;

      _tocObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const id = entry.target.getAttribute('id');
            tocLinks.forEach(link => {
              link.classList.toggle('active', link.getAttribute('href') === '#' + id);
            });
          }
        });
      }, { rootMargin: '-80px 0px -60% 0px', threshold: 0 });

      sections.forEach(section => _tocObserver.observe(section));
    }

    // ── Tab switching ──
    document.querySelectorAll('.tab-item').forEach(tab => {
      tab.addEventListener('click', () => {
        document.querySelectorAll('.tab-item').forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        const tabMap = { 'Overview': 'tab-overview', 'Style': 'tab-style', 'Usage': 'tab-usage', 'Code': 'tab-code', 'Accessibility': 'tab-accessibility' };
        document.querySelectorAll('.tab-content').forEach(panel => panel.style.display = 'none');
        const target = tabMap[tab.textContent.trim()];
        if (target) {
          document.getElementById(target).style.display = 'block';
          updateTOC(target);
        }
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    });

    // Initialize TOC
    updateTOC('tab-overview');

    // ── Theme Toggle ──
    const themeToggle = document.getElementById('themeToggle');
    const moonIcon = document.getElementById('moonIcon');
    const sunIcon = document.getElementById('sunIcon');
    const currentTheme = localStorage.getItem('theme') || 'light';

    if (currentTheme === 'dark') {
      document.documentElement.removeAttribute('data-theme');
      moonIcon.style.display = 'block';
      sunIcon.style.display = 'none';
    }

    themeToggle.addEventListener('click', () => {
      let theme = document.documentElement.getAttribute('data-theme');
      if (theme === 'light') {
        document.documentElement.removeAttribute('data-theme');
        localStorage.setItem('theme', 'dark');
        moonIcon.style.display = 'block';
        sunIcon.style.display = 'none';
      } else {
        document.documentElement.setAttribute('data-theme', 'light');
        localStorage.setItem('theme', 'light');
        moonIcon.style.display = 'none';
        sunIcon.style.display = 'block';
      }
    });

    // ── Code Playground ──
    (function() {
      const pgType = document.getElementById('pg-type');
      const pgSize = document.getElementById('pg-size');
      const pgShape = document.getElementById('pg-shape');
      const pgPreviewArea = document.getElementById('pg-preview-area');
      const pgButtonElement = document.getElementById('pg-button-element');
      const pgCodeOutput = document.getElementById('pg-code-output');
      const pgCopyBtn = document.getElementById('pg-copy-btn');
      const pgShowMoreBtn = document.getElementById('pg-show-more-btn');
      const pgShowMoreFade = document.getElementById('pg-show-more-fade');

      if (!pgType) return;

      let isCodeExpanded = false;

      pgShowMoreBtn.addEventListener('click', () => {
        isCodeExpanded = !isCodeExpanded;
        if (isCodeExpanded) {
          pgCodeOutput.style.maxHeight = '800px';
          pgShowMoreFade.style.background = 'transparent';
          pgShowMoreBtn.textContent = 'Show less';
        } else {
          pgCodeOutput.style.maxHeight = '260px';
          pgShowMoreFade.style.background = 'linear-gradient(transparent, #0a0a0c 80%)';
          pgShowMoreBtn.textContent = 'Show more';
        }
      });

      const escapeHtml = (unsafe) => {
        return unsafe
             .replace(/&/g, "&amp;")
             .replace(/</g, "&lt;")
             .replace(/>/g, "&gt;")
             .replace(/"/g, "&quot;")
             .replace(/'/g, "&#039;");
      };

      const typeStyles = {
        'primary': { bg: '#006AFF', hoverBg: '#1E52BB', color: '#fff', border: '' },
        'secondary': { bg: '#EAF0FC', hoverBg: '#D6E4F9', color: '#1E52BB', border: '' },
        'tertiary': { bg: 'transparent', hoverBg: '#F0F4FF', color: '#1E52BB', border: '' },
        'outline': { bg: '#FFFFFF', hoverBg: '#F4F5F7', color: '#2A303D', border: '1px solid #C3C9D6' },
        'danger': { bg: '#E42527', hoverBg: '#C21E20', color: '#fff', border: '' },
        'tertiary-grey': { bg: 'transparent', hoverBg: '#F4F5F7', color: '#55607A', border: '' }
      };

      const sizeMap = {
        'xl': { container: '40px', icon: '20px' },
        'l': { container: '36px', icon: '18px' },
        's': { container: '28px', icon: '16px' },
        'xs': { container: '24px', icon: '14px' }
      };

      function updatePlayground() {
        const type = pgType.value;
        const size = pgSize.value;
        const shape = pgShape.value;

        pgButtonElement.className = 'ib-base ib-' + type + ' ib-' + size + ' ib-' + shape;

        const svgHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>';
        pgButtonElement.innerHTML = svgHTML;

        const ts = typeStyles[type];
        const sz = sizeMap[size];
        const radius = shape === 'circle' ? '50%' : '4px';

        let cssCode = '<style>\n';
        cssCode += '.icon-button {\n';
        cssCode += '  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n';
        cssCode += '  width: ' + sz.container + ';\n  height: ' + sz.container + ';\n';
        cssCode += '  border-radius: ' + radius + ';\n';
        cssCode += '  background: ' + ts.bg + ';\n';
        cssCode += '  color: ' + ts.color + ';\n';
        if (ts.border) cssCode += '  border: ' + ts.border + ';\n';
        else cssCode += '  border: none;\n';
        cssCode += '  cursor: pointer;\n  padding: 0;\n';
        cssCode += '  transition: all 0.2s ease;\n';
        cssCode += '}\n';
        cssCode += '.icon-button:hover {\n  background: ' + ts.hoverBg + ';\n}\n';
        cssCode += '.icon-button svg {\n  width: ' + sz.icon + ';\n  height: ' + sz.icon + ';\n}\n';
        cssCode += '</style>\n\n';

        let htmlCode = '<button class="icon-button" aria-label="Edit">\n';
        htmlCode += '  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">\n';
        htmlCode += '    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>\n';
        htmlCode += '    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>\n';
        htmlCode += '  </svg>\n</button>';

        const fullCode = cssCode + htmlCode;

        const highlightedHTML = escapeHtml(fullCode)
          .replace(/class=&quot;(.*?)&quot;/g, '<span class="token-attr">class</span>=<span class="token-string">"$1"</span>')
          .replace(/([a-zA-Z-]+)=&quot;(.*?)&quot;/g, '<span class="token-attr">$1</span>=<span class="token-string">"$2"</span>')
          .replace(/&lt;(\/?)(style|button|svg|path)(.*?)&gt;/g, '&lt;$1<span class="token-tag">$2</span>$3&gt;')
          .replace(/([a-zA-Z-]+):([\s\S]*?);/g, '<span class="token-attr">$1</span>:<span class="token-string">$2</span>;')
          .replace(/\n/g, '<br/>')
          .replace(/  /g, '&nbsp;&nbsp;');

        pgCodeOutput.innerHTML = highlightedHTML;
      }

      pgType.addEventListener('change', updatePlayground);
      pgSize.addEventListener('change', updatePlayground);
      pgShape.addEventListener('change', updatePlayground);

      pgCopyBtn.addEventListener('click', () => {
        const rawCodeElem = document.createElement('div');
        rawCodeElem.innerHTML = pgCodeOutput.innerHTML.replace(/<br[^>]*>/gi, '\n').replace(/&nbsp;/g, ' ');
        const tempTextarea = document.createElement('textarea');
        tempTextarea.value = rawCodeElem.innerText;
        document.body.appendChild(tempTextarea);
        tempTextarea.select();
        document.execCommand('copy');
        document.body.removeChild(tempTextarea);

        const originalText = pgCopyBtn.innerHTML;
        pgCopyBtn.innerHTML = '<svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Copied!';
        setTimeout(() => pgCopyBtn.innerHTML = originalText, 2000);
      });

      updatePlayground();
    })();

    // Sidebar search filter
    (function(){
      var searchInput = document.querySelector('.sidebar-search input');
      if (!searchInput) return;
      var items = document.querySelectorAll('.sidebar-nav li');
      searchInput.addEventListener('input', function(){
        var q = this.value.toLowerCase().trim();
        items.forEach(function(li){
          var link = li.querySelector('a');
          if (!link) return;
          var text = link.textContent.toLowerCase();
          li.style.display = (!q || text.indexOf(q) !== -1) ? '' : 'none';
        });
      });
      // Cmd+K / Ctrl+K shortcut to focus search
      document.addEventListener('keydown', function(e){
        if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
          e.preventDefault();
          searchInput.focus();
          searchInput.select();
        }
      });
    })();

    // Scroll sidebar to active link on page load
    (function(){
      var active = document.querySelector('.sidebar-link.active');
      if (active) {
        var sidebar = active.closest('.sidebar');
        if (sidebar) {
          var top = active.offsetTop - sidebar.offsetTop - (sidebar.clientHeight / 3);
          sidebar.scrollTop = Math.max(0, top);
        }
      }
    })();

  </script>
<script>
(function(){
  const nav = document.querySelector('.nav');
  if (!nav) return;
  const toggle = () => {
    if (window.scrollY > 10) nav.classList.add('scrolled');
    else nav.classList.remove('scrolled');
  };
  toggle();
  window.addEventListener('scroll', toggle, { passive: true });
})();
</script>
<script>
(function(){
  const hamburger = document.querySelector('.nav-hamburger');
  const sidebar = document.querySelector('.sidebar');
  const backdrop = document.querySelector('.sidebar-backdrop');
  const navLinks = document.querySelector('.nav-links');
  if (!hamburger || !sidebar || !backdrop) return;

  // Build a mobile-only nav section at the top of the sidebar by cloning the nav links
  if (navLinks && !sidebar.querySelector('.sidebar-mobile-nav')) {
    const mobileNav = document.createElement('div');
    mobileNav.className = 'sidebar-mobile-nav';
    const heading = document.createElement('h4');
    heading.textContent = 'Navigate';
    mobileNav.appendChild(heading);
    const ul = document.createElement('ul');
    navLinks.querySelectorAll(':scope > a').forEach(a => {
      const li = document.createElement('li');
      const clone = a.cloneNode(true);
      li.appendChild(clone);
      ul.appendChild(li);
    });
    navLinks.querySelectorAll(':scope > .nav-dropdown > .nav-dropdown-menu > a').forEach(a => {
      const li = document.createElement('li');
      const clone = a.cloneNode(true);
      li.appendChild(clone);
      ul.appendChild(li);
    });
    mobileNav.appendChild(ul);
    sidebar.insertBefore(mobileNav, sidebar.firstChild);
  }

  const open = () => {
    sidebar.classList.add('open');
    backdrop.classList.add('open');
    document.body.classList.add('sidebar-locked');
    hamburger.setAttribute('aria-expanded', 'true');
  };
  const close = () => {
    sidebar.classList.remove('open');
    backdrop.classList.remove('open');
    document.body.classList.remove('sidebar-locked');
    hamburger.setAttribute('aria-expanded', 'false');
  };
  hamburger.addEventListener('click', () => sidebar.classList.contains('open') ? close() : open());
  backdrop.addEventListener('click', close);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && sidebar.classList.contains('open')) close(); });
  sidebar.addEventListener('click', (e) => { if (e.target.closest('a')) close(); });
})();
</script>

