<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="UTF-8">
  <link rel="icon" type="image/png" href="assets/prism-logo.png">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Icon Button — UEMS Design System</title>
<style>
  /* Zoho Puvi Font Family */
  @font-face { font-family: 'Zoho Puvi'; src: url('https://fonts.zohowebstatic.com/zohopuvi/3.5/zoho_puvi_thin.woff2') format('woff2'); font-weight: 100; font-style: normal; font-display: swap; }
  @font-face { font-family: 'Zoho Puvi'; src: url('https://fonts.zohowebstatic.com/zohopuvi/3.5/zoho_puvi_extralight.woff2') format('woff2'); font-weight: 200; font-style: normal; font-display: swap; }
  @font-face { font-family: 'Zoho Puvi'; src: url('https://fonts.zohowebstatic.com/zohopuvi/3.5/zoho_puvi_light.woff2') format('woff2'); font-weight: 300; font-style: normal; font-display: swap; }
  @font-face { font-family: 'Zoho Puvi'; src: url('https://fonts.zohowebstatic.com/zohopuvi/3.5/zoho_puvi_regular.woff2') format('woff2'); font-weight: 400; font-style: normal; font-display: swap; }
  @font-face { font-family: 'Zoho Puvi'; src: url('https://fonts.zohowebstatic.com/zohopuvi/3.5/zoho_puvi_medium.woff2') format('woff2'); font-weight: 500; font-style: normal; font-display: swap; }
  @font-face { font-family: 'Zoho Puvi'; src: url('https://fonts.zohowebstatic.com/zohopuvi/3.5/zoho_puvi_semibold.woff2') format('woff2'); font-weight: 600; font-style: normal; font-display: swap; }
  @font-face { font-family: 'Zoho Puvi'; src: url('https://fonts.zohowebstatic.com/zohopuvi/3.5/zoho_puvi_bold.woff2') format('woff2'); font-weight: 700; font-style: normal; font-display: swap; }
  @font-face { font-family: 'Zoho Puvi'; src: url('https://fonts.zohowebstatic.com/zohopuvi/3.5/zoho_puvi_extrabold.woff2') format('woff2'); font-weight: 800; font-style: normal; font-display: swap; }
  @font-face { font-family: 'Zoho Puvi'; src: url('https://fonts.zohowebstatic.com/zohopuvi/3.5/zoho_puvi_black.woff2') format('woff2'); font-weight: 900; font-style: normal; font-display: swap; }
  @font-face { font-family: 'Zoho Puvi'; src: url('https://fonts.zohowebstatic.com/zohopuvi/3.5/zoho_puvi_extrablack.woff2') format('woff2'); font-weight: 950; font-style: normal; font-display: swap; }
  @font-face { font-family: 'Zoho Puvi'; src: url('https://fonts.zohowebstatic.com/zohopuvi/3.5/zoho_puvi_regular_italic.woff2') format('woff2'); font-weight: 400; font-style: italic; font-display: swap; }
  @font-face { font-family: 'Zoho Puvi'; src: url('https://fonts.zohowebstatic.com/zohopuvi/3.5/zoho_puvi_bold_italic.woff2') format('woff2'); font-weight: 700; font-style: italic; font-display: swap; }
  @font-face { font-family: 'Zoho Puvi'; src: url('https://fonts.zohowebstatic.com/zohopuvi/3.5/zoho_puvi_semibold_italic.woff2') format('woff2'); font-weight: 600; font-style: italic; font-display: swap; }

  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --prism-black: #0a0a0c;
    --prism-violet: #2563eb;
    --prism-violet-light: #60a5fa;
    --prism-fuchsia: #0ea5e9;
    --prism-cyan: #06b6d4;
    --prism-surface: rgba(255, 255, 255, 0.05);
    --prism-surface-hover: rgba(255, 255, 255, 0.09);
    --prism-border: rgba(255, 255, 255, 0.07);
    --prism-text: rgba(255, 255, 255, 0.92);
    --prism-text-muted: rgba(255, 255, 255, 0.48);
    --nav-bg: rgba(10,10,12,0.75);
    --nav-link-color: var(--prism-text-muted);
    --logo-gradient: linear-gradient(135deg, #0058ff 40%, #3c50ff 30%, #0fd095 100%);
    --logo-filter: drop-shadow(0 2px 10px rgba(37, 99, 235, 0.3));
    --radius: 20px;
  }

  [data-theme="light"] {
    --prism-black: #ffffff;
    --prism-violet: #2563eb;
    --prism-violet-light: #1d4ed8;
    --prism-fuchsia: #0284c7;
    --prism-cyan: #0891b2;
    --prism-surface: rgba(37, 99, 235, 0.028);
    --prism-surface-hover: rgba(37, 99, 235, 0.055);
    --prism-border: rgba(37, 99, 235, 0.10);
    --prism-text: #1a1a2e;
    --prism-text-muted: #64748b;
    --nav-bg: rgba(255, 255, 255, 0.82);
    --logo-gradient: linear-gradient(135deg, #0058ff 40%, #3c50ff 30%, #0fd095 100%);
    --logo-filter: drop-shadow(0 2px 12px rgba(37, 99, 235, 0.25));
    --nav-link-color: #475569;
  }

  html { scroll-behavior: smooth; scroll-padding-top: 100px; }

  body {
    font-family: 'Zoho Puvi', sans-serif;
    background: var(--prism-black);
    color: var(--prism-text);
    transition: background 0.5s cubic-bezier(0.4, 0, 0.2, 1), color 0.4s ease;
  }

  /* ── Premium Light Theme Global Enhancements ── */
  [data-theme="light"] body {
    background: linear-gradient(180deg, #ffffff 0%, #f8faff 100%);
  }
  [data-theme="light"] .nav { background: transparent; border-bottom: 1px solid transparent; box-shadow: none; }
  [data-theme="light"] .nav.scrolled { background: rgba(255, 255, 255, 0.78); border-bottom: 1px solid rgba(37, 99, 235, 0.06); box-shadow: 0 1px 3px rgba(37, 99, 235, 0.04), 0 4px 24px rgba(37, 99, 235, 0.03); }
  .nav.scrolled {
    background: var(--nav-bg);
    backdrop-filter: blur(24px) saturate(1.4);
    -webkit-backdrop-filter: blur(24px) saturate(1.4);
    border-bottom: 1px solid var(--prism-border);
  }
  [data-theme="light"] .sidebar {
    border-right: 1px solid rgba(37, 99, 235, 0.06);
    background: linear-gradient(180deg, rgba(248, 250, 255, 0.6) 0%, rgba(255, 255, 255, 0.4) 100%);
  }
  [data-theme="light"] .sidebar-link {
    color: #64748b;
  }
  [data-theme="light"] .sidebar-link:hover {
    color: #1e293b;
    background: rgba(37, 99, 235, 0.05);
  }
  [data-theme="light"] .sidebar-link.active {
    color: #2563eb;
    background: rgba(37, 99, 235, 0.06);
    box-shadow: 0 1px 4px rgba(37, 99, 235, 0.08);
  }
  [data-theme="light"] .sidebar-search {
    background: rgba(255, 255, 255, 0.8);
    border: 1px solid rgba(37, 99, 235, 0.10);
    box-shadow: 0 1px 4px rgba(37, 99, 235, 0.04);
  }
  [data-theme="light"] .sidebar-search:focus-within {
    background: #fff;
    border-color: #2563eb;
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.10), 0 2px 8px rgba(37, 99, 235, 0.06);
  }
  [data-theme="light"] .content-tabs {
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(37, 99, 235, 0.08);
    box-shadow: 0 1px 4px rgba(37, 99, 235, 0.04);
  }
  [data-theme="light"] .tab-item:hover {
    color: #1e293b;
    background: rgba(37, 99, 235, 0.05);
  }
  [data-theme="light"] .tab-item.active {
    color: #fff;
    background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
    box-shadow: 0 2px 8px rgba(37, 99, 235, 0.30), 0 1px 2px rgba(37, 99, 235, 0.15);
  }
  [data-theme="light"] .accordion-item {
    background: #fff;
    border: 1px solid rgba(37, 99, 235, 0.08);
    box-shadow: 0 1px 3px rgba(37, 99, 235, 0.04);
  }
  [data-theme="light"] .accordion-item:hover {
    border-color: rgba(37, 99, 235, 0.22);
    box-shadow: 0 4px 16px rgba(37, 99, 235, 0.08);
  }
  [data-theme="light"] .accordion-item.open {
    border-color: rgba(37, 99, 235, 0.30);
    box-shadow: 0 8px 32px rgba(37, 99, 235, 0.10), 0 2px 8px rgba(37, 99, 235, 0.06);
    background: #fff;
  }
  [data-theme="light"] .doc-list li {
    background: #fff;
    border: 1px solid rgba(37, 99, 235, 0.12);
    box-shadow: 0 2px 6px rgba(37, 99, 235, 0.06);
  }
  [data-theme="light"] .doc-list li:hover {
    background: rgba(37, 99, 235, 0.025);
    border-color: rgba(37, 99, 235, 0.22);
    box-shadow: 0 4px 16px rgba(37, 99, 235, 0.10);
  }
  [data-theme="light"] .do-card, [data-theme="light"] .dont-card {
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  }
  [data-theme="light"] .do-card:hover, [data-theme="light"] .dont-card:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }
  [data-theme="light"] .do-card { border-top: 3px solid #16a34a; }
  [data-theme="light"] .dont-card { border-top: 3px solid #dc2626; }
  [data-theme="light"] .related-chip {
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.10);
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
  }
  [data-theme="light"] .related-chip:hover {
    background: rgba(37, 99, 235, 0.03);
    border-color: rgba(37, 99, 235, 0.30);
    box-shadow: 0 6px 24px rgba(37, 99, 235, 0.12);
  }
  [data-theme="light"] .feedback-banner {
    background: linear-gradient(135deg, rgba(37, 99, 235, 0.05) 0%, rgba(6, 182, 212, 0.05) 100%);
    border: 1px solid rgba(37, 99, 235, 0.12);
    box-shadow: 0 2px 12px rgba(37, 99, 235, 0.06);
  }
  [data-theme="light"] .feedback-btn {
    background: #fff;
    border: 1px solid rgba(37, 99, 235, 0.12);
    box-shadow: 0 1px 3px rgba(37, 99, 235, 0.04);
  }
  [data-theme="light"] .feedback-btn:hover {
    background: rgba(37, 99, 235, 0.04);
    border-color: rgba(37, 99, 235, 0.25);
  }
  [data-theme="light"] .feedback-btn.primary {
    background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
    border-color: transparent;
    box-shadow: 0 2px 8px rgba(37, 99, 235, 0.25);
  }
  [data-theme="light"] .feedback-btn.primary:hover {
    box-shadow: 0 4px 20px rgba(37, 99, 235, 0.35);
  }
  [data-theme="light"] .toc-sidebar {
    background: transparent;
  }
  [data-theme="light"] .toc-link {
    color: #94a3b8;
  }
  [data-theme="light"] .toc-link:hover {
    color: #475569;
  }
  [data-theme="light"] .toc-link.active {
    color: #2563eb;
    font-weight: 600;
  }
  [data-theme="light"] .toc-nav {
    border-left: 2px solid rgba(37, 99, 235, 0.08);
  }
  [data-theme="light"] .quick-actions-card {
    border-top: 1px solid rgba(37, 99, 235, 0.06);
  }
  [data-theme="light"] .action-link {
    color: #94a3b8;
  }
  [data-theme="light"] .action-link:hover {
    color: #1e293b;
  }
  [data-theme="light"] .doc-divider {
    border-top: 1px solid rgba(37, 99, 235, 0.06);
  }
  [data-theme="light"] .icon-btn {
    color: #94a3b8;
  }
  [data-theme="light"] .icon-btn:hover {
    color: #1e293b;
    background: rgba(37, 99, 235, 0.06);
  }
  [data-theme="light"] .nav-links a {
    color: #64748b;
  }
  [data-theme="light"] .nav-links a:hover {
    color: #1e293b;
    background: rgba(37, 99, 235, 0.05);
  }
  [data-theme="light"] .nav-links a.active {
    color: #2563eb;
    background: rgba(37, 99, 235, 0.06);
  }

  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    padding: 0 32px; height: 72px;
    display: flex; align-items: center; justify-content: space-between;
    background: transparent;
    border-bottom: 1px solid transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    transition: background 0.3s ease, backdrop-filter 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .nav-logo { display: inline-flex; flex-direction: row; align-items: center; gap: 10px; text-decoration: none; line-height: 1; }
  .nav-logo-img { width: 40px; height: 40px; flex-shrink: 0; display: block; }
  .nav-logo-text { display: inline-flex; flex-direction: column; align-items: flex-start; gap: 0; }
   .nav-logo-mark { font-size: 26px; font-weight: 900; letter-spacing: 0.02em; background: var(--logo-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; padding-right: 0.1em; padding-bottom: 0.05em; line-height: 1; }
  .nav-logo-sub { font-size: 10px; font-weight: 600; color: var(--prism-text-muted); letter-spacing: 0.08em; text-transform: none; margin-top: 2px; }
  .nav-logo-sub .caps { text-transform: uppercase; }

  .nav-links { display: flex; align-items: center; gap: 6px; }
  .nav-links a {
    color: var(--nav-link-color, var(--prism-text-muted)); text-decoration: none; font-size: 14px; font-weight: 600;
    padding: 8px 16px; border-radius: 999px; transition: all 0.3s ease; border: none;
  }
  .nav-links a:hover { color: var(--prism-text); background: var(--prism-surface-hover); }
  .nav-links a.active { color: var(--prism-violet); background: rgba(37, 99, 235, 0.08); border: none; }

  .icon-btn {
    background: transparent; border: none; cursor: pointer;
    color: var(--prism-text-muted); padding: 8px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    transition: all 0.2s ease; margin-left: 4px;
  }
  .icon-btn:hover { color: var(--prism-text); background: var(--prism-surface-hover); }

  /* Nav dropdown */
  .nav-dropdown { position: relative; }
  .nav-dropdown > a { display: flex; align-items: center; gap: 4px; }
  .nav-dropdown > a .nav-chevron { width: 12px; height: 12px; transition: transform 0.2s ease; }
  .nav-dropdown:hover > a .nav-chevron { transform: rotate(180deg); }
  .nav-dropdown-menu { position: absolute; top: calc(100% + 8px); right: 0; min-width: 200px; background: var(--prism-black); border: 1px solid var(--prism-border); border-radius: 12px; padding: 6px; opacity: 0; visibility: hidden; transform: translateY(-8px); transition: all 0.25s cubic-bezier(0.4,0,0.2,1); z-index: 200; backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); box-shadow: 0 8px 32px rgba(0,0,0,0.12); }
  .nav-dropdown:hover .nav-dropdown-menu { opacity: 1; visibility: visible; transform: translateY(0); }
  .nav-dropdown-menu a { display: flex; align-items: center; gap: 10px; padding: 10px 14px; border-radius: 8px; font-size: 13.5px; font-weight: 500; color: var(--prism-text-muted); text-decoration: none; transition: all 0.2s ease; background: transparent; }
  .nav-dropdown-menu a:hover { color: var(--prism-text); background: var(--prism-surface-hover); }
  .nav-dropdown-menu a svg { width: 18px; height: 18px; flex-shrink: 0; color: var(--prism-text-muted); opacity: 0.7; }
  .nav-dropdown-menu a:hover svg { color: var(--prism-violet); opacity: 1; }
  [data-theme="light"] .nav-dropdown-menu { background: #fff; border: 1px solid rgba(37,99,235,0.10); box-shadow: 0 8px 32px rgba(37,99,235,0.10), 0 2px 8px rgba(37,99,235,0.06); }
  [data-theme="light"] .nav-dropdown-menu a { color: #64748b; }
  [data-theme="light"] .nav-dropdown-menu a:hover { color: #1e293b; background: rgba(37,99,235,0.05); }
  [data-theme="light"] .nav-dropdown-menu a:hover svg { color: #2563eb; }

  .components-layout {
    display: grid;
    grid-template-columns: 260px 1fr;
    width: 100%;
    padding-top: 72px;
    min-height: 100vh;
  }

  .sidebar {
    grid-column: 1;
    grid-row: 1;
    width: 260px;
    border-right: 1px solid var(--prism-border);
    padding: 32px 24px 64px;
    position: sticky;
    top: 72px;
    height: calc(100vh - 72px);
    overflow-y: auto;
  }
  .sidebar::-webkit-scrollbar { width: 4px; }
  .sidebar::-webkit-scrollbar-thumb { background: var(--prism-border); border-radius: 4px; }

  .sidebar-heading {
    font-size: 11px; font-weight: 700; color: var(--prism-text-muted);
    text-transform: uppercase; letter-spacing: 0.1em;
    margin-bottom: 16px; padding-left: 12px;
  }

  .sidebar-nav { list-style: none; display: flex; flex-direction: column; gap: 2px; }

  .sidebar-link {
    display: flex; align-items: center; padding: 8px 12px; font-size: 13.5px; font-weight: 500;
    color: var(--prism-text-muted); text-decoration: none;
    border-radius: 8px; transition: all 0.2s ease;
  }
  .sidebar-link:hover {
    color: var(--prism-text); background: var(--prism-surface-hover);
    transform: translateX(4px);
  }
  .sidebar-link.active {
    color: var(--prism-violet); background: rgba(37, 99, 235, 0.08);
    font-weight: 600;
  }
  .sidebar-link.active::before {
    content: ''; width: 4px; height: 16px; background: var(--prism-violet);
    border-radius: 4px; margin-right: 12px; margin-left: -4px;
  }

  .main-panel {
    grid-column: 2;
    grid-row: 1;
    padding: 48px 64px 0 64px;
    display: flex;
    flex-direction: column;
  }
  .page-header-area {
    width: 100%;
    max-width: none;
  }
  .page-title {
    font-size: 48px; font-weight: 800; letter-spacing: -0.03em; margin-bottom: 8px;
    background: var(--logo-gradient);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    display: inline-block; padding-right: 8px; padding-bottom: 4px;
  }
  .page-desc {
    color: var(--prism-text); font-size: 20px; font-weight: 400;
    line-height: 1.5; margin-bottom: 32px; margin-top: 8px;
    max-width: 900px;
  }
  .main-content-area {
    display: grid;
    grid-template-columns: 1fr 240px;
    gap: 0;
    flex: 1;
    align-items: start;
  }
  .main-content-inner {
    padding-bottom: 64px;
    min-width: 0;
  }

  /* Modern Ambient Glows */
  .bg-glow {
    position: fixed; border-radius: 50%; width: 60vw; height: 60vh;
    filter: blur(140px); z-index: -1; pointer-events: none; opacity: 0.15;
    transition: opacity 0.6s ease, filter 0.6s ease;
  }
  .glow-1 { top: -20%; right: -10%; background: var(--prism-violet); }
  .glow-2 { bottom: -20%; left: -10%; background: var(--prism-cyan); }
  [data-theme="light"] .bg-glow { opacity: 0.09; filter: blur(180px); }

  /* Glassmorphic Sidebars */
  .sidebar, .toc-sidebar {
    background: transparent;
    backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
  }

  /* Sidebar Search */
  .sidebar-search {
    display: flex; align-items: center; background: var(--prism-surface);
    border: 1px solid var(--prism-border); border-radius: 999px;
    padding: 8px 16px; margin-bottom: 24px; transition: all 0.2s ease;
  }
  .sidebar-search:focus-within {
    border-color: var(--prism-violet); background: transparent;
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.15);
  }
  .sidebar-search svg { color: var(--prism-text-muted); }
  .sidebar-search input {
    background: transparent; border: none; outline: none;
    color: var(--prism-text); font-family: inherit; font-size: 14px;
    width: 100%; margin-left: 10px;
  }
  .sidebar-search input::placeholder { color: var(--prism-text-muted); }
  .search-shortcut {
    font-size: 11px; font-weight: 600; color: var(--prism-text-muted);
    background: var(--prism-surface-hover); padding: 2px 6px; border-radius: 4px; border: 1px solid var(--prism-border);
  }

  /* Right Side TOC */
  .toc-sidebar {
    width: 240px; padding: 20px;
    position: sticky; top: 72px; height: calc(100vh - 72px);
    overflow-y: auto;
    align-self: start;
  }
  .toc-heading {
    font-size: 11px; font-weight: 700; color: var(--prism-text);
    text-transform: uppercase; letter-spacing: 0.1em;
    margin-bottom: 16px;
  }
  .toc-nav {
    list-style: none; display: flex; flex-direction: column; gap: 10px;
    border-left: 1px solid var(--prism-border); padding-left: 16px; margin-left: 4px; line-height: 1.6;
  }
  .toc-link {
    display: block; font-size: 13px; font-weight: 400;
    color: var(--prism-text-muted); text-decoration: none;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative; padding-left: 0;
  }
  .toc-link:hover { color: var(--prism-text); }
  .toc-link.active {
    color: var(--prism-violet); font-weight: 600;
  }

  /* Quick Action Links */
  .quick-actions-card {
    margin-top: 32px; padding-top: 32px; border-top: 1px solid var(--prism-border);
    display: flex; flex-direction: column; gap: 4px;
  }
  .quick-actions-title {
    font-size: 11px; font-weight: 700; color: var(--prism-text-muted);
    text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 8px;
  }
  .action-link {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 13.5px; font-weight: 600; color: var(--prism-text-muted);
    text-decoration: none; padding: 6px 0;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .action-link svg {
    opacity: 0.8; transition: all 0.2s ease;
  }
  .action-link:hover {
    color: var(--prism-text); transform: translateX(2px);
  }
  .action-link:hover svg {
    opacity: 1; transform: scale(1.05); color: var(--prism-violet);
  }

  .content-tabs {
    display: flex; gap: 4px; margin-bottom: 40px;
    background: var(--prism-surface); padding: 4px; border-radius: 999px;
    width: max-content; border: 1px solid var(--prism-border);
  }
  .tab-item {
    background: transparent; border: none; font-family: inherit;
    font-size: 14px; font-weight: 600; color: var(--prism-text-muted);
    padding: 10px 24px; cursor: pointer; transition: all 0.3s ease;
    border-radius: 999px; position: relative;
  }
  .tab-item:hover { color: var(--prism-text); background: var(--prism-surface-hover); }
  .tab-item.active {
    color: #fff; background: var(--prism-violet);
    box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3);
  }

  /* ── Modern Documentation Styles ── */
  .doc-section {
    margin-bottom: 64px;
  }
  .doc-section-title {
    font-size: 32px; font-weight: 400; color: var(--prism-text);
    margin-bottom: 12px;
  }
  .doc-section-subtitle {
    font-size: 16px; color: var(--prism-text-muted); line-height: 1.6;
    margin-bottom: 32px; max-width: 720px;
  }
  .doc-h3 {
    font-size: 20px; font-weight: 600; color: var(--prism-text);
    margin-bottom: 16px; display: flex; align-items: center; gap: 10px;
  }
  .doc-h3 .h3-badge {
    font-size: 11px; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.08em; padding: 3px 10px; border-radius: 999px;
  }
  .doc-divider {
    border: none; border-top: 1px solid var(--prism-border); margin: 56px 0;
  }

  /* Content list with left accent */
  .doc-list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 12px;
  }
  .doc-list li {
    font-size: 15px; line-height: 1.65; color: var(--prism-text);
    padding: 14px 20px; background: var(--prism-surface);
    border: 1px solid var(--prism-border); border-radius: 10px;
    border-left: 3px solid var(--prism-violet);
    transition: all 0.2s ease;
  }
  .doc-list li:hover {
    border-left-color: var(--prism-cyan);
    background: var(--prism-surface-hover);
    transform: translateX(4px);
  }

  /* Do / Don't cards */
  .do-dont-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 20px;
  }
  .do-card, .dont-card {
    padding: 24px; border-radius: 12px; border: 1px solid var(--prism-border);
    background: var(--prism-surface);
  }
  .do-card { border-top: 3px solid #22c55e; }
  .dont-card { border-top: 3px solid #ef4444; }
  .do-card .card-label, .dont-card .card-label {
    font-size: 14px; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.06em; margin-bottom: 16px; display: flex;
    align-items: center; gap: 8px;
  }
  .do-card .card-label { color: #22c55e; }
  .dont-card .card-label { color: #ef4444; }
  .do-card ul, .dont-card ul {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 10px;
  }
  .do-card li, .dont-card li {
    font-size: 14.5px; line-height: 1.6; color: var(--prism-text-muted);
    padding-left: 20px; position: relative;
  }
  .do-card li::before {
    content: '\2713'; position: absolute; left: 0; color: #22c55e; font-weight: 700;
  }
  .dont-card li::before {
    content: '\2717'; position: absolute; left: 0; color: #ef4444; font-weight: 700;
  }

  /* Related component chips */
  .related-grid {
    display: flex; flex-wrap: wrap; gap: 12px;
  }
  .related-chip {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 10px 20px; background: var(--prism-surface);
    border: 1px solid var(--prism-border); border-radius: 10px;
    font-size: 14px; font-weight: 600; color: var(--prism-text);
    text-decoration: none; transition: all 0.25s cubic-bezier(0.4,0,0.2,1);
  }
  .related-chip:hover {
    border-color: var(--prism-violet); color: var(--prism-violet);
    background: rgba(37, 99, 235, 0.06);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(37, 99, 235, 0.1);
  }
  .related-chip svg { color: var(--prism-text-muted); transition: color 0.2s; }
  .related-chip:hover svg { color: var(--prism-violet); }

  /* Feedback banner */
  .feedback-banner {
    margin-top: 72px; padding: 32px; border-radius: 16px;
    background: linear-gradient(135deg, rgba(37,99,235,0.06) 0%, rgba(6,182,212,0.06) 100%);
    border: 1px solid var(--prism-border);
    display: flex; align-items: center; justify-content: space-between;
  }
  .feedback-banner .fb-text {
    font-size: 16px; font-weight: 600; color: var(--prism-text);
  }
  .feedback-banner .fb-sub {
    font-size: 13.5px; color: var(--prism-text-muted); margin-top: 4px;
  }
  .feedback-btn {
    padding: 10px 28px; border-radius: 999px; font-family: inherit;
    font-size: 14px; font-weight: 600; cursor: pointer;
    transition: all 0.2s ease; border: 1px solid var(--prism-border);
    background: var(--prism-surface); color: var(--prism-text);
  }
  .feedback-btn:hover {
    border-color: var(--prism-violet); color: var(--prism-violet);
    background: rgba(37, 99, 235, 0.08);
  }
  .feedback-btn.primary {
    background: var(--prism-violet); color: #fff; border-color: var(--prism-violet);
  }
  .feedback-btn.primary:hover {
    background: #1d4ed8; box-shadow: 0 4px 16px rgba(37, 99, 235, 0.3);
    transform: translateY(-1px);
  }

  /* ── Icon Button Component Styles ── */
  .ib-base {
    display: inline-flex; align-items: center; justify-content: center;
    border: none; cursor: pointer; padding: 0;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .ib-base:active { transform: scale(0.95); }
  .ib-base svg { flex-shrink: 0; }

  /* Types */
  .ib-primary { background: #006AFF; color: #fff; }
  .ib-primary:hover { background: #1E52BB; }

  .ib-secondary { background: #EAF0FC; color: #1E52BB; }
  .ib-secondary:hover { background: #D6E4F9; }
  html:not([data-theme="light"]) .ib-secondary { background: rgba(234,240,252,0.12); color: #60a5fa; }
  html:not([data-theme="light"]) .ib-secondary:hover { background: rgba(234,240,252,0.2); }

  .ib-tertiary { background: transparent; color: #1E52BB; }
  .ib-tertiary:hover { background: #F0F4FF; }
  html:not([data-theme="light"]) .ib-tertiary { background: transparent; color: #60a5fa; }
  html:not([data-theme="light"]) .ib-tertiary:hover { background: rgba(96,165,250,0.1); }

  .ib-outline { background: #FFFFFF; border: 1px solid #C3C9D6; color: #2A303D; }
  .ib-outline:hover { background: #F4F5F7; }
  html:not([data-theme="light"]) .ib-outline { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.2); color: #fff; }
  html:not([data-theme="light"]) .ib-outline:hover { background: rgba(255,255,255,0.1); }

  .ib-danger { background: #E42527; color: #fff; }
  .ib-danger:hover { background: #C21E20; }

  .ib-tertiary-grey { background: transparent; color: #55607A; }
  .ib-tertiary-grey:hover { background: #F4F5F7; }
  html:not([data-theme="light"]) .ib-tertiary-grey { background: transparent; color: #94a3b8; }
  html:not([data-theme="light"]) .ib-tertiary-grey:hover { background: rgba(148,163,184,0.1); }

  /* Sizes */
  .ib-xl { width: 40px; height: 40px; }
  .ib-xl svg { width: 20px; height: 20px; }
  .ib-l { width: 36px; height: 36px; }
  .ib-l svg { width: 18px; height: 18px; }
  .ib-s { width: 28px; height: 28px; }
  .ib-s svg { width: 16px; height: 16px; }
  .ib-xs { width: 24px; height: 24px; }
  .ib-xs svg { width: 14px; height: 14px; }

  /* Shapes */
  .ib-square { border-radius: 4px; }
  .ib-circle { border-radius: 50%; }

  /* Disabled */
  .ib-disabled { background: #E1E4EB !important; color: #889DAD !important; cursor: not-allowed !important; border: none !important; }
  .ib-disabled:hover { background: #E1E4EB !important; transform: none !important; }

  /* Size table reuse */
  .size-table { width: 100%; border-collapse: collapse; font-size: 14px; }
  .size-table th { text-align: left; padding: 14px 12px; color: var(--prism-text-muted); font-weight: 600; font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 2px solid var(--prism-border); }
  .size-table td { padding: 16px 12px; border-bottom: 1px solid var(--prism-border); color: var(--prism-text); vertical-align: middle; }
  .size-table tr:hover td { background: rgba(37,99,235,0.02); }
  .size-table code { font-family: 'JetBrains Mono', monospace; font-size: 12.5px; padding: 2px 8px; border-radius: 6px; background: rgba(37,99,235,0.06); color: var(--prism-violet); }

  /* State grid */
  .state-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 14px; margin-top: 24px; }
  .state-card { padding: 24px 16px; border-radius: 14px; background: var(--prism-surface); border: 1px solid var(--prism-border); text-align: center; transition: all 0.25s ease; }
  [data-theme="light"] .state-card { background: #fff; border: 1px solid rgba(37,99,235,0.07); box-shadow: 0 1px 4px rgba(37,99,235,0.04); }
  .state-card:hover { border-color: rgba(37,99,235,0.3); transform: translateY(-3px); box-shadow: 0 8px 24px rgba(37,99,235,0.08); }
  .state-card-title { font-size: 13px; font-weight: 600; color: var(--prism-text); margin-top: 16px; }
  .state-card-desc { font-size: 12px; color: var(--prism-text-muted); margin-top: 6px; line-height: 1.5; }

  /* Demo container */
  .demo-container { border: 1px solid var(--prism-border); border-radius: 16px; overflow: hidden; position: relative; }
  .demo-toolbar { display: flex; align-items: center; justify-content: space-between; padding: 12px 20px; background: var(--prism-surface); border-bottom: 1px solid var(--prism-border); }
  [data-theme="light"] .demo-container { border: 1px solid rgba(37, 99, 235, 0.14); box-shadow: 0 2px 16px rgba(37, 99, 235, 0.08); }
  [data-theme="light"] .demo-toolbar { background: rgba(255, 255, 255, 0.7); border-bottom: 1px solid rgba(37, 99, 235, 0.06); }
  .demo-toolbar-left { display: flex; align-items: center; gap: 12px; }
  .demo-theme-pill { display: flex; align-items: center; gap: 8px; padding: 6px 14px; border-radius: 8px; font-size: 13px; font-weight: 500; background: rgba(37,99,235,0.08); color: var(--prism-violet); border: 1px solid rgba(37,99,235,0.2); cursor: pointer; transition: all 0.2s ease; }
  .demo-canvas { padding: 64px; position: relative; background-image: radial-gradient(circle, rgba(255,255,255,0.15) 1px, transparent 1px); background-size: 24px 24px; background-color: #0a0a0c66; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 280px; gap: 32px; transition: background-color 0.5s ease; }
  [data-theme="light"] .demo-canvas { background-color: #f4f6fb; background-image: radial-gradient(circle, rgba(37, 99, 235, 0.08) 1px, transparent 1px); }
  .demo-btn-row { display: flex; align-items: center; gap: 16px; flex-wrap: wrap; justify-content: center; }

  /* Anatomy diagram */
  .anatomy-diagram { background: var(--prism-surface); border: 1px solid var(--prism-border); border-radius: 16px; padding: 48px 40px; margin-bottom: 28px; position: relative; overflow: hidden; }
  [data-theme="light"] .anatomy-diagram { background: #fff; border: 1px solid rgba(37, 99, 235, 0.07); box-shadow: 0 2px 12px rgba(37, 99, 235, 0.05); }
  .anatomy-diagram::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, #2563eb, #60a5fa, #06b6d4); }
  .anat-marker-inline { width: 22px; height: 22px; border-radius: 50%; flex-shrink: 0; background: linear-gradient(135deg, #2563eb, #3b82f6); color: #fff !important; font-size: 11px; font-weight: 700; display: inline-flex; align-items: center; justify-content: center; box-shadow: 0 2px 10px rgba(37, 99, 235, 0.35); }
  .anat-legend { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
  .anat-legend-item { display: flex; align-items: flex-start; gap: 14px; padding: 20px; background: var(--prism-surface); border: 1px solid var(--prism-border); border-radius: 14px; transition: all 0.25s cubic-bezier(0.4,0,0.2,1); }
  [data-theme="light"] .anat-legend-item { background: #fff; border: 1px solid rgba(37, 99, 235, 0.07); box-shadow: 0 1px 4px rgba(37, 99, 235, 0.04); }
  .anat-legend-item strong { display: block; font-size: 14.5px; font-weight: 600; color: var(--prism-text); margin-bottom: 6px; }
  .anat-legend-item span { font-size: 13px; line-height: 1.55; color: var(--prism-text-muted); }
  .anat-button-container { display: flex; justify-content: center; margin: 40px 0; }

  /* Code playground */
  .code-playground { border: 1px solid var(--prism-border); border-radius: 12px; overflow: hidden; background: var(--prism-surface); margin-bottom: 40px; box-shadow: 0 4px 20px rgba(0,0,0,0.05); }
  [data-theme="light"] .code-playground { background: #fff; border: 1px solid rgba(37,99,235,0.1); box-shadow: 0 8px 30px rgba(37,99,235,0.08); }
  .cp-toolbar { display: flex; flex-wrap: wrap; gap: 20px; padding: 16px 24px; border-bottom: 1px solid var(--prism-border); background: var(--prism-surface-hover); }
  [data-theme="light"] .cp-toolbar { background: rgba(248, 250, 255, 0.6); border-bottom: 1px solid rgba(37,99,235,0.1); }
  .cp-control-group { display: flex; flex-direction: column; gap: 8px; flex: 1; min-width: 140px; }
  .cp-label { font-size: 13px; font-weight: 600; color: var(--prism-text-muted); }
  .cp-select { background: var(--prism-surface); border: 1px solid var(--prism-border); color: var(--prism-text); padding: 8px 12px; border-radius: 8px; outline: none; font-family: inherit; font-size: 14px; cursor: pointer; transition: all 0.2s; }
  [data-theme="light"] .cp-select { background: #fff; border-color: rgba(37,99,235,0.15); color: #1e293b; }
  .cp-select:focus { border-color: var(--prism-violet); box-shadow: 0 0 0 3px rgba(37,99,235,0.15); }
  .cp-preview { padding: 60px; min-height: 240px; display: flex; align-items: center; justify-content: center; position: relative; transition: background 0.3s ease; }
  .cp-preview { background: #0a0a0c; background-image: radial-gradient(circle, rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 20px 20px; }
  [data-theme="light"] .cp-preview { background: #ffffff; background-image: radial-gradient(circle, rgba(37,99,235,0.08) 1px, transparent 1px); background-size: 20px 20px; }
  .cp-code-header { display: flex; align-items: center; justify-content: space-between; padding: 12px 24px; background: var(--prism-surface); border-top: 1px solid var(--prism-border); border-bottom: 1px solid var(--prism-border); }
  [data-theme="light"] .cp-code-header { background: rgba(248, 250, 255, 0.8); border-color: rgba(37,99,235,0.1); }
  .cp-code-actions { display: flex; gap: 12px; }
  .cp-action-btn { display: flex; align-items: center; gap: 8px; background: transparent; border: none; font-family: inherit; font-size: 13.5px; font-weight: 500; color: var(--prism-text-muted); cursor: pointer; padding: 6px 12px; border-radius: 6px; transition: all 0.2s; }
  .cp-action-btn:hover { background: var(--prism-surface-hover); color: var(--prism-text); }
  [data-theme="light"] .cp-action-btn:hover { background: rgba(37,99,235,0.08); color: var(--prism-violet); }
  .cp-code-area { background: #0a0a0c; padding: 24px; overflow-x: auto; font-family: 'JetBrains Mono', monospace; font-size: 14px; line-height: 1.6; color: #e2e8f0; }
  .cp-code-area .token-keyword { color: #60a5fa; }
  .cp-code-area .token-string { color: #34d399; }
  .cp-code-area .token-tag { color: #a78bfa; }
  .cp-code-area .token-attr { color: #38bdf8; }
  .cp-code-area .token-punct { color: #94a3b8; }

  /* Dark theme overrides for preview buttons (follows global theme) */
  html:not([data-theme="light"]) .cp-preview .ib-secondary { background: rgba(234,240,252,0.12); color: #60a5fa; }
  html:not([data-theme="light"]) .cp-preview .ib-tertiary { background: transparent; color: #60a5fa; }
  html:not([data-theme="light"]) .cp-preview .ib-outline { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.2); color: #fff; }
  html:not([data-theme="light"]) .cp-preview .ib-tertiary-grey { background: transparent; color: #94a3b8; }


    /* ══ Mobile responsive (added globally) ══ */
  .nav-hamburger { display: none; background: transparent; border: none; color: var(--prism-text); padding: 8px; margin-right: 8px; cursor: pointer; border-radius: 8px; align-items: center; justify-content: center; }
  .nav-hamburger:hover { background: var(--prism-surface-hover); }
  .sidebar-backdrop { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 95; opacity: 0; transition: opacity 0.25s ease; }
  .sidebar-backdrop.open { display: block; opacity: 1; }
  .sidebar-mobile-nav { display: none; }

  @media (max-width: 900px) {
    .nav { padding: 0 16px; height: 64px; justify-content: flex-start; gap: 4px; }
    .nav-links { margin-left: auto; }
    .nav-hamburger { display: inline-flex; order: -1; margin-right: 4px; }
    .nav-logo-mark { font-size: 22px; }
    .nav-logo-sub { font-size: 9px; }
    .nav-links > a,
    .nav-links > .nav-dropdown,
    .nav-links > div[style] { display: none !important; }
    .nav-links { gap: 0; }

    .components-layout { display: block; padding-top: 64px; grid-template-columns: 1fr; }
    .sidebar { position: fixed; top: 64px; left: 0; width: 300px; max-width: 86vw; height: calc(100vh - 64px); max-height: none; padding: 20px 18px 32px; border-right: 1px solid var(--prism-border); border-bottom: none; overflow-y: auto; transform: translateX(-100%); transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1); z-index: 96; background: var(--prism-black); }
    [data-theme="light"] .sidebar { background: #ffffff; }
    .sidebar.open { transform: translateX(0); box-shadow: 12px 0 40px rgba(0,0,0,0.25); }
    body.sidebar-locked { overflow: hidden; }

    .sidebar-mobile-nav { display: block; margin: 0 -18px 16px; padding: 0 18px 18px; border-bottom: 1px solid var(--prism-border); }
    .sidebar-mobile-nav h4 { font-size: 11px; font-weight: 700; color: var(--prism-text-muted); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 12px; padding-left: 4px; }
    .sidebar-mobile-nav ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 4px; }
    .sidebar-mobile-nav a { display: block; padding: 10px 12px; font-size: 14px; font-weight: 600; color: var(--prism-text); text-decoration: none; border-radius: 8px; transition: all 0.2s ease; }
    .sidebar-mobile-nav a:hover { background: var(--prism-surface-hover); color: var(--prism-violet); }
    .sidebar-mobile-nav a.active { color: var(--prism-violet); background: rgba(37, 99, 235, 0.08); }

    .main-panel { padding: 24px 20px 48px; grid-column: auto; grid-row: auto; }
    /* mobile-width-safety v4 — collapse any inline grid on narrow viewports */
    .main-panel, .main-content-inner, .main-content-area { max-width: 100%; width: 100%; box-sizing: border-box; min-width: 0; }
    .main-content-inner > *, .doc-section, .doc-section > * { max-width: 100%; box-sizing: border-box; min-width: 0; }
    .main-content-inner img, .main-content-inner svg:not(.inline-svg) { max-width: 100%; height: auto; }
    .main-content-inner pre, .main-content-inner code { white-space: pre-wrap; word-break: break-word; }
    .main-content-inner pre { overflow-x: auto; }
    .anatomy-diagram { overflow: visible !important; padding: 48px 40px !important; zoom: 0.82; }
    .anatomy-diagram > * { max-width: 100%; }
    .demo-container { overflow: hidden; }
    .demo-canvas { padding: 32px 20px !important; overflow-x: auto; }
    .code-playground, .cp-code-area { overflow-x: auto; }
    /* Foundation inner-page grids: collapse every multi-column inline grid */
    [style*="grid-template-columns: 1fr 1fr"],
    [style*="grid-template-columns:1fr 1fr"],
    [style*="grid-template-columns: repeat(4, 1fr)"],
    [style*="grid-template-columns: repeat(5, 1fr)"],
    [style*="grid-template-columns: repeat(6, 1fr)"],
    [style*="grid-template-columns: 320px 1fr"],
    [style*="grid-template-columns: 280px 1fr"],
    [style*="grid-template-columns: 240px 1fr"] { grid-template-columns: 1fr !important; }
    /* Flex rows with heavy fixed widths should wrap */
    [style*="display: flex"][style*="gap"] { flex-wrap: wrap; }
    .main-content-area { display: flex; flex-direction: column; grid-template-columns: 1fr; }
    .main-content-inner { padding-bottom: 32px; }
    .toc-sidebar { display: none; }

    .page-header-area .page-title,
    .page-title { font-size: 30px; line-height: 1.15; }
    .page-desc { font-size: 16px; }
    .doc-section h2, .doc-section-title { font-size: 22px; }

    .do-dont-grid,
    .illus-type-grid,
    .comp-grid,
    .density-grid,
    .illus-showcase-grid,
    .pattern-category-grid,
    .tone-grid,
    .voice-traits,
    .principles-grid,
    .theme-grid,
    .message-grid,
    .weight-grid,
    .pattern-grid,
    .collection-grid,
    .anti-pattern-list,
    .dodont-grid,
    .icon-metaphor-grid { grid-template-columns: 1fr !important; }

    table { display: block; overflow-x: auto; }
    .size-table, .token-table, .anatomy-table, .doc-table, .tone-table { display: block; overflow-x: auto; white-space: nowrap; min-width: 0; }

    .feedback-banner { flex-direction: column; align-items: flex-start; gap: 16px; padding: 24px; }
    .illus-type-card { grid-template-columns: 1fr !important; }
    .illus-type-preview { min-height: 180px; padding: 24px 16px; }

    /* Component detail page grids */
    .state-grid,
    .anatomy-grid,
    .usecase-grid,
    .anat-legend,
    /* Zia Experience hub grids */
    .zia-prompt-grid,
    /* Resource hub grids */
    .lib-grid,
    .lib-grid-logo,
    .lib-grid-illust { grid-template-columns: 1fr !important; gap: 12px !important; }

    /* Inline-styled 2- or 3-column grids */
    [style*="grid-template-columns: repeat(3, 1fr)"],
    [style*="grid-template-columns: repeat(2, 1fr)"],
    [style*="grid-template-columns:repeat(3,1fr)"],
    [style*="grid-template-columns:repeat(2,1fr)"] { grid-template-columns: 1fr !important; }

    /* Resource hub outer padding */
    .page-content { padding: 88px 16px 48px !important; }
  }

  @media (max-width: 600px) {
    .nav { padding: 0 12px; height: 60px; }
    .components-layout { padding-top: 60px; }
    .sidebar { top: 60px; height: calc(100vh - 60px); }
    .nav-logo-mark { font-size: 20px; }
    .main-panel { padding: 18px 14px 36px; }
    /* mobile-width-safety v3 */
    .main-panel { padding: 16px 10px 24px !important; }
    .anatomy-diagram { padding: 40px 28px !important; overflow: visible !important; zoom: 0.66; }
    .demo-canvas { padding: 24px 12px !important; }
    .page-header-area .page-title,
    .page-title { font-size: 26px; }
    .page-desc { font-size: 15px; }
    .sidebar-heading { font-size: 10px; }
    .search-shortcut { display: none; }
    .page-content { padding: 72px 12px 32px !important; }
  }
</style>
</head>
