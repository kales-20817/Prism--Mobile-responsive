    <main class="main-panel">
      <div class="page-header-area">
        <h1 class="page-title">Icon Button</h1>
        <p class="page-desc">
          A compact button that displays only an icon, used for toolbar actions, inline controls, and space-constrained interfaces where a text label is unnecessary. Unlike the standard Button, the Icon Button has no visible label and requires an aria-label for accessibility.
        </p>
        <nav class="content-tabs">
          <button class="tab-item active">Overview</button>
          <button class="tab-item">Style</button>
          <button class="tab-item">Usage</button>
          <button class="tab-item">Code</button>
          <button class="tab-item">Accessibility</button>
        </nav>
      </div>
      <div class="main-content-area">
        <div class="main-content-inner">

        <!-- ═══ OVERVIEW TAB ═══ -->
        <div class="tab-content" id="tab-overview" style="display: block;">

        <!-- Anatomy Section -->
        <h3 id="anatomy" class="doc-h3">Anatomy</h3>

        <div class="anatomy-diagram">
          <div class="anat-button-container">
            <div style="display: inline-flex; align-items: center; justify-content: center; width: 56px; height: 56px; border: 2px dashed rgba(37,99,235,0.4); border-radius: 8px; position: relative; overflow: visible;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
              <!-- 1 Container: marker above, line ends at container top edge -->
              <div style="position: absolute; bottom: calc(100% + 6px); left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: 4px; z-index: 5;">
                <span class="anat-marker-inline">1</span><div style="width: 2px; height: 14px; background: #2563eb;"></div>
              </div>
              <!-- 2 Icon: marker left, line ends at container left edge -->
              <div style="position: absolute; right: calc(100% + 6px); top: 50%; transform: translateY(-50%); display: flex; align-items: center; gap: 6px; z-index: 5;">
                <span class="anat-marker-inline">2</span><div style="width: 28px; height: 2px; background: #2563eb;"></div>
              </div>
            </div>
          </div>
        </div>

        <div class="anat-legend">
          <div class="anat-legend-item"><span class="anat-marker-inline">1</span><div><strong>Container</strong><span>Square or circular container with centered content. Background and border change per type and state.</span></div></div>
          <div class="anat-legend-item"><span class="anat-marker-inline">2</span><div><strong>Icon</strong><span>Single icon instance, centered within the container. Scales with size.</span></div></div>
        </div>

        <hr class="doc-divider" />

        <!-- Live Demo -->
        <div style="margin-bottom: 64px;">
          <h2 id="live-demo" class="doc-section-title" style="margin-bottom: 8px;">Preview</h2>
          <p class="doc-section-subtitle" style="margin-bottom: 28px;">Interact with the icon button variants to explore their hover states and layouts across different sizes and shapes.</p>

          <div class="demo-container">
            <div class="demo-canvas">
              <!-- Row 1: All 6 types at XL square -->
              <div class="demo-btn-row">
                <button class="ib-base ib-primary ib-xl ib-square" aria-label="Edit"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
                <button class="ib-base ib-secondary ib-xl ib-square" aria-label="Edit"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
                <button class="ib-base ib-tertiary ib-xl ib-square" aria-label="Edit"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
                <button class="ib-base ib-outline ib-xl ib-square" aria-label="Edit"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
                <button class="ib-base ib-danger ib-xl ib-square" aria-label="Delete"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
                <button class="ib-base ib-tertiary-grey ib-xl ib-square" aria-label="Edit"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
              </div>
              <!-- Row 2: Primary in all 4 sizes -->
              <div class="demo-btn-row">
                <button class="ib-base ib-primary ib-xl ib-square" aria-label="Edit"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
                <button class="ib-base ib-primary ib-l ib-square" aria-label="Edit"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
                <button class="ib-base ib-primary ib-s ib-square" aria-label="Edit"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
                <button class="ib-base ib-primary ib-xs ib-square" aria-label="Edit"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
              </div>
              <!-- Row 3: Circle shapes -->
              <div class="demo-btn-row">
                <button class="ib-base ib-primary ib-xl ib-circle" aria-label="Edit"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
                <button class="ib-base ib-secondary ib-xl ib-circle" aria-label="Edit"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
                <button class="ib-base ib-danger ib-xl ib-circle" aria-label="Delete"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
              </div>
            </div>
          </div>
        </div>

        <!-- Content Guidelines -->
        <div class="doc-section">
          <h3 id="content-guidelines" class="doc-h3">Content Guidelines<span class="h3-badge" style="background: rgba(37,99,235,0.1); color: var(--prism-violet);">Recommended</span></h3>
          <div class="do-dont-grid">
            <div class="do-card"><span class="card-label">Do</span>
              <ul class="doc-list" style="border: none; background: transparent; padding: 0;">
                <li style="border: none; background: transparent; padding-left: 20px;">Always provide an aria-label that describes the action.</li>
                <li style="border: none; background: transparent; padding-left: 20px;">Use universally recognized icons (close, add, edit, delete).</li>
                <li style="border: none; background: transparent; padding-left: 20px;">Use tooltips to show the action label on hover.</li>
                <li style="border: none; background: transparent; padding-left: 20px;">Match icon button type to the Button type used nearby for consistency.</li>
                <li style="border: none; background: transparent; padding-left: 20px;">Use the circle shape for FAB-style (floating action button) actions.</li>
              </ul>
            </div>
            <div class="dont-card"><span class="card-label">Don't</span>
              <ul class="doc-list" style="border: none; background: transparent; padding: 0;">
                <li style="border: none; background: transparent; padding-left: 20px;">Don't use icon buttons for ambiguous or uncommon actions without a tooltip.</li>
                <li style="border: none; background: transparent; padding-left: 20px;">Don't use when the action needs a text label for clarity -- use a Button instead.</li>
                <li style="border: none; background: transparent; padding-left: 20px;">Don't mix square and circle shapes in the same toolbar.</li>
                <li style="border: none; background: transparent; padding-left: 20px;">Don't use danger type for non-destructive actions.</li>
                <li style="border: none; background: transparent; padding-left: 20px;">Don't disable without providing a reason via tooltip.</li>
              </ul>
            </div>
          </div>
        </div>

        </div> <!-- End tab-overview -->

        <!-- ═══ STYLE TAB ═══ -->
        <div class="tab-content" id="tab-style" style="display: none; padding-top: 32px;">
          <h2 id="style-overview" class="doc-section-title">Style</h2>
          <p class="doc-section-subtitle">Design tokens, color mappings, and sizing tokens that define the Icon Button's visual language.</p>

          <!-- Types Section -->
          <div class="doc-section">
            <h2 id="types" class="doc-section-title">Types</h2>
            <p class="doc-section-subtitle">Icon buttons convey their hierarchy and semantic meaning through distinct visual styles.</p>

            <table class="size-table" style="margin-top: 24px;">
              <thead>
                <tr style="border-bottom: 1px solid var(--prism-border);">
                  <th>Type</th>
                  <th>Usage</th>
                  <th>Example</th>
                </tr>
              </thead>
              <tbody>
                <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                  <td style="font-weight: 600;">Primary</td>
                  <td style="color: var(--prism-text-muted);">High-emphasis primary actions (FAB add button, main CTA icon)</td>
                  <td><button class="ib-base ib-primary ib-l ib-square" aria-label="Edit"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button></td>
                </tr>
                <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                  <td style="font-weight: 600;">Secondary</td>
                  <td style="color: var(--prism-text-muted);">Medium-emphasis supportive actions (edit action in a card header)</td>
                  <td><button class="ib-base ib-secondary ib-l ib-square" aria-label="Edit"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button></td>
                </tr>
                <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                  <td style="font-weight: 600;">Tertiary</td>
                  <td style="color: var(--prism-text-muted);">Low-emphasis actions discoverable on hover (toolbar icons in a rich text editor)</td>
                  <td><button class="ib-base ib-tertiary ib-l ib-square" aria-label="Edit"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button></td>
                </tr>
                <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                  <td style="font-weight: 600;">Outline</td>
                  <td style="color: var(--prism-text-muted);">Actions that need a clear clickable boundary (filter toggle, sort controls)</td>
                  <td><button class="ib-base ib-outline ib-l ib-square" aria-label="Edit"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button></td>
                </tr>
                <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                  <td style="font-weight: 600;">Danger</td>
                  <td style="color: var(--prism-text-muted);">Destructive actions (delete row, remove item)</td>
                  <td><button class="ib-base ib-danger ib-l ib-square" aria-label="Delete"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button></td>
                </tr>
                <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                  <td style="font-weight: 600;">Tertiary Grey</td>
                  <td style="color: var(--prism-text-muted);">Lowest-emphasis neutral actions (close dialog, dismiss notification)</td>
                  <td><button class="ib-base ib-tertiary-grey ib-l ib-square" aria-label="Close"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button></td>
                </tr>
              </tbody>
            </table>
          </div>

          <hr class="doc-divider" />

          <!-- States Section -->
          <div class="doc-section">
            <h2 id="states" class="doc-section-title">States</h2>
            <p class="doc-section-subtitle">Icon buttons cycle through five states, each with distinct visual treatments to communicate interactivity.</p>
            <div class="state-grid">
              <div class="state-card">
                <button class="ib-base ib-primary ib-xl ib-square" aria-label="Edit"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
                <div class="state-card-title">Default</div>
                <div class="state-card-desc">Standard resting state</div>
              </div>
              <div class="state-card">
                <button class="ib-base ib-xl ib-square" style="background: #1E52BB; color: #fff;" aria-label="Edit"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
                <div class="state-card-title">Hover</div>
                <div class="state-card-desc">Darker background fill</div>
              </div>
              <div class="state-card">
                <button class="ib-base ib-primary ib-xl ib-square" style="outline: 2px solid #0C66E4; outline-offset: 2px;" aria-label="Edit"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
                <div class="state-card-title">Focus</div>
                <div class="state-card-desc">2px outline ring offset 2px</div>
              </div>
              <div class="state-card">
                <button class="ib-base ib-xl ib-square" style="background: #2B66DE; color: #fff;" aria-label="Edit"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
                <div class="state-card-title">Active</div>
                <div class="state-card-desc">Further shift from hover</div>
              </div>
              <div class="state-card">
                <button class="ib-base ib-disabled ib-xl ib-square" disabled aria-label="Edit"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
                <div class="state-card-title">Disabled</div>
                <div class="state-card-desc">#E1E4EB bg, no interaction</div>
              </div>
            </div>
          </div>

          <hr class="doc-divider" />

          <!-- Sizes Section -->
          <div class="doc-section">
            <h2 id="sizes" class="doc-section-title">Sizes</h2>
            <p class="doc-section-subtitle">Four sizes to fit different layout contexts.</p>
            <table class="size-table">
              <thead><tr><th>Size</th><th>Container</th><th>Icon</th><th>Square Radius</th><th>Circle Radius</th><th>Preview</th></tr></thead>
              <tbody>
                <tr><td><strong>XL</strong></td><td>40 x 40 px</td><td>20 x 20 px</td><td>4px</td><td>50%</td><td><button class="ib-base ib-primary ib-xl ib-square" aria-label="Edit"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button></td></tr>
                <tr><td><strong>Large</strong></td><td>36 x 36 px</td><td>18 x 18 px</td><td>4px</td><td>50%</td><td><button class="ib-base ib-primary ib-l ib-square" aria-label="Edit"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button></td></tr>
                <tr><td><strong>Small</strong></td><td>28 x 28 px</td><td>16 x 16 px</td><td>4px</td><td>50%</td><td><button class="ib-base ib-primary ib-s ib-square" aria-label="Edit"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button></td></tr>
                <tr><td><strong>XSmall</strong></td><td>24 x 24 px</td><td>14 x 14 px</td><td>4px</td><td>50%</td><td><button class="ib-base ib-primary ib-xs ib-square" aria-label="Edit"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button></td></tr>
              </tbody>
            </table>
          </div>

          <hr class="doc-divider" />

          <!-- Color Tokens -->
          <div class="doc-section">
            <h3 id="color-tokens" class="doc-h3">Color Tokens<span class="h3-badge" style="background: rgba(37,99,235,0.1); color: var(--prism-violet);">Tokens</span></h3>
            <table class="size-table">
              <thead><tr><th>Type</th><th>Background</th><th>Hover BG</th><th>Icon Color</th></tr></thead>
              <tbody>
                <tr><td><strong>Primary</strong></td><td><code>#006AFF</code></td><td><code>#1E52BB</code></td><td>#FFFFFF</td></tr>
                <tr><td><strong>Secondary</strong></td><td><code>#EAF0FC</code></td><td><code>#D6E4F9</code></td><td>#1E52BB</td></tr>
                <tr><td><strong>Tertiary</strong></td><td>Transparent</td><td><code>#F0F4FF</code></td><td>#1E52BB</td></tr>
                <tr><td><strong>Outline</strong></td><td><code>#FFFFFF</code></td><td><code>#F4F5F7</code></td><td>#2A303D</td></tr>
                <tr><td><strong>Danger</strong></td><td><code>#E42527</code></td><td><code>#C21E20</code></td><td>#FFFFFF</td></tr>
                <tr><td><strong>Tertiary Grey</strong></td><td>Transparent</td><td><code>#F4F5F7</code></td><td>#55607A</td></tr>
              </tbody>
