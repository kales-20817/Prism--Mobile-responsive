    <main class="main-panel">
      <div class="page-header-area">
        <h1 class="page-title">Accordion</h1>
        <p class="page-desc">
          The Accordion component progressively discloses content by expanding and collapsing sections. It supports two types (Default and With Checkbox), two visual styles (Filled and Outlined), and five interaction states across 40 total variants.
        </p>
        <nav class="content-tabs">
          <button class="tab-item active">Overview</button>
          <button class="tab-item">Style</button>
          <button class="tab-item">Usage</button>
          <button class="tab-item">Code</button>
          <button class="tab-item">Accessibility</button>
        </nav>
      </div>
      <div class="main-content-area">
        <div class="main-content-inner">

        <!-- ═══ OVERVIEW TAB ═══ -->
        <div class="tab-content" id="tab-overview">

        <!-- Anatomy Section -->
        <h3 id="anatomy" class="doc-h3">Anatomy</h3>
        <style>
          .anatomy-diagram { background: var(--prism-surface); border: 1px solid var(--prism-border); border-radius: 16px; padding: 48px 40px; margin-bottom: 28px; position: relative; overflow: hidden; }
          [data-theme="light"] .anatomy-diagram { background: #fff; border: 1px solid rgba(37, 99, 235, 0.07); box-shadow: 0 2px 12px rgba(37, 99, 235, 0.05); }
          .anatomy-diagram::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, #2563eb, #60a5fa, #06b6d4); }
          .anat-marker-inline { width: 22px; height: 22px; border-radius: 50%; flex-shrink: 0; background: linear-gradient(135deg, #2563eb, #3b82f6); color: #fff !important; font-size: 11px; font-weight: 700; display: inline-flex; align-items: center; justify-content: center; box-shadow: 0 2px 10px rgba(37, 99, 235, 0.35); }
          .anat-legend { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
          .anat-legend-item { display: flex; align-items: flex-start; gap: 14px; padding: 20px; background: var(--prism-surface); border: 1px solid var(--prism-border); border-radius: 14px; transition: all 0.25s cubic-bezier(0.4,0,0.2,1); }
          [data-theme="light"] .anat-legend-item { background: #fff; border: 1px solid rgba(37, 99, 235, 0.07); box-shadow: 0 1px 4px rgba(37, 99, 235, 0.04); }
          .anat-legend-item strong { display: block; font-size: 14.5px; font-weight: 600; color: var(--prism-text); margin-bottom: 6px; }
          .anat-legend-item span { font-size: 13px; line-height: 1.55; color: var(--prism-text-muted); }
          .anat-accordion-container { display: flex; flex-direction: column; align-items: center; margin: 40px 0; }
          .anat-accordion { display: flex; flex-direction: column; width: 480px; border-radius: 12px; border: 2px dashed rgba(37,99,235,0.4); position: relative; overflow: visible; }
          .anat-accordion-header { display: flex; align-items: center; padding: 14px 20px; gap: 12px; position: relative; }
          .anat-accordion-body { padding: 0 20px 16px; border-top: 1px dashed rgba(37,99,235,0.25); margin-top: 4px; position: relative; }
        </style>

        <div class="anatomy-diagram">
          <div class="anat-accordion-container">
            <div class="anat-accordion">
              <div class="anat-accordion-header">
                <div style="position: absolute; top: -32px; left: 20px; display: flex; flex-direction: column; align-items: center; gap: 4px;">
                  <span class="anat-marker-inline">1</span><div style="width: 2px; height: 14px; background: #2563eb;"></div>
                </div>
                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"></polyline></svg>
                <span style="flex: 1; font-size: 14px; font-weight: 500; color: var(--prism-text);">Accordion Title Text</span>
                <div style="position: absolute; top: -32px; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: 4px;">
                  <span class="anat-marker-inline">2</span><div style="width: 2px; height: 14px; background: #2563eb;"></div>
                </div>
                <span style="font-size: 11px; font-weight: 600; background: rgba(37,99,235,0.1); color: var(--prism-violet); padding: 2px 8px; border-radius: 999px;">Badge</span>
                <div style="position: absolute; top: -32px; right: 80px; display: flex; flex-direction: column; align-items: center; gap: 4px;">
                  <span class="anat-marker-inline">3</span><div style="width: 2px; height: 14px; background: #2563eb;"></div>
                </div>
                <span style="font-size: 13px; font-weight: 600; color: var(--prism-violet); cursor: pointer;">Action</span>
                <div style="position: absolute; top: -32px; right: 12px; display: flex; flex-direction: column; align-items: center; gap: 4px;">
                  <span class="anat-marker-inline">4</span><div style="width: 2px; height: 14px; background: #2563eb;"></div>
                </div>
              </div>
              <div class="anat-accordion-body">
                <div style="position: absolute; bottom: -32px; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column-reverse; align-items: center; gap: 4px;">
                  <span class="anat-marker-inline">5</span><div style="width: 2px; height: 14px; background: #2563eb;"></div>
                </div>
                <div style="font-size: 13px; color: var(--prism-text-muted); line-height: 1.5; padding-top: 12px;">Body slot content area (visible when expanded). Accepts up to 8 slots.</div>
              </div>
            </div>
          </div>
        </div>

        <div class="anat-legend" style="grid-template-columns: repeat(3, 1fr);">
          <div class="anat-legend-item"><span class="anat-marker-inline">1</span><div><strong>Chevron / Checkbox</strong><span>Leading element (20x20). Chevron for Default type, checkbox for With Checkbox type.</span></div></div>
          <div class="anat-legend-item"><span class="anat-marker-inline">2</span><div><strong>Title</strong><span>Fill-width text, 14px medium weight. Truncates with ellipsis on overflow.</span></div></div>
          <div class="anat-legend-item"><span class="anat-marker-inline">3</span><div><strong>Badge</strong><span>Optional Badge instance, toggled via Show Badge property.</span></div></div>
          <div class="anat-legend-item"><span class="anat-marker-inline">4</span><div><strong>Action Button</strong><span>Optional TextLink or Button, toggled via Show Action property.</span></div></div>
          <div class="anat-legend-item"><span class="anat-marker-inline">5</span><div><strong>Body</strong><span>Slot container visible when expanded. Accepts up to 8 content slots.</span></div></div>
        </div>

        <hr class="doc-divider" />

        <!-- Live Demo -->
        <div style="margin-bottom: 64px;">
          <h2 id="live-demo" class="doc-section-title" style="margin-bottom: 8px;">Preview</h2>
          <p class="doc-section-subtitle" style="margin-bottom: 28px;">Interact with the accordion variants to explore their expanded states, styles, and types.</p>

          <style>
            .demo-container { border: 1px solid var(--prism-border); border-radius: 16px; overflow: hidden; position: relative; }
            .demo-toolbar { display: flex; align-items: center; justify-content: space-between; padding: 12px 20px; background: var(--prism-surface); border-bottom: 1px solid var(--prism-border); }
            [data-theme="light"] .demo-container { border: 1px solid rgba(37, 99, 235, 0.14); box-shadow: 0 2px 16px rgba(37, 99, 235, 0.08); }
            [data-theme="light"] .demo-toolbar { background: rgba(255, 255, 255, 0.7); border-bottom: 1px solid rgba(37, 99, 235, 0.06); }
            .demo-toolbar-left { display: flex; align-items: center; gap: 12px; }
            .demo-theme-pill { display: flex; align-items: center; gap: 8px; padding: 6px 14px; border-radius: 8px; font-size: 13px; font-weight: 500; background: rgba(37,99,235,0.08); color: var(--prism-violet); border: 1px solid rgba(37,99,235,0.2); cursor: pointer; transition: all 0.2s ease; }
            .demo-theme-pill:hover { background: rgba(37,99,235,0.14); }
            .demo-canvas { padding: 48px; position: relative; background-image: radial-gradient(circle, rgba(255,255,255,0.15) 1px, transparent 1px); background-size: 24px 24px; background-color: #0a0a0c66; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 400px; gap: 16px; transition: background-color 0.5s ease; }
            [data-theme="light"] .demo-canvas { background-color: #f4f6fb; background-image: radial-gradient(circle, rgba(37, 99, 235, 0.08) 1px, transparent 1px); }

            /* Demo accordion styles */
            .demo-acc { width: 100%; max-width: 520px; border-radius: 10px; overflow: hidden; transition: all 0.25s ease; }
            .demo-acc-filled { background: rgba(37,99,235,0.04); }
            .demo-acc-outlined { background: transparent; border: 1px solid var(--prism-border); }
            [data-theme="light"] .demo-acc-filled { background: #f0f4ff; }
            [data-theme="light"] .demo-acc-outlined { background: #fff; border: 1px solid rgba(37,99,235,0.15); }
            .demo-acc-header { display: flex; align-items: center; padding: 12px 16px; gap: 10px; cursor: pointer; }
            .demo-acc-header .demo-acc-title { flex: 1; font-size: 14px; font-weight: 500; color: var(--prism-text); }
            .demo-acc-chevron { width: 20px; height: 20px; color: var(--prism-text-muted); transition: transform 0.3s ease; }
            .demo-acc-body { padding: 0 16px 14px; font-size: 13px; color: var(--prism-text-muted); line-height: 1.6; }
            .demo-acc-label { font-size: 11px; font-weight: 700; color: var(--prism-text-muted); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 8px; padding-left: 16px; }
          </style>

          <div class="demo-container">
            <div class="demo-canvas">
              <!-- Filled + Default (Collapsed) -->
              <div style="width: 100%; max-width: 520px;">
                <div class="demo-acc-label">Filled + Default (Collapsed)</div>
                <div class="demo-acc demo-acc-filled">
                  <div class="demo-acc-header">
                    <svg class="demo-acc-chevron" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"></polyline></svg>
                    <span class="demo-acc-title">Account Settings</span>
                  </div>
                </div>
              </div>

              <!-- Filled + Expanded -->
              <div style="width: 100%; max-width: 520px;">
                <div class="demo-acc-label">Filled + Expanded</div>
                <div class="demo-acc demo-acc-filled">
                  <div class="demo-acc-header">
                    <svg class="demo-acc-chevron" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="transform: rotate(180deg); color: var(--prism-violet);"><polyline points="6 9 12 15 18 9"></polyline></svg>
                    <span class="demo-acc-title">Notification Preferences</span>
                    <span style="font-size: 11px; font-weight: 600; background: rgba(37,99,235,0.1); color: var(--prism-violet); padding: 2px 8px; border-radius: 999px;">3 Active</span>
                  </div>
                  <div class="demo-acc-body">Configure how and when you receive notifications. You can set preferences for email, push notifications, and in-app alerts independently.</div>
                </div>
              </div>

              <!-- Outlined + Default (Collapsed) -->
              <div style="width: 100%; max-width: 520px;">
                <div class="demo-acc-label">Outlined + Default (Collapsed)</div>
                <div class="demo-acc demo-acc-outlined">
                  <div class="demo-acc-header">
                    <svg class="demo-acc-chevron" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"></polyline></svg>
                    <span class="demo-acc-title">Privacy &amp; Security</span>
                  </div>
                </div>
              </div>

              <!-- Outlined + With Checkbox (Expanded) -->
              <div style="width: 100%; max-width: 520px;">
                <div class="demo-acc-label">Outlined + With Checkbox (Expanded)</div>
                <div class="demo-acc demo-acc-outlined">
                  <div class="demo-acc-header">
                    <input type="checkbox" checked style="width: 18px; height: 18px; accent-color: #2563eb; cursor: pointer;">
                    <span class="demo-acc-title">Enable Two-Factor Authentication</span>
                    <span style="font-size: 13px; font-weight: 600; color: var(--prism-violet); cursor: pointer;">Configure</span>
                  </div>
                  <div class="demo-acc-body">Two-factor authentication adds an extra layer of security to your account. When enabled, you will need to provide a verification code in addition to your password.</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="doc-section">
          <h3 id="content-guidelines" class="doc-h3">Content Guidelines<span class="h3-badge" style="background: rgba(37,99,235,0.1); color: var(--prism-violet);">Recommended</span></h3>
          <div class="do-dont-grid">
            <div class="do-card"><span class="card-label">Do</span>
              <ul class="doc-list" style="border: none; background: transparent; padding: 0;">
                <li style="border: none; background: transparent; padding-left: 20px;">Use accordions to progressively reveal content in long forms, settings panels, or FAQs.</li>
                <li style="border: none; background: transparent; padding-left: 20px;">Keep header titles concise and descriptive.</li>
                <li style="border: none; background: transparent; padding-left: 20px;">Use Show Badge to surface critical status information without requiring expansion.</li>
                <li style="border: none; background: transparent; padding-left: 20px;">Use Style=Filled for accordions inside panels or cards.</li>
              </ul>
            </div>
            <div class="dont-card"><span class="card-label">Don't</span>
              <ul class="doc-list" style="border: none; background: transparent; padding: 0;">
                <li style="border: none; background: transparent; padding-left: 20px;">Don't hide critical required information inside a collapsed accordion.</li>
                <li style="border: none; background: transparent; padding-left: 20px;">Don't use accordions for very short content.</li>
                <li style="border: none; background: transparent; padding-left: 20px;">Don't nest accordions more than one level deep.</li>
                <li style="border: none; background: transparent; padding-left: 20px;">Don't put primary form submission buttons inside accordion bodies.</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- States Section -->
      </div> <!-- End tab-overview -->

      <!-- ═══ USAGE TAB ═══ -->
      <div class="tab-content" id="tab-usage" style="display: none; padding-top: 32px;">

        <hr style="border: none; border-top: 1px solid var(--prism-border); margin: 0 0 40px 0; display: none;" />

        <!-- When and Where to Use Section -->
        <div class="doc-section">
          <h2 id="when-to-use" class="doc-section-title">When and Where to Use</h2>
          <p class="doc-section-subtitle">Accordions progressively disclose content, reducing visual complexity by letting users expand only the sections they need.</p>

          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 24px;">
            <div style="padding: 24px; background: var(--prism-surface); border: 1px solid var(--prism-border); border-radius: 12px; transition: all 0.25s ease;">
              <h3 id="when-to-use-details" style="font-size: 15px; font-weight: 600; color: var(--prism-text); margin-bottom: 16px; display: flex; align-items: center; gap: 8px;">
                <svg width="20" height="20" fill="none" stroke="#2563eb" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                When to use
              </h3>
              <ul class="doc-list" style="border: none; background: transparent; padding-left: 20px; font-size: 14.5px;">
                <li style="border: none; background: transparent; margin-bottom: 8px;">Progressive content reveal in long forms, settings panels, or FAQs.</li>
                <li style="border: none; background: transparent; margin-bottom: 8px;">Grouped content that needs to be revealed on demand.</li>
                <li style="border: none; background: transparent; margin-bottom: 8px;">Settings panels where sections can be independently expanded.</li>
                <li style="border: none; background: transparent;">Filter panels with collapsible filter groups.</li>
              </ul>
            </div>
            <div style="padding: 24px; background: var(--prism-surface); border: 1px solid var(--prism-border); border-radius: 12px; transition: all 0.25s ease;">
              <h3 id="when-not-to-use" style="font-size: 15px; font-weight: 600; color: var(--prism-text); margin-bottom: 16px; display: flex; align-items: center; gap: 8px;">
                <svg width="20" height="20" fill="none" stroke="#e42527" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                When NOT to use
              </h3>
              <ul class="doc-list" style="border: none; background: transparent; padding-left: 20px; font-size: 14.5px;">
                <li style="border: none; background: transparent; margin-bottom: 8px;">For very short content that doesn't justify expand/collapse.</li>
                <li style="border: none; background: transparent; margin-bottom: 8px;">When content exclusivity is needed (use Tabs instead).</li>
                <li style="border: none; background: transparent; margin-bottom: 8px;">For navigation purposes (use a sidebar or nav menu).</li>
                <li style="border: none; background: transparent;">When nesting would exceed one level deep.</li>
              </ul>
            </div>
          </div>
        </div>

        <hr class="doc-divider" />

        <!-- Types -->
        <div class="doc-section">
          <h2 id="types" class="doc-section-title">Types</h2>
          <p class="doc-section-subtitle">Two accordion types serve different interaction patterns.</p>

          <div class="accordion-wrapper">
            <div class="accordion-item open">
              <button class="accordion-header" onclick="this.parentElement.classList.toggle('open')">
                <span>Default</span>
                <svg class="accordion-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"></polyline></svg>
              </button>
              <div class="accordion-content">
                <p class="accordion-text">Chevron icon as the leading element. Clicking the header toggles the accordion between expanded and collapsed states. Best for general content disclosure where no selection behavior is needed.</p>
              </div>
            </div>
            <div class="accordion-item">
              <button class="accordion-header" onclick="this.parentElement.classList.toggle('open')">
                <span>With Checkbox</span>
                <svg class="accordion-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"></polyline></svg>
              </button>
              <div class="accordion-content">
                <p class="accordion-text">Checkbox replaces the chevron as the leading element. The checkbox controls selection for batch operations (e.g., selecting multiple items), while the header click still toggles expansion. Useful in settings or configuration panels.</p>
              </div>
            </div>
          </div>
        </div>

        <hr class="doc-divider" />

        <!-- Body Slots -->
        <div class="doc-section">
          <h2 id="body-slots" class="doc-section-title">Body Slots</h2>
          <p class="doc-section-subtitle">The accordion body uses a flexible slot system to accept varied content layouts.</p>
          <ul class="doc-list">
            <li><strong>Slot 1 &amp; Slot 2:</strong> Enabled by default. These slots appear when the accordion is expanded.</li>
            <li><strong>Slot 3:</strong> Off by default. Can be toggled on for additional content.</li>
            <li><strong>Slots 4&ndash;8:</strong> Available for complex content layouts. Each slot can be independently toggled and populated with any content.</li>
          </ul>
        </div>

        <hr class="doc-divider" />

        <!-- RTL Support -->
        <div class="doc-section">
          <h2 id="rtl-support" class="doc-section-title">RTL Support</h2>
          <p class="doc-section-subtitle">When RTL is enabled, the accordion layout mirrors horizontally.</p>
          <ul class="doc-list">
            <li>Leading element (chevron or checkbox) moves to the trailing position.</li>
            <li>Action button and badge swap to the leading side.</li>
            <li>Text direction is set to RTL with proper alignment.</li>
            <li>All spacing and padding values are mirrored accordingly.</li>
          </ul>
        </div>

        <hr class="doc-divider" />

        <!-- Comparison -->
        <div class="doc-section">
          <h2 id="comparison" class="doc-section-title">Accordion vs Other Disclosure Patterns</h2>
          <p class="doc-section-subtitle">Choose the right pattern based on your content's behavior and user expectations.</p>
          <style>
            .size-table { width: 100%; border-collapse: collapse; font-size: 14px; }
            .size-table th { text-align: left; padding: 14px 12px; color: var(--prism-text-muted); font-weight: 600; font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 2px solid var(--prism-border); }
            .size-table td { padding: 16px 12px; border-bottom: 1px solid var(--prism-border); color: var(--prism-text); vertical-align: middle; }
            .size-table tr:hover td { background: rgba(37,99,235,0.02); }
            .size-table code { font-family: 'JetBrains Mono', monospace; font-size: 12.5px; padding: 2px 8px; border-radius: 6px; background: rgba(37,99,235,0.06); color: var(--prism-violet); }
          </style>
          <table class="size-table">
            <thead><tr><th>Pattern</th><th>Behavior</th></tr></thead>
            <tbody>
              <tr><td><strong>Accordion</strong></td><td>Multiple collapsible sections, each independently expandable.</td></tr>
              <tr><td><strong>Tabs</strong></td><td>Mutually exclusive content panels; only one visible at a time.</td></tr>
              <tr><td><strong>Modal</strong></td><td>Overlay requiring focused attention, blocks background interaction.</td></tr>
              <tr><td><strong>Expandable Row</strong></td><td>Inline expansion within table rows for supplementary details.</td></tr>
            </tbody>
          </table>
        </div>

        <hr class="doc-divider" />

        <!-- Detailed Do's and Don'ts -->
        <div class="doc-section">
          <h2 id="detailed-guidelines" class="doc-section-title">Complete Do's and Don'ts</h2>
          <p class="doc-section-subtitle">Visual and interaction guidelines to ensure accordions are effective and accessible.</p>
          <div class="do-dont-grid">
            <div class="do-card"><span class="card-label">Do</span>
              <ul class="doc-list" style="border: none; background: transparent; padding: 0;">
                <li style="border: none; background: transparent; padding-left: 20px;"><strong>Progressive disclosure:</strong> Use accordions to reduce visual complexity in long forms, settings, and FAQs.</li>
                <li style="border: none; background: transparent; padding-left: 20px;"><strong>Concise headers:</strong> Keep header titles concise and descriptive so users know what to expect.</li>
                <li style="border: none; background: transparent; padding-left: 20px;"><strong>Badge for status:</strong> Use Show Badge to surface critical status information without requiring expansion.</li>
                <li style="border: none; background: transparent; padding-left: 20px;"><strong>Filled in panels:</strong> Use Style=Filled for accordions inside panels or cards for visual cohesion.</li>
              </ul>
            </div>
            <div class="dont-card"><span class="card-label">Don't</span>
              <ul class="doc-list" style="border: none; background: transparent; padding: 0;">
                <li style="border: none; background: transparent; padding-left: 20px;"><strong>Hide critical info:</strong> Don't hide critical required information inside a collapsed accordion.</li>
                <li style="border: none; background: transparent; padding-left: 20px;"><strong>Too short content:</strong> Don't use accordions for very short content that doesn't justify expand/collapse.</li>
                <li style="border: none; background: transparent; padding-left: 20px;"><strong>Deep nesting:</strong> Don't nest accordions more than one level deep.</li>
                <li style="border: none; background: transparent; padding-left: 20px;"><strong>No submit buttons:</strong> Don't put primary form submission buttons inside accordion bodies.</li>
              </ul>
            </div>
          </div>
        </div>

        <hr class="doc-divider" />

        <!-- Related -->
        <div class="doc-section">
          <h2 id="related" class="doc-section-title">Related</h2>
          <p class="doc-section-subtitle">Components that complement or can be used alongside the Accordion.</p>
          <div class="related-grid">
            <a href="Badges.html" class="related-chip"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M8 12h8"/></svg> Badge</a>
            <a href="Checkbox.html" class="related-chip"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M9 12l2 2 4-4"/></svg> Checkbox</a>
            <a href="Link.html" class="related-chip"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg> TextLink / Button</a>
            <a href="Tabs.html" class="related-chip"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 10h18"/></svg> Tabs</a>
          </div>
        </div>

        <hr class="doc-divider" />

        <!-- References -->
        <div class="doc-section">
          <h2 id="references" class="doc-section-title">References</h2>
          <p class="doc-section-subtitle">Design tokens and resources for implementing the Accordion component.</p>
          <ul class="doc-list">
            <li><strong>Figma Node:</strong> <code style="font-family: monospace; font-size: 13px; padding: 2px 8px; border-radius: 6px; background: rgba(37,99,235,0.06); color: var(--prism-violet);">17355:226378</code> &mdash; Component Set: Accordion</li>
            <li><strong>Typography:</strong> Zoho Puvi Medium (weight 500) for title text, 14px</li>
            <li><strong>Border Radius:</strong> <code style="font-family: monospace; font-size: 13px; padding: 2px 8px; border-radius: 6px; background: rgba(37,99,235,0.06); color: var(--prism-violet);">radius/radius-8 = 8px</code></li>
            <li><strong>Total Variants:</strong> 2 &times; 5 &times; 2 &times; 2 = <strong>40 variants</strong></li>
          </ul>
        </div>


      </div>

      <!-- ═══ STYLE TAB ═══ -->
      <div class="tab-content" id="tab-style" style="display: none; padding-top: 32px;">
        <h2 id="style-overview" class="doc-section-title">Style</h2>
        <p class="doc-section-subtitle">Design tokens, variant axes, and visual treatments that define the Accordion's visual language.</p>

        <!-- Variant Axes Section -->
        <div class="doc-section">
          <h2 id="variant-axes" class="doc-section-title">Variant Axes</h2>
          <p class="doc-section-subtitle">The Accordion component is built on four independent axes that combine to produce 40 unique variants.</p>

          <style>
            .size-table { width: 100%; border-collapse: collapse; font-size: 14px; }
            .size-table th { text-align: left; padding: 14px 12px; color: var(--prism-text-muted); font-weight: 600; font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 2px solid var(--prism-border); }
            .size-table td { padding: 16px 12px; border-bottom: 1px solid var(--prism-border); color: var(--prism-text); vertical-align: middle; }
            .size-table tr:hover td { background: rgba(37,99,235,0.02); }
            .size-table code { font-family: 'JetBrains Mono', monospace; font-size: 12.5px; padding: 2px 8px; border-radius: 6px; background: rgba(37,99,235,0.06); color: var(--prism-violet); }
          </style>

          <table class="size-table">
            <thead><tr><th>Property</th><th>Values</th><th>Description</th></tr></thead>
            <tbody>
              <tr><td><strong>Type</strong></td><td><code>Default</code>, <code>With Checkbox</code></td><td>Controls the leading element (chevron vs checkbox).</td></tr>
              <tr><td><strong>State</strong></td><td><code>Collapsed</code>, <code>Expanded</code>, <code>Hover</code>, <code>Focus</code>, <code>Disabled</code></td><td>Interaction state of the accordion.</td></tr>
              <tr><td><strong>Style</strong></td><td><code>Filled</code>, <code>Outlined</code></td><td>Visual container treatment.</td></tr>
              <tr><td><strong>RTL</strong></td><td><code>False</code>, <code>True</code></td><td>Right-to-left layout support.</td></tr>
            </tbody>
          </table>
          <p style="margin-top: 16px; font-size: 14px; color: var(--prism-text-muted);">Total: 2 &times; 5 &times; 2 &times; 2 = <strong style="color: var(--prism-text);">40 variants</strong></p>
        </div>

        <hr class="doc-divider" />

        <!-- Styles -->
        <div class="doc-section">
          <h2 id="styles" class="doc-section-title">Styles</h2>
          <p class="doc-section-subtitle">Two visual container styles define the accordion's surface treatment.</p>
          <table class="size-table">
            <thead><tr><th>Style</th><th>Background</th><th>Border</th><th>Min Header Height</th></tr></thead>
            <tbody>
              <tr><td><strong>Filled</strong></td><td><code>BG-Secondary-alt</code></td><td>None</td><td>40px</td></tr>
              <tr><td><strong>Outlined</strong></td><td><code>BG-White</code></td><td><code>Border-Secondary</code>, 1px</td><td>44px</td></tr>
            </tbody>
          </table>
        </div>

        <hr class="doc-divider" />

        <div class="doc-section">
          <h2 id="states" class="doc-section-title">States</h2>
          <p class="doc-section-subtitle">Accordions cycle through five states, each with distinct visual treatments to communicate interactivity.</p>
          <style>
            .state-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 14px; margin-top: 24px; }
            .state-card { padding: 24px 16px; border-radius: 14px; background: var(--prism-surface); border: 1px solid var(--prism-border); text-align: center; transition: all 0.25s ease; }
            [data-theme="light"] .state-card { background: #fff; border: 1px solid rgba(37,99,235,0.07); box-shadow: 0 1px 4px rgba(37,99,235,0.04); }
            .state-card:hover { border-color: rgba(37,99,235,0.3); transform: translateY(-3px); box-shadow: 0 8px 24px rgba(37,99,235,0.08); }
            .state-card-title { font-size: 13px; font-weight: 600; color: var(--prism-text); margin-top: 16px; }
            .state-card-desc { font-size: 12px; color: var(--prism-text-muted); margin-top: 6px; line-height: 1.5; }
            .state-icon-box { width: 48px; height: 32px; border-radius: 8px; display: inline-flex; align-items: center; justify-content: center; margin: 0 auto; }
          </style>
          <div class="state-grid">
            <div class="state-card">
              <div class="state-icon-box" style="background: var(--prism-surface); border: 1px solid var(--prism-border);">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"></polyline></svg>
              </div>
              <div class="state-card-title">Collapsed</div>
              <div class="state-card-desc">Default resting state, body hidden</div>
            </div>
            <div class="state-card">
              <div class="state-icon-box" style="background: rgba(37,99,235,0.08); border: 1px solid rgba(37,99,235,0.3);">
                <svg width="16" height="16" fill="none" stroke="#2563eb" stroke-width="2" viewBox="0 0 24 24" style="transform: rotate(180deg);"><polyline points="6 9 12 15 18 9"></polyline></svg>
              </div>
              <div class="state-card-title">Expanded</div>
              <div class="state-card-desc">Body visible, chevron rotated 180&deg;</div>
            </div>
            <div class="state-card">
              <div class="state-icon-box" style="background: var(--prism-surface-hover); border: 1px solid rgba(37,99,235,0.2);">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"></polyline></svg>
              </div>
              <div class="state-card-title">Hover</div>
              <div class="state-card-desc">BG-Secondary-hover background</div>
            </div>
            <div class="state-card">
              <div class="state-icon-box" style="background: var(--prism-surface); border: 1px solid var(--prism-border); outline: 2px solid #2563eb; outline-offset: 2px;">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"></polyline></svg>
              </div>
              <div class="state-card-title">Focus</div>
              <div class="state-card-desc">2px Border-Accent focus ring</div>
            </div>
            <div class="state-card">
              <div class="state-icon-box" style="background: #E1E4EB; border: 1px solid #E1E4EB; opacity: 0.6;">
                <svg width="16" height="16" fill="none" stroke="#8893AD" stroke-width="2" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"></polyline></svg>
              </div>
              <div class="state-card-title">Disabled</div>
              <div class="state-card-desc">No interaction, reduced opacity</div>
            </div>
          </div>
        </div>

        <hr class="doc-divider" />

        <!-- Design Tokens Used -->
        <div class="doc-section">
          <h3 id="design-tokens" class="doc-h3">Design Tokens Used<span class="h3-badge" style="background: rgba(37,99,235,0.1); color: var(--prism-violet);">Tokens</span></h3>
          <table class="size-table">
            <thead><tr><th>Token</th><th>Usage</th></tr></thead>
            <tbody>
              <tr><td><code>BG-Secondary-alt</code></td><td>Filled style background</td></tr>
              <tr><td><code>BG-Secondary-hover</code></td><td>Hover background</td></tr>
              <tr><td><code>BG-White</code></td><td>Outlined style background</td></tr>
              <tr><td><code>Border-Secondary</code></td><td>Outlined default border</td></tr>
              <tr><td><code>Border-Accent</code></td><td>Focus ring (2px outside)</td></tr>
              <tr><td><code>Border-Disabled</code></td><td>Outlined hover border</td></tr>
              <tr><td><code>Text-Primary</code></td><td>Title text color</td></tr>
              <tr><td><code>Icon-Primary</code></td><td>Chevron icon color</td></tr>
              <tr><td><code>radius-8</code></td><td>Header corner radius</td></tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- ═══ CODE TAB ═══ -->
      <div class="tab-content" id="tab-code" style="display: none; padding-top: 32px;">

        <style>
          .code-playground { border: 1px solid var(--prism-border); border-radius: 12px; overflow: hidden; background: var(--prism-surface); margin-bottom: 40px; }
          [data-theme="light"] .code-playground { background: #fff; border: 1px solid rgba(37,99,235,0.1); box-shadow: 0 8px 30px rgba(37,99,235,0.08); }
          .cp-toolbar { display: flex; flex-wrap: wrap; gap: 20px; padding: 16px 24px; border-bottom: 1px solid var(--prism-border); background: var(--prism-surface-hover); }
          [data-theme="light"] .cp-toolbar { background: rgba(248,250,255,0.6); border-bottom: 1px solid rgba(37,99,235,0.1); }
          .cp-control-group { display: flex; flex-direction: column; gap: 8px; flex: 1; min-width: 120px; }
          .cp-label { font-size: 13px; font-weight: 600; color: var(--prism-text-muted); }
          .cp-select { background: var(--prism-surface); border: 1px solid var(--prism-border); color: var(--prism-text); padding: 8px 12px; border-radius: 8px; outline: none; font-family: inherit; font-size: 14px; cursor: pointer; transition: all 0.2s; }
          [data-theme="light"] .cp-select { background: #fff; border-color: rgba(37,99,235,0.15); color: #1e293b; }
          .cp-select:focus { border-color: var(--prism-violet); box-shadow: 0 0 0 3px rgba(37,99,235,0.15); }
          .cp-preview { padding: 60px; min-height: 200px; display: flex; align-items: center; justify-content: center; background: #0a0a0c; background-image: radial-gradient(circle, rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 20px 20px; transition: background 0.3s ease; }
          [data-theme="light"] .cp-preview { background: #fff; background-image: radial-gradient(circle, rgba(37,99,235,0.08) 1px, transparent 1px); }
          .cp-code-header { display: flex; align-items: center; justify-content: space-between; padding: 12px 24px; background: var(--prism-surface); border-top: 1px solid var(--prism-border); border-bottom: 1px solid var(--prism-border); }
          [data-theme="light"] .cp-code-header { background: rgba(248,250,255,0.8); border-color: rgba(37,99,235,0.1); }
          .cp-action-btn { display: flex; align-items: center; gap: 8px; background: transparent; border: none; font-family: inherit; font-size: 13.5px; font-weight: 500; color: var(--prism-text-muted); cursor: pointer; padding: 6px 12px; border-radius: 6px; transition: all 0.2s; }
          .cp-action-btn:hover { background: var(--prism-surface-hover); color: var(--prism-text); }
          .cp-code-area { background: #0a0a0c; padding: 24px; overflow-x: auto; font-family: 'JetBrains Mono', monospace; font-size: 14px; line-height: 1.6; color: #e2e8f0; border-radius: 12px; }
        
  /* ══ Mobile responsive (added globally) ══ */
  .nav-hamburger { display: none; background: transparent; border: none; color: var(--prism-text); padding: 8px; margin-right: 8px; cursor: pointer; border-radius: 8px; align-items: center; justify-content: center; }
  .nav-hamburger:hover { background: var(--prism-surface-hover); }
  .sidebar-backdrop { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 95; opacity: 0; transition: opacity 0.25s ease; }
  .sidebar-backdrop.open { display: block; opacity: 1; }
  .sidebar-mobile-nav { display: none; }

  @media (max-width: 900px) {
    .nav { padding: 0 16px; height: 64px; justify-content: flex-start; gap: 4px; }
    .nav-links { margin-left: auto; }
    .nav-hamburger { display: inline-flex; order: -1; margin-right: 4px; }
    .nav-logo-mark { font-size: 22px; }
    .nav-logo-sub { font-size: 9px; }
    .nav-links > a,
    .nav-links > .nav-dropdown,
    .nav-links > div[style] { display: none !important; }
    .nav-links { gap: 0; }

    .components-layout { display: block; padding-top: 64px; grid-template-columns: 1fr; }
    .sidebar { position: fixed; top: 64px; left: 0; width: 300px; max-width: 86vw; height: calc(100vh - 64px); max-height: none; padding: 20px 18px 32px; border-right: 1px solid var(--prism-border); border-bottom: none; overflow-y: auto; transform: translateX(-100%); transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1); z-index: 96; background: var(--prism-black); }
    [data-theme="light"] .sidebar { background: #ffffff; }
    .sidebar.open { transform: translateX(0); box-shadow: 12px 0 40px rgba(0,0,0,0.25); }
    body.sidebar-locked { overflow: hidden; }

    .sidebar-mobile-nav { display: block; margin: 0 -18px 16px; padding: 0 18px 18px; border-bottom: 1px solid var(--prism-border); }
    .sidebar-mobile-nav h4 { font-size: 11px; font-weight: 700; color: var(--prism-text-muted); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 12px; padding-left: 4px; }
    .sidebar-mobile-nav ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 4px; }
    .sidebar-mobile-nav a { display: block; padding: 10px 12px; font-size: 14px; font-weight: 600; color: var(--prism-text); text-decoration: none; border-radius: 8px; transition: all 0.2s ease; }
    .sidebar-mobile-nav a:hover { background: var(--prism-surface-hover); color: var(--prism-violet); }
    .sidebar-mobile-nav a.active { color: var(--prism-violet); background: rgba(37, 99, 235, 0.08); }

    .main-panel { padding: 24px 20px 48px; grid-column: auto; grid-row: auto; }
    /* mobile-width-safety v4 — collapse any inline grid on narrow viewports */
    .main-panel, .main-content-inner, .main-content-area { max-width: 100%; width: 100%; box-sizing: border-box; min-width: 0; }
    .main-content-inner > *, .doc-section, .doc-section > * { max-width: 100%; box-sizing: border-box; min-width: 0; }
    .main-content-inner img, .main-content-inner svg:not(.inline-svg) { max-width: 100%; height: auto; }
    .main-content-inner pre, .main-content-inner code { white-space: pre-wrap; word-break: break-word; }
    .main-content-inner pre { overflow-x: auto; }
    .anatomy-diagram { overflow: visible !important; padding: 48px 40px !important; zoom: 0.82; }
    .anatomy-diagram > * { max-width: 100%; }
    .demo-container { overflow: hidden; }
    .demo-canvas { padding: 32px 20px !important; overflow-x: auto; }
    .code-playground, .cp-code-area { overflow-x: auto; }
    /* Foundation inner-page grids: collapse every multi-column inline grid */
    [style*="grid-template-columns: 1fr 1fr"],
    [style*="grid-template-columns:1fr 1fr"],
    [style*="grid-template-columns: repeat(4, 1fr)"],
    [style*="grid-template-columns: repeat(5, 1fr)"],
    [style*="grid-template-columns: repeat(6, 1fr)"],
    [style*="grid-template-columns: 320px 1fr"],
    [style*="grid-template-columns: 280px 1fr"],
    [style*="grid-template-columns: 240px 1fr"] { grid-template-columns: 1fr !important; }
    /* Flex rows with heavy fixed widths should wrap */
    [style*="display: flex"][style*="gap"] { flex-wrap: wrap; }
    .main-content-area { display: flex; flex-direction: column; grid-template-columns: 1fr; }
    .main-content-inner { padding-bottom: 32px; }
    .toc-sidebar { display: none; }

    .page-header-area .page-title,
    .page-title { font-size: 30px; line-height: 1.15; }
    .page-desc { font-size: 16px; }
    .doc-section h2, .doc-section-title { font-size: 22px; }

    .do-dont-grid,
    .illus-type-grid,
    .comp-grid,
    .density-grid,
    .illus-showcase-grid,
    .pattern-category-grid,
    .tone-grid,
    .voice-traits,
    .principles-grid,
    .theme-grid,
    .message-grid,
    .weight-grid,
    .pattern-grid,
    .collection-grid,
    .anti-pattern-list,
    .dodont-grid,
    .icon-metaphor-grid { grid-template-columns: 1fr !important; }

    table { display: block; overflow-x: auto; }
    .size-table, .token-table, .anatomy-table, .doc-table, .tone-table { display: block; overflow-x: auto; white-space: nowrap; min-width: 0; }

    .feedback-banner { flex-direction: column; align-items: flex-start; gap: 16px; padding: 24px; }
    .illus-type-card { grid-template-columns: 1fr !important; }
    .illus-type-preview { min-height: 180px; padding: 24px 16px; }

    /* Component detail page grids */
    .state-grid,
    .anatomy-grid,
    .usecase-grid,
    .anat-legend,
    /* Zia Experience hub grids */
    .zia-prompt-grid,
    /* Resource hub grids */
    .lib-grid,
    .lib-grid-logo,
    .lib-grid-illust { grid-template-columns: 1fr !important; gap: 12px !important; }

    /* Inline-styled 2- or 3-column grids */
    [style*="grid-template-columns: repeat(3, 1fr)"],
    [style*="grid-template-columns: repeat(2, 1fr)"],
    [style*="grid-template-columns:repeat(3,1fr)"],
    [style*="grid-template-columns:repeat(2,1fr)"] { grid-template-columns: 1fr !important; }

    /* Resource hub outer padding */
    .page-content { padding: 88px 16px 48px !important; }
  }

  @media (max-width: 600px) {
    .nav { padding: 0 12px; height: 60px; }
    .components-layout { padding-top: 60px; }
    .sidebar { top: 60px; height: calc(100vh - 60px); }
    .nav-logo-mark { font-size: 20px; }
    .main-panel { padding: 18px 14px 36px; }
    /* mobile-width-safety v3 */
    .main-panel { padding: 16px 10px 24px !important; }
    .anatomy-diagram { padding: 40px 28px !important; overflow: visible !important; zoom: 0.66; }
    .demo-canvas { padding: 24px 12px !important; }
    .page-header-area .page-title,
    .page-title { font-size: 26px; }
    .page-desc { font-size: 15px; }
    .sidebar-heading { font-size: 10px; }
    .search-shortcut { display: none; }
    .page-content { padding: 72px 12px 32px !important; }
  }
</style>

        <h2 id="live-demo-code" class="doc-section-title">Live demo (Code)</h2>
        <p class="doc-section-subtitle">Configure the Accordion component and view generated HTML.</p>
        <div class="code-playground">
          <div class="cp-toolbar">
            <div class="cp-control-group"><label class="cp-label">Style</label><select class="cp-select" id="pg-style"><option value="filled" selected>Filled</option><option value="outlined">Outlined</option></select></div>
            <div class="cp-control-group"><label class="cp-label">State</label><select class="cp-select" id="pg-state"><option value="collapsed" selected>Collapsed</option><option value="expanded">Expanded</option><option value="disabled">Disabled</option></select></div>
            <div class="cp-control-group"><label class="cp-label">Type</label><select class="cp-select" id="pg-type"><option value="default" selected>Default</option><option value="checkbox">With Checkbox</option></select></div>
            <div class="cp-control-group"><label class="cp-label">Show Badge</label><select class="cp-select" id="pg-badge"><option value="true" selected>Yes</option><option value="false">No</option></select></div>
          </div>
          <div class="cp-preview" id="pg-preview-area"></div>
          <div class="cp-code-header">
            <div style="font-size:13.5px;font-weight:600;color:var(--prism-text);">HTML</div>
            <button class="cp-action-btn" id="pg-copy-btn"><svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2"/></svg> Copy code</button>
          </div>
          <div class="cp-code-area" id="pg-code-output"></div>
        </div>
        <script>
        (function(){
          var els={style:document.getElementById('pg-style'),state:document.getElementById('pg-state'),type:document.getElementById('pg-type'),badge:document.getElementById('pg-badge')};
          var previewArea=document.getElementById('pg-preview-area');
          var codeOut=document.getElementById('pg-code-output');
          var copyBtn=document.getElementById('pg-copy-btn');
          function esc(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
          function update(){
            var st=els.style.value,state=els.state.value,type=els.type.value,badge=els.badge.value==='true';
            var isExpanded=state==='expanded';
            var isDisabled=state==='disabled';
            var isFilled=st==='filled';
            var hasCheckbox=type==='checkbox';

            // Build preview
            var bgStyle=isFilled?'background:var(--prism-surface);border:1px solid var(--prism-border);':'background:transparent;border:1px solid var(--prism-border);';
            var openClass=isExpanded?' open':'';
            var disabledStyle=isDisabled?'opacity:0.5;pointer-events:none;':'';
            var html='<div class="accordion-wrapper" style="width:100%;max-width:500px;">';
            html+='<div class="accordion-item'+openClass+'" style="'+bgStyle+disabledStyle+'">';
            html+='<button class="accordion-header" onclick="this.parentElement.classList.toggle(\'open\')" style="background:none;border:none;width:100%;cursor:pointer;">';
            if(hasCheckbox) html+='<input type="checkbox" style="width:16px;height:16px;accent-color:var(--prism-violet);margin-right:8px;" onclick="event.stopPropagation()"'+(isExpanded?' checked':'')+'>';
            html+='<span style="flex:1;font-size:16px;font-weight:600;color:var(--prism-text);text-align:left;">Accordion Title</span>';
            if(badge) html+='<span style="font-size:11px;font-weight:600;padding:2px 10px;border-radius:999px;background:rgba(37,99,235,0.1);color:var(--prism-violet);margin-right:8px;">Badge</span>';
            html+='<svg class="accordion-icon" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 9l6 6 6-6"/></svg>';
            html+='</button>';
            html+='<div class="accordion-content">';
            html+='<div class="accordion-text">This is the accordion body content. It can contain text, forms, or other components arranged in up to 8 body slots.</div>';
            html+='</div>';
            html+='</div></div>';
            previewArea.innerHTML=html;

            // Build code output
            var stateAttr=isDisabled?' disabled':'';
            var expandedAttr=isExpanded?' aria-expanded="true"':' aria-expanded="false"';
            var styleAttr=isFilled?' data-style="filled"':' data-style="outlined"';
            var code='<div class="accordion-item"'+styleAttr+stateAttr+'>\n';
            code+='  <button class="accordion-header"'+expandedAttr+' aria-controls="panel-1">\n';
            if(hasCheckbox) code+='    <input type="checkbox" aria-label="Select item" />\n';
            code+='    <span class="accordion-title">Accordion Title</span>\n';
            if(badge) code+='    <span class="accordion-badge">Badge</span>\n';
            code+='    <svg class="accordion-icon" aria-hidden="true"><!-- chevron --></svg>\n';
            code+='  </button>\n';
            code+='  <div class="accordion-panel" id="panel-1" role="region"'+(isExpanded?'':' hidden')+'>\n';
            code+='    <div class="accordion-body">\n';
            code+='      <p>Accordion body content.</p>\n';
            code+='    </div>\n';
            code+='  </div>\n';
            code+='</div>';
            codeOut.innerHTML=esc(code)
              .replace(/class=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">class</span>=<span style="color:#34d399;">"$1"</span>')
              .replace(/aria-expanded=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">aria-expanded</span>=<span style="color:#34d399;">"$1"</span>')
              .replace(/aria-controls=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">aria-controls</span>=<span style="color:#34d399;">"$1"</span>')
              .replace(/aria-label=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">aria-label</span>=<span style="color:#34d399;">"$1"</span>')
              .replace(/aria-hidden=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">aria-hidden</span>=<span style="color:#34d399;">"$1"</span>')
              .replace(/data-style=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">data-style</span>=<span style="color:#34d399;">"$1"</span>')
              .replace(/id=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">id</span>=<span style="color:#34d399;">"$1"</span>')
              .replace(/role=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">role</span>=<span style="color:#34d399;">"$1"</span>')
              .replace(/ disabled/g,' <span style="color:#f97316;">disabled</span>')
              .replace(/ hidden/g,' <span style="color:#f97316;">hidden</span>')
              .replace(/&lt;(\/?)(div|button|span|svg|input|p)(.*?)&gt;/g,'&lt;$1<span style="color:#a78bfa;">$2</span>$3&gt;')
              .replace(/&lt;!--(.*?)--&gt;/g,'<span style="color:#6b7280;">&lt;!--$1--&gt;</span>');
          }
          Object.values(els).forEach(function(e){e.addEventListener('change',update);});
          copyBtn.addEventListener('click',function(){
            var r=document.createElement('div');r.innerHTML=codeOut.innerHTML;
            navigator.clipboard.writeText(r.innerText).then(function(){
              var o=copyBtn.innerHTML;copyBtn.innerHTML='<svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Copied!';setTimeout(function(){copyBtn.innerHTML=o;},2000);
            });
          });
          update();
        })();
        </script>

        <hr class="doc-divider"/>

        <h2 id="component-properties" class="doc-section-title">Component Properties</h2>
        <p class="doc-section-subtitle">Configuration properties for the Accordion component from the Figma design spec.</p>

        <!-- Content Properties -->
        <div class="doc-section">
          <h3 id="content-properties" class="doc-h3">Content Properties</h3>
          <table class="size-table">
            <thead><tr><th>Property</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
            <tbody>
              <tr><td><code>Title</code></td><td>string</td><td>"Accordion Title"</td><td>The header text displayed in the accordion.</td></tr>
              <tr><td><code>Title RTL</code></td><td>string</td><td>&mdash;</td><td>RTL variant of the title text for right-to-left locales.</td></tr>
              <tr><td><code>Show Badge</code></td><td>boolean</td><td>false</td><td>Toggles the optional Badge instance in the header.</td></tr>
              <tr><td><code>Show Action</code></td><td>boolean</td><td>false</td><td>Toggles the optional TextLink/Button action in the header.</td></tr>
            </tbody>
          </table>
        </div>

        <hr class="doc-divider" />

        <!-- Body Slot Visibility -->
        <div class="doc-section">
          <h3 id="body-slot-visibility" class="doc-h3">Body Slot Visibility</h3>
          <table class="size-table">
            <thead><tr><th>Slot</th><th>Default</th><th>Description</th></tr></thead>
            <tbody>
              <tr><td><code>Slot 1</code></td><td>true</td><td>First body content slot, visible by default when expanded.</td></tr>
              <tr><td><code>Slot 2</code></td><td>true</td><td>Second body content slot, visible by default when expanded.</td></tr>
              <tr><td><code>Slot 3</code></td><td>false</td><td>Third body content slot, hidden by default.</td></tr>
            </tbody>
          </table>
        </div>

        <hr class="doc-divider" />

        <!-- Body Content Slots -->
        <div class="doc-section">
          <h3 id="body-content-slots" class="doc-h3">Body Content Slots</h3>
          <p class="doc-section-subtitle">Each slot accepts arbitrary content. Slots Body2 through Body8 are available for complex layouts.</p>
          <table class="size-table">
            <thead><tr><th>Slot Name</th><th>Description</th></tr></thead>
            <tbody>
              <tr><td><code>Body</code></td><td>Primary body content slot (maps to Slot 1).</td></tr>
              <tr><td><code>Body2</code></td><td>Second body content slot.</td></tr>
              <tr><td><code>Body3</code></td><td>Third body content slot (off by default).</td></tr>
              <tr><td><code>Body4 &ndash; Body8</code></td><td>Additional body content slots for complex layouts.</td></tr>
            </tbody>
          </table>
        </div>

        <hr class="doc-divider" />

        <!-- Layer Structure -->
        <div class="doc-section">
          <h3 id="layer-structure" class="doc-h3">Layer Structure</h3>
          <p class="doc-section-subtitle">The component tree as structured in Figma.</p>
          <div class="cp-code-area">
            <div style="font-family: 'JetBrains Mono', monospace; font-size: 13.5px; line-height: 1.8;">
              <span style="color:#94a3b8;">// Accordion Component Tree</span><br>
              <span style="color:#a78bfa;">Accordion</span><br>
              &nbsp;&nbsp;<span style="color:#94a3b8;">|--</span> <span style="color:#E06C75;">Header</span><br>
              &nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#94a3b8;">|--</span> <span style="color:#38bdf8;">Chevron</span> <span style="color:#94a3b8;">// or Checkbox (Type=With Checkbox)</span><br>
              &nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#94a3b8;">|--</span> <span style="color:#38bdf8;">Title</span> <span style="color:#94a3b8;">// fill-width, 14px medium</span><br>
              &nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#94a3b8;">|--</span> <span style="color:#38bdf8;">Badge</span> <span style="color:#94a3b8;">// optional (Show Badge)</span><br>
              &nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#94a3b8;">|--</span> <span style="color:#38bdf8;">Action</span> <span style="color:#94a3b8;">// optional (Show Action)</span><br>
              &nbsp;&nbsp;<span style="color:#94a3b8;">|--</span> <span style="color:#E06C75;">Body</span> <span style="color:#94a3b8;">// visible when expanded</span><br>
              &nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#94a3b8;">|--</span> <span style="color:#34d399;">Slot 1</span> <span style="color:#94a3b8;">// default: on</span><br>
              &nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#94a3b8;">|--</span> <span style="color:#34d399;">Slot 2</span> <span style="color:#94a3b8;">// default: on</span><br>
              &nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#94a3b8;">|--</span> <span style="color:#34d399;">Slot 3</span> <span style="color:#94a3b8;">// default: off</span><br>
              &nbsp;&nbsp;&nbsp;&nbsp;<span style="color:#94a3b8;">|--</span> <span style="color:#34d399;">Slot 4-8</span> <span style="color:#94a3b8;">// available</span>
            </div>
          </div>
        </div>
      </div>

      <!-- ═══ ACCESSIBILITY TAB ═══ -->
      <div class="tab-content" id="tab-accessibility" style="display: none; padding-top: 32px;">
        <h2 id="accessibility" class="doc-section-title">Accessibility</h2>
        <p class="doc-section-subtitle">Guidelines for ensuring all accordion interactions are accessible across assistive technologies.</p>

        <div class="doc-section">
          <h3 id="accessibility-requirements" class="doc-h3">Accessibility Requirements</h3>
          <table class="size-table">
            <thead><tr><th>Requirement</th><th>Implementation</th></tr></thead>
            <tbody>
              <tr><td><strong>ARIA Role</strong></td><td>The accordion header uses <code>role="button"</code>. The content region uses <code>role="region"</code> with an <code>aria-labelledby</code> pointing to the header.</td></tr>
              <tr><td><strong>ARIA Controls</strong></td><td>The header button includes <code>aria-expanded="true|false"</code> to indicate the current state, and <code>aria-controls</code> pointing to the body panel ID.</td></tr>
              <tr><td><strong>Keyboard Navigation</strong></td><td><code>Enter</code> / <code>Space</code> toggles the accordion. <code>Tab</code> moves focus between accordion headers. <code>Arrow Up/Down</code> can optionally navigate between headers in a group.</td></tr>
              <tr><td><strong>Focus Indicator</strong></td><td>2px <code>Border-Accent</code> focus ring displayed around the header on keyboard focus, using <code>outline-offset: 2px</code>.</td></tr>
              <tr><td><strong>Disabled State</strong></td><td>Use <code>aria-disabled="true"</code> on the header. The accordion cannot be expanded or collapsed when disabled.</td></tr>
              <tr><td><strong>Screen Reader</strong></td><td>Screen readers announce the title, expanded/collapsed state, and any badge content. Body content is announced when expanded.</td></tr>
              <tr><td><strong>RTL</strong></td><td>When <code>dir="rtl"</code> is set, all layout and reading order mirrors correctly. Keyboard navigation order remains logical.</td></tr>
              <tr><td><strong>Color Contrast</strong></td><td>Title text meets WCAG AA 4.5:1 ratio. Chevron/checkbox icons meet 3:1 for UI components. Focus ring meets 3:1 against adjacent colors.</td></tr>
            </tbody>
          </table>
        </div>

        <hr class="doc-divider" />

        <div class="doc-section">
          <h3 id="keyboard-interaction" class="doc-h3">Keyboard Interaction</h3>
          <table class="size-table">
            <thead><tr><th>Key</th><th>Action</th></tr></thead>
            <tbody>
              <tr><td><code>Tab</code></td><td>Move focus to the next accordion header or focusable element.</td></tr>
              <tr><td><code>Shift + Tab</code></td><td>Move focus to the previous accordion header or focusable element.</td></tr>
              <tr><td><code>Enter</code> / <code>Space</code></td><td>Toggle the focused accordion between expanded and collapsed states.</td></tr>
              <tr><td><code>Arrow Down</code></td><td>Move focus to the next accordion header (when in an accordion group).</td></tr>
              <tr><td><code>Arrow Up</code></td><td>Move focus to the previous accordion header (when in an accordion group).</td></tr>
              <tr><td><code>Home</code></td><td>Move focus to the first accordion header in the group.</td></tr>
              <tr><td><code>End</code></td><td>Move focus to the last accordion header in the group.</td></tr>
            </tbody>
          </table>
        </div>

        <hr class="doc-divider" />

        <div class="doc-section">
          <h3 id="focus-state-design" class="doc-h3">Focus State Design</h3>
          <ul class="doc-list">
            <li>Focus ring: <strong>2px solid</strong> using <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">Border-Accent</code> token.</li>
            <li>Offset: <strong>2px</strong> outside the header boundary using <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">outline-offset: 2px</code>.</li>
            <li>Inner container retains the default state background during focus.</li>
          </ul>
        </div>

        <hr class="doc-divider" />

        <div class="doc-section">
          <h3 id="color-contrast" class="doc-h3">Color Contrast<span class="h3-badge" style="background: rgba(34,197,94,0.15); color: #16a34a;">WCAG AA Pass</span></h3>
          <p class="doc-section-subtitle">All accordion text and interactive elements meet WCAG 2.1 AA contrast requirements.</p>

          <div style="margin-top: 24px; padding: 16px 20px; background: rgba(34,197,94,0.05); border: 1px solid rgba(34,197,94,0.2); border-radius: 12px; display: flex; gap: 12px; align-items: flex-start;">
             <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2" style="flex-shrink: 0; margin-top: 2px;"><circle cx="12" cy="12" r="10"></circle><path d="M12 16v-4"></path><path d="M12 8h.01"></path></svg>
             <p style="font-size: 14px; color: var(--prism-text); line-height: 1.6; margin: 0;"><strong>WCAG 2.1 Level AA Requires:</strong> A contrast ratio of at least <strong>4.5:1</strong> for normal text (title labels) and <strong>3.0:1</strong> for UI components (chevron icons, focus rings, borders). All UEMS accordion variants pass these standards.</p>
          </div>
        </div>
        </div>

      </div> <!-- close main-content-inner -->


