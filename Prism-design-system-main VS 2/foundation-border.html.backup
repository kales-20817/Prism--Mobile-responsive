                </tr>
                <tr style="border-bottom: 1px solid var(--prism-border);">
                  <td style="padding: 14px 16px;"><code style="font-family: 'JetBrains Mono', monospace; font-size: 12.5px; color: var(--prism-violet);">Border-Secondary</code></td>
                  <td style="padding: 14px 16px; color: var(--prism-text-muted); font-size: 13px;">Lighter separator — row dividers, sub-sections</td>
                  <td style="padding: 14px 16px;"><span class="swatch-light token-swatch"><span class="token-swatch-color" style="background:#c3c9d6"></span><span class="token-swatch-hex">#c3c9d6</span></span><span class="swatch-dark token-swatch"><span class="token-swatch-color" style="background:#2a303d"></span><span class="token-swatch-hex">#2a303d</span></span></td>
