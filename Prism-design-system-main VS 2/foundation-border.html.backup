                  <td style="padding: 14px 16px;"><div style="width: 40px; height: 40px; border: 2px solid var(--prism-violet); border-radius: 16px;"></div></td>
                  <td style="padding: 14px 16px; color: var(--prism-text-muted); font-size: 13px;">XL — hero cards, feature containers</td>
