          <!-- Anti-patterns -->
          <div class="doc-section" id="anti-patterns">
            <h2>Anti-patterns</h2>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 20px;">
              <div style="padding: 20px 24px; background: rgba(228, 37, 39, 0.06); border: 1px solid rgba(228, 37, 39, 0.2); border-radius: 12px;">
                <div style="font-size: 12px; font-weight: 700; color: #e42527; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 12px;">&#10007; Don't</div>
                <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px;">
                  <li style="font-size: 13px; color: var(--prism-text-muted); line-height: 1.5;">Hardcode hex colors for borders — always use tokens</li>
                  <li style="font-size: 13px; color: var(--prism-text-muted); line-height: 1.5;">Use borders where whitespace suffices</li>
                  <li style="font-size: 13px; color: var(--prism-text-muted); line-height: 1.5;">Mix border-width values without tokens</li>
                  <li style="font-size: 13px; color: var(--prism-text-muted); line-height: 1.5;">Use <code style="font-size: 12px;">border: 1px solid #ccc</code> — this breaks in dark mode</li>
                  <li style="font-size: 13px; color: var(--prism-text-muted); line-height: 1.5;">Apply accent borders for non-interactive elements</li>
                </ul>
              </div>
              <div style="padding: 20px 24px; background: rgba(12, 136, 68, 0.06); border: 1px solid rgba(12, 136, 68, 0.2); border-radius: 12px;">
                <div style="font-size: 12px; font-weight: 700; color: #0c8844; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 12px;">&#10003; Do</div>
                <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px;">
                  <li style="font-size: 13px; color: var(--prism-text-muted); line-height: 1.5;">Pair width + color tokens for every border</li>
                  <li style="font-size: 13px; color: var(--prism-text-muted); line-height: 1.5;">Use semantic variants (success, error, warning) for status</li>
                  <li style="font-size: 13px; color: var(--prism-text-muted); line-height: 1.5;">Test borders in both light and dark themes</li>
                  <li style="font-size: 13px; color: var(--prism-text-muted); line-height: 1.5;">Use <code style="font-size: 12px;">Border-Accent-Focus</code> for keyboard focus rings</li>
                  <li style="font-size: 13px; color: var(--prism-text-muted); line-height: 1.5;">Choose the right hierarchy (Primary → Quaternary)</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Closing principle -->
          <div class="doc-section" id="closing-principle">
            <h2>Principle</h2>
            <div style="margin-top: 20px; padding: 32px; background: linear-gradient(135deg, rgba(37,99,235,0.06) 0%, rgba(6,182,212,0.06) 100%); border: 1px solid var(--prism-border); border-radius: 16px; text-align: center;">
              <p style="font-size: 20px; font-weight: 600; color: var(--prism-text); line-height: 1.6; max-width: 700px; margin: 0 auto;">
                "A border is a promise of separation. Break that promise, and you break trust."
              </p>
              <p style="font-size: 14px; color: var(--prism-text-muted); margin-top: 12px;">
                Every border in Prism exists because a boundary was needed — not because a pixel was empty.
              </p>
            </div>
