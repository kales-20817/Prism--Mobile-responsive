        <!-- ========== CODE ========== -->
        <div class="tab-content" id="tab-code" style="display:none;padding-top:32px;">
          <h2 id="live-demo-code" class="doc-section-title">Live demo (Code)</h2>
          <p class="doc-section-subtitle">Configure the Data Table and view the generated HTML. The preview remains fully interactive.</p>
          <div class="code-playground">
            <div class="cp-toolbar">
              <div class="cp-control-group"><label class="cp-label">Rows</label><select class="cp-select" id="pg-rows"><option value="3">3</option><option value="5" selected>5</option><option value="10">10</option></select></div>
              <div class="cp-control-group"><label class="cp-label">Selectable</label><select class="cp-select" id="pg-select"><option value="yes" selected>Yes</option><option value="no">No</option></select></div>
              <div class="cp-control-group"><label class="cp-label">Show Footer</label><select class="cp-select" id="pg-footer"><option value="yes" selected>Yes</option><option value="no">No</option></select></div>
              <div class="cp-control-group"><label class="cp-label">Density</label><select class="cp-select" id="pg-density"><option value="comfortable">Comfortable</option><option value="default" selected>Default</option><option value="compact">Compact</option></select></div>
            </div>
            <div class="cp-preview" id="pg-preview-area"></div>
            <div class="cp-code-header">
              <div style="font-size:13.5px;font-weight:600;color:var(--prism-text);">HTML</div>
              <button class="cp-action-btn" id="pg-copy-btn"><svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2"/></svg> Copy code</button>
            </div>
            <div class="cp-code-area" id="pg-code-output"></div>
          </div>
          <script>
          (function(){
            var sampleRows = [
              {id:'r1',name:'MacBook-Pro-14',type:'Laptop',status:'Online',statusClass:'success',last:'2 min ago',owner:'Aravinth M'},
              {id:'r2',name:'iPhone-15-Pro',type:'Mobile',status:'Online',statusClass:'success',last:'5 min ago',owner:'Priya R'},
              {id:'r3',name:'Dell-XPS-Desk-01',type:'Desktop',status:'Idle',statusClass:'warning',last:'1 hr ago',owner:'Kiran V'},
              {id:'r4',name:'iPad-Air-5',type:'Tablet',status:'Online',statusClass:'success',last:'12 min ago',owner:'Neha S'},
              {id:'r5',name:'Pixel-8-Pro',type:'Mobile',status:'Offline',statusClass:'danger',last:'3 days ago',owner:'Rahul K'},
              {id:'r6',name:'Surface-Laptop-5',type:'Laptop',status:'Online',statusClass:'success',last:'just now',owner:'Ananya P'},
              {id:'r7',name:'ThinkPad-X1',type:'Laptop',status:'Online',statusClass:'success',last:'8 min ago',owner:'Vikram I'},
              {id:'r8',name:'Galaxy-S24',type:'Mobile',status:'Idle',statusClass:'warning',last:'30 min ago',owner:'Divya N'},
              {id:'r9',name:'Mac-Mini-M2',type:'Desktop',status:'Online',statusClass:'success',last:'1 min ago',owner:'Arun T'},
              {id:'r10',name:'Pixel-Tablet',type:'Tablet',status:'Offline',statusClass:'danger',last:'yesterday',owner:'Meera J'}
            ];
            var els = {rows:document.getElementById('pg-rows'),select:document.getElementById('pg-select'),footer:document.getElementById('pg-footer'),density:document.getElementById('pg-density')};
            var previewArea = document.getElementById('pg-preview-area');
            var codeOut = document.getElementById('pg-code-output');
            var copyBtn = document.getElementById('pg-copy-btn');
            function esc(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}

            function buildPreviewHtml(){
              var rowCount = parseInt(els.rows.value);
              var selectable = els.select.value === 'yes';
              var footer = els.footer.value === 'yes';
              var density = els.density.value;
              var data = sampleRows.slice(0, rowCount);
              var tableCls = 'dt-table' + (density==='compact'?' compact':density==='comfortable'?' comfortable':'');
              var html = '<div class="dt-wrapper" id="pg-dt">';
              html += '<div class="dt-toolbar">';
              html += '<div class="dt-search"><svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg><input type="text" placeholder="Search..."></div>';
              html += '<div style="flex:1;"></div>';
              html += '<button class="dt-toolbar-btn with-label"><svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 4h18l-7 8v6l-4 2v-8z"/></svg> Filter</button>';
              html += '<button class="dt-toolbar-btn"><svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="5" r="1"/><circle cx="12" cy="12" r="1"/><circle cx="12" cy="19" r="1"/></svg></button>';
              html += '</div>';
              html += '<div class="dt-table-scroll"><table class="'+tableCls+'"><thead><tr>';
              if(selectable) html += '<th class="dt-check-cell"><input type="checkbox" class="dt-checkbox" id="pg-head-check"></th>';
              html += '<th>Name</th><th>Type</th><th>Status</th><th>Last Seen</th><th>Owner</th></tr></thead><tbody id="pg-body">';
              data.forEach(function(r){
                html += '<tr data-rowid="'+r.id+'">';
                if(selectable) html += '<td class="dt-check-cell"><input type="checkbox" class="dt-checkbox pg-row-check"></td>';
                html += '<td><a class="dt-link">'+r.name+'</a></td><td>'+r.type+'</td><td><span class="dt-badge '+r.statusClass+'">'+r.status+'</span></td><td>'+r.last+'</td><td>'+r.owner+'</td></tr>';
              });
              html += '</tbody></table></div>';
              if(footer){
                html += '<div class="dt-footer" id="pg-footer-row"><div class="dt-footer-left"><span>Rows per page</span><select class="dt-rows-select"><option>10</option><option selected>20</option><option>50</option></select><span style="margin-left:12px;">1&ndash;'+rowCount+' of 243</span></div>';
                html += '<div class="dt-pagination"><button class="dt-page-btn" disabled>&lsaquo; Previous</button><button class="dt-page-btn active">1</button><button class="dt-page-btn">2</button><button class="dt-page-btn">Next &rsaquo;</button></div></div>';
              }
              if(selectable){
                html += '<div class="dt-bulk-bar" id="pg-bulk-bar"><div class="dt-bulk-left"><span id="pg-bulk-count">0 Selected</span></div>';
                html += '<div class="dt-bulk-actions">';
                html += '<button class="dt-bulk-btn"><svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg> Edit</button>';
                html += '<button class="dt-bulk-btn"><svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg> Export</button>';
                html += '<button class="dt-bulk-btn danger"><svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-2 14H7L5 6M10 11v6M14 11v6"/></svg> Delete</button>';
                html += '<button class="dt-bulk-close" id="pg-bulk-close" title="Clear selection"><svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg></button>';
                html += '</div></div>';
              }
              html += '</div>';
              return html;
            }

            function buildCodeHtml(){
              var rowCount = parseInt(els.rows.value);
              var selectable = els.select.value === 'yes';
              var footer = els.footer.value === 'yes';
              var density = els.density.value;
              var tableCls = 'dt-table' + (density==='compact'?' compact':density==='comfortable'?' comfortable':'');
              var s = '<div class="dt-wrapper">\n';
              s += '  <div class="dt-toolbar">\n    <!-- search + filter + overflow -->\n  </div>\n';
              s += '  <table class="'+tableCls+'">\n    <thead>\n      <tr>\n';
              if(selectable) s += '        <th class="dt-check-cell"><input type="checkbox" aria-label="Select all rows"/></th>\n';
              s += '        <th scope="col">Name</th>\n        <th scope="col">Type</th>\n        <th scope="col">Status</th>\n        <th scope="col">Last Seen</th>\n        <th scope="col">Owner</th>\n      </tr>\n    </thead>\n    <tbody>\n';
              for(var i=0;i<Math.min(rowCount,2);i++){
                s += '      <tr>\n';
                if(selectable) s += '        <td class="dt-check-cell"><input type="checkbox" aria-label="Select row '+(i+1)+'"/></td>\n';
                s += '        <th scope="row"><a class="dt-link">Device-'+(i+1)+'</a></th>\n        <td>Laptop</td>\n        <td><span class="dt-badge success">Online</span></td>\n        <td>just now</td>\n        <td>Owner Name</td>\n      </tr>\n';
              }
              s += '      <!-- '+(rowCount-2>0?rowCount-2+' more rows':'...')+' -->\n    </tbody>\n  </table>\n';
              if(footer){
                s += '  <div class="dt-footer">\n    <span>Rows per page 20   1&ndash;'+rowCount+' of 243</span>\n    <div class="dt-pagination">\n      <button>&lsaquo; Previous</button>\n      <button class="active">1</button>\n      <button>Next &rsaquo;</button>\n    </div>\n  </div>\n';
              }
              if(selectable){
                s += '  <div class="dt-bulk-bar" role="region" aria-label="Bulk actions">\n    <span>N Selected</span>\n    <button>Edit</button><button>Export</button><button class="danger">Delete</button>\n  </div>\n';
              }
              s += '</div>';
              return s;
            }

            function wirePreview(){
              var wrapper = previewArea.querySelector('#pg-dt');
              if(!wrapper) return;
              var head = wrapper.querySelector('#pg-head-check');
              var rowChecks = wrapper.querySelectorAll('.pg-row-check');
              var bulkBar = wrapper.querySelector('#pg-bulk-bar');
              var bulkCount = wrapper.querySelector('#pg-bulk-count');
              var bulkClose = wrapper.querySelector('#pg-bulk-close');
              var footerRow = wrapper.querySelector('#pg-footer-row');
              function sync(){
                var checked = Array.prototype.filter.call(rowChecks, function(cb){return cb.checked;});
                rowChecks.forEach(function(cb){
                  var tr = cb.closest('tr');
                  if(cb.checked) tr.classList.add('selected'); else tr.classList.remove('selected');
                });
                if(head){
                  if(checked.length === 0){ head.checked = false; head.indeterminate = false; }
                  else if(checked.length === rowChecks.length){ head.checked = true; head.indeterminate = false; }
                  else { head.checked = false; head.indeterminate = true; }
                }
                if(bulkBar){
                  if(checked.length > 0){
                    bulkBar.classList.add('visible');
                    if(footerRow) footerRow.style.display = 'none';
                    if(bulkCount) bulkCount.textContent = checked.length + ' Selected';
                  } else {
                    bulkBar.classList.remove('visible');
                    if(footerRow) footerRow.style.display = '';
                  }
                }
              }
              rowChecks.forEach(function(cb){ cb.addEventListener('change', sync); });
              if(head){
                head.addEventListener('change', function(){
                  rowChecks.forEach(function(cb){ cb.checked = head.checked; });
                  sync();
                });
              }
              if(bulkClose){
                bulkClose.addEventListener('click', function(){
                  rowChecks.forEach(function(cb){ cb.checked = false; });
                  sync();
                });
              }
            }

            function update(){
              previewArea.innerHTML = buildPreviewHtml();
              wirePreview();
              var codeStr = buildCodeHtml();
              codeOut.innerHTML = esc(codeStr)
                .replace(/class=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">class</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/type=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">type</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/scope=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">scope</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/aria-label=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">aria-label</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/role=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">role</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/&lt;!--(.*?)--&gt;/g,'<span style="color:#94a3b8;">&lt;!--$1--&gt;</span>')
                .replace(/&lt;(\/?)(div|table|thead|tbody|tr|th|td|span|button|input|a)(\b.*?)&gt;/g,'&lt;$1<span style="color:#a78bfa;">$2</span>$3&gt;');
            }
            Object.values(els).forEach(function(e){e.addEventListener('change',update);});
            copyBtn.addEventListener('click',function(){
              var r=document.createElement('div');r.innerHTML=codeOut.innerHTML;
              navigator.clipboard.writeText(r.innerText).then(function(){
                var o=copyBtn.innerHTML;copyBtn.innerHTML='<svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Copied!';setTimeout(function(){copyBtn.innerHTML=o;},2000);
              });
            });
            update();
          })();
          </script>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="component-api" class="doc-h3">Component API &amp; Properties</h3>
            <table class="size-table">
              <thead><tr><th>Prop</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
              <tbody>
                <tr><td><code>columns</code></td><td><code>Column[]</code></td><td>&mdash;</td><td>Column definitions: <code>{ id, header, accessor, align?, sortable?, width?, render? }</code>.</td></tr>
                <tr><td><code>rows</code></td><td><code>Row[]</code></td><td>&mdash;</td><td>Row data: array of objects keyed by each column's accessor.</td></tr>
                <tr><td><code>selectedRowIds</code></td><td><code>string[]</code></td><td><code>[]</code></td><td>Controlled set of selected row ids. Non-empty renders the Selected variant.</td></tr>
                <tr><td><code>onSelectionChange</code></td><td><code>(ids) =&gt; void</code></td><td>&mdash;</td><td>Fires when the user toggles row / header checkboxes.</td></tr>
                <tr><td><code>selectionMode</code></td><td><code>'multi' | 'single' | 'none'</code></td><td><code>'multi'</code></td><td>Multi (checkbox), single (radio / click), or off.</td></tr>
                <tr><td><code>showToolbar</code></td><td>boolean</td><td><code>true</code></td><td>Show the top toolbar.</td></tr>
                <tr><td><code>toolbarActions</code></td><td>ReactNode</td><td>Default icons</td><td>Right-hand toolbar slot (replaces default refresh / search / filter cluster).</td></tr>
                <tr><td><code>onRefresh</code></td><td><code>() =&gt; void</code></td><td>&mdash;</td><td>Fires when the refresh icon is activated.</td></tr>
                <tr><td><code>searchValue</code> / <code>onSearchChange</code></td><td><code>string</code> / <code>(v) =&gt; void</code></td><td>&mdash;</td><td>Controlled search input.</td></tr>
                <tr><td><code>filters</code></td><td><code>Filter[]</code></td><td><code>[]</code></td><td>Active filters shown in the Filter dropdown.</td></tr>
                <tr><td><code>overflowMenuItems</code></td><td><code>MenuItem[]</code></td><td><code>[]</code></td><td>Items for the &#8942; overflow menu.</td></tr>
                <tr><td><code>showFooter</code></td><td>boolean</td><td><code>true</code></td><td>Show the bottom footer.</td></tr>
                <tr><td><code>rowsPerPage</code></td><td>number</td><td><code>20</code></td><td>Current rows-per-page value.</td></tr>
                <tr><td><code>rowsPerPageOptions</code></td><td><code>number[]</code></td><td><code>[10,20,50,100]</code></td><td>Options shown in the rows-per-page select.</td></tr>
                <tr><td><code>totalRows</code></td><td><code>number | '#'</code></td><td><code>'#'</code></td><td>Total row count for the range display.</td></tr>
                <tr><td><code>page</code></td><td>number</td><td><code>1</code></td><td>1-based current page.</td></tr>
                <tr><td><code>onPageChange</code></td><td><code>(page) =&gt; void</code></td><td>&mdash;</td><td>Fires on Previous / Next.</td></tr>
                <tr><td><code>bulkActions</code></td><td><code>BulkAction[]</code></td><td>Default</td><td>Actions shown in the floating bulk-action bar (Edit, Delete, Export).</td></tr>
                <tr><td><code>onBulkAction</code></td><td><code>(id, ids) =&gt; void</code></td><td>&mdash;</td><td>Fires when a bulk action is activated.</td></tr>
                <tr><td><code>emptyState</code></td><td>ReactNode</td><td>Default</td><td>Rendered when <code>rows.length === 0</code>.</td></tr>
                <tr><td><code>loading</code></td><td>boolean</td><td><code>false</code></td><td>Renders a row-shimmer skeleton overlay.</td></tr>
                <tr><td><code>rowHeight</code></td><td><code>'compact' | 'default' | 'comfortable'</code></td><td><code>'default'</code></td><td>Row density. Compact=32px, Default=40px, Comfortable=48px.</td></tr>
                <tr><td><code>stickyHeader</code></td><td>boolean</td><td><code>true</code></td><td>Column header sticks to top of scroll container.</td></tr>
                <tr><td><code>rtl</code></td><td>boolean</td><td><code>false</code></td><td>Mirrors the layout for right-to-left reading order.</td></tr>
              </tbody>
            </table>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="html-structure" class="doc-h3">HTML Structure</h3>
            <p class="doc-section-subtitle" style="margin-bottom:16px;">The semantic base: a <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;table&gt;</code> with proper <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;thead&gt;</code> / <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;tbody&gt;</code>, scope attributes on headers, and ARIA hooks for bulk actions.</p>
            <div class="cp-code-area" style="border-radius:12px;">
              <pre style="margin:0;font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;color:#e2e8f0;"><span style="color:#a78bfa;">&lt;div</span> <span style="color:#38bdf8;">class</span>=<span style="color:#34d399;">"dt-wrapper"</span><span style="color:#a78bfa;">&gt;</span>
  <span style="color:#a78bfa;">&lt;div</span> <span style="color:#38bdf8;">class</span>=<span style="color:#34d399;">"dt-toolbar"</span><span style="color:#a78bfa;">&gt;</span>
    <span style="color:#94a3b8;">&lt;!-- search input + filter button + overflow menu --&gt;</span>
  <span style="color:#a78bfa;">&lt;/div&gt;</span>
  <span style="color:#a78bfa;">&lt;table</span> <span style="color:#38bdf8;">role</span>=<span style="color:#34d399;">"table"</span><span style="color:#a78bfa;">&gt;</span>
    <span style="color:#a78bfa;">&lt;thead&gt;</span>
      <span style="color:#a78bfa;">&lt;tr&gt;</span>
        <span style="color:#a78bfa;">&lt;th</span> <span style="color:#38bdf8;">scope</span>=<span style="color:#34d399;">"col"</span><span style="color:#a78bfa;">&gt;</span>
          <span style="color:#a78bfa;">&lt;input</span> <span style="color:#38bdf8;">type</span>=<span style="color:#34d399;">"checkbox"</span> <span style="color:#38bdf8;">aria-label</span>=<span style="color:#34d399;">"Select all rows"</span><span style="color:#a78bfa;">/&gt;</span>
        <span style="color:#a78bfa;">&lt;/th&gt;</span>
        <span style="color:#a78bfa;">&lt;th</span> <span style="color:#38bdf8;">scope</span>=<span style="color:#34d399;">"col"</span><span style="color:#a78bfa;">&gt;</span>Name<span style="color:#a78bfa;">&lt;/th&gt;</span>
      <span style="color:#a78bfa;">&lt;/tr&gt;</span>
    <span style="color:#a78bfa;">&lt;/thead&gt;</span>
    <span style="color:#a78bfa;">&lt;tbody&gt;</span>
      <span style="color:#a78bfa;">&lt;tr&gt;</span>
        <span style="color:#a78bfa;">&lt;td&gt;&lt;input</span> <span style="color:#38bdf8;">type</span>=<span style="color:#34d399;">"checkbox"</span> <span style="color:#38bdf8;">aria-label</span>=<span style="color:#34d399;">"Select row 1"</span><span style="color:#a78bfa;">/&gt;&lt;/td&gt;</span>
        <span style="color:#a78bfa;">&lt;th</span> <span style="color:#38bdf8;">scope</span>=<span style="color:#34d399;">"row"</span><span style="color:#a78bfa;">&gt;&lt;a&gt;</span>MacBook-Pro-14<span style="color:#a78bfa;">&lt;/a&gt;&lt;/th&gt;</span>
      <span style="color:#a78bfa;">&lt;/tr&gt;</span>
    <span style="color:#a78bfa;">&lt;/tbody&gt;</span>
  <span style="color:#a78bfa;">&lt;/table&gt;</span>
  <span style="color:#a78bfa;">&lt;div</span> <span style="color:#38bdf8;">class</span>=<span style="color:#34d399;">"dt-footer"</span><span style="color:#a78bfa;">&gt;</span>...<span style="color:#a78bfa;">&lt;/div&gt;</span>
  <span style="color:#a78bfa;">&lt;div</span> <span style="color:#38bdf8;">class</span>=<span style="color:#34d399;">"dt-bulk-bar"</span> <span style="color:#38bdf8;">role</span>=<span style="color:#34d399;">"region"</span> <span style="color:#38bdf8;">aria-label</span>=<span style="color:#34d399;">"Bulk actions"</span><span style="color:#a78bfa;">&gt;</span>...<span style="color:#a78bfa;">&lt;/div&gt;</span>
<span style="color:#a78bfa;">&lt;/div&gt;</span></pre>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="basic-usage" class="doc-h3">Basic usage (React)</h3>
            <div class="cp-code-area" style="border-radius:12px;">
              <pre style="margin:0;font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;color:#e2e8f0;"><span style="color:#a78bfa;">&lt;DataTable</span>
  <span style="color:#D19A66;">columns</span>=<span style="color:#C678DD;">{[</span>
    <span style="color:#C678DD;">{</span> <span style="color:#D19A66;">id</span>: <span style="color:#98C379;">'name'</span>, <span style="color:#D19A66;">header</span>: <span style="color:#98C379;">'Name'</span>, <span style="color:#D19A66;">accessor</span>: <span style="color:#98C379;">'name'</span> <span style="color:#C678DD;">}</span>,
    <span style="color:#C678DD;">{</span> <span style="color:#D19A66;">id</span>: <span style="color:#98C379;">'owner'</span>, <span style="color:#D19A66;">header</span>: <span style="color:#98C379;">'Owner'</span>, <span style="color:#D19A66;">accessor</span>: <span style="color:#98C379;">'owner'</span> <span style="color:#C678DD;">}</span>,
    <span style="color:#C678DD;">{</span> <span style="color:#D19A66;">id</span>: <span style="color:#98C379;">'status'</span>, <span style="color:#D19A66;">header</span>: <span style="color:#98C379;">'Status'</span>, <span style="color:#D19A66;">accessor</span>: <span style="color:#98C379;">'status'</span> <span style="color:#C678DD;">}</span>,
  <span style="color:#C678DD;">]}</span>
  <span style="color:#D19A66;">rows</span>=<span style="color:#C678DD;">{rows}</span>
  <span style="color:#D19A66;">totalRows</span>=<span style="color:#C678DD;">{243}</span>
  <span style="color:#D19A66;">page</span>=<span style="color:#C678DD;">{page}</span>
  <span style="color:#D19A66;">onPageChange</span>=<span style="color:#C678DD;">{setPage}</span>
  <span style="color:#D19A66;">rowsPerPage</span>=<span style="color:#C678DD;">{20}</span>
<span style="color:#a78bfa;">/&gt;</span></pre>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="selection-bulk-actions" class="doc-h3">With selection and bulk actions</h3>
            <div class="cp-code-area" style="border-radius:12px;">
              <pre style="margin:0;font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;color:#e2e8f0;"><span style="color:#C678DD;">const</span> [<span style="color:#E5C07B;">selectedIds</span>, <span style="color:#E5C07B;">setSelectedIds</span>] = <span style="color:#56B6C2;">useState</span>&lt;<span style="color:#E06C75;">string</span>[]&gt;([]);

<span style="color:#a78bfa;">&lt;DataTable</span>
  <span style="color:#D19A66;">columns</span>=<span style="color:#C678DD;">{columns}</span>
  <span style="color:#D19A66;">rows</span>=<span style="color:#C678DD;">{rows}</span>
  <span style="color:#D19A66;">selectedRowIds</span>=<span style="color:#C678DD;">{selectedIds}</span>
  <span style="color:#D19A66;">onSelectionChange</span>=<span style="color:#C678DD;">{setSelectedIds}</span>
  <span style="color:#D19A66;">bulkActions</span>=<span style="color:#C678DD;">{[</span>
    <span style="color:#C678DD;">{</span> <span style="color:#D19A66;">id</span>: <span style="color:#98C379;">'edit'</span>, <span style="color:#D19A66;">label</span>: <span style="color:#98C379;">'Edit'</span> <span style="color:#C678DD;">}</span>,
    <span style="color:#C678DD;">{</span> <span style="color:#D19A66;">id</span>: <span style="color:#98C379;">'delete'</span>, <span style="color:#D19A66;">label</span>: <span style="color:#98C379;">'Delete'</span>, <span style="color:#D19A66;">destructive</span>: <span style="color:#D19A66;">true</span> <span style="color:#C678DD;">}</span>,
    <span style="color:#C678DD;">{</span> <span style="color:#D19A66;">id</span>: <span style="color:#98C379;">'export'</span>, <span style="color:#D19A66;">label</span>: <span style="color:#98C379;">'Export'</span> <span style="color:#C678DD;">}</span>,
  <span style="color:#C678DD;">]}</span>
  <span style="color:#D19A66;">onBulkAction</span>=<span style="color:#C678DD;">{(id, ids) =&gt; runBulkAction(id, ids)}</span>
<span style="color:#a78bfa;">/&gt;</span></pre>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="js-patterns" class="doc-h3">JS pattern: select-all / indeterminate</h3>
            <div class="cp-code-area" style="border-radius:12px;">
              <pre style="margin:0;font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;color:#e2e8f0;"><span style="color:#C678DD;">function</span> <span style="color:#61AFEF;">syncSelection</span>() {
  <span style="color:#C678DD;">const</span> rowChecks = <span style="color:#56B6C2;">document</span>.<span style="color:#61AFEF;">querySelectorAll</span>(<span style="color:#98C379;">'.dt-row-check'</span>);
  <span style="color:#C678DD;">const</span> head      = <span style="color:#56B6C2;">document</span>.<span style="color:#61AFEF;">querySelector</span>(<span style="color:#98C379;">'#dt-head-check'</span>);
  <span style="color:#C678DD;">const</span> checked   = [...rowChecks].<span style="color:#61AFEF;">filter</span>(<span style="color:#C678DD;">cb =&gt; cb.checked</span>);
  <span style="color:#C678DD;">if</span> (checked.length === <span style="color:#D19A66;">0</span>)            { head.checked = <span style="color:#D19A66;">false</span>; head.indeterminate = <span style="color:#D19A66;">false</span>; }
  <span style="color:#C678DD;">else if</span> (checked.length === rowChecks.length) { head.checked = <span style="color:#D19A66;">true</span>;  head.indeterminate = <span style="color:#D19A66;">false</span>; }
  <span style="color:#C678DD;">else</span>                                          { head.checked = <span style="color:#D19A66;">false</span>; head.indeterminate = <span style="color:#D19A66;">true</span>;  }
  <span style="color:#56B6C2;">document</span>.<span style="color:#61AFEF;">getElementById</span>(<span style="color:#98C379;">'dt-bulk-bar'</span>).<span style="color:#61AFEF;">classList</span>.<span style="color:#61AFEF;">toggle</span>(<span style="color:#98C379;">'visible'</span>, checked.length &gt; <span style="color:#D19A66;">0</span>);
}</pre>
            </div>
          </div>
        </div>

        <!-- ========== ACCESSIBILITY ========== -->
        <div class="tab-content" id="tab-accessibility" style="display:none;padding-top:32px;">
          <h2 id="accessibility" class="doc-section-title">Accessibility</h2>
          <p class="doc-section-subtitle">Guidelines for ensuring Data Table is accessible across assistive technologies, keyboard, and screen readers.</p>

          <div class="doc-section">
            <h3 id="keyboard-navigation" class="doc-h3">Keyboard Navigation</h3>
            <table class="size-table">
              <thead><tr><th>Action</th><th>Result</th></tr></thead>
              <tbody>
                <tr><td><code>Tab</code></td><td>Enters the table; moves focus to the next interactive element (checkbox, link, button).</td></tr>
                <tr><td><code>Arrow</code> keys (grid mode)</td><td>Move focus between cells.</td></tr>
                <tr><td><code>Space</code></td><td>Toggles row selection when focus is on a row checkbox.</td></tr>
                <tr><td><code>Shift+Arrow</code></td><td>Extends selection to adjacent rows.</td></tr>
                <tr><td><code>&#8984;/Ctrl+A</code></td><td>Selects all visible rows.</td></tr>
                <tr><td><code>Enter</code></td><td>Activates the primary link in the focused cell.</td></tr>
                <tr><td><code>Escape</code></td><td>Clears selection and closes the bulk-action bar.</td></tr>
                <tr><td><code>PageUp</code> / <code>PageDown</code></td><td>Advance pagination one step.</td></tr>
              </tbody>
            </table>
            <div style="margin-top:16px;padding:16px 20px;background:rgba(37,99,235,0.05);border:1px solid rgba(37,99,235,0.15);border-radius:12px;">
              <p style="font-size:14px;color:var(--prism-text);line-height:1.6;margin:0;">Keyboard users must always be able to reach the bulk-action bar via <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">Tab</code> from the last selected row &mdash; never trap focus inside the table body.</p>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="aria-attributes" class="doc-h3">ARIA Attributes &amp; Semantics</h3>
            <ul class="doc-list">
              <li><strong>Element:</strong> Use a proper <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;table&gt;</code> with <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;thead&gt;</code>, <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;tbody&gt;</code>, <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;tr&gt;</code>, <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;th scope="col"&gt;</code>, <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;td&gt;</code>.</li>
              <li><strong>Virtualized grid:</strong> If built from <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;div&gt;</code>s, expose grid roles: <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">role="grid"</code>, <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">role="row"</code>, <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">role="columnheader"</code>, <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">role="gridcell"</code>.</li>
              <li><strong>Row checkbox:</strong> Each row checkbox has <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-label="Select row N"</code> (or row identifier).</li>
              <li><strong>Header checkbox:</strong> <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-label="Select all rows"</code> + <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-checked="mixed"</code> when selection is partial.</li>
              <li><strong>Sort:</strong> Sortable headers expose <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-sort="ascending"</code>, <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">"descending"</code>, or <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">"none"</code>.</li>
              <li><strong>Row headers:</strong> If the first data column is the row's primary identifier, mark those cells with <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;th scope="row"&gt;</code>.</li>
              <li><strong>Bulk bar:</strong> Render as <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">role="region" aria-label="Bulk actions"</code> so it is announced when it appears.</li>
              <li><strong>Loading:</strong> Set <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-busy="true"</code> on the <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;table&gt;</code> while the skeleton renders.</li>
              <li><strong>Empty state:</strong> Wrap in <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">role="status"</code>.</li>
            </ul>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="screen-reader" class="doc-h3">Screen Reader Guidance</h3>
            <ul class="doc-list">
              <li><strong>Column context:</strong> <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;th scope="col"&gt;</code> causes assistive tech to announce the column name when reading each cell.</li>
              <li><strong>Live updates:</strong> On filter / sort / pagination, announce the new range via an <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-live="polite"</code> visually-hidden status node &mdash; e.g. "Showing 1 to 20 of 243".</li>
              <li><strong>Selection count:</strong> When the bulk bar appears, the counter ("3 Selected") should be in a live region so the selection delta is announced.</li>
              <li><strong>Destructive actions:</strong> Follow Delete with a confirmation dialog &mdash; never delete straight from the bulk bar.</li>
              <li><strong>Pagination:</strong> Previous / Next buttons must expose their state via <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">disabled</code> when at the boundary, not just grey styling.</li>
            </ul>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="focus-management" class="doc-h3">Focus Management</h3>
            <ul class="doc-list">
              <li><strong>Visible focus ring:</strong> Each interactive cell (checkbox, link, per-row icon button) must have a visible 2px focus ring. Never remove <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">:focus-visible</code> outlines without replacement.</li>
              <li><strong>Bulk bar focus:</strong> When the bulk bar appears, focus remains on the last-checked row checkbox. Users Tab forward to reach the bulk actions.</li>
              <li><strong>Row delete:</strong> After deleting rows via bulk action, move focus to a sensible next element &mdash; the toolbar or the first remaining row &mdash; never leave focus on a detached node.</li>
              <li><strong>Pagination:</strong> After Previous / Next, keep focus on the same button (so repeated paging works). Announce the new page via <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-live</code>.</li>
              <li><strong>RTL:</strong> Column order and toolbar mirror in RTL. Pagination arrows swap visually but keep their logical meaning.</li>
            </ul>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="contrast" class="doc-h3">Color Contrast<span class="h3-badge" style="background:rgba(34,197,94,0.15);color:#16a34a;">WCAG AA Pass</span></h3>
            <p class="doc-section-subtitle">Selected-row background + text must meet 4.5:1. Link cells must meet 4.5:1 and have a non-color affordance (underline on hover).</p>
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px;margin-top:24px;">
              <div style="background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;overflow:hidden;">
                <div style="background:rgba(37,99,235,0.08);padding:28px 24px;text-align:center;color:#15181E;border-radius:12px 12px 0 0;font-family:'Zoho Puvi',sans-serif;"><div style="font-size:16px;font-weight:500;">MacBook-Pro-14</div></div>
                <div style="padding:16px 24px;display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--prism-border);"><div><div style="font-size:13px;color:var(--prism-text-muted);font-weight:600;">TEXT ON SELECTED ROW</div><div style="font-size:15px;color:var(--prism-text);font-family:monospace;margin-top:4px;">#15181E on BG-Selected</div></div><div style="text-align:right;"><div style="display:inline-flex;align-items:center;gap:6px;background:rgba(34,197,94,0.1);color:#16a34a;padding:4px 10px;border-radius:100px;font-size:12px;font-weight:700;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><polyline points="20 6 9 17 4 12"></polyline></svg> 15.8:1</div><div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;font-weight:600;">WCAG AAA Pass</div></div></div>
              </div>
              <div style="background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;overflow:hidden;">
                <div style="background:#15181E;padding:28px 24px;text-align:center;color:#fff;border-radius:12px 12px 0 0;font-family:'Zoho Puvi',sans-serif;"><div style="font-size:16px;font-weight:500;">3 Selected &middot; Edit / Delete</div></div>
                <div style="padding:16px 24px;display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--prism-border);"><div><div style="font-size:13px;color:var(--prism-text-muted);font-weight:600;">BULK BAR TEXT ON DARK</div><div style="font-size:15px;color:var(--prism-text);font-family:monospace;margin-top:4px;">#FFFFFF on #15181E</div></div><div style="text-align:right;"><div style="display:inline-flex;align-items:center;gap:6px;background:rgba(34,197,94,0.1);color:#16a34a;padding:4px 10px;border-radius:100px;font-size:12px;font-weight:700;"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><polyline points="20 6 9 17 4 12"></polyline></svg> 17.1:1</div><div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;font-weight:600;">WCAG AAA Pass</div></div></div>
              </div>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="touch-target" class="doc-h3">Touch Target Size</h3>
            <p class="doc-section-subtitle">Checkboxes and per-row action icons must provide an effective 44px touch area. For Compact density, rely on the full row being clickable to expand the hit area.</p>
            <div style="margin-top:16px;padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;display:flex;align-items:center;gap:24px;">
              <div style="width:44px;height:44px;background:rgba(37,99,235,0.1);border:1px dashed var(--prism-violet);border-radius:8px;display:flex;align-items:center;justify-content:center;color:var(--prism-violet);font-size:12px;font-weight:600;flex-shrink:0;">44px</div>
              <div><div style="font-weight:600;font-size:15px;color:var(--prism-text);">Minimum tap area: 44&times;44 px</div><div style="font-size:14px;color:var(--prism-text-muted);margin-top:4px;">Default (40px) and Comfortable (48px) rows meet the WCAG 2.5.5 minimum. For Compact (32px), enlarge the clickable hit area using padding rather than the visual box.</div></div>
            </div>
          </div>
