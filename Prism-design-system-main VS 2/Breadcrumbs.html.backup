          <!-- Content Guidelines -->
          <div class="doc-section">
            <h3 id="content-guidelines" class="doc-h3">Content Guidelines<span class="h3-badge" style="background: rgba(37,99,235,0.1); color: var(--prism-violet);">Recommended</span></h3>
            <div class="do-dont-grid">
              <div class="do-card"><span class="card-label">Do</span>
                <ul>
                  <li>Reflect the real page hierarchy in the trail.</li>
                  <li>Mark only the last item as Current (bold).</li>
                  <li>Keep labels concise and meaningful (e.g. "Settings", "Profile").</li>
                  <li>Use the home icon for app root level entries.</li>
                </ul>
              </div>
              <div class="dont-card"><span class="card-label">Don't</span>
                <ul>
                  <li>Show the user's click history instead of the actual path.</li>
                  <li>Bold or highlight intermediate items.</li>
                  <li>Truncate labels mid-word with ellipsis; abbreviate instead.</li>
                  <li>Place the home icon on every item.</li>
                </ul>
              </div>
            </div>
          </div>
        </div>

        <!-- =============== STYLE TAB =============== -->
        <div class="tab-content" id="tab-style" style="display: none; padding-top: 32px;">
          <h2 id="style-overview" class="doc-section-title">Style</h2>
          <p class="doc-section-subtitle">Design tokens, color mappings, and spacing tokens that define the Breadcrumb's visual language.</p>

          <!-- Variants -->
          <div class="doc-section">
            <h2 id="variants" class="doc-section-title">Variants</h2>
            <p class="doc-section-subtitle">The component set contains 12 variants across three axes: Count, Overflow, and RTL.</p>
            <table class="size-table">
              <thead><tr><th>Axis</th><th>Values</th><th>Description</th></tr></thead>
              <tbody>
                <tr><td><strong>Count</strong></td><td><code>2</code>, <code>3</code>, <code>4</code>, <code>5</code></td><td>Number of breadcrumb levels shown</td></tr>
                <tr><td><strong>Overflow</strong></td><td><code>False</code>, <code>True</code></td><td>Collapses middle items into &#183;&#183;&#183; (only for Count 4 and 5)</td></tr>
                <tr><td><strong>RTL</strong></td><td><code>False</code>, <code>True</code></td><td>Reverses item order with &#8249; separators and Arabic text</td></tr>
              </tbody>
            </table>
            <div style="margin-top: 24px; padding: 16px 20px; background: rgba(37,99,235,0.05); border: 1px solid rgba(37,99,235,0.15); border-radius: 12px; display: flex; gap: 12px; align-items: flex-start;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2" style="flex-shrink: 0; margin-top: 2px;"><circle cx="12" cy="12" r="10"></circle><path d="M12 16v-4"></path><path d="M12 8h.01"></path></svg>
              <p style="font-size: 14px; color: var(--prism-text); line-height: 1.6; margin: 0;"><strong>Overflow behaviour:</strong> When <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">Overflow=True</code>, middle items are hidden and replaced with a &#183;&#183;&#183; ellipsis token, keeping the first and last two items visible.</p>
            </div>
          </div>

          <hr class="doc-divider" />

          <!-- States -->
          <div class="doc-section">
            <h2 id="states" class="doc-section-title">States</h2>
            <p class="doc-section-subtitle">Breadcrumb items cycle through distinct visual states to communicate interactivity.</p>
            <div class="state-grid">
              <div class="state-card">
                <nav aria-label="Breadcrumb demo"><ol class="bc-nav" style="justify-content:center;"><li><a class="bc-item" href="#" onclick="return false;">Settings</a></li></ol></nav>
                <div class="state-card-title">Default</div>
                <div class="state-card-desc">Standard resting state. Light gray text.</div>
              </div>
              <div class="state-card">
                <nav aria-label="Breadcrumb demo"><ol class="bc-nav" style="justify-content:center;"><li><a class="bc-item" href="#" onclick="return false;" style="color:#2563eb;">Settings</a></li></ol></nav>
                <div class="state-card-title">Hover</div>
                <div class="state-card-desc">Text shifts to brand accent color.</div>
              </div>
              <div class="state-card">
                <nav aria-label="Breadcrumb demo"><ol class="bc-nav" style="justify-content:center;"><li><span class="bc-item current">Current Page</span></li></ol></nav>
                <div class="state-card-title">Current</div>
                <div class="state-card-desc">Bold, dark text. Non-interactive.</div>
              </div>
            </div>
          </div>

          <hr class="doc-divider" />

          <!-- Sizes -->
          <div class="doc-section">
            <h2 id="sizes" class="doc-section-title">Sizes</h2>
            <p class="doc-section-subtitle">Breadcrumbs use a single size profile that adapts naturally to the surrounding typography context.</p>
            <table class="size-table">
              <thead><tr><th>Element</th><th>Font Size</th><th>Line Height</th><th>Font Weight</th></tr></thead>
              <tbody>
                <tr><td><strong>Default item</strong></td><td>14px</td><td>20px</td><td>400 (Regular)</td></tr>
                <tr><td><strong>Current item</strong></td><td>14px</td><td>20px</td><td>700 (Bold)</td></tr>
                <tr><td><strong>Separator</strong></td><td>14px</td><td>20px</td><td>400</td></tr>
                <tr><td><strong>Overflow token</strong></td><td>14px</td><td>20px</td><td>500 (Medium)</td></tr>
              </tbody>
            </table>
          </div>

          <hr class="doc-divider" />

          <!-- Color Tokens -->
          <div class="doc-section">
            <h3 id="color-tokens" class="doc-h3">Color Tokens<span class="h3-badge" style="background: rgba(37,99,235,0.1); color: var(--prism-violet);">Tokens</span></h3>
            <table class="size-table">
              <thead><tr><th>Element</th><th>Token / Style</th><th>Light Value</th><th>Dark Value</th></tr></thead>
              <tbody>
                <tr><td><strong>Default item text</strong></td><td><code>text-secondary</code></td><td>#8993A4</td><td>rgba(255,255,255,0.48)</td></tr>
                <tr><td><strong>Current item text</strong></td><td><code>text-primary</code></td><td>#292A2E</td><td>rgba(255,255,255,0.92)</td></tr>
                <tr><td><strong>Separator</strong></td><td><code>text-secondary</code></td><td>#8993A4</td><td>rgba(255,255,255,0.3)</td></tr>
                <tr><td><strong>Hover text</strong></td><td><code>text-link</code></td><td>#2563EB</td><td>#60A5FA</td></tr>
                <tr><td><strong>Overflow token</strong></td><td><code>text-secondary</code></td><td>#8993A4</td><td>rgba(255,255,255,0.48)</td></tr>
              </tbody>
            </table>
          </div>

          <hr class="doc-divider" />

          <!-- Spacing Tokens -->
          <div class="doc-section">
            <h3 id="spacing-tokens" class="doc-h3">Spacing Tokens</h3>
            <table class="size-table">
              <thead><tr><th>Property</th><th>Value</th><th>Token</th></tr></thead>
              <tbody>
                <tr><td>Separator horizontal padding</td><td>8px (each side)</td><td><code>spacing/8px</code></td></tr>
                <tr><td>Icon-to-label gap</td><td>4px</td><td><code>spacing/4px</code></td></tr>
                <tr><td>Home icon size</td><td>16 x 16px</td><td><code>icon/sm</code></td></tr>
                <tr><td>Component vertical padding</td><td>0px</td><td>Inline element</td></tr>
              </tbody>
