    <main class="main-panel">
      <div class="page-header-area">
        <h1 class="page-title">Breadcrumb</h1>
        <p class="page-desc">Navigation breadcrumb trail that shows a user's current location within a hierarchy. Supports 2-5 levels, overflow collapse, and RTL layouts.</p>
        <nav class="content-tabs">
          <button class="tab-item active">Overview</button>
          <button class="tab-item">Style</button>
          <button class="tab-item">Usage</button>
          <button class="tab-item">Code</button>
          <button class="tab-item">Accessibility</button>
        </nav>
      </div>

      <div class="main-content-area">
        <div class="main-content-inner">

        <!-- =============== OVERVIEW TAB =============== -->
        <div class="tab-content" id="tab-overview">

          <!-- Anatomy Section -->
          <h3 id="anatomy" class="doc-h3">Anatomy</h3>
          <div class="anatomy-diagram">
            <div style="display: flex; justify-content: center; margin: 40px 0;">
              <div style="display: inline-flex; align-items: center; padding: 20px 32px; border-radius: 12px; border: 2px dashed rgba(37,99,235,0.4); font-size: 16px; font-weight: 500; color: var(--prism-text); position: relative; gap: 0;">
                <!-- Home Icon -->
                <div style="position: relative; display: inline-flex; align-items: center;">
                  <div style="position: absolute; top: -38px; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: 4px;">
                    <span class="anat-marker-inline">1</span><div style="width: 2px; height: 12px; background: #2563eb;"></div>
                  </div>
                  <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="opacity:0.6;"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1"/></svg>
                </div>
                <span style="padding: 0 8px; color: #8993A4;">Home</span>
                <!-- Separator -->
                <div style="position: relative; display: inline-flex; align-items: center;">
                  <div style="position: absolute; bottom: -38px; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column-reverse; align-items: center; gap: 4px;">
                    <span class="anat-marker-inline">2</span><div style="width: 2px; height: 12px; background: #2563eb;"></div>
                  </div>
                  <span style="padding: 0 6px; color: #8993A4; font-size: 14px;">&#8250;</span>
                </div>
                <!-- Default Item -->
                <div style="position: relative; display: inline-flex; align-items: center;">
                  <div style="position: absolute; top: -38px; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: 4px;">
                    <span class="anat-marker-inline">3</span><div style="width: 2px; height: 12px; background: #2563eb;"></div>
                  </div>
                  <span style="padding: 0 8px; color: #8993A4;">Settings</span>
                </div>
                <span style="padding: 0 6px; color: #8993A4; font-size: 14px;">&#8250;</span>
                <!-- Collapsed -->
                <div style="position: relative; display: inline-flex; align-items: center;">
                  <div style="position: absolute; bottom: -38px; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column-reverse; align-items: center; gap: 4px;">
                    <span class="anat-marker-inline">4</span><div style="width: 2px; height: 12px; background: #2563eb;"></div>
                  </div>
                  <span style="padding: 0 8px; color: #8993A4; letter-spacing: 2px;">&#183;&#183;&#183;</span>
                </div>
                <span style="padding: 0 6px; color: #8993A4; font-size: 14px;">&#8250;</span>
                <span style="padding: 0 8px; color: #8993A4;">Profile</span>
                <span style="padding: 0 6px; color: #8993A4; font-size: 14px;">&#8250;</span>
                <!-- Current Item -->
                <div style="position: relative; display: inline-flex; align-items: center;">
                  <div style="position: absolute; top: -38px; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: 4px;">
                    <span class="anat-marker-inline">5</span><div style="width: 2px; height: 12px; background: #2563eb;"></div>
                  </div>
                  <span style="padding: 0 8px; color: #292A2E; font-weight: 700;">Edit Account</span>
                </div>
                <!-- Container callout -->
                <div style="position: absolute; left: -32px; top: 50%; transform: translateY(-50%); display: flex; align-items: center; gap: 8px;">
                  <span class="anat-marker-inline">6</span><div style="width: 16px; height: 2px; background: #2563eb;"></div>
                </div>
              </div>
            </div>
          </div>
          <div class="anat-legend">
            <div class="anat-legend-item"><span class="anat-marker-inline">1</span><div><strong>Home Icon</strong><span>Optional leading icon on the first item. Toggle via Show Home Icon property.</span></div></div>
            <div class="anat-legend-item"><span class="anat-marker-inline">2</span><div><strong>Separator</strong><span>Chevron &#8250; between items. Swappable via instance swap. Uses &#8249; for RTL.</span></div></div>
            <div class="anat-legend-item"><span class="anat-marker-inline">3</span><div><strong>Default Item</strong><span>Ancestor page link. Rendered in lighter text (#8993A4). Interactive.</span></div></div>
            <div class="anat-legend-item"><span class="anat-marker-inline">4</span><div><strong>Collapsed Item</strong><span>Overflow placeholder (&#183;&#183;&#183;) shown when Overflow=True. Hides middle items.</span></div></div>
            <div class="anat-legend-item"><span class="anat-marker-inline">5</span><div><strong>Current Item</strong><span>Active page label. Bold, dark text (#292A2E). Non-interactive.</span></div></div>
            <div class="anat-legend-item"><span class="anat-marker-inline">6</span><div><strong>Container</strong><span>Horizontal flex wrapper. Houses all items, separators, and overflow tokens.</span></div></div>
          </div>

          <hr class="doc-divider" />

          <!-- Live Demo -->
          <div style="margin-bottom: 64px;">
            <h2 id="live-demo" class="doc-section-title" style="margin-bottom: 8px;">Preview</h2>
            <p class="doc-section-subtitle" style="margin-bottom: 28px;">Interact with the breadcrumb variants to explore different level counts, overflow behaviour, and RTL layouts.</p>
            <div class="demo-container">
              <div class="demo-canvas">
