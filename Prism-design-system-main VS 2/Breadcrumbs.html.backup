                <nav aria-label="Breadcrumb" dir="rtl" style="width: 100%;">
                  <ol class="bc-nav" style="justify-content: center;">
                    <li><a class="bc-item" href="#">&#1575;&#1604;&#1585;&#1574;&#1610;&#1587;&#1610;&#1577;</a></li>
