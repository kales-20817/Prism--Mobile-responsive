          <script>
          (function(){
            var els = {position:document.getElementById('pg-position'),theme:document.getElementById('pg-theme'),rtl:document.getElementById('pg-rtl'),icon:document.getElementById('pg-icon')};
            var previewArea = document.getElementById('pg-preview-area');
            var codeOut = document.getElementById('pg-code-output');
            var copyBtn = document.getElementById('pg-copy-btn');
            var themeColors = {
              dark: {bg:'#2A2E3F',text:'#fff',border:'transparent',iconStroke:'#fff'},
              light: {bg:'#fff',text:'#15181E',border:'#C3C9D6',iconStroke:'#2A303D'},
              red: {bg:'#FFEBE9',text:'#E42527',border:'transparent',iconStroke:'#E42527'}
            };
            function esc(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
            function update(){
              var pos = els.position.value;
              var theme = els.theme.value;
              var isRTL = els.rtl.value === 'yes';
              var showIcon = els.icon.value === 'yes';
              var c = themeColors[theme];
              var label = isRTL ? '\u0647\u0630\u0627 \u062A\u0644\u0645\u064A\u062D \u0645\u0641\u064A\u062F \u064A\u0648\u0641\u0631 \u0633\u064A\u0627\u0642\u064B\u0627 \u0625\u0636\u0627\u0641\u064A\u064B\u0627 \u062D\u0648\u0644 \u0647\u0630\u0627 \u0627\u0644\u0639\u0646\u0635\u0631' : 'This is a helpful tooltip that provides additional context about this element.';
              var iconSvg = showIcon ? '<svg style="width:20px;height:20px;flex-shrink:0;" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="9" stroke="'+c.iconStroke+'" stroke-width="1.5"/><path d="M10 9v4M10 7h.01" stroke="'+c.iconStroke+'" stroke-width="1.5" stroke-linecap="round"/></svg>' : '';
              var bodyStyle = 'display:flex;align-items:flex-start;gap:6px;width:240px;max-width:240px;padding:8px 12px;border-radius:4px;font-size:12px;line-height:1.5;background:'+c.bg+';color:'+c.text+';'+(theme==='light'?'border:1px solid '+c.border+';box-shadow:0 2px 8px rgba(0,0,0,0.12);':'');
              var dirAttr = isRTL ? ' dir="rtl"' : '';
              var html = '';
              var arrowUp = '<div style="width:0;height:0;border-left:6px solid transparent;border-right:6px solid transparent;border-bottom:6px solid '+c.bg+';margin-left:'+(pos.indexOf('left')>-1?'16px':pos.indexOf('right')>-1?'auto':'50%')+';'+(pos.indexOf('center')>-1?'transform:translateX(-50%);':'')+(pos.indexOf('right')>-1?'margin-right:16px;':'')+'"></div>';
              var arrowDown = '<div style="width:0;height:0;border-left:6px solid transparent;border-right:6px solid transparent;border-top:6px solid '+c.bg+';margin-left:'+(pos.indexOf('left')>-1?'16px':pos.indexOf('right')>-1?'auto':'50%')+';'+(pos.indexOf('center')>-1?'transform:translateX(-50%);':'')+(pos.indexOf('right')>-1?'margin-right:16px;':'')+'"></div>';
              var arrowLeft = '<div style="width:0;height:0;border-top:6px solid transparent;border-bottom:6px solid transparent;border-right:6px solid '+c.bg+';align-self:center;"></div>';
              var arrowRight = '<div style="width:0;height:0;border-top:6px solid transparent;border-bottom:6px solid transparent;border-left:6px solid '+c.bg+';align-self:center;"></div>';
              var bodyHtml = '<div style="'+bodyStyle+'"'+dirAttr+'>'+iconSvg+'<span>'+label+'</span></div>';
              if(pos.indexOf('up')===0){
                html = '<div style="display:flex;flex-direction:column;align-items:stretch;">'+arrowUp+bodyHtml+'</div>';
              } else if(pos.indexOf('down')===0){
                html = '<div style="display:flex;flex-direction:column;align-items:stretch;">'+bodyHtml+arrowDown+'</div>';
              } else if(pos==='left'){
                html = '<div style="display:flex;align-items:center;">'+arrowLeft+bodyHtml+'</div>';
              } else if(pos==='right'){
                html = '<div style="display:flex;align-items:center;">'+bodyHtml+arrowRight+'</div>';
              } else {
                html = bodyHtml;
              }
              previewArea.innerHTML = html;
              var posClass = 'tooltip--'+pos;
              var themeClass = 'tooltip--'+theme;
              var codeStr = '<!-- Trigger element -->\n<button\n  type="button"\n  aria-describedby="tooltip-1"\n  aria-label="More information"\n>\n  <svg><!-- icon --></svg>\n</button>\n\n<!-- Tooltip -->\n<div\n  id="tooltip-1"\n  role="tooltip"\n  class="tooltip '+themeClass+' '+posClass+'"'+(isRTL?'\n  dir="rtl"':'')+'\n  aria-hidden="true"\n>\n  <div class="tooltip__body">\n';
              if(showIcon){ codeStr += '    <svg class="tooltip__icon" aria-hidden="true" width="20" height="20"><!-- info-circle --></svg>\n'; }
              codeStr += '    <span class="tooltip__text">\n      '+label+'\n    </span>\n  </div>\n';
              if(pos!=='without-arrow'){ codeStr += '  <div class="tooltip__arrow" aria-hidden="true"></div>\n'; }
              codeStr += '</div>';
              codeOut.innerHTML = esc(codeStr)
                .replace(/class=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">class</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/type=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">type</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/role=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">role</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/id=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">id</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/aria-describedby=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">aria-describedby</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/aria-label=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">aria-label</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/aria-hidden=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">aria-hidden</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/dir=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">dir</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/width=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">width</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/height=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">height</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/&lt;(\/?)(button|div|svg|span|path|circle)(.*?)&gt;/g,'&lt;$1<span style="color:#a78bfa;">$2</span>$3&gt;');
            }
            Object.values(els).forEach(function(e){e.addEventListener('change',update);});
            copyBtn.addEventListener('click',function(){
              var r=document.createElement('div');r.innerHTML=codeOut.innerHTML;
              navigator.clipboard.writeText(r.innerText).then(function(){
                var o=copyBtn.innerHTML;copyBtn.innerHTML='<svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Copied!';setTimeout(function(){copyBtn.innerHTML=o;},2000);
              });
            });
            update();
          })();
          </script>

