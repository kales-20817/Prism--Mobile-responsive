          <div class="doc-section">
            <h2 id="variants" class="doc-section-title">Variants</h2>
            <p class="doc-section-subtitle">54 variants across Position (9) &times; Theme (3) &times; RTL (2).</p>
            <table class="size-table">
              <thead><tr><th>Axis</th><th>Values</th><th>Count</th></tr></thead>
              <tbody>
