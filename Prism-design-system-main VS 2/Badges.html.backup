            <!-- Critical Intense Contrast -->
            <div style="background: var(--prism-surface); border: 1px solid var(--prism-border); border-radius: 12px; overflow: hidden;">
              <div style="background: #dc2626; padding: 32px 24px; text-align: center; color: #ffffff;">
                <div style="font-size: 24px; font-weight: 600;">Critical</div>
