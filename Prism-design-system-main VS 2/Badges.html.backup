        <!-- Figma Usage -->
        <div class="doc-section">
          <h2 id="figma-usage" class="doc-section-title">Figma Usage</h2>
          <p class="doc-section-subtitle">How to locate and configure the Badge component in Figma.</p>
          <div style="background: #0a0a0c; border-radius: 12px; padding: 24px; margin-bottom: 24px; font-family: 'JetBrains Mono', monospace; font-size: 13.5px; line-height: 1.8; color: #e2e8f0; overflow-x: auto;">
            <div style="color: #94a3b8;">// Component location</div>
            <div><span style="color: #60a5fa;">Component Set:</span> Badge</div>
            <div><span style="color: #60a5fa;">Node ID:</span> <span style="color: #34d399;">16484:122065</span></div>
            <div><span style="color: #60a5fa;">Page:</span> Badge</div>
            <div style="margin-top: 12px; color: #94a3b8;">// Example variant string</div>
            <div><span style="color: #a78bfa;">Style=</span><span style="color: #34d399;">Intense</span>, <span style="color: #a78bfa;">Size=</span><span style="color: #34d399;">Medium</span>, <span style="color: #a78bfa;">State=</span><span style="color: #34d399;">Active</span>, <span style="color: #a78bfa;">RTL=</span><span style="color: #34d399;">Off</span>, <span style="color: #a78bfa;">Shape=</span><span style="color: #34d399;">Pill</span></div>
          </div>

          <h3 id="instance-overrides" class="doc-h3">Instance Overrides</h3>
          <p class="doc-section-subtitle">Steps to customize a badge instance in Figma.</p>
          <div style="display: flex; flex-direction: column; gap: 12px; margin-top: 16px;">
            <div style="display: flex; align-items: flex-start; gap: 16px; padding: 16px 20px; background: var(--prism-surface); border: 1px solid var(--prism-border); border-radius: 12px;">
              <div style="width: 28px; height: 28px; border-radius: 50%; background: linear-gradient(135deg, #2563eb, #3b82f6); color: #fff; font-size: 13px; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">1</div>
              <div><strong style="color: var(--prism-text);">Select the badge instance</strong><div style="font-size: 13px; color: var(--prism-text-muted); margin-top: 4px;">Click on any Badge instance in your Figma canvas.</div></div>
            </div>
            <div style="display: flex; align-items: flex-start; gap: 16px; padding: 16px 20px; background: var(--prism-surface); border: 1px solid var(--prism-border); border-radius: 12px;">
              <div style="width: 28px; height: 28px; border-radius: 50%; background: linear-gradient(135deg, #2563eb, #3b82f6); color: #fff; font-size: 13px; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">2</div>
              <div><strong style="color: var(--prism-text);">Toggle Show Icon</strong><div style="font-size: 13px; color: var(--prism-text-muted); margin-top: 4px;">In the properties panel, toggle <code style="font-family:monospace;font-size:12px;padding:2px 6px;border-radius:4px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">Show Icon</code> on/off to show or hide the leading icon.</div></div>
            </div>
            <div style="display: flex; align-items: flex-start; gap: 16px; padding: 16px 20px; background: var(--prism-surface); border: 1px solid var(--prism-border); border-radius: 12px;">
              <div style="width: 28px; height: 28px; border-radius: 50%; background: linear-gradient(135deg, #2563eb, #3b82f6); color: #fff; font-size: 13px; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">3</div>
              <div><strong style="color: var(--prism-text);">Swap the Icon</strong><div style="font-size: 13px; color: var(--prism-text-muted); margin-top: 4px;">Swap the <code style="font-family:monospace;font-size:12px;padding:2px 6px;border-radius:4px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">Icon</code> to any icon from the icon library via Instance Swap.</div></div>
            </div>
            <div style="display: flex; align-items: flex-start; gap: 16px; padding: 16px 20px; background: var(--prism-surface); border: 1px solid var(--prism-border); border-radius: 12px;">
              <div style="width: 28px; height: 28px; border-radius: 50%; background: linear-gradient(135deg, #2563eb, #3b82f6); color: #fff; font-size: 13px; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">4</div>
              <div><strong style="color: var(--prism-text);">Edit the Label text</strong><div style="font-size: 13px; color: var(--prism-text-muted); margin-top: 4px;">Double-click the label and type your desired text directly (e.g. "Pending", "Approved").</div></div>
            </div>
          </div>
        </div>


