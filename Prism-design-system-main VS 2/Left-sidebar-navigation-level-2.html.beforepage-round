          <script>
          (function(){
            var modules = {
              configurations: {
                label: 'Configurations navigation',
                groups: [
                  { name: 'Add Configurations', items: [{t:'Configuration',sub:true},{t:'Templates'},{t:'Collection',sub:true}] },
                  { name: 'Views', items: [{t:'Nav Item'},{t:'Trash'}] },
                  { name: 'Reports', items: [{t:'USB Reports'},{t:'Script Repository'}] },
                  { name: 'Settings', items: [{t:'Configuration Settings'},{t:'Script Repository'}] }
                ]
              },
              patches: {
                label: 'Threats & Patches navigation',
                groups: [
                  { name: 'Threats', items: [{t:'Vulnerabilities'},{t:'Zero-day Vulnerabilities'},{t:'System Misconfigurations'},{t:'High Risk Software'},{t:'Web Server Misconfigurations'},{t:'Port Audit'},{t:'Manage Exceptions'}] },
                  { name: 'Patches', items: [{t:'Missing Patches'},{t:'Installed Patches',badge:'81'},{t:'Applicable Patches',badge:'397'},{t:'Top-Priority Patches'},{t:'Supported Patches',badge:'554K'},{t:'Latest Patches',badge:'78K'},{t:'Detailed View'},{t:'Downloaded Patches'},{t:'Decline Patch'}] },
                  { name: 'Attention Required', items: [{t:'Upload Pending',badge:'1'}] }
                ]
              },
              browsers: {
                label: 'Browsers navigation',
                groups: [
                  { name: 'Manage', items: [{t:'Groups & Computers'},{t:'Website Group'},{t:'Extension Repository'}] },
                  { name: 'Policies', items: [{t:'Add-on Management'},{t:'File Activity Restriction'},{t:'Threat Prevention'},{t:'Data Leakage Prevention'},{t:'Browser Customization'},{t:'Browser Router'},{t:'Browser Lockdown'},{t:'Java Manager'},{t:'Web Filter'},{t:'Web Isolation'},{t:'Browser Restriction'}] },
                  { name: 'Insights', items: [{t:'Dashboard'},{t:'Browsers'},{t:'Browser Add-ons'},{t:'Computers'},{t:'Web Activity'},{t:'Scan Computers'},{t:'Schedule Scan'}] }
                ]
              },
              software: {
                label: 'Software Deployment navigation',
                groups: [
                  { name: 'Package creation', items: [{t:'Packages'},{t:'Templates'}] },
                  { name: 'Deployment', items: [{t:'Install/Uninstall Software',sub:true},{t:'View Configurations'},{t:'User-defined Templates'},{t:'Trash'},{t:'Self Service Portal'}] },
                  { name: 'Reports', items: [{t:'Self Service Portal Reports'},{t:'SSP Usage Reports'}] },
                  { name: 'Settings', items: [{t:'Software Repository'},{t:'Script Repository'},{t:'Auto-update Templates'},{t:'Proxy Settings'},{t:'Deployment Policies'},{t:'Package Cleanup Settings'},{t:'Self Service Portal Settings'},{t:'Red Hat Linux Settings'}] }
                ]
              }
            };
            var els = {module:document.getElementById('pg-module'),active:document.getElementById('pg-active'),groups:document.getElementById('pg-groups')};
            var previewArea = document.getElementById('pg-preview-area');
            var codeOut = document.getElementById('pg-code-output');
            var copyBtn = document.getElementById('pg-copy-btn');

            function esc(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
            function slugify(s){return s.toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,'');}

            function update(){
              var mod = modules[els.module.value];
              var activeVal = els.active.value;
              var groupMode = els.groups.value;
              var allItems = [];
              mod.groups.forEach(function(g){g.items.forEach(function(it){allItems.push(it);});});
              var activeIdx = -1;
              if(activeVal==='0') activeIdx=0;
              else if(activeVal==='2') activeIdx=2;
              else if(activeVal==='last') activeIdx=allItems.length-1;

              // Build preview HTML
              var phtml = '<nav class="snl2-panel" aria-label="'+mod.label+'" style="max-height:480px;">';
              phtml += '<div class="snl2-search"><svg class="snl2-search-icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg><input type="search" placeholder="Search..." aria-label="Search navigation"/></div>';
              phtml += '<ul class="snl2-tree" role="list">';

              var globalIdx = 0;
              mod.groups.forEach(function(g, gi){
                var expanded = true;
                if(groupMode==='first' && gi>0) expanded = false;
                if(groupMode==='mixed' && gi!==0 && gi!==2) expanded = false;
                phtml += '<li class="snl2-group'+(expanded?'':' collapsed')+'">';
                phtml += '<button class="snl2-group-header" aria-expanded="'+(expanded?'true':'false')+'">';
                phtml += '<svg class="snl2-group-chevron" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M6 9l6 6 6-6"/></svg> '+g.name+'</button>';
                phtml += '<ul class="snl2-group-items" role="list"'+(expanded?'':' hidden')+'>';
                g.items.forEach(function(it){
                  var isActive = globalIdx === activeIdx;
                  phtml += '<li><a href="#" class="snl2-item'+(isActive?' active':'')+'"'+(isActive?' aria-current="page"':'')+'>';
                  phtml += it.t;
                  if(it.badge) phtml += ' <span class="snl2-item-badge" aria-label="'+it.badge+' items">'+it.badge+'</span>';
                  if(it.sub) phtml += ' <svg class="snl2-item-chevron" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg>';
                  phtml += '</a></li>';
                  globalIdx++;
                });
                phtml += '</ul></li>';
              });
              phtml += '</ul></nav>';
              previewArea.innerHTML = phtml;

              // Attach interactive group toggles in preview
              previewArea.querySelectorAll('.snl2-group-header').forEach(function(hdr){
                hdr.addEventListener('click', function(e){
                  e.preventDefault();
                  var grp = hdr.closest('.snl2-group');
                  var items = grp.querySelector('.snl2-group-items');
                  var isExp = hdr.getAttribute('aria-expanded')==='true';
                  hdr.setAttribute('aria-expanded', String(!isExp));
                  if(isExp){ items.setAttribute('hidden',''); grp.classList.add('collapsed'); }
                  else { items.removeAttribute('hidden'); grp.classList.remove('collapsed'); }
                });
              });
              // Prevent nav on item clicks in preview
              previewArea.querySelectorAll('.snl2-item').forEach(function(a){
                a.addEventListener('click', function(e){
                  e.preventDefault();
                  previewArea.querySelectorAll('.snl2-item.active').forEach(function(el){el.classList.remove('active');el.removeAttribute('aria-current');});
                  a.classList.add('active');
                  a.setAttribute('aria-current','page');
                });
              });

