              var code = '<nav\n  class="sidebar-nav-l2"\n  aria-label="'+mod.label+'"\n>\n';
              code += '  <!-- Search -->\n  <div class="sidebar-l2__search">\n    <svg class="search-icon" aria-hidden="true"><!-- magnifier --></svg>\n    <input type="search" placeholder="Search..." aria-label="Search navigation" />\n  </div>\n\n';
              code += '  <!-- Nav tree -->\n  <ul class="sidebar-l2__tree" role="list">\n';
              var gIdx = 0;
              mod.groups.forEach(function(g, gi){
                var expanded = true;
                if(groupMode==='first' && gi>0) expanded = false;
                if(groupMode==='mixed' && gi!==0 && gi!==2) expanded = false;
                var gSlug = slugify(g.name);
                code += '\n    <!-- '+(expanded?'Expanded':'Collapsed')+' group -->\n';
                code += '    <li class="nav-group nav-group--'+(expanded?'expanded':'collapsed')+'">\n';
                code += '      <button\n        class="nav-group__header"\n        aria-expanded="'+(expanded?'true':'false')+'"\n        aria-controls="group-'+gSlug+'"\n      >\n';
                code += '        <svg class="nav-group__chevron" aria-hidden="true"><!-- chevron-'+(expanded?'down':'right')+' --></svg>\n';
                code += '        '+g.name+'\n      </button>\n';
                code += '      <ul id="group-'+gSlug+'" class="nav-group__items" role="list"'+(expanded?'':' hidden')+'>\n';
                g.items.forEach(function(it){
                  var isActive = gIdx === activeIdx;
                  code += '        <li>\n          <a href="#" class="nav-item'+(it.sub?' nav-item--sub':'')+(isActive?' nav-item--active':'')+'"'+(isActive?' aria-current="page"':'')+'>\n';
                  code += '            '+it.t+'\n';
                  if(it.badge) code += '            <span class="nav-item__badge" aria-label="'+it.badge+' items">'+it.badge+'</span>\n';
                  if(it.sub) code += '            <svg class="nav-item__chevron" aria-hidden="true"><!-- chevron-right --></svg>\n';
                  code += '          </a>\n        </li>\n';
                  gIdx++;
                });
                code += '      </ul>\n    </li>\n';
              });
              code += '\n  </ul>\n</nav>';

              codeOut.innerHTML = esc(code)
                .replace(/class=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">class</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/aria-label=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">aria-label</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/aria-expanded=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">aria-expanded</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/aria-controls=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">aria-controls</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/aria-current=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">aria-current</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/aria-hidden=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">aria-hidden</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/type=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">type</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/placeholder=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">placeholder</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/href=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">href</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/id=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">id</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/role=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">role</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/ hidden/g,' <span style="color:#f97316;">hidden</span>')
                .replace(/&lt;(\/?)(nav|div|ul|li|a|button|input|svg|span)([\s&])/g,'&lt;$1<span style="color:#a78bfa;">$2</span>$3')
                .replace(/&lt;(\/?)(nav|div|ul|li|a|button|input|svg|span)&gt;/g,'&lt;$1<span style="color:#a78bfa;">$2</span>&gt;')
                .replace(/&lt;!--(.*?)--&gt;/g,'<span style="color:#6b7280;">&lt;!--$1--&gt;</span>');
            }
            Object.values(els).forEach(function(e){e.addEventListener('change',update);});
            copyBtn.addEventListener('click',function(){
              var r=document.createElement('div');r.innerHTML=codeOut.innerHTML;
              navigator.clipboard.writeText(r.innerText).then(function(){
                var o=copyBtn.innerHTML;copyBtn.innerHTML='<svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Copied!';setTimeout(function(){copyBtn.innerHTML=o;},2000);
              });
            });
            update();
          })();
          </script>

