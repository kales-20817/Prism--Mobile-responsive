        <!-- ========== CODE ========== -->
        <div class="tab-content" id="tab-code" style="display:none;padding-top:32px;">
          <h2 id="live-demo-code" class="doc-section-title">Live demo (Code)</h2>
          <p class="doc-section-subtitle">Configure the Right Pane component and view generated HTML.</p>
          <div class="code-playground">
            <div class="cp-toolbar">
              <div class="cp-control-group"><label class="cp-label">Top Icons</label><select class="cp-select" id="pg-top"><option value="all" selected>All (5)</option><option value="minimal">Help + Videos only</option><option value="none">None</option></select></div>
              <div class="cp-control-group"><label class="cp-label">Bottom Icons</label><select class="cp-select" id="pg-bottom"><option value="all" selected>All (5)</option><option value="minimal">Theme + Chat only</option><option value="none">None</option></select></div>
              <div class="cp-control-group"><label class="cp-label">Theme Icon</label><select class="cp-select" id="pg-theme"><option value="dark" selected>Dark (Moon)</option><option value="light">Light (Sun)</option></select></div>
              <div class="cp-control-group"><label class="cp-label">Extension Slots</label><select class="cp-select" id="pg-ext"><option value="0" selected>None</option><option value="1">1 slot</option><option value="2">2 slots</option></select></div>
            </div>
            <div class="cp-preview" id="pg-preview-area" style="padding:0;min-height:400px;"></div>
            <div class="cp-code-header">
              <div style="font-size:13.5px;font-weight:600;color:var(--prism-text);">HTML</div>
              <button class="cp-action-btn" id="pg-copy-btn"><svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2"/></svg> Copy code</button>
            </div>
            <div class="cp-code-area" id="pg-code-output"></div>
          </div>
          <script>
          (function(){
            var els = {top:document.getElementById('pg-top'),bottom:document.getElementById('pg-bottom'),theme:document.getElementById('pg-theme'),ext:document.getElementById('pg-ext')};
            var previewArea = document.getElementById('pg-preview-area');
            var codeOut = document.getElementById('pg-code-output');
            var copyBtn = document.getElementById('pg-copy-btn');

            var topIcons = [
              {id:'askzia', label:'Ask ZIA', icon:'<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>'},
              {id:'help', label:'Help', icon:'<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3m.08 4h.01"/></svg>'},
              {id:'videos', label:'Help Videos', icon:'<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3"/></svg>'},
              {id:'roadmap', label:'Road Map', icon:'<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"/></svg>'},
              {id:'sdp', label:'SDP', icon:'<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 3v18M3 9h6"/></svg>'}
            ];

            var bottomIcons = [
              {id:'announce', label:'Announcement', icon:'<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/></svg>'},
              {id:'a11y', label:'Accessibility', icon:'<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>'},
              {id:'tickets', label:'Tickets', icon:'<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/></svg>'},
              {id:'chat', label:'Chat', icon:'<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>'}
            ];

            var moonSvg = '<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>';
            var sunSvg = '<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>';

            var extIcon = '<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>';

            function esc(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}

            function update(){
              var topMode = els.top.value;
              var bottomMode = els.bottom.value;
              var themeMode = els.theme.value;
              var extCount = parseInt(els.ext.value);

              var visibleTop = [];
              if(topMode==='all') visibleTop = topIcons.slice();
              else if(topMode==='minimal') visibleTop = [topIcons[1], topIcons[2]];

              var visibleBottom = [];
              if(bottomMode==='all') visibleBottom = bottomIcons.slice();
              else if(bottomMode==='minimal') visibleBottom = [bottomIcons[3]];

              // Preview
              var html = '<div style="display:flex;width:100%;height:100%;min-height:400px;"><div style="flex:1;display:flex;align-items:center;justify-content:center;"><span style="font-size:14px;color:var(--prism-text-muted);">App Canvas</span></div>';
              html += '<nav class="rp-rail" aria-label="Utilities" style="min-height:auto;border-radius:0;">';
              html += '<div class="rp-section" style="padding-top:8px;">';
              visibleTop.forEach(function(ic){
                html += '<button class="rp-icon-btn" onclick="this.classList.toggle(\'active\')" aria-label="'+ic.label+'"><span class="rp-tooltip">'+ic.label+'</span>'+ic.icon+'</button>';
              });
              html += '</div><div class="rp-spacer"></div><div class="rp-section" style="padding-bottom:8px;">';
              // Theme icon
              var tIcon = themeMode==='dark' ? moonSvg : sunSvg;
              var tLabel = themeMode==='dark' ? 'Switch to light theme' : 'Switch to dark theme';
              html += '<button class="rp-icon-btn" onclick="this.classList.toggle(\'active\')" aria-label="'+tLabel+'"><span class="rp-tooltip">Theme</span>'+tIcon+'</button>';
              visibleBottom.forEach(function(ic){
                html += '<button class="rp-icon-btn" onclick="this.classList.toggle(\'active\')" aria-label="'+ic.label+'"><span class="rp-tooltip">'+ic.label+'</span>'+ic.icon+'</button>';
              });
              for(var e=0;e<extCount;e++){
                html += '<button class="rp-icon-btn" onclick="this.classList.toggle(\'active\')" aria-label="Extension '+(e+1)+'"><span class="rp-tooltip">Extension '+(e+1)+'</span>'+extIcon+'</button>';
              }
              html += '</div></nav></div>';
              previewArea.innerHTML = html;

              // Code output
              var code = '<nav class="right-pane" aria-label="Utilities">\n';
              code += '  <!-- Top Section -->\n  <div class="rp-top">\n';
              visibleTop.forEach(function(ic){
                code += '    <button class="icon-btn" aria-label="'+ic.label+'" data-tooltip="'+ic.label+'">\n      <!-- '+ic.label+' icon -->\n    </button>\n';
              });
              code += '  </div>\n\n  <!-- Spacer -->\n  <div class="rp-spacer"></div>\n\n  <!-- Bottom Section -->\n  <div class="rp-bottom">\n';
              if(themeMode==='dark'){
                code += '    <button class="icon-btn" aria-label="Switch to light theme" aria-pressed="false">\n      <!-- Moon icon -->\n    </button>\n';
              } else {
                code += '    <button class="icon-btn" aria-label="Switch to dark theme" aria-pressed="false">\n      <!-- Sun icon -->\n    </button>\n';
              }
              visibleBottom.forEach(function(ic){
                code += '    <button class="icon-btn" aria-label="'+ic.label+'" data-tooltip="'+ic.label+'">\n      <!-- '+ic.label+' icon -->\n    </button>\n';
              });
              for(var e2=0;e2<extCount;e2++){
                code += '    <button class="icon-btn" aria-label="Extension '+(e2+1)+'">\n      <!-- Extension icon -->\n    </button>\n';
              }
              code += '  </div>\n</nav>';
              codeOut.innerHTML = esc(code)
                .replace(/class=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">class</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/aria-label=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">aria-label</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/aria-pressed=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">aria-pressed</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/data-tooltip=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">data-tooltip</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/&lt;(\/?)(nav|div|button)(.*?)&gt;/g,'&lt;$1<span style="color:#a78bfa;">$2</span>$3&gt;')
                .replace(/&lt;!--(.*?)--&gt;/g,'<span style="color:#6b7280;">&lt;!--$1--&gt;</span>');
            }
            Object.values(els).forEach(function(e){e.addEventListener('change',update);});
            copyBtn.addEventListener('click',function(){
              var r=document.createElement('div');r.innerHTML=codeOut.innerHTML;
              navigator.clipboard.writeText(r.innerText).then(function(){
                var o=copyBtn.innerHTML;copyBtn.innerHTML='<svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Copied!';setTimeout(function(){copyBtn.innerHTML=o;},2000);
              });
            });
            update();
          })();
          </script>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="component-api-properties" class="doc-h3">Component API &amp; Properties</h3>
            <table class="size-table">
              <thead><tr><th>Property</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
              <tbody>
                <tr><td><code>showAskZIA</code></td><td>boolean</td><td><code>true</code></td><td>Show the Zia AI assistant launcher in the top section.</td></tr>
                <tr><td><code>showHelp</code></td><td>boolean</td><td><code>true</code></td><td>Show the help-centre launcher.</td></tr>
                <tr><td><code>showHelpVideos</code></td><td>boolean</td><td><code>true</code></td><td>Show the help-videos launcher.</td></tr>
                <tr><td><code>showRoadMap</code></td><td>boolean</td><td><code>true</code></td><td>Show the product-roadmap launcher.</td></tr>
                <tr><td><code>showSDP</code></td><td>boolean</td><td><code>true</code></td><td>Show the ServiceDesk Plus quick-access icon.</td></tr>
                <tr><td><code>showDarkTheme</code></td><td>boolean</td><td><code>true</code></td><td>Show the dark-theme toggle. Set to <code>false</code> and flip <code>showLightTheme</code> to render the sun icon instead.</td></tr>
                <tr><td><code>showLightTheme</code></td><td>boolean</td><td><code>false</code></td><td>Show the light-theme toggle (alternate of <code>showDarkTheme</code>).</td></tr>
                <tr><td><code>showAnnouncement</code></td><td>boolean</td><td><code>true</code></td><td>Show the announcement icon.</td></tr>
                <tr><td><code>showAccessibility</code></td><td>boolean</td><td><code>true</code></td><td>Show the accessibility icon.</td></tr>
                <tr><td><code>showTickets</code></td><td>boolean</td><td><code>true</code></td><td>Show the tickets icon.</td></tr>
                <tr><td><code>showChat</code></td><td>boolean</td><td><code>true</code></td><td>Show the chat icon.</td></tr>
                <tr><td><code>showOther1</code> &hellip; <code>showOther8</code></td><td>boolean</td><td><code>false</code></td><td>Product-specific extension slots.</td></tr>
                <tr><td><code>askZiaSwap</code></td><td>ReactNode</td><td>Icon Button</td><td>Instance-swap slot for the Ask ZIA icon button.</td></tr>
                <tr><td><code>helpSwap</code></td><td>ReactNode</td><td>Icon Button</td><td>Instance-swap slot for the Help icon button.</td></tr>
                <tr><td><code>darkThemeSwap</code> / <code>lightThemeSwap</code></td><td>ReactNode</td><td>Icon Button</td><td>Instance-swap slots for theme toggle icon buttons.</td></tr>
                <tr><td><code>onThemeToggle</code></td><td><code>() =&gt; void</code></td><td>&mdash;</td><td>Fires when the theme icon is activated.</td></tr>
              </tbody>
            </table>
            <div style="margin-top:16px;padding:16px 20px;background:rgba(37,99,235,0.05);border:1px solid rgba(37,99,235,0.15);border-radius:12px;">
              <p style="font-size:14px;color:var(--prism-text);line-height:1.6;margin:0;"><strong>Note:</strong> Each icon button also forwards the standard Icon Button props (<code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">onClick</code>, <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">tooltip</code>, <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-label</code>) through its instance.</p>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="code-examples" class="doc-h3">Code Examples</h3>

            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:12px;margin-top:24px;">Default &mdash; all core icons visible</h4>
            <div class="cp-code-area" style="border-radius:12px;margin-bottom:24px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;">
                <span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">RightPane</span> <span style="color:#ABB2BF;">/&gt;</span>
              </div>
            </div>

            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:12px;">Minimal &mdash; only Help and Chat</h4>
            <div class="cp-code-area" style="border-radius:12px;margin-bottom:24px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;">
                <span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">RightPane</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">showAskZIA</span><span style="color:#56B6C2;">=</span><span style="color:#C678DD;">{</span><span style="color:#D19A66;">false</span><span style="color:#C678DD;">}</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">showHelpVideos</span><span style="color:#56B6C2;">=</span><span style="color:#C678DD;">{</span><span style="color:#D19A66;">false</span><span style="color:#C678DD;">}</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">showRoadMap</span><span style="color:#56B6C2;">=</span><span style="color:#C678DD;">{</span><span style="color:#D19A66;">false</span><span style="color:#C678DD;">}</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">showSDP</span><span style="color:#56B6C2;">=</span><span style="color:#C678DD;">{</span><span style="color:#D19A66;">false</span><span style="color:#C678DD;">}</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">showAnnouncement</span><span style="color:#56B6C2;">=</span><span style="color:#C678DD;">{</span><span style="color:#D19A66;">false</span><span style="color:#C678DD;">}</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">showAccessibility</span><span style="color:#56B6C2;">=</span><span style="color:#C678DD;">{</span><span style="color:#D19A66;">false</span><span style="color:#C678DD;">}</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">showTickets</span><span style="color:#56B6C2;">=</span><span style="color:#C678DD;">{</span><span style="color:#D19A66;">false</span><span style="color:#C678DD;">}</span><br>
                <span style="color:#ABB2BF;">/&gt;</span>
              </div>
            </div>

            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:12px;">Light-theme toggle visible</h4>
            <div class="cp-code-area" style="border-radius:12px;margin-bottom:24px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;">
                <span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">RightPane</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">showDarkTheme</span><span style="color:#56B6C2;">=</span><span style="color:#C678DD;">{</span><span style="color:#D19A66;">false</span><span style="color:#C678DD;">}</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">showLightTheme</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">onThemeToggle</span><span style="color:#56B6C2;">=</span><span style="color:#C678DD;">{</span><span style="color:#ABB2BF;">() =&gt; setTheme('dark')</span><span style="color:#C678DD;">}</span><br>
                <span style="color:#ABB2BF;">/&gt;</span>
              </div>
            </div>

            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:12px;">App-shell placement</h4>
            <div class="cp-code-area" style="border-radius:12px;margin-bottom:24px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;">
                <span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">div</span> <span style="color:#D19A66;">className</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"app-shell"</span><span style="color:#ABB2BF;">&gt;</span><br>
                &nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">LeftSidebarNavigation</span> <span style="color:#ABB2BF;">/&gt;</span><br>
                &nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">main</span> <span style="color:#D19A66;">className</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"app-main"</span><span style="color:#ABB2BF;">&gt;</span><span style="color:#C678DD;">{</span><span style="color:#E5C07B;">children</span><span style="color:#C678DD;">}</span><span style="color:#ABB2BF;">&lt;/</span><span style="color:#E06C75;">main</span><span style="color:#ABB2BF;">&gt;</span><br>
                &nbsp;&nbsp;<span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">RightPane</span> <span style="color:#ABB2BF;">/&gt;</span><br>
                <span style="color:#ABB2BF;">&lt;/</span><span style="color:#E06C75;">div</span><span style="color:#ABB2BF;">&gt;</span><br><br>
                <span style="color:#94a3b8;">/* CSS */</span><br>
                <span style="color:#E06C75;">.app-shell</span> <span style="color:#ABB2BF;">{ </span><span style="color:#D19A66;">display</span>: <span style="color:#98C379;">grid</span>; <span style="color:#D19A66;">grid-template-columns</span>: <span style="color:#98C379;">auto 1fr 48px</span>; <span style="color:#D19A66;">min-height</span>: <span style="color:#98C379;">100vh</span>; <span style="color:#ABB2BF;">}</span>
              </div>
            </div>
          </div>
        </div>

        <!-- ========== ACCESSIBILITY ========== -->
        <div class="tab-content" id="tab-accessibility" style="display:none;padding-top:32px;">
          <h2 id="accessibility" class="doc-section-title">Accessibility</h2>
          <p class="doc-section-subtitle">Guidelines for ensuring the Right Pane is accessible across assistive technologies and input methods.</p>

          <div class="doc-section">
            <h3 id="landmark-role" class="doc-h3">Landmark Role</h3>
            <ul class="doc-list">
              <li>Wrap the rail in <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;nav aria-label="Utilities"&gt;</code> or <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;aside aria-label="Utilities"&gt;</code> so it appears as a landmark in screen-reader rotor lists.</li>
            </ul>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="icon-only-buttons" class="doc-h3">Icon-Only Buttons</h3>
            <ul class="doc-list">
              <li>Every icon button must expose an <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-label</code> matching its tooltip text (e.g. <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-label="Help"</code>). Do not rely on the tooltip alone.</li>
              <li>Tooltips appear on hover and keyboard focus, positioned to the <strong>left</strong> of the rail. Use the design system's Tooltip component.</li>
            </ul>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="keyboard-interaction" class="doc-h3">Keyboard Interaction</h3>
            <table class="size-table">
              <thead><tr><th>Action</th><th>Result</th></tr></thead>
              <tbody>
                <tr><td><code>Tab</code></td><td>Moves top-to-bottom through visible icon buttons (top section first, then bottom).</td></tr>
                <tr><td><code>Shift+Tab</code></td><td>Reverses direction.</td></tr>
                <tr><td><code>Enter</code> / <code>Space</code></td><td>Activates the focused icon button.</td></tr>
                <tr><td><code>Escape</code></td><td>Closes any open panel triggered from the rail.</td></tr>
              </tbody>
            </table>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="active-state-aria" class="doc-h3">Active State &amp; ARIA</h3>
            <ul class="doc-list">
              <li>When a panel triggered by the rail is open, set <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-expanded="true"</code> (for popovers) or <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-pressed="true"</code> (for toggles like theme) on the icon button.</li>
              <li><strong>Theme toggle:</strong> Announce the resulting state (<code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">"Switch to light theme"</code> / <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">"Switch to dark theme"</code>) in the <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-label</code>, not the current state.</li>
            </ul>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="focus-ring" class="doc-h3">Focus Ring</h3>
            <ul class="doc-list">
              <li>Use the Icon Button focus ring (blue, 2 px) &mdash; do not remove it. The rail's white background makes the ring clearly visible.</li>
            </ul>
            <div style="margin-top:24px;display:flex;gap:16px;align-items:center;padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;">
              <button class="rp-icon-btn" style="pointer-events:none;box-shadow:0 0 0 2px var(--prism-violet);">
                <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3m.08 4h.01"/></svg>
              </button>
              <div>
                <div style="font-weight:600;font-size:15px;color:var(--prism-text);">Focus ring: 2px solid blue</div>
                <div style="font-size:14px;color:var(--prism-text-muted);margin-top:4px;">Shadow-Focus-Blue token &mdash; visible against BG-Base-White</div>
              </div>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="color-contrast" class="doc-h3">Color Contrast<span class="h3-badge" style="background:rgba(34,197,94,0.15);color:#16a34a;">WCAG AA Pass</span></h3>
            <ul class="doc-list">
              <li>Icon glyphs at <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">Icon-Tertiary</code> must meet WCAG AA 3:1 contrast against <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">BG-Base-White</code>.</li>
              <li>Active glyphs at <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">Icon-Primary</code> should meet 4.5:1.</li>
            </ul>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="rtl-support" class="doc-h3">RTL Support</h3>
            <ul class="doc-list">
              <li>In RTL layouts, the rail swaps to the <strong>left</strong> edge and the border moves to the right side.</li>
              <li>Tooltips anchor to the <strong>right</strong> of the rail in RTL mode.</li>
            </ul>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="responsive" class="doc-h3">Responsive Behaviour</h3>
            <ul class="doc-list">
              <li>Below ~768 px viewport width, hide the rail and surface its contents in a help menu within Header Navigation.</li>
              <li>Do not attempt to shrink the 48 px rail &mdash; it should be completely hidden on narrow viewports.</li>
            </ul>
          </div>
        </div>

        </div><!-- main-content-inner -->

