                  </div>
                </div>
                <div style="position:absolute;left:50%;bottom:calc(100% + 6px);transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:4px;"><span class="anat-marker-inline">1</span><div style="width:2px; height:14px; background:#2563eb;"></div></div>
              </div>
            </div>
          </div>
          <div class="anat-legend" style="grid-template-columns:repeat(3,1fr);">
            <div class="anat-legend-item"><span class="anat-marker-inline">1</span><div><strong>Container</strong><span>48 px fixed width, fills viewport height. <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">BG-Base-White</code> background, 1 px left border.</span></div></div>
            <div class="anat-legend-item"><span class="anat-marker-inline">2</span><div><strong>Top Section</strong><span>Vertical stack of up to 5 primary icon buttons, anchored to the top of the rail.</span></div></div>
            <div class="anat-legend-item"><span class="anat-marker-inline">3</span><div><strong>Spacer</strong><span>Flexible fill frame between the two sections &mdash; expands to push the bottom section down.</span></div></div>
            <div class="anat-legend-item"><span class="anat-marker-inline">4</span><div><strong>Bottom Section</strong><span>Vertical stack of up to 13 utility icon buttons (5 fixed + 8 "Other" slots + theme toggle), anchored to the bottom.</span></div></div>
            <div class="anat-legend-item"><span class="anat-marker-inline">5</span><div><strong>Icon Button</strong><span>Each slot is an instance of Icon Button &mdash; <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">Tertiary</code>, <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">Square</code>, <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">Large</code> (24 &times; 24).</span></div></div>
          </div>

          <hr class="doc-divider"/>

          <div style="margin-bottom:64px;">
            <h2 id="live-demo" class="doc-section-title" style="margin-bottom:8px;">Preview</h2>
            <p class="doc-section-subtitle" style="margin-bottom:28px;">Explore the Right Pane rail in context. Click icons to toggle their active state.</p>
            <div class="demo-container">
<div class="demo-canvas" style="flex-direction:row;align-items:stretch;gap:0;padding:0;min-height:480px;">
                <!-- Simulated app content area -->
                <div style="flex:1;display:flex;align-items:center;justify-content:center;padding:40px;">
                  <div style="text-align:center;">
                    <div style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:8px;">Application Canvas</div>
                    <div style="font-size:13px;color:var(--prism-text-muted);">Main content area &mdash; the Right Pane sits at the right edge</div>
                  </div>
                </div>
                <!-- Live Right Pane rail -->
                <nav class="rp-rail" id="demo-rail" aria-label="Utilities" style="min-height:auto;border-radius:0;">
                  <div class="rp-section" style="padding-top:8px;">
                    <button class="rp-icon-btn" onclick="this.classList.toggle('active')" aria-label="Ask ZIA"><span class="rp-tooltip">Ask ZIA</span><svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg></button>
                    <button class="rp-icon-btn" onclick="this.classList.toggle('active')" aria-label="Help"><span class="rp-tooltip">Help</span><svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3m.08 4h.01"/></svg></button>
                    <button class="rp-icon-btn" onclick="this.classList.toggle('active')" aria-label="Help Videos"><span class="rp-tooltip">Help Videos</span><svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3"/></svg></button>
                    <button class="rp-icon-btn" onclick="this.classList.toggle('active')" aria-label="Road Map"><span class="rp-tooltip">Road Map</span><svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"/></svg></button>
                    <button class="rp-icon-btn" onclick="this.classList.toggle('active')" aria-label="SDP"><span class="rp-tooltip">SDP</span><svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 3v18M3 9h6"/></svg></button>
                  </div>
                  <div class="rp-spacer"></div>
                  <div class="rp-section" style="padding-bottom:8px;">
                    <button class="rp-icon-btn" id="demo-theme-btn" aria-label="Switch to light theme"><span class="rp-tooltip">Theme</span><svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg></button>
                    <button class="rp-icon-btn" onclick="this.classList.toggle('active')" aria-label="Announcement"><span class="rp-tooltip">Announcement</span><svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/></svg></button>
                    <button class="rp-icon-btn" onclick="this.classList.toggle('active')" aria-label="Accessibility"><span class="rp-tooltip">Accessibility</span><svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg></button>
                    <button class="rp-icon-btn" onclick="this.classList.toggle('active')" aria-label="Tickets"><span class="rp-tooltip">Tickets</span><svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/></svg></button>
                    <button class="rp-icon-btn" onclick="this.classList.toggle('active')" aria-label="Chat"><span class="rp-tooltip">Chat</span><svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg></button>
                  </div>
                </nav>
              </div>
            </div>
          </div>

          <div class="doc-section">
            <h3 id="sections-icon-slots" class="doc-h3">Sections &amp; Icon Slots</h3>

            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Top Section &mdash; primary utilities</h4>
            <table class="size-table" style="margin-bottom:32px;">
              <thead><tr><th>Slot</th><th>Boolean Prop</th><th>Default</th><th>Typical Icon</th><th>Purpose</th></tr></thead>
              <tbody>
                <tr><td>1</td><td><code>showAskZIA</code></td><td><code>true</code></td><td>Zia / AI prompt</td><td>Launch the Zia AI assistant</td></tr>
                <tr><td>2</td><td><code>showHelp</code></td><td><code>true</code></td><td>Question mark</td><td>Open the in-app help centre</td></tr>
                <tr><td>3</td><td><code>showHelpVideos</code></td><td><code>true</code></td><td>Play button</td><td>Open help-video library</td></tr>
                <tr><td>4</td><td><code>showRoadMap</code></td><td><code>true</code></td><td>Branching / share</td><td>Open the product roadmap</td></tr>
                <tr><td>5</td><td><code>showSDP</code></td><td><code>true</code></td><td>ServiceDesk Plus logo</td><td>Jump to SDP cross-sell / quick-access</td></tr>
              </tbody>
            </table>

            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Bottom Section &mdash; supporting actions</h4>
            <table class="size-table">
              <thead><tr><th>Slot</th><th>Boolean Prop</th><th>Default</th><th>Typical Icon</th><th>Purpose</th></tr></thead>
              <tbody>
                <tr><td>1</td><td><code>showDarkTheme</code></td><td><code>true</code></td><td>Moon</td><td>Toggle to dark theme</td></tr>
                <tr><td>2</td><td><code>showLightTheme</code></td><td><code>false</code></td><td>Sun</td><td>Toggle to light theme (alternate of slot 1)</td></tr>
                <tr><td>3</td><td><code>showAnnouncement</code></td><td><code>true</code></td><td>Megaphone</td><td>Show product announcements / what's new</td></tr>
                <tr><td>4</td><td><code>showAccessibility</code></td><td><code>true</code></td><td>Accessibility glyph</td><td>Accessibility settings / statement</td></tr>
                <tr><td>5</td><td><code>showTickets</code></td><td><code>true</code></td><td>Ticket</td><td>Create or view support tickets</td></tr>
                <tr><td>6</td><td><code>showChat</code></td><td><code>true</code></td><td>Chat bubble</td><td>Launch live chat / support conversation</td></tr>
                <tr><td>7&ndash;14</td><td><code>showOther1</code> &hellip; <code>showOther8</code></td><td><code>false</code></td><td>User-supplied</td><td>Product-specific extension slots</td></tr>
              </tbody>
            </table>
            <div style="margin-top:16px;padding:16px 20px;background:rgba(37,99,235,0.05);border:1px solid rgba(37,99,235,0.15);border-radius:12px;">
              <p style="font-size:14px;color:var(--prism-text);line-height:1.6;margin:0;"><strong>Note:</strong> <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">showDarkTheme</code> and <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">showLightTheme</code> are mutually exclusive &mdash; surface one at a time based on the active theme. All <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">Other N</code> slots are hidden by default.</p>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="content-guidelines" class="doc-h3">Content Guidelines<span class="h3-badge" style="background:rgba(37,99,235,0.1);color:var(--prism-violet);">Recommended</span></h3>
            <div class="do-dont-grid">
              <div class="do-card"><span class="card-label">Do</span><ul>
                <li>Keep the rail at 48 px wide &mdash; it is a design-system constant.</li>
                <li>Show a tooltip on hover/focus for every icon ("Help", "Tickets", etc.).</li>
                <li>Cap the top section at 5 icons and the bottom section at ~6 visible icons.</li>
                <li>Swap <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">showDarkTheme</code> / <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">showLightTheme</code> to reflect the current theme.</li>
                <li>Open content in an overlay, popover, or external destination &mdash; never navigate away in-place.</li>
              </ul></div>
              <div class="dont-card"><span class="card-label">Don't</span><ul>
                <li>Widen the rail to accommodate labels; use tooltips instead.</li>
                <li>Rely on icons alone &mdash; un-labelled icons fail accessibility.</li>
                <li>Stack more than 6&ndash;7 icons per section &mdash; the rail becomes noisy and the flex spacer shrinks.</li>
                <li>Show both theme icons at the same time.</li>
                <li>Repurpose the named slots (Help, Tickets, Chat) for unrelated actions.</li>
                <li>Treat rail icons as navigation tabs that replace the main canvas.</li>
              </ul></div>
            </div>
          </div>
        </div>

        <!-- ========== STYLE ========== -->
        <div class="tab-content" id="tab-style" style="display:none;padding-top:32px;">
          <h2 id="style-overview" class="doc-section-title">Style</h2>
          <p class="doc-section-subtitle">Design tokens, spacing specifications, and layout rules that define the Right Pane's appearance.</p>

          <div class="doc-section">
            <h3 id="color-tokens" class="doc-h3">Color Tokens<span class="h3-badge" style="background:rgba(37,99,235,0.1);color:var(--prism-violet);">Tokens</span></h3>
            <table class="size-table">
              <thead><tr><th>Token</th><th>Role</th></tr></thead>
              <tbody>
                <tr><td><code>Background/BG-Base-White</code></td><td>Rail background</td></tr>
                <tr><td><code>Border/Border-Secondary</code></td><td>Left border separating the rail from the app canvas</td></tr>
                <tr><td><code>Border/Icon/Icon-Tertiary</code></td><td>Default icon colour (inherited from Icon Button &mdash; Tertiary)</td></tr>
                <tr><td><code>Border/Icon/Icon-Primary</code></td><td>Icon colour when the button is active / selected</td></tr>
                <tr><td><code>Background/BG-Hover</code></td><td>Icon-button hover background</td></tr>
                <tr><td><code>Shadow/Shadow-Focus-Blue</code></td><td>Focus ring on keyboard focus (Icon Button default)</td></tr>
              </tbody>
            </table>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="spacing-tokens" class="doc-h3">Spacing Tokens</h3>
            <table class="size-table">
              <thead><tr><th>Token</th><th>Value</th><th>Usage</th></tr></thead>
              <tbody>
                <tr><td><code>spacing/12</code></td><td>12 px</td><td>Rail horizontal padding (left / right inside the 48 px rail)</td></tr>
                <tr><td><code>spacing/16</code></td><td>16 px</td><td>Vertical gap between adjacent icon buttons</td></tr>
                <tr><td><code>spacing/20</code></td><td>20 px</td><td>Rail vertical padding (top and bottom)</td></tr>
              </tbody>
            </table>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="layout-specs" class="doc-h3">Layout Specifications</h3>
            <table class="size-table">
              <thead><tr><th>Property</th><th>Value</th></tr></thead>
              <tbody>
                <tr><td><strong>Rail width</strong></td><td><strong>48 px</strong> (fixed)</td></tr>
                <tr><td><strong>Rail height</strong></td><td><strong>Fill container</strong> (full viewport height)</td></tr>
                <tr><td><strong>Left border</strong></td><td>1 px, <code>Border-Secondary</code></td></tr>
                <tr><td><strong>Horizontal padding</strong></td><td>12 px</td></tr>
                <tr><td><strong>Vertical padding</strong></td><td>20 px</td></tr>
                <tr><td><strong>Icon button size</strong></td><td>24 &times; 24 px (inside a 48 &minus; 2&times;12 = 24 px column)</td></tr>
                <tr><td><strong>Icon-button spacing</strong></td><td>16 px</td></tr>
                <tr><td><strong>Section alignment</strong></td><td>Top section: top-anchored &middot; Bottom section: bottom-anchored &middot; Spacer fills remainder</td></tr>
              </tbody>
            </table>
            <!-- Visual layout diagram -->
            <div style="display:flex;gap:24px;flex-wrap:wrap;margin-top:32px;">
              <div style="flex:1;min-width:200px;padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;text-align:center;">
                <div style="width:48px;height:48px;border:2px dashed #006AFF;border-radius:6px;margin:0 auto 16px;display:flex;align-items:center;justify-content:center;background:rgba(0,106,255,0.05);color:#006AFF;font-weight:600;font-size:11px;">48px</div>
                <div style="font-size:14px;font-weight:600;color:var(--prism-text);">Rail Width</div>
                <div style="font-size:12px;color:var(--prism-text-muted);margin-top:4px;">Fixed &mdash; never changes</div>
              </div>
              <div style="flex:1;min-width:200px;padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;text-align:center;">
                <div style="width:24px;height:24px;border:2px dashed #006AFF;border-radius:4px;margin:0 auto 16px;display:flex;align-items:center;justify-content:center;background:rgba(0,106,255,0.05);color:#006AFF;font-weight:600;font-size:9px;">24</div>
                <div style="font-size:14px;font-weight:600;color:var(--prism-text);">Icon Button</div>
                <div style="font-size:12px;color:var(--prism-text-muted);margin-top:4px;">24 &times; 24 px</div>
              </div>
              <div style="flex:1;min-width:200px;padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;text-align:center;">
                <div style="display:flex;flex-direction:column;align-items:center;gap:4px;margin-bottom:16px;">
                  <div style="width:16px;height:16px;background:rgba(0,106,255,0.15);border-radius:3px;"></div>
                  <div style="width:1px;height:16px;border-left:2px dashed #006AFF;"></div>
                  <div style="width:16px;height:16px;background:rgba(0,106,255,0.15);border-radius:3px;"></div>
                </div>
                <div style="font-size:14px;font-weight:600;color:var(--prism-text);">16 px gap</div>
                <div style="font-size:12px;color:var(--prism-text-muted);margin-top:4px;">Between icon buttons</div>
              </div>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="icon-button-states" class="doc-h3">Icon Button States</h3>
            <p class="doc-section-subtitle">Each rail icon inherits standard Icon Button states.</p>
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:14px;margin-top:24px;">
              <div style="padding:24px 16px;border-radius:14px;background:var(--prism-surface);border:1px solid var(--prism-border);text-align:center;">
                <div style="display:flex;justify-content:center;margin-bottom:16px;"><button class="rp-icon-btn" style="pointer-events:none;"><svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3m.08 4h.01"/></svg></button></div>
                <div style="font-size:13px;font-weight:600;color:var(--prism-text);">Default</div>
                <div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;">Icon-Tertiary colour</div>
              </div>
              <div style="padding:24px 16px;border-radius:14px;background:var(--prism-surface);border:1px solid var(--prism-border);text-align:center;">
                <div style="display:flex;justify-content:center;margin-bottom:16px;"><button class="rp-icon-btn" style="pointer-events:none;background:rgba(37,99,235,0.06);color:var(--prism-text);"><svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3m.08 4h.01"/></svg></button></div>
                <div style="font-size:13px;font-weight:600;color:var(--prism-text);">Hover</div>
                <div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;">BG-Hover background</div>
              </div>
              <div style="padding:24px 16px;border-radius:14px;background:var(--prism-surface);border:1px solid var(--prism-border);text-align:center;">
                <div style="display:flex;justify-content:center;margin-bottom:16px;"><button class="rp-icon-btn" style="pointer-events:none;box-shadow:0 0 0 2px var(--prism-violet);"><svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3m.08 4h.01"/></svg></button></div>
                <div style="font-size:13px;font-weight:600;color:var(--prism-text);">Focus</div>
                <div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;">Blue 2 px focus ring</div>
              </div>
              <div style="padding:24px 16px;border-radius:14px;background:var(--prism-surface);border:1px solid var(--prism-border);text-align:center;">
                <div style="display:flex;justify-content:center;margin-bottom:16px;"><button class="rp-icon-btn active" style="pointer-events:none;"><svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3m.08 4h.01"/></svg></button></div>
                <div style="font-size:13px;font-weight:600;color:var(--prism-text);">Active</div>
                <div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;">Icon-Primary colour</div>
              </div>
            </div>
          </div>
        </div>

        <!-- ========== USAGE ========== -->
        <div class="tab-content" id="tab-usage" style="display:none;padding-top:32px;">
          <div class="doc-section">
            <h2 id="when-to-use" class="doc-section-title">When and Where to Use</h2>
            <p class="doc-section-subtitle">The Right Pane provides a persistent vertical rail for always-available utilities in an application shell.</p>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:24px;">
              <div style="padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;">
                <h3 style="font-size:15px;font-weight:600;color:var(--prism-text);margin-bottom:16px;display:flex;align-items:center;gap:8px;"><svg width="20" height="20" fill="none" stroke="#2563eb" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>When to use</h3>
                <ul class="doc-list" style="border:none;background:transparent;padding-left:20px;font-size:14.5px;">
                  <li style="border:none;background:transparent;margin-bottom:8px;">As a <strong>persistent right-hand rail</strong> in an application shell that exposes always-available utilities (AI assistant, help, support, theme, announcements).</li>
                  <li style="border:none;background:transparent;margin-bottom:8px;">When primary product navigation lives in the left sidebar and secondary / contextual affordances belong on the right.</li>
                  <li style="border:none;background:transparent;">When you need a <strong>dense, low-chrome</strong> entry point for utilities &mdash; each icon opens a panel, popover, modal, or external destination.</li>
                </ul>
              </div>
              <div style="padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;">
                <h3 style="font-size:15px;font-weight:600;color:var(--prism-text);margin-bottom:16px;display:flex;align-items:center;gap:8px;"><svg width="20" height="20" fill="none" stroke="#e42527" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>When NOT to use</h3>
                <ul class="doc-list" style="border:none;background:transparent;padding-left:20px;font-size:14.5px;">
                  <li style="border:none;background:transparent;margin-bottom:8px;">For <strong>primary navigation</strong> between major app sections &rarr; use Left Sidebar Navigation.</li>
                  <li style="border:none;background:transparent;margin-bottom:8px;">For <strong>contextual actions</strong> tied to a selected record &rarr; use an inline action bar or Split Button.</li>
                  <li style="border:none;background:transparent;margin-bottom:8px;">When the viewport is below ~768 px wide &mdash; hide the rail and move its items into a help menu in the Header Navigation.</li>
                  <li style="border:none;background:transparent;">For <strong>rich content panes</strong> (comments, activity, details) &rarr; use a collapsible right drawer anchored to this rail.</li>
                </ul>
              </div>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h2 id="detailed-guidelines" class="doc-section-title">Complete Do's and Don'ts</h2>
            <p class="doc-section-subtitle">Guidelines for effective Right Pane usage.</p>
            <div class="do-dont-grid">
              <div class="do-card"><span class="card-label">Do</span><ul>
                <li><strong>Fixed width:</strong> Keep the rail at 48 px wide &mdash; it is a design-system constant.</li>
                <li><strong>Tooltip every icon:</strong> Show a tooltip on hover/focus for every icon ("Help", "Tickets", etc.).</li>
                <li><strong>Cap icon count:</strong> Cap the top section at 5 icons and the bottom section at ~6 visible icons.</li>
                <li><strong>Theme toggle:</strong> Swap <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">showDarkTheme</code> &#8596; <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">showLightTheme</code> to reflect the current theme.</li>
                <li><strong>Extension slots:</strong> Use the <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">Other 1&ndash;8</code> slots for genuinely product-specific utilities.</li>
                <li><strong>Overlay content:</strong> Open content in an overlay, popover, or external destination &mdash; never navigate away in-place.</li>
                <li><strong>Sync active state:</strong> Keep icon-button state (<code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">active</code>) in sync with the currently open panel.</li>
              </ul></div>
              <div class="dont-card"><span class="card-label">Don't</span><ul>
                <li><strong>No labels in rail:</strong> Widen the rail to accommodate labels; use tooltips instead.</li>
                <li><strong>No unlabelled icons:</strong> Rely on icons alone &mdash; un-labelled icons fail accessibility.</li>
                <li><strong>No overcrowding:</strong> Stack more than 6&ndash;7 icons per section &mdash; the rail becomes noisy and the flex spacer shrinks.</li>
                <li><strong>No dual theme icons:</strong> Show both theme icons at the same time.</li>
                <li><strong>No slot repurposing:</strong> Repurpose the named slots (Help, Tickets, Chat) for unrelated actions.</li>
                <li><strong>No in-place nav:</strong> Treat rail icons as navigation tabs that replace the main canvas.</li>
                <li><strong>No inactive panels:</strong> Leave all icons inactive when an associated panel is open.</li>
              </ul></div>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h2 id="app-shell-placement" class="doc-section-title">App-Shell Placement</h2>
            <p class="doc-section-subtitle">The Right Pane lives as the last column in a three-column grid layout.</p>
            <div style="margin-top:16px;padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;">
              <div style="display:grid;grid-template-columns:60px 1fr 48px;min-height:200px;border:1px dashed var(--prism-border);border-radius:8px;overflow:hidden;">
                <div style="background:rgba(37,99,235,0.06);display:flex;align-items:center;justify-content:center;border-right:1px dashed var(--prism-border);"><span style="writing-mode:vertical-rl;font-size:11px;font-weight:600;color:var(--prism-text-muted);letter-spacing:0.1em;">LEFT NAV</span></div>
                <div style="display:flex;align-items:center;justify-content:center;"><span style="font-size:13px;font-weight:600;color:var(--prism-text-muted);">MAIN CONTENT (1fr)</span></div>
                <div style="background:rgba(37,99,235,0.06);display:flex;align-items:center;justify-content:center;border-left:1px dashed var(--prism-border);"><span style="writing-mode:vertical-rl;font-size:11px;font-weight:600;color:var(--prism-violet);letter-spacing:0.1em;">RIGHT PANE</span></div>
              </div>
              <div style="margin-top:16px;font-family:'JetBrains Mono',monospace;font-size:13px;color:var(--prism-text-muted);line-height:1.6;">
                <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">grid-template-columns: auto 1fr 48px;</code>
              </div>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h2 id="related" class="doc-section-title">Related</h2>
            <p class="doc-section-subtitle">Components that complement or can be used alongside the Right Pane.</p>
            <div class="related-grid">
              <a href="Sidebar.html" class="related-chip"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 3v18"/></svg> Left Sidebar Navigation</a>
              <a href="Header-navigation.html" class="related-chip"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12h18M3 6h18M3 18h18"/></svg> Header Navigation</a>
