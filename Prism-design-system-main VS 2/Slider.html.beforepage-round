          <script>
          (function(){
            var els = {type:document.getElementById('pg-type'),size:document.getElementById('pg-size'),state:document.getElementById('pg-state'),value:document.getElementById('pg-value'),label:document.getElementById('pg-label')};
            var sliderEl = document.getElementById('pg-slider-el');
            var sLabel = document.getElementById('pg-s-label');
            var sValue = document.getElementById('pg-s-value');
            var sActive = document.getElementById('pg-s-active');
            var sThumb1 = document.getElementById('pg-s-thumb1');
            var sThumb2 = document.getElementById('pg-s-thumb2');
            var codeOut = document.getElementById('pg-code-output');
            var copyBtn = document.getElementById('pg-copy-btn');
            function esc(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
            function update(){
              var tp=els.type.value, sz=els.size.value, st=els.state.value, v=els.value.value||'50', lb=els.label.value||'Label';
              sLabel.textContent=lb;
              var isRange = tp==='range';
              var pct = 50, leftPct = 20, rightPct = 80;
              if(isRange){
                var parts = v.split(/[,\-\s]+/);
                var a = parseInt(parts[0])||20, b = parseInt(parts[1])||80;
                leftPct = Math.max(0,Math.min(100,a));
                rightPct = Math.max(0,Math.min(100,b));
                sValue.textContent = leftPct + ' \u2013 ' + rightPct;
                sActive.style.left = leftPct+'%';
                sActive.style.width = (rightPct-leftPct)+'%';
                sThumb1.style.left = leftPct+'%';
                sThumb1.style.display = '';
                sThumb2.style.left = rightPct+'%';
                sThumb2.style.display = '';
              } else {
                pct = Math.max(0,Math.min(100,parseInt(v)||50));
                sValue.textContent = pct;
                sActive.style.left = '0';
                sActive.style.width = pct+'%';
                sThumb1.style.left = pct+'%';
                sThumb1.style.display = '';
                sThumb2.style.display = 'none';
              }
              sliderEl.className = 'slider-demo';
              if(sz==='Small') sliderEl.classList.add('slider-sm');
              else if(sz==='Large') sliderEl.classList.add('slider-lg');
              var stateMap = {'Hover':'slider-hover','Focus':'slider-focus','Active':'slider-active','Disabled':'slider-disabled','Error':'slider-error'};
              if(stateMap[st]) sliderEl.classList.add(stateMap[st]);
              var code = '<Slider\n';
              if(isRange) code += '  type="Range"\n';
              code += '  label="'+lb+'"\n';
              if(isRange) code += '  value={['+leftPct+', '+rightPct+']}\n';
              else code += '  value={'+pct+'}\n';
              code += '  min={0}\n  max={100}\n';
              if(sz!=='Small') code += '  size="'+sz+'"\n';
              if(st==='Disabled') code += '  disabled\n';
              if(st==='Error') code += '  state="Error"\n';
              code += '  onChange={(val) => setValue(val)}\n';
              if(isRange) code += '  onChangeEnd={(val) => fetchResults(val)}\n';
              code += '/>';
              codeOut.innerHTML = esc(code)
                .replace(/(type|label|value|min|max|size|disabled|state|onChange|onChangeEnd)=/g,'<span style="color:#38bdf8;">$1</span>=')
                .replace(/&lt;(\/?)(Slider)/g,'&lt;$1<span style="color:#a78bfa;">$2</span>')
                .replace(/"([^"]*)"/g,'<span style="color:#34d399;">"$1"</span>')
                .replace(/\{([^}]*)\}/g,'{<span style="color:#fbbf24;">$1</span>}');
            }
            Object.values(els).forEach(function(e){e.addEventListener(e.tagName==='INPUT'?'input':'change',update);});
            copyBtn.addEventListener('click',function(){
              var r=document.createElement('div');r.innerHTML=codeOut.innerHTML;
              navigator.clipboard.writeText(r.innerText).then(function(){
                var o=copyBtn.innerHTML;copyBtn.innerHTML='<svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Copied!';setTimeout(function(){copyBtn.innerHTML=o;},2000);
              });
            });
            update();
          })();
          </script>

