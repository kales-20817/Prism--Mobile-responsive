    <main class="main-panel">
      <div class="page-header-area">
        <h1 class="page-title">Divider</h1>
        <p class="page-desc">A thin line used to visually separate content sections, list items, or layout regions. Supports horizontal and vertical orientations, three line styles, two thickness levels, four layout types including a centred label variant, and inset spacing options.</p>
        <nav class="content-tabs">
          <button class="tab-item active">Overview</button>
          <button class="tab-item">Style</button>
          <button class="tab-item">Usage</button>
          <button class="tab-item">Code</button>
          <button class="tab-item">Accessibility</button>
        </nav>
      </div>

      <div class="main-content-area">
        <div class="main-content-inner">

        <!-- ========== OVERVIEW ========== -->
        <div class="tab-content" id="tab-overview">
          <h3 id="anatomy" class="doc-h3">Anatomy</h3>
          <div class="anatomy-diagram" style="padding-left:100px;">
            <!-- Horizontal Full Width -->
            <div style="margin-bottom:32px;">
              <div style="font-size:12px;font-weight:600;color:var(--prism-text-muted);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:12px;">Horizontal &mdash; Full Width</div>
              <div style="position:relative;padding:20px 0;">
                <div style="position:absolute;right:calc(100% + 6px);top:50%;transform:translateY(-50%);display:flex;align-items:center;gap:6px;z-index:5;"><span class="anat-marker-inline">1</span><div style="width:36px;height:2px;background:#2563eb;"></div></div>
                <div class="divider-h" style="width:100%;"></div>
              </div>
            </div>
            <!-- Horizontal With Text -->
            <div style="margin-bottom:32px;">
              <div style="font-size:12px;font-weight:600;color:var(--prism-text-muted);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:12px;">Horizontal &mdash; With Text</div>
              <div style="position:relative;padding:20px 0;">
                <div style="position:absolute;right:calc(100% + 6px);top:50%;transform:translateY(-50%);display:flex;align-items:center;gap:6px;z-index:5;"><span class="anat-marker-inline">2</span><div style="width:36px;height:2px;background:#2563eb;"></div></div>
                <div class="divider-with-text">Label</div>
              </div>
            </div>
            <!-- Vertical Full Width -->
            <div style="display:flex;gap:48px;align-items:flex-start;">
              <div>
                <div style="font-size:12px;font-weight:600;color:var(--prism-text-muted);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:12px;">Vertical &mdash; Full Width</div>
                <div style="position:relative;display:flex;align-items:center;gap:6px;height:80px;">
                  <span class="anat-marker-inline">3</span>
                  <div style="width:20px;height:2px;background:#2563eb;"></div>
                  <div class="divider-v" style="height:80px;"></div>
                </div>
              </div>
              <div>
                <div style="font-size:12px;font-weight:600;color:var(--prism-text-muted);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:12px;">Vertical &mdash; With Text</div>
                <div style="position:relative;display:flex;align-items:center;gap:6px;">
                  <span class="anat-marker-inline">4</span>
                  <div style="width:20px;height:2px;background:#2563eb;"></div>
                  <div class="divider-with-text-v" style="height:120px;">Label</div>
                </div>
              </div>
            </div>
          </div>
          <div class="anat-legend">
            <div class="anat-legend-item"><span class="anat-marker-inline">1</span><div><strong>Line</strong><span>The dividing rule. A single frame rendered as a stroke (non-With Text) or a filled frame (With Text).</span></div></div>
            <div class="anat-legend-item"><span class="anat-marker-inline">2</span><div><strong>Label</strong><span>Optional centred text label splitting the line into two equal segments. 12 px Regular, Text/Text-Secondary. Present only in With Text type.</span></div></div>
            <div class="anat-legend-item"><span class="anat-marker-inline">3</span><div><strong>Line Left / Line Right</strong><span>The two line segments flanking the label in horizontal With Text variants. Each fills equally.</span></div></div>
            <div class="anat-legend-item"><span class="anat-marker-inline">4</span><div><strong>Line Top / Line Bottom</strong><span>The two line segments flanking the label in vertical With Text variants. Each fills equally.</span></div></div>
          </div>

          <hr class="doc-divider"/>

          <div style="margin-bottom:64px;">
            <h2 id="live-demo" class="doc-section-title" style="margin-bottom:8px;">Preview</h2>
            <p class="doc-section-subtitle" style="margin-bottom:28px;">Explore all divider variants across orientations, types, styles, and thicknesses.</p>
            <div class="demo-container">
<div class="demo-canvas" style="gap:32px;">
                <!-- Full Width Solid Thin -->
                <div style="width:100%;max-width:400px;">
                  <div style="font-size:11px;font-weight:600;color:var(--prism-text-muted);margin-bottom:8px;text-transform:uppercase;letter-spacing:0.06em;">Full Width &middot; Solid &middot; Thin</div>
                  <div class="divider-h"></div>
                </div>
                <!-- Full Width Solid Medium -->
                <div style="width:100%;max-width:400px;">
                  <div style="font-size:11px;font-weight:600;color:var(--prism-text-muted);margin-bottom:8px;text-transform:uppercase;letter-spacing:0.06em;">Full Width &middot; Solid &middot; Medium</div>
                  <div class="divider-h divider-h--medium"></div>
                </div>
                <!-- Dashed Thin -->
                <div style="width:100%;max-width:400px;">
                  <div style="font-size:11px;font-weight:600;color:var(--prism-text-muted);margin-bottom:8px;text-transform:uppercase;letter-spacing:0.06em;">Full Width &middot; Dashed &middot; Thin</div>
                  <div class="divider-h divider-h--dashed"></div>
                </div>
                <!-- Dotted Thin -->
                <div style="width:100%;max-width:400px;">
                  <div style="font-size:11px;font-weight:600;color:var(--prism-text-muted);margin-bottom:8px;text-transform:uppercase;letter-spacing:0.06em;">Full Width &middot; Dotted &middot; Thin</div>
                  <div class="divider-h divider-h--dotted"></div>
                </div>
                <!-- Inset -->
                <div style="width:100%;max-width:400px;">
                  <div style="font-size:11px;font-weight:600;color:var(--prism-text-muted);margin-bottom:8px;text-transform:uppercase;letter-spacing:0.06em;">Inset &middot; Solid &middot; Thin</div>
                  <div class="divider-h divider-h--inset"></div>
                </div>
                <!-- Middle Inset -->
                <div style="width:100%;max-width:400px;">
                  <div style="font-size:11px;font-weight:600;color:var(--prism-text-muted);margin-bottom:8px;text-transform:uppercase;letter-spacing:0.06em;">Middle Inset &middot; Solid &middot; Thin</div>
                  <div class="divider-h divider-h--m-inset"></div>
                </div>
                <!-- With Text -->
                <div style="width:100%;max-width:400px;">
                  <div style="font-size:11px;font-weight:600;color:var(--prism-text-muted);margin-bottom:8px;text-transform:uppercase;letter-spacing:0.06em;">With Text &middot; Solid &middot; Thin</div>
                  <div class="divider-with-text">Or</div>
                </div>
                <!-- Vertical row -->
                <div style="display:flex;gap:40px;align-items:center;height:80px;">
                  <div style="text-align:center;">
                    <div style="font-size:11px;font-weight:600;color:var(--prism-text-muted);margin-bottom:8px;text-transform:uppercase;letter-spacing:0.06em;">Vertical Thin</div>
                    <div style="display:flex;justify-content:center;height:60px;"><div class="divider-v" style="height:60px;"></div></div>
                  </div>
                  <div style="text-align:center;">
                    <div style="font-size:11px;font-weight:600;color:var(--prism-text-muted);margin-bottom:8px;text-transform:uppercase;letter-spacing:0.06em;">Vertical Medium</div>
                    <div style="display:flex;justify-content:center;height:60px;"><div class="divider-v divider-v--medium" style="height:60px;"></div></div>
                  </div>
                  <div style="text-align:center;">
                    <div style="font-size:11px;font-weight:600;color:var(--prism-text-muted);margin-bottom:8px;text-transform:uppercase;letter-spacing:0.06em;">Vertical Dashed</div>
                    <div style="display:flex;justify-content:center;height:60px;"><div class="divider-v divider-v--dashed" style="height:60px;"></div></div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="doc-section">
            <h3 id="content-guidelines" class="doc-h3">Content Guidelines<span class="h3-badge" style="background:rgba(37,99,235,0.1);color:var(--prism-violet);">Recommended</span></h3>
            <div class="do-dont-grid">
              <div class="do-card"><span class="card-label">Do</span><ul>
                <li>Keep With Text labels very short (1-3 words, e.g. "Or", "Today", "Continue").</li>
                <li>Use Thin as the default thickness -- it is the least intrusive.</li>
                <li>Use Solid as the default style; reach for Dashed/Dotted for softer boundaries.</li>
              </ul></div>
              <div class="dont-card"><span class="card-label">Don't</span><ul>
                <li>Write full sentences as divider labels.</li>
                <li>Use dividers as a substitute for vertical spacing -- use Spacing tokens instead.</li>
                <li>Overuse dividers -- too many fragment a layout and increase visual noise.</li>
              </ul></div>
            </div>
          </div>
        </div>

        <!-- ========== STYLE ========== -->
        <div class="tab-content" id="tab-style" style="display:none;padding-top:32px;">
          <h2 id="style-overview" class="doc-section-title">Style</h2>
          <p class="doc-section-subtitle">Design tokens, color mappings, and spacing tokens that define the Divider's visual language.</p>

          <div class="doc-section">
            <h2 id="variants" class="doc-section-title">Variants</h2>
            <p class="doc-section-subtitle">48 variants across Orientation (2) &times; Type (4) &times; Style (3) &times; Thickness (2).</p>
            <table class="size-table">
              <thead><tr><th>Axis</th><th>Values</th><th>Description</th></tr></thead>
              <tbody>
                <tr><td><strong>Orientation</strong></td><td><code>Horizontal</code>, <code>Vertical</code></td><td>Horizontal spans width; Vertical spans height of container.</td></tr>
                <tr><td><strong>Type</strong></td><td><code>Full Width</code>, <code>Inset</code>, <code>Middle Inset</code>, <code>With Text</code></td><td>Controls indent and whether a label is shown.</td></tr>
                <tr><td><strong>Style</strong></td><td><code>Solid</code>, <code>Dashed</code>, <code>Dotted</code></td><td>Visual line style: continuous rule, dashes, or dots.</td></tr>
                <tr><td><strong>Thickness</strong></td><td><code>Thin</code>, <code>Medium</code></td><td>Thin = 1 px (default). Medium = 2 px for stronger visual weight.</td></tr>
              </tbody>
            </table>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h2 id="states" class="doc-section-title">States</h2>
            <p class="doc-section-subtitle">The Divider is a non-interactive element with no hover, focus, or active states. Its appearance is entirely determined by the variant properties.</p>
            <div style="margin-top:24px;padding:16px 20px;background:rgba(37,99,235,0.05);border:1px solid rgba(37,99,235,0.15);border-radius:12px;">
              <p style="font-size:14px;color:var(--prism-text);line-height:1.6;margin:0;">Dividers have no Boolean or Instance Swap properties -- all four axes are pure variant switches. The divider has no interactive states.</p>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h2 id="sizes" class="doc-section-title">Sizes</h2>
            <p class="doc-section-subtitle">Two thickness levels to fit different layout contexts.</p>
            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Horizontal Variants</h4>
            <table class="size-table" style="margin-bottom:32px;">
              <thead><tr><th>Type</th><th>Thickness</th><th>Component Size</th><th>Line</th><th>Padding</th></tr></thead>
              <tbody>
                <tr><td>Full Width</td><td>Thin</td><td>280 &times; 1 px</td><td>1 px</td><td>&mdash;</td></tr>
                <tr><td>Full Width</td><td>Medium</td><td>280 &times; 2 px</td><td>2 px</td><td>&mdash;</td></tr>
                <tr><td>Inset</td><td>Thin</td><td>280 &times; 1 px</td><td>1 px</td><td>Left 16 px</td></tr>
                <tr><td>Inset</td><td>Medium</td><td>280 &times; 2 px</td><td>2 px</td><td>Left 16 px</td></tr>
                <tr><td>Middle Inset</td><td>Thin</td><td>280 &times; 1 px</td><td>1 px</td><td>Left + Right 16 px</td></tr>
                <tr><td>Middle Inset</td><td>Medium</td><td>280 &times; 2 px</td><td>2 px</td><td>Left + Right 16 px</td></tr>
                <tr><td>With Text</td><td>Thin</td><td>280 &times; 20 px</td><td>1 px</td><td>Gap 8 px each side</td></tr>
                <tr><td>With Text</td><td>Medium</td><td>280 &times; 20 px</td><td>2 px</td><td>Gap 8 px each side</td></tr>
              </tbody>
            </table>
            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Vertical Variants</h4>
            <table class="size-table">
              <thead><tr><th>Type</th><th>Thickness</th><th>Component Size</th><th>Line</th><th>Padding</th></tr></thead>
              <tbody>
                <tr><td>Full Width</td><td>Thin</td><td>1 &times; 80 px</td><td>1 px</td><td>&mdash;</td></tr>
                <tr><td>Full Width</td><td>Medium</td><td>2 &times; 80 px</td><td>2 px</td><td>&mdash;</td></tr>
                <tr><td>Inset</td><td>Thin</td><td>1 &times; 80 px</td><td>1 px</td><td>Top 16 px</td></tr>
                <tr><td>Inset</td><td>Medium</td><td>2 &times; 80 px</td><td>2 px</td><td>Top 16 px</td></tr>
                <tr><td>Middle Inset</td><td>Thin</td><td>1 &times; 80 px</td><td>1 px</td><td>Top + Bottom 16 px</td></tr>
                <tr><td>Middle Inset</td><td>Medium</td><td>2 &times; 80 px</td><td>2 px</td><td>Top + Bottom 16 px</td></tr>
                <tr><td>With Text</td><td>Thin</td><td>20 &times; 120 px</td><td>1 px</td><td>Gap 8 px each side</td></tr>
                <tr><td>With Text</td><td>Medium</td><td>20 &times; 120 px</td><td>2 px</td><td>Gap 8 px each side</td></tr>
              </tbody>
            </table>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="color-tokens" class="doc-h3">Color Tokens<span class="h3-badge" style="background:rgba(37,99,235,0.1);color:var(--prism-violet);">Tokens</span></h3>
            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Line Colour</h4>
            <table class="size-table" style="margin-bottom:32px;">
              <thead><tr><th>Token</th><th>Usage</th><th>Hex</th></tr></thead>
              <tbody>
                <tr><td><code>Border/Border-Tertiary</code></td><td>Solid line colour (all non-With-Text variants)</td><td>#E1E4EB</td></tr>
                <tr><td><code>Border/Border-Secondary</code></td><td>Dashed + Dotted line colour; all With-Text line segment fills</td><td>#C3C9D6</td></tr>
              </tbody>
            </table>
            <h4 style="font-size:16px;font-weight:600;color:var(--prism-text);margin-bottom:16px;">Text Colour</h4>
            <table class="size-table">
              <thead><tr><th>Token</th><th>Usage</th><th>Hex</th></tr></thead>
              <tbody>
                <tr><td><code>Text/Text-Secondary</code></td><td>Label text in With Text variants</td><td>#64748B</td></tr>
              </tbody>
            </table>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="spacing-tokens" class="doc-h3">Spacing Tokens</h3>
            <table class="size-table">
              <thead><tr><th>Value</th><th>Usage</th><th>Suggested Token</th></tr></thead>
              <tbody>
                <tr><td>16 px</td><td>Leading indent for Inset; both-side indent for Middle Inset</td><td><code>spacing/16</code></td></tr>
                <tr><td>8 px</td><td>Gap between line segments and label in With Text variants</td><td><code>spacing/8</code></td></tr>
              </tbody>
            </table>
            <div style="margin-top:16px;padding:16px 20px;background:rgba(37,99,235,0.05);border:1px solid rgba(37,99,235,0.15);border-radius:12px;">
              <p style="font-size:14px;color:var(--prism-text);line-height:1.6;margin:0;">No spacing design tokens are applied directly -- padding and itemSpacing are set as raw values in the component. When implementing, consider mapping these to <code>spacing/16</code> and <code>spacing/8</code> from the UEMS Global Tokens collection for consistency.</p>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="corner-radius-border-radius" class="doc-h3">Corner Radius (Border Radius)</h3>
            <p class="doc-section-subtitle">Dividers do not use border radius. They are rendered as simple line elements.</p>
            <div style="display:flex;gap:24px;flex-wrap:wrap;">
              <div style="flex:1;min-width:200px;padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;text-align:center;">
                <div style="width:80px;height:2px;background:#2563eb;margin:16px auto;"></div>
                <div style="font-size:14px;font-weight:600;color:var(--prism-text);">radius/none</div>
                <div style="font-size:12px;color:var(--prism-text-muted);margin-top:4px;">0 px &mdash; straight line</div>
              </div>
            </div>
          </div>

          <hr class="doc-divider"/>

          <div class="doc-section">
            <h3 id="typography-family" class="doc-h3">Typography Family</h3>
            <p class="doc-section-subtitle">Only the With Text variant uses typography for the centred label.</p>
            <table class="size-table">
              <thead><tr><th>Element</th><th>Token</th><th>Font</th><th>Size</th><th>Weight</th><th>Line Height</th></tr></thead>
              <tbody>
                <tr><td>Label</td><td><code>body/Small/Default</code></td><td>Zoho Puvi</td><td>12 px</td><td>Regular (400)</td><td>16 px</td></tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- ========== USAGE ========== -->
        <div class="tab-content" id="tab-usage" style="display:none;padding-top:32px;">
          <div class="doc-section">
            <h2 id="when-to-use" class="doc-section-title">When and Where to Use</h2>
            <p class="doc-section-subtitle">Dividers separate content sections, group related items, and define visual boundaries in layouts.</p>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:24px;">
              <div style="padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;">
                <h3 style="font-size:15px;font-weight:600;color:var(--prism-text);margin-bottom:16px;display:flex;align-items:center;gap:8px;"><svg width="20" height="20" fill="none" stroke="#2563eb" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>When to use</h3>
                <ul class="doc-list" style="border:none;background:transparent;padding-left:20px;font-size:14.5px;">
                  <li style="border:none;background:transparent;margin-bottom:8px;">To visually separate distinct sections of a page, card, panel, or list.</li>
                  <li style="border:none;background:transparent;margin-bottom:8px;">To group related content -- a divider signals a boundary between two logical groups.</li>
                  <li style="border:none;background:transparent;margin-bottom:8px;">Use With Text to label a section transition (e.g. "Or", "Today", "More options").</li>
                  <li style="border:none;background:transparent;margin-bottom:8px;">Use Inset or Middle Inset inside lists where items have leading icons or avatars.</li>
                  <li style="border:none;background:transparent;">Use Vertical to separate items in a horizontal row (e.g. toolbar actions, breadcrumb segments).</li>
                </ul>
              </div>
              <div style="padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;">
                <h3 style="font-size:15px;font-weight:600;color:var(--prism-text);margin-bottom:16px;display:flex;align-items:center;gap:8px;"><svg width="20" height="20" fill="none" stroke="#e42527" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>When NOT to use</h3>
                <ul class="doc-list" style="border:none;background:transparent;padding-left:20px;font-size:14.5px;">
                  <li style="border:none;background:transparent;margin-bottom:8px;">As a padding substitute -- use a Spacing token instead.</li>
                  <li style="border:none;background:transparent;margin-bottom:8px;">Inside dense data tables -- row borders serve the same purpose more efficiently.</li>
                  <li style="border:none;background:transparent;margin-bottom:8px;">Decoratively -- a divider communicates a semantic boundary; if there is no logical separation, omit it.</li>
                  <li style="border:none;background:transparent;">Overuse -- too many dividers fragment a layout and increase visual noise.</li>
                </ul>
              </div>
            </div>
          </div>
          <hr class="doc-divider"/>
          <div class="doc-section">
            <h2 id="alignment-placement" class="doc-section-title">Alignment &amp; Placement</h2>
            <p class="doc-section-subtitle">Consistent placement ensures dividers are predictable and effective.</p>
            <ul class="doc-list">
              <li><strong>Full Width:</strong> Line spans the full available width or height. Use as the default for section separators.</li>
              <li><strong>Inset:</strong> 16 px indent on the leading edge only (left for horizontal, top for vertical). Use inside lists with leading icons.</li>
              <li><strong>Middle Inset:</strong> 16 px indent on both edges. Use when content has leading and trailing padding.</li>
              <li><strong>With Text:</strong> Line is split by a centred label with 8 px gaps. Use to label section transitions.</li>
              <li><strong>Vertical:</strong> Use between inline items in a horizontal row (toolbar actions, stat figures).</li>
            </ul>
          </div>
          <hr class="doc-divider"/>
          <div class="doc-section">
            <h2 id="detailed-guidelines" class="doc-section-title">Complete Do's and Don'ts</h2>
            <p class="doc-section-subtitle">Guidelines for effective divider usage.</p>
            <div class="do-dont-grid">
              <div class="do-card"><span class="card-label">Do</span><ul>
                <li><strong>Use Thin for most separators:</strong> It is the default and least intrusive.</li>
                <li><strong>Use Solid as the default:</strong> Reach for Dashed/Dotted to signal softer or provisional boundaries.</li>
                <li><strong>Use Inset inside lists:</strong> Align the rule to the text column when items have leading icons or avatars.</li>
                <li><strong>Keep With Text labels short:</strong> 1-3 words (e.g. "Or", "Today", "Continue").</li>
                <li><strong>Let the Divider fill its container:</strong> Use CSS flex: 1 or width: 100%.</li>
                <li><strong>Use Vertical for inline items:</strong> Toolbar buttons, stats, and breadcrumb segments.</li>
              </ul></div>
              <div class="dont-card"><span class="card-label">Don't</span><ul>
                <li><strong>Default to Medium everywhere:</strong> Reserve it for major section breaks.</li>
                <li><strong>Use Dashed/Dotted without reason:</strong> Only use with a clear semantic purpose.</li>
                <li><strong>Use Full Width in icon lists:</strong> Use Inset instead when items have left-aligned icons or avatars.</li>
                <li><strong>Write full sentences as labels:</strong> Keep divider text extremely brief.</li>
                <li><strong>Use Vertical in vertical stacks:</strong> Use Horizontal there instead.</li>
                <li><strong>Hard-code fixed pixel width:</strong> Let horizontal dividers flow with their container.</li>
              </ul></div>
            </div>
          </div>
          <hr class="doc-divider"/>
          <div class="doc-section">
            <h2 id="related" class="doc-section-title">Related</h2>
            <p class="doc-section-subtitle">Components that complement or can be used alongside the Divider.</p>
            <div class="related-grid">
              <a href="Accordion.html" class="related-chip"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg> Accordion</a>
              <a href="Data-table.html" class="related-chip"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M3 15h18M9 3v18"/></svg> Data Table</a>
              <a href="List.html" class="related-chip"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01"/></svg> List</a>
              <a href="Tabs.html" class="related-chip"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h8"/></svg> Tabs</a>
            </div>
          </div>
          <hr class="doc-divider"/>
          <div class="doc-section">
            <h2 id="references" class="doc-section-title">References</h2>
            <p class="doc-section-subtitle">Design tokens and resources for implementing the Divider component.</p>
            <ul class="doc-list">
              <li><strong>Figma Node:</strong> <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">17009:925007</code> &mdash; Component Set: Divider</li>
              <li><strong>Total Variants:</strong> 2 Orientations &times; 4 Types &times; 3 Styles &times; 2 Thicknesses = <strong>48 variants</strong></li>
              <li><strong>Typography:</strong> Zoho Puvi Regular (400) &mdash; 12 px / 16 px for With Text label only</li>
              <li><strong>Thickness:</strong> Thin = <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">1px</code>, Medium = <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">2px</code></li>
            </ul>
          </div>
        </div>

        <!-- ========== CODE ========== -->
        <div class="tab-content" id="tab-code" style="display:none;padding-top:32px;">
          <h2 id="live-demo-code" class="doc-section-title">Live demo (Code)</h2>
          <p class="doc-section-subtitle">Configure the Divider component and view generated HTML.</p>
          <div class="code-playground">
            <div class="cp-toolbar">
              <div class="cp-control-group"><label class="cp-label">Orientation</label><select class="cp-select" id="pg-orientation"><option value="horizontal">Horizontal</option><option value="vertical">Vertical</option></select></div>
              <div class="cp-control-group"><label class="cp-label">Type</label><select class="cp-select" id="pg-type"><option value="full-width">Full Width</option><option value="inset">Inset</option><option value="middle-inset">Middle Inset</option><option value="with-text">With Text</option></select></div>
              <div class="cp-control-group"><label class="cp-label">Style</label><select class="cp-select" id="pg-style"><option value="solid">Solid</option><option value="dashed">Dashed</option><option value="dotted">Dotted</option></select></div>
              <div class="cp-control-group"><label class="cp-label">Thickness</label><select class="cp-select" id="pg-thickness"><option value="thin">Thin</option><option value="medium">Medium</option></select></div>
              <div class="cp-control-group" id="pg-label-group"><label class="cp-label">Label</label><input class="cp-select" id="pg-label" type="text" value="Or" style="width:100%;"></div>
            </div>
            <div class="cp-preview" id="pg-preview-area" style="min-height:200px;">
              <div id="pg-divider-el" style="width:100%;max-width:400px;">
                <div class="divider-h"></div>
              </div>
            </div>
            <div class="cp-code-header">
              <div style="font-size:13.5px;font-weight:600;color:var(--prism-text);">HTML</div>
              <button class="cp-action-btn" id="pg-copy-btn"><svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7v8a2 2 0 002 2h6M8 7V5a2 2 0 012-2h4.586a1 1 0 01.707.293l4.414 4.414a1 1 0 01.293.707V15a2 2 0 01-2 2h-2M8 7H6a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2v-2"/></svg> Copy code</button>
            </div>
            <div class="cp-code-area" id="pg-code-output"></div>
          </div>
          <script>
          (function(){
            var els = {orientation:document.getElementById('pg-orientation'),type:document.getElementById('pg-type'),style:document.getElementById('pg-style'),thickness:document.getElementById('pg-thickness'),label:document.getElementById('pg-label')};
            var previewArea = document.getElementById('pg-divider-el');
            var codeOut = document.getElementById('pg-code-output');
            var copyBtn = document.getElementById('pg-copy-btn');
            var labelGroup = document.getElementById('pg-label-group');
            function esc(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
            function update(){
              var o=els.orientation.value, t=els.type.value, s=els.style.value, th=els.thickness.value, lbl=els.label.value||'Label';
              labelGroup.style.display = t==='with-text' ? '' : 'none';
              var html='', cls='', code='';
              if(t==='with-text'){
                if(o==='horizontal'){
                  cls='divider-with-text';
                  if(s==='dashed') cls+=' divider-with-text--dashed';
                  if(s==='dotted') cls+=' divider-with-text--dotted';
                  if(th==='medium') cls+=' divider-with-text--medium';
                  html='<div class="'+cls+'" style="width:100%;max-width:400px;">'+lbl+'</div>';
                  code='<div class="'+cls+'">'+lbl+'</div>';
                } else {
                  cls='divider-with-text-v';
                  if(th==='medium') cls+=' divider-with-text-v--medium';
                  html='<div class="'+cls+'" style="height:120px;">'+lbl+'</div>';
                  code='<div class="'+cls+'">'+lbl+'</div>';
                }
              } else if(o==='horizontal'){
                cls='divider-h';
                if(s==='dashed') cls+=' divider-h--dashed';
                if(s==='dotted') cls+=' divider-h--dotted';
                if(th==='medium') cls+=' divider-h--medium';
                if(t==='inset') cls+=' divider-h--inset';
                if(t==='middle-inset') cls+=' divider-h--m-inset';
                html='<hr class="'+cls+'" style="width:100%;max-width:400px;" />';
                code='<hr class="'+cls+'" />';
              } else {
                cls='divider-v';
                if(s==='dashed') cls+=' divider-v--dashed';
                if(s==='dotted') cls+=' divider-v--dotted';
                if(th==='medium') cls+=' divider-v--medium';
                if(t==='inset') cls+=' divider-v--inset';
                if(t==='middle-inset') cls+=' divider-v--m-inset';
                html='<div class="'+cls+'" style="height:80px;"></div>';
                code='<div class="'+cls+'"></div>';
              }
              previewArea.innerHTML=html;
              if(o==='vertical'){ previewArea.style.width='auto'; previewArea.style.maxWidth='none'; previewArea.style.display='flex'; previewArea.style.justifyContent='center'; }
              else { previewArea.style.width='100%'; previewArea.style.maxWidth='400px'; previewArea.style.display='block'; }
              codeOut.innerHTML=esc(code).replace(/class=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">class</span>=<span style="color:#34d399;">"$1"</span>').replace(/&lt;(\/?)(hr|div|span)(.*?)(\/?)\s*&gt;/g,'&lt;$1<span style="color:#a78bfa;">$2</span>$3$4&gt;');
            }
            Object.values(els).forEach(function(e){e.addEventListener(e.tagName==='INPUT'?'input':'change',update);});
            copyBtn.addEventListener('click',function(){
              var r=document.createElement('div');r.innerHTML=codeOut.innerHTML;
              navigator.clipboard.writeText(r.innerText).then(function(){
                var orig=copyBtn.innerHTML;copyBtn.innerHTML='<svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Copied!';setTimeout(function(){copyBtn.innerHTML=orig;},2000);
              });
            });
            update();
          })();
          </script>

          <hr class="doc-divider"/>
          <div class="doc-section">
            <h3 id="component-api-properties" class="doc-h3">Component API &amp; Properties</h3>
            <table class="size-table">
              <thead><tr><th>Property</th><th>Type</th><th>Default</th><th>Description</th></tr></thead>
              <tbody>
                <tr><td><code>orientation</code></td><td>'Horizontal' | 'Vertical'</td><td>'Horizontal'</td><td>Direction of the dividing line.</td></tr>
                <tr><td><code>type</code></td><td>'Full Width' | 'Inset' | 'Middle Inset' | 'With Text'</td><td>'Full Width'</td><td>Layout type. Controls indent and whether a label is shown.</td></tr>
                <tr><td><code>style</code></td><td>'Solid' | 'Dashed' | 'Dotted'</td><td>'Solid'</td><td>Visual line style.</td></tr>
                <tr><td><code>thickness</code></td><td>'Thin' | 'Medium'</td><td>'Thin'</td><td>Line thickness -- 1 px (Thin) or 2 px (Medium).</td></tr>
                <tr><td><code>label</code></td><td>string</td><td>"Label"</td><td>Text displayed in the centre of a With Text divider.</td></tr>
              </tbody>
            </table>
          </div>
          <hr class="doc-divider"/>
          <div class="doc-section">
            <h3 id="implementation-idea-ember-hook-form" class="doc-h3">Implementation Idea: Ember Hook Form</h3>
            <div class="cp-code-area" style="border-radius:12px;margin-top:16px;">
              <div style="font-family:'JetBrains Mono',monospace;font-size:13.5px;line-height:1.6;">
                <span style="color:#94a3b8;">&lt;!-- section-divider.hbs --&gt;</span><br>
                <span style="color:#ABB2BF;">&lt;</span><span style="color:#E06C75;">UemsDivider</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">@orientation</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"Horizontal"</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">@type</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"With Text"</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">@style</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"Solid"</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">@thickness</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"Thin"</span><br>
                &nbsp;&nbsp;<span style="color:#D19A66;">@label</span><span style="color:#56B6C2;">=</span><span style="color:#98C379;">"Or"</span><br>
                <span style="color:#ABB2BF;">/&gt;</span>
              </div>
            </div>
          </div>
          <hr class="doc-divider"/>
          <div class="doc-section">
            <h3 id="rtl-support" class="doc-h3">RTL Support</h3>
            <ul class="doc-list">
              <li>Horizontal Full Width and With Text dividers are direction-neutral and render identically in LTR and RTL.</li>
              <li>In RTL layouts, Inset indent moves from left to right automatically when using <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">margin-inline-start</code> instead of <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">margin-left</code>.</li>
              <li>Vertical dividers remain unchanged in RTL as they are orientation-independent.</li>
              <li>With Text label text direction follows the document <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">dir</code> attribute automatically.</li>
            </ul>
          </div>
        </div>

        <!-- ========== ACCESSIBILITY ========== -->
        <div class="tab-content" id="tab-accessibility" style="display:none;padding-top:32px;">
          <h2 id="accessibility" class="doc-section-title">Accessibility</h2>
          <p class="doc-section-subtitle">Guidelines for ensuring divider elements are accessible across assistive technologies.</p>
          <div class="doc-section">
            <h3 id="keyboard-interaction" class="doc-h3">Keyboard Interaction</h3>
            <table class="size-table">
              <thead><tr><th>Key</th><th>Action</th></tr></thead>
              <tbody>
                <tr><td><code>Tab</code></td><td>Dividers are non-interactive and should never receive focus. Focus moves to the next interactive element.</td></tr>
              </tbody>
            </table>
            <div style="margin-top:16px;padding:16px 20px;background:rgba(37,99,235,0.05);border:1px solid rgba(37,99,235,0.15);border-radius:12px;">
              <p style="font-size:14px;color:var(--prism-text);line-height:1.6;margin:0;">Dividers are purely presentational. They do not receive keyboard focus and have no interactive behaviour.</p>
            </div>
          </div>
          <hr class="doc-divider"/>
          <div class="doc-section">
            <h3 id="aria-attributes-screen-reader-guidance" class="doc-h3">ARIA Attributes &amp; Screen Reader Guidance</h3>
            <ul class="doc-list">
              <li><strong>Semantic element:</strong> Use <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;hr&gt;</code> for meaningful horizontal section breaks. It has an implicit <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">role="separator"</code>.</li>
              <li><strong>Vertical dividers:</strong> Use <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;div role="separator" aria-orientation="vertical"&gt;</code> or <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;hr&gt;</code> with <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-orientation="vertical"</code>.</li>
              <li><strong>Decorative dividers:</strong> If purely visual, use <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">&lt;hr aria-hidden="true"&gt;</code> or a CSS pseudo-element so screen readers skip it.</li>
              <li><strong>With Text:</strong> The label text is already in the DOM -- no additional aria-label is needed. Ensure the surrounding wrapper has <code style="font-family:monospace;font-size:13px;padding:2px 8px;border-radius:6px;background:rgba(37,99,235,0.06);color:var(--prism-violet);">aria-hidden="true"</code> if the text itself is the meaningful content.</li>
            </ul>
          </div>
          <hr class="doc-divider"/>
          <div class="doc-section">
            <h3 id="focus-state-design" class="doc-h3">Focus State Design</h3>
            <ul class="doc-list">
              <li>Dividers do not receive focus -- they are non-interactive presentational elements.</li>
              <li>No focus ring or focus indicator is needed for dividers.</li>
            </ul>
          </div>
          <hr class="doc-divider"/>
          <div class="doc-section">
            <h3 id="color-contrast-minimums" class="doc-h3">Color Contrast Minimums<span class="h3-badge" style="background:rgba(251,191,36,0.15);color:#d97706;">Intentional</span></h3>
            <p class="doc-section-subtitle">Border/Border-Tertiary (#E1E4EB) on white is low-contrast by design -- this is intentional for a subtle separator. Do not rely on the divider colour alone to communicate meaning.</p>
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px;margin-top:24px;">
              <div style="background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;overflow:hidden;">
                <div style="background:#ffffff;padding:28px 24px;text-align:center;position:relative;">
                  <div style="height:2px;background:#E1E4EB;width:80%;margin:0 auto;"></div>
                </div>
                <div style="padding:16px 24px;display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--prism-border);"><div><div style="font-size:13px;color:var(--prism-text-muted);font-weight:600;">SOLID / TERTIARY</div><div style="font-size:15px;color:var(--prism-text);font-family:monospace;margin-top:4px;">#E1E4EB on #FFF</div></div><div style="text-align:right;"><div style="display:inline-flex;align-items:center;gap:6px;background:rgba(251,191,36,0.1);color:#d97706;padding:4px 10px;border-radius:100px;font-size:12px;font-weight:700;">1.2:1</div><div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;font-weight:600;">Intentional low contrast</div></div></div>
              </div>
              <div style="background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;overflow:hidden;">
                <div style="background:#ffffff;padding:28px 24px;text-align:center;position:relative;">
                  <div style="height:0;border-top:2px dashed #C3C9D6;width:80%;margin:0 auto;"></div>
                </div>
                <div style="padding:16px 24px;display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--prism-border);"><div><div style="font-size:13px;color:var(--prism-text-muted);font-weight:600;">DASHED / SECONDARY</div><div style="font-size:15px;color:var(--prism-text);font-family:monospace;margin-top:4px;">#C3C9D6 on #FFF</div></div><div style="text-align:right;"><div style="display:inline-flex;align-items:center;gap:6px;background:rgba(251,191,36,0.1);color:#d97706;padding:4px 10px;border-radius:100px;font-size:12px;font-weight:700;">1.5:1</div><div style="font-size:11px;color:var(--prism-text-muted);margin-top:4px;font-weight:600;">Subtle separator</div></div></div>
              </div>
            </div>
          </div>
          <hr class="doc-divider"/>
          <div class="doc-section">
            <h3 id="touch-target-size" class="doc-h3">Touch Target Size</h3>
            <p class="doc-section-subtitle">Dividers are non-interactive, so touch target requirements do not apply.</p>
            <div style="margin-top:16px;padding:24px;background:var(--prism-surface);border:1px solid var(--prism-border);border-radius:12px;display:flex;align-items:center;gap:24px;">
              <div style="width:44px;height:44px;background:rgba(148,163,184,0.1);border:1px dashed var(--prism-text-muted);border-radius:8px;display:flex;align-items:center;justify-content:center;color:var(--prism-text-muted);font-size:13px;font-weight:600;flex-shrink:0;">N/A</div>
              <div><div style="font-weight:600;font-size:15px;color:var(--prism-text);">No touch target required</div><div style="font-size:14px;color:var(--prism-text-muted);margin-top:4px;">Dividers are not interactive and do not require a minimum touch target. They should not respond to tap, click, or pointer events.</div></div>
            </div>
          </div>
        </div>

