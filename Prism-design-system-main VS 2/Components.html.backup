      <div class="page-header-area">
        <h1 class="page-title">Components</h1>
        <p class="page-desc">
          Components are the reusable building blocks of the Prism design system. Use them to build consistent, accessible, and scalable Endpoint Central experiences.
        </p>
      </div>
      <div class="main-content-area">
        <div class="main-content-inner">

        <!-- Forms and inputs -->
        <div class="comp-category-section">
          <h2 id="forms-and-inputs" class="comp-category-heading">Forms and inputs</h2>
          <div class="comp-grid">

            <a href="Button.html" class="comp-card">
              <div class="comp-card-preview">
                <div style="display:flex; gap:8px; align-items:center;">
                  <button style="padding:8px 20px; border-radius:8px; background:linear-gradient(135deg, #006AFF, #1E52BB); color:#fff; border:none; font-size:12px; font-weight:600; font-family:inherit; cursor:pointer;">Primary</button>
                  <button style="padding:8px 20px; border-radius:8px; background:transparent; color:var(--prism-text); border:1px solid var(--prism-border); font-size:12px; font-weight:600; font-family:inherit; cursor:pointer;">Secondary</button>
                </div>
              </div>
              <div class="comp-card-body"><div class="comp-card-name">Button</div><div class="comp-card-desc">Triggers an action or event when clicked.</div></div>
            </a>

            <a href="Checkbox.html" class="comp-card">
              <div class="comp-card-preview">
                <div style="display:flex; flex-direction:column; gap:8px;">
                  <label style="display:flex; align-items:center; gap:8px; font-size:12px; color:var(--prism-text); cursor:pointer;">
                    <div style="width:18px; height:18px; border-radius:4px; background:#2563eb; display:flex; align-items:center; justify-content:center;"><svg width="12" height="12" fill="none" stroke="#fff" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></div>
                    Selected
                  </label>
                  <label style="display:flex; align-items:center; gap:8px; font-size:12px; color:var(--prism-text-muted); cursor:pointer;">
                    <div style="width:18px; height:18px; border-radius:4px; border:2px solid var(--prism-border);"></div>
                    Unselected
                  </label>
                </div>
              </div>
              <div class="comp-card-body"><div class="comp-card-name">Checkbox</div><div class="comp-card-desc">Allows selection of one or more options from a set.</div></div>
            </a>

            <a href="Date-picker.html" class="comp-card">
              <div class="comp-card-preview">
                <div style="width:85%; max-width:210px; display:flex; align-items:center; justify-content:space-between; gap:10px; padding:9px 12px; border-radius:8px; border:1px solid var(--prism-border); background:var(--prism-surface);">
                  <span style="font-size:12px; color:var(--prism-text); font-variant-numeric:tabular-nums;">Apr 21, 2026</span>
                  <svg width="16" height="16" fill="none" stroke="#2563eb" stroke-width="2" viewBox="0 0 24 24" style="flex-shrink:0;">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                    <line x1="16" y1="2" x2="16" y2="6"/>
                    <line x1="8" y1="2" x2="8" y2="6"/>
                    <line x1="3" y1="10" x2="21" y2="10"/>
                  </svg>
                </div>
              </div>
              <div class="comp-card-body"><div class="comp-card-name">Date picker</div><div class="comp-card-desc">Lets users select a date or date range from a calendar.</div></div>
            </a>

            <a href="Dropdown.html" class="comp-card">
              <div class="comp-card-preview">
                <div style="width:80%; max-width:180px; display:flex; flex-direction:column; gap:2px;">
                  <div style="display:flex; align-items:center; justify-content:space-between; padding:7px 10px; border-radius:6px; border:1px solid var(--prism-border); background:var(--prism-surface);">
                    <span style="font-size:11px; color:var(--prism-text);">Options</span>
                    <svg width="10" height="10" fill="none" stroke="var(--prism-text-muted)" stroke-width="2" viewBox="0 0 24 24"><path d="M6 9l6 6 6-6"/></svg>
                  </div>
                  <div style="border-radius:6px; border:1px solid var(--prism-border); background:var(--prism-surface); overflow:hidden;">
                    <div style="padding:6px 10px; font-size:10px; color:var(--prism-text); background:rgba(37,99,235,0.08);">Edit</div>
                    <div style="padding:6px 10px; font-size:10px; color:var(--prism-text);">Duplicate</div>
                    <div style="padding:6px 10px; font-size:10px; color:#ef4444;">Delete</div>
                  </div>
                </div>
              </div>
              <div class="comp-card-body"><div class="comp-card-name">Dropdown</div><div class="comp-card-desc">Displays a list of actions or options on demand.</div></div>
            </a>

            <a href="Radio-button.html" class="comp-card">
              <div class="comp-card-preview">
                <div style="display:flex; flex-direction:column; gap:8px;">
                  <label style="display:flex; align-items:center; gap:8px; font-size:12px; color:var(--prism-text); cursor:pointer;">
                    <div style="width:18px; height:18px; border-radius:50%; border:2px solid #2563eb; display:flex; align-items:center; justify-content:center;"><div style="width:8px; height:8px; border-radius:50%; background:#2563eb;"></div></div>
                    Option A
                  </label>
                  <label style="display:flex; align-items:center; gap:8px; font-size:12px; color:var(--prism-text-muted); cursor:pointer;">
                    <div style="width:18px; height:18px; border-radius:50%; border:2px solid var(--prism-border);"></div>
                    Option B
                  </label>
                </div>
              </div>
              <div class="comp-card-body"><div class="comp-card-name">Radio button</div><div class="comp-card-desc">Selects a single option from a mutually exclusive set.</div></div>
            </a>

            <a href="Slider.html" class="comp-card">
              <div class="comp-card-preview">
                <div style="width:80%; max-width:200px; position:relative;">
                  <div style="height:4px; border-radius:2px; background:var(--prism-border);"></div>
                  <div style="height:4px; border-radius:2px; background:linear-gradient(135deg, #0058ff, #0fd095); width:60%; position:absolute; top:0; left:0;"></div>
                  <div style="width:16px; height:16px; border-radius:50%; background:#2563eb; border:3px solid #fff; box-shadow:0 1px 4px rgba(0,0,0,0.2); position:absolute; top:-6px; left:calc(60% - 8px);"></div>
                </div>
              </div>
              <div class="comp-card-body"><div class="comp-card-name">Slider</div><div class="comp-card-desc">Allows selection of a value from a continuous range.</div></div>
            </a>

            <a href="Split-button.html" class="comp-card">
              <div class="comp-card-preview">
                <div style="display:flex; align-items:center;">
                  <button style="padding:8px 18px; border-radius:8px 0 0 8px; background:linear-gradient(135deg, #006AFF, #1E52BB); color:#fff; border:none; font-size:12px; font-weight:600; font-family:inherit; cursor:pointer;">Save</button>
                  <div style="width:1px; height:34px; background:rgba(255,255,255,0.25);"></div>
                  <button style="padding:8px 10px; border-radius:0 8px 8px 0; background:linear-gradient(135deg, #006AFF, #1E52BB); color:#fff; border:none; cursor:pointer; display:flex; align-items:center;">
                    <svg width="12" height="12" fill="none" stroke="#fff" stroke-width="2.5" viewBox="0 0 24 24"><path d="M6 9l6 6 6-6"/></svg>
                  </button>
                </div>
              </div>
              <div class="comp-card-body"><div class="comp-card-name">Split button</div><div class="comp-card-desc">Combines a primary action with a dropdown of alternatives.</div></div>
            </a>

            <a href="Switch.html" class="comp-card">
              <div class="comp-card-preview">
                <div style="display:flex; align-items:center; gap:12px;">
                  <div style="width:40px; height:22px; border-radius:11px; background:linear-gradient(135deg, #006AFF, #1E52BB); position:relative; cursor:pointer;">
                    <div style="width:16px; height:16px; border-radius:50%; background:#fff; position:absolute; top:3px; right:3px;"></div>
                  </div>
                  <div style="width:40px; height:22px; border-radius:11px; background:var(--prism-border); position:relative; cursor:pointer;">
                    <div style="width:16px; height:16px; border-radius:50%; background:#fff; position:absolute; top:3px; left:3px;"></div>
                  </div>
                </div>
              </div>
              <div class="comp-card-body"><div class="comp-card-name">Switch</div><div class="comp-card-desc">Toggles a setting between two states instantly.</div></div>
            </a>

            <a href="Text-area.html" class="comp-card">
              <div class="comp-card-preview">
                <div style="width:85%; max-width:210px;">
                  <div style="font-size:10px; font-weight:600; color:var(--prism-text-muted); margin-bottom:4px;">Message</div>
                  <div style="padding:8px 12px; border-radius:8px; border:1px solid var(--prism-border); background:var(--prism-surface); min-height:60px;">
                    <div style="font-size:11px; color:var(--prism-text); line-height:1.5;">Type your message here...</div>
                    <div style="font-size:11px; color:var(--prism-text-muted); line-height:1.5; margin-top:2px;">Second line of text</div>
                  </div>
                </div>
              </div>
              <div class="comp-card-body"><div class="comp-card-name">Text area</div><div class="comp-card-desc">Multi-line text input for longer content entry.</div></div>
            </a>

            <a href="Text-field.html" class="comp-card">
              <div class="comp-card-preview">
                <div style="width:80%; max-width:200px;">
                  <div style="font-size:10px; font-weight:600; color:var(--prism-text-muted); margin-bottom:4px;">Label</div>
                  <div style="padding:8px 12px; border-radius:8px; border:1px solid var(--prism-border); background:var(--prism-surface); font-size:12px; color:var(--prism-text-muted);">Placeholder text</div>
                </div>
              </div>
              <div class="comp-card-body"><div class="comp-card-name">Text field</div><div class="comp-card-desc">Single-line text input for short-form data entry.</div></div>
