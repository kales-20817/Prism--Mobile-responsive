              footerGroup.style.display = isMulti ? '' : 'none';

              var html = '';
              var dirAttr = dir === 'rtl' ? ' dir="rtl"' : '';

              if (type === 'single') {
                html = '<div class="dd-panel"' + dirAttr + ' role="menu">\n';
                html += '  <div class="dd-item" role="menuitem">Edit</div>\n';
                html += '  <div class="dd-item" role="menuitem">Duplicate</div>\n';
                html += '  <div class="dd-item" role="menuitem">Share</div>\n';
                html += '  <div class="dd-item" role="menuitem">Delete</div>\n';
                html += '</div>';
              } else if (type === 'multi') {
                html = '<div class="dd-panel"' + dirAttr + ' role="menu">\n';
                if (showHeader) {
                  html += '  <div class="dd-header">\n';
                  html += '    <span>Select Options</span>\n';
                  html += '    <button aria-label="Dismiss">&times;</button>\n';
                  html += '  </div>\n';
                }
                html += '  <div class="dd-item" role="menuitemcheckbox" aria-checked="true">\n';
                html += '    <input type="checkbox" checked> Option A\n';
                html += '  </div>\n';
                html += '  <div class="dd-item" role="menuitemcheckbox" aria-checked="false">\n';
                html += '    <input type="checkbox"> Option B\n';
                html += '  </div>\n';
                html += '  <div class="dd-item" role="menuitemcheckbox" aria-checked="false">\n';
                html += '    <input type="checkbox"> Option C\n';
                html += '  </div>\n';
                if (showFooter) {
                  html += '  <div class="dd-footer">\n';
                  html += '    <button class="dd-clear-btn">Clear All</button>\n';
                  html += '    <button class="dd-apply-btn">Apply</button>\n';
                  html += '  </div>\n';
                }
                html += '</div>';
              } else {
                html = '<div class="dd-panel"' + dirAttr + ' role="menu">\n';
                html += '  <div class="dd-section-heading">Actions</div>\n';
                html += '  <div class="dd-item" role="menuitem">Edit</div>\n';
                html += '  <div class="dd-item" role="menuitem">Duplicate</div>\n';
                html += '  <div class="dd-divider" role="separator"></div>\n';
                html += '  <div class="dd-section-heading">More</div>\n';
                html += '  <div class="dd-item" role="menuitem">Share</div>\n';
                html += '  <div class="dd-item" role="menuitem">Archive</div>\n';
                html += '</div>';
              }

              // Build preview
              var previewHtml = '';
              if (type === 'single') {
                previewHtml = '<div class="dd-panel"' + (dir==='rtl'?' dir="rtl"':'') + '>';
                previewHtml += '<div class="dd-item"><svg class="dd-item-icon" viewBox="0 0 24 24" fill="none" stroke="#626870" stroke-width="2"><circle cx="12" cy="12" r="3"/></svg><span>Edit</span></div>';
                previewHtml += '<div class="dd-item"><svg class="dd-item-icon" viewBox="0 0 24 24" fill="none" stroke="#626870" stroke-width="2"><path d="M16 4h2a2 2 0 012 2v14a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2h2"/><rect x="8" y="2" width="8" height="4" rx="1"/></svg><span>Duplicate</span></div>';
                previewHtml += '<div class="dd-item"><svg class="dd-item-icon" viewBox="0 0 24 24" fill="none" stroke="#626870" stroke-width="2"><path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg><span>Share</span></div>';
                previewHtml += '<div class="dd-item"><svg class="dd-item-icon" viewBox="0 0 24 24" fill="none" stroke="#626870" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg><span>Delete</span></div>';
                previewHtml += '</div>';
              } else if (type === 'multi') {
                previewHtml = '<div class="dd-panel"' + (dir==='rtl'?' dir="rtl"':'') + '>';
                if (showHeader) {
                  previewHtml += '<div class="dd-header"><span>Select Options</span><svg class="dd-header-dismiss" viewBox="0 0 24 24" fill="none" stroke="#626870" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></div>';
                }
                previewHtml += '<div class="dd-item"><div class="dd-item-check checked"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg></div><span>Option A</span></div>';
                previewHtml += '<div class="dd-item"><div class="dd-item-check"></div><span>Option B</span></div>';
                previewHtml += '<div class="dd-item"><div class="dd-item-check"></div><span>Option C</span></div>';
                if (showFooter) {
                  previewHtml += '<div class="dd-footer"><button class="dd-clear-btn">Clear All</button><button class="dd-apply-btn">Apply</button></div>';
                }
                previewHtml += '</div>';
              } else {
                previewHtml = '<div class="dd-panel"' + (dir==='rtl'?' dir="rtl"':'') + '>';
                previewHtml += '<div class="dd-section-heading">Actions</div>';
                previewHtml += '<div class="dd-item"><svg class="dd-item-icon" viewBox="0 0 24 24" fill="none" stroke="#626870" stroke-width="2"><circle cx="12" cy="12" r="3"/></svg><span>Edit</span></div>';
                previewHtml += '<div class="dd-item"><svg class="dd-item-icon" viewBox="0 0 24 24" fill="none" stroke="#626870" stroke-width="2"><path d="M16 4h2a2 2 0 012 2v14a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2h2"/><rect x="8" y="2" width="8" height="4" rx="1"/></svg><span>Duplicate</span></div>';
                previewHtml += '<div class="dd-divider"></div>';
                previewHtml += '<div class="dd-section-heading">More</div>';
                previewHtml += '<div class="dd-item"><svg class="dd-item-icon" viewBox="0 0 24 24" fill="none" stroke="#626870" stroke-width="2"><path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg><span>Share</span></div>';
                previewHtml += '<div class="dd-item"><svg class="dd-item-icon" viewBox="0 0 24 24" fill="none" stroke="#626870" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg><span>Archive</span></div>';
                previewHtml += '</div>';
              }
              previewArea.innerHTML = previewHtml;

              // Code output
              codeOut.innerHTML = esc(html)
                .replace(/class=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">class</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/role=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">role</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/aria-checked=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">aria-checked</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/aria-label=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">aria-label</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/dir=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">dir</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/type=&quot;(.*?)&quot;/g,'<span style="color:#38bdf8;">type</span>=<span style="color:#34d399;">"$1"</span>')
                .replace(/ checked/g,' <span style="color:#38bdf8;">checked</span>')
                .replace(/&lt;(\/?)(div|button|input|span)(.*?)&gt;/g,'&lt;$1<span style="color:#a78bfa;">$2</span>$3&gt;');
            }

            typeEl.addEventListener('change', update);
            dirEl.addEventListener('change', update);
            copyBtn.addEventListener('click', function(){
              var r = document.createElement('div'); r.innerHTML = codeOut.innerHTML;
              navigator.clipboard.writeText(r.innerText).then(function(){
                var o = copyBtn.innerHTML; copyBtn.innerHTML='<svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Copied!'; setTimeout(function(){ copyBtn.innerHTML=o; },2000);
              });
            });
            update();
          })();
          </script>

